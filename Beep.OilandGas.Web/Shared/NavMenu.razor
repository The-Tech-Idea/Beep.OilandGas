@code {
    private bool _personaLoaded;

    protected override async Task OnInitializedAsync()
    {
        await PersonaContext.EnsureLoadedAsync();
        _personaLoaded = true;
    }

    private string GetWorkflowMenuClass(string workflow)
    {
        if (!_personaLoaded)
        {
            return string.Empty;
        }

        return PersonaContext.CanAccessWorkflow(workflow) ? string.Empty : "d-none";
    }
}
