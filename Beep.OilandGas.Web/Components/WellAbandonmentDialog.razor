@using System
@using System.Collections.Generic
@using Microsoft.AspNetCore.Components
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudContainer MaxWidth="MaxWidth.Medium">
            <MudStack Spacing="3">
                <MudTextField @bind-Value="@_wellId" 
                             Label="Well ID" 
                             Variant="Variant.Outlined" 
                             Required="true" />

                <MudTextField @bind-Value="@_abandonmentType" 
                             Label="Abandonment Type" 
                             Variant="Variant.Outlined" />

                <MudDatePicker @bind-Date="@_abandonmentDate" 
                              Label="Abandonment Date" 
                              Variant="Variant.Outlined" />

                <MudTextField @bind-Value="@_abandonmentStatus" 
                             Label="Abandonment Status" 
                             Variant="Variant.Outlined" />

                <MudTextField @bind-Value="@_description" 
                             Label="Description" 
                             Variant="Variant.Outlined" 
                             Lines="3" />
            </MudStack>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string? WellId { get; set; }
    [Parameter] public string? AbandonmentType { get; set; }
    [Parameter] public DateTime? AbandonmentDate { get; set; }
    [Parameter] public string? AbandonmentStatus { get; set; }

    private string _wellId = string.Empty;
    private string _abandonmentType = string.Empty;
    private DateTime? _abandonmentDate;
    private string _abandonmentStatus = string.Empty;
    private string _description = string.Empty;

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrWhiteSpace(WellId))
            _wellId = WellId;

        if (string.IsNullOrWhiteSpace(_abandonmentType) && !string.IsNullOrWhiteSpace(AbandonmentType))
            _abandonmentType = AbandonmentType;

        if (!_abandonmentDate.HasValue && AbandonmentDate.HasValue)
            _abandonmentDate = AbandonmentDate;

        if (string.IsNullOrWhiteSpace(_abandonmentStatus) && !string.IsNullOrWhiteSpace(AbandonmentStatus))
            _abandonmentStatus = AbandonmentStatus;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void Save()
    {
        if (string.IsNullOrWhiteSpace(_wellId))
        {
            Snackbar.Add("Well ID is required.", Severity.Warning);
            return;
        }

        var result = new Dictionary<string, object>
        {
            { "wellId", _wellId },
            { "abandonmentType", _abandonmentType },
            { "abandonmentStatus", _abandonmentStatus },
            { "description", _description }
        };

        if (_abandonmentDate.HasValue)
            result["abandonmentDate"] = _abandonmentDate.Value;

        MudDialog.Close(DialogResult.Ok(result));
    }
}
