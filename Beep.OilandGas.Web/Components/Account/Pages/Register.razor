@page "/Account/Register"
@page "/register"

@inject NavigationManager NavigationManager
@inject Beep.OilandGas.Web.Theme.IThemeProvider ThemeProvider
@using Beep.OilandGas.Web.Theme

<PageTitle>Sign Up - Beep Oil & Gas</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="d-flex align-center justify-center og-page-bg">
    <MudPaper Elevation="0" Class="pa-0 og-auth-panel">
        
        <!-- Terminal Header -->
        <MudPaper Class="pa-4 mb-0 og-terminal-header-top" Elevation="0">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudStack Row="true" Spacing="1">
                    <div class="og-terminal-dot og-terminal-dot--red"></div>
                    <div class="og-terminal-dot og-terminal-dot--yellow"></div>
                    <div class="og-terminal-dot og-terminal-dot--green"></div>
                </MudStack>
                <MudText Color="Color.Secondary" Class="og-terminal-prompt">
                    ~/account <span class="og-terminal-success">$</span> ./register.sh
                </MudText>
            </MudStack>
        </MudPaper>

        <MudPaper Elevation="0" Class="pa-8 og-terminal-body">
            
            <MudStack Spacing="4" AlignItems="AlignItems.Center" Class="mb-6">
                @if (!string.IsNullOrEmpty(_branding.LogoUrl))
                {
                    <img src="@_branding.LogoUrl" alt="@(_branding.AppName ?? "Beep Oil & Gas")" class="og-auth-logo" />
                }
                else
                {
                    <img src="/imgs/BeepOGDM.svg" alt="Beep Oil & Gas" class="og-auth-logo" />
                }
            </MudStack>

            <MudText Typo="Typo.h4" Class="mb-2 og-terminal-heading">
                <span class="og-terminal-success">sudo</span> register
            </MudText>
            <MudText Typo="Typo.body1" Class="mb-6 og-terminal-code" Color="Color.Secondary">
                // @(_branding.RegisterSubtitle ?? "Create your account with Identity Server")
            </MudText>

            @if (!string.IsNullOrEmpty(Error))
            {
                <MudPaper Elevation="0" Class="pa-4 mb-6 og-terminal-error">
                    <MudText Color="Color.Error" Class="og-terminal-code">
                        Error: @Error
                    </MudText>
                </MudPaper>
            }

            <div class="d-flex flex-column gap-4">
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
                    You will be redirected to our secure Identity Server to create your account.
                </MudAlert>

                <MudButton Variant="Variant.Filled" 
                           Size="Size.Large"
                           FullWidth="true"
                           Href="@($"/authentication/start-login?returnUrl={Uri.EscapeDataString(ReturnUrl ?? "/")}")"
                           StartIcon="@Icons.Material.Filled.PersonAdd"
                           Class="og-terminal-code">
                    create_account()
                </MudButton>
            </div>

            <div class="d-flex justify-center mt-4">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="og-terminal-code">
                    // Redirects to Beep.Foundation.IdentityServer
                </MudText>
            </div>

        </MudPaper>
    </MudPaper>
</MudContainer>

@code {
    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    private string? Error { get; set; }

    private BrandingConfig _branding = new();

    protected override void OnInitialized()
    {
        _branding = ThemeProvider.GetBranding();
    }
}

