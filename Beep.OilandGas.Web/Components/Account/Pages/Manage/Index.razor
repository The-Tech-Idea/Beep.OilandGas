@page "/Account/Manage"

@inject IAccountManagementService AccountService
@inject ISnackbar Snackbar

<PageTitle>Profile - Beep Oil & Gas</PageTitle>

<MudText Typo="Typo.h4" Class="og-terminal-heading mb-2">
    <span class="og-terminal-success">$</span> user.profile()
</MudText>
<MudText Typo="Typo.body2" Class="mb-6" Color="Color.Secondary">
    Manage your account profile and preferences
</MudText>

@if (isLoading)
{
    <MudStack AlignItems="AlignItems.Center" Class="pa-8">
        <MudProgressCircular Color="Color.Success" Indeterminate="true" />
        <MudText Typo="Typo.body2" Class="og-terminal-code mt-4" Color="Color.Secondary">
            Loading profile...
        </MudText>
    </MudStack>
}
else if (authProfile == null)
{
    <MudPaper Elevation="0" Class="og-terminal-card-error pa-6">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
            <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Large" />
            <div>
                <MudText Typo="Typo.h6" Class="og-terminal-code" Color="Color.Error">
                    // Error: PROFILE_LOAD_FAILED
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Failed to load profile. Please try again.
                </MudText>
            </div>
        </MudStack>
        <MudButton Variant="Variant.Outlined" Color="Color.Error" Class="mt-4 og-terminal-code" OnClick="LoadProfileAsync">
            retry()
        </MudButton>
    </MudPaper>
}
else
{
    <MudTabs Elevation="0" ApplyEffectsToContainer="true" Rounded="true" PanelClass="pa-4">
        <!-- Personal Information Tab -->
        <MudTabPanel Text="Personal Info" Icon="@Icons.Material.Filled.Person">
            <MudGrid>
                <!-- Account Credentials Card (from IdentityServer) -->
                <MudItem xs="12">
                    <MudPaper Elevation="0" Class="og-terminal-card pa-4 mb-4">
                        <MudText Typo="Typo.subtitle1" Class="mb-4 og-terminal-code">
                            <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Class="mr-2 og-vertical-middle" />
                            Account Credentials
                        </MudText>
                        
                        <MudGrid>
                            <MudItem xs="12" md="6">
                                <MudTextField Value="@authProfile.UserName" 
                                              Label="Username" 
                                              Variant="Variant.Outlined"
                                              Disabled="true"
                                              Class="og-terminal-dark mb-4"
                                              Adornment="Adornment.Start"
                                              AdornmentIcon="@Icons.Material.Filled.AlternateEmail" />
                            </MudItem>
                            
                            <MudItem xs="12" md="6">
                                <MudTextField Value="@authProfile.Email" 
                                              Label="Email" 
                                              Variant="Variant.Outlined"
                                              Disabled="true"
                                              Class="og-terminal-dark mb-4"
                                              Adornment="Adornment.End"
                                              AdornmentIcon="@(authProfile.EmailConfirmed ? Icons.Material.Filled.Verified : Icons.Material.Filled.Warning)"
                                              AdornmentColor="@(authProfile.EmailConfirmed ? Color.Success : Color.Warning)" />
                            </MudItem>
                        </MudGrid>
                        
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-1 og-vertical-middle" />
                            Email and password are managed in <MudLink Href="/Account/Manage/Email" Color="Color.Primary">Email Settings</MudLink>
                        </MudText>
                    </MudPaper>
                </MudItem>
                
                <!-- Personal Info Card -->
                <MudItem xs="12">
                    <MudPaper Elevation="0" Class="og-terminal-card pa-4 mb-4">
                        <MudText Typo="Typo.subtitle1" Class="mb-4 og-terminal-code">
                            <MudIcon Icon="@Icons.Material.Filled.Badge" Class="mr-2 og-vertical-middle" />
                            Personal Information
                        </MudText>
                        
                        <MudGrid>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="phoneNumber"
                                              Label="Phone Number" 
                                              Variant="Variant.Outlined"
                                              Class="og-terminal-dark mb-4"
                                              Adornment="Adornment.End"
                                              AdornmentIcon="@(authProfile.PhoneNumberConfirmed ? Icons.Material.Filled.Verified : Icons.Material.Filled.Phone)"
                                              AdornmentColor="@(authProfile.PhoneNumberConfirmed ? Color.Success : Color.Default)" />
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                </MudItem>
                
                <!-- Security Status Cards -->
                <MudItem xs="12" md="6">
                    <MudPaper Elevation="0" Class="og-terminal-card pa-4 og-h-full">
                        <MudText Typo="Typo.subtitle1" Class="mb-3 og-terminal-code">
                            <MudIcon Icon="@Icons.Material.Filled.Security" Class="mr-2 og-vertical-middle" />
                            Two-Factor Authentication
                        </MudText>
                        
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-2">
                            @if (authProfile.TwoFactorEnabled)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                                <MudText Class="og-terminal-success og-terminal-code">
                                    Enabled
                                </MudText>
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" />
                                <MudText Class="og-terminal-warning og-terminal-code">
                                    Not Enabled
                                </MudText>
                            }
                            <MudSpacer />
                            <MudButton Variant="Variant.Text" Color="Color.Info" Href="/Account/Manage/TwoFactorAuthentication"
                                       Class="og-terminal-code">
                                manage()
                            </MudButton>
                        </MudStack>
                    </MudPaper>
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudPaper Elevation="0" Class="og-terminal-card pa-4 og-h-full">
                        <MudText Typo="Typo.subtitle1" Class="mb-3 og-terminal-code">
                            <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Class="mr-2 og-vertical-middle" />
                            Account Status
                        </MudText>
                        
                        <MudStack Spacing="1" Class="mt-2">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                Email: <span>@(authProfile.EmailConfirmed ? "Verified" : "Unverified")</span>
                            </MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                Phone: <span>@(authProfile.PhoneNumberConfirmed ? "Verified" : "Unverified")</span>
                            </MudText>
                        </MudStack>
                    </MudPaper>
                </MudItem>
                
                <!-- Save Button -->
                <MudItem xs="12">
                    <MudButton Variant="Variant.Filled" 
                               Color="Color.Success" 
                               OnClick="SaveProfileAsync"
                               Disabled="@isSaving"
                               StartIcon="@Icons.Material.Filled.Save"
                           Class="og-terminal-code">
                        @if (isSaving)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        save_profile()
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudTabPanel>
    </MudTabs>
}

@code {
    // Auth profile from IdentityServer
    private Beep.Foundation.IdentityServer.Shared.Services.UserProfile? authProfile;
    
    // Form fields
    private string? phoneNumber;
    
    // UI state
    private bool isLoading = true;
    private bool isSaving = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadProfileAsync();
    }

    private async Task LoadProfileAsync()
    {
        isLoading = true;
        StateHasChanged();
        
        // Load auth profile from IdentityServer
        authProfile = await AccountService.GetProfileAsync();
        
        if (authProfile != null)
        {
            phoneNumber = authProfile.PhoneNumber;
        }
        
        isLoading = false;
    }

    private async Task SaveProfileAsync()
    {
        if (authProfile == null) return;
        
        isSaving = true;
        StateHasChanged();
        
        // Update auth profile (phone number)
        if (authProfile.PhoneNumber != phoneNumber)
        {
            var authResult = await AccountService.UpdateProfileAsync(new UpdateProfileRequest
            {
                Email = authProfile.Email,
                PhoneNumber = phoneNumber
            });
            
            if (!authResult.IsSuccess)
            {
                foreach (var error in authResult.Errors)
                {
                    Snackbar.Add(error, Severity.Error);
                }
            }
            else
            {
                Snackbar.Add("Profile updated successfully!", Severity.Success);
                await LoadProfileAsync(); // Reload to get updated data
            }
        }
        else
        {
            Snackbar.Add("No changes to save.", Severity.Info);
        }
        
        isSaving = false;
    }
}


