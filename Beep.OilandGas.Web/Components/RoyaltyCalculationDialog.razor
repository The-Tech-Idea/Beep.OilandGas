@using System.Collections.Generic
@using Beep.OilandGas.Models.Data
@using Beep.OilandGas.Models.Data.Accounting.Royalty

<MudDialog>
    <DialogContent>
        <MudContainer MaxWidth="MaxWidth.Medium">
            <MudStack Spacing="3">
                <MudTextField @bind-Value="@_poolId" 
                             Label="Pool ID (Optional)" 
                             Variant="Variant.Outlined" />

                <MudDatePicker @bind-Date="@_calculationDate" 
                              Label="Calculation Date" 
                              Variant="Variant.Outlined" 
                              Required="true" />

                <MudTextField T="decimal?" @bind-Value="@_oilRoyaltyRate" 
                             Label="Oil Royalty Rate (%)" 
                             Variant="Variant.Outlined" 
                             HelperText="Default: 12.5%" />

                <MudTextField T="decimal?" @bind-Value="@_gasRoyaltyRate" 
                             Label="Gas Royalty Rate (%)" 
                             Variant="Variant.Outlined" 
                             HelperText="Default: 12.5%" />

                <MudTextField T="decimal?" @bind-Value="@_oilPrice" 
                             Label="Oil Price" 
                             Variant="Variant.Outlined" />

                <MudTextField T="decimal?" @bind-Value="@_gasPrice" 
                             Label="Gas Price" 
                             Variant="Variant.Outlined" />
            </MudStack>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Calculate">Calculate</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Inject] ApiClient ApiClient { get; set; } = default!;
    [Inject] ISnackbar Snackbar { get; set; } = default!;
    [Parameter] public string FieldId { get; set; } = string.Empty;

    private string _poolId = string.Empty;
    private DateTime? _calculationDate = DateTime.Today;
    private decimal? _oilRoyaltyRate = 12.5m;
    private decimal? _gasRoyaltyRate = 12.5m;
    private decimal? _oilPrice;
    private decimal? _gasPrice;

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task Calculate()
    {
        if (!_calculationDate.HasValue)
        {
            Snackbar.Add("Calculation date is required", Severity.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(FieldId))
        {
            Snackbar.Add("No active field is available for royalty calculation.", Severity.Error);
            return;
        }

        try
        {
            var request = new CalculateRoyaltyRequest
            {
                FieldId = FieldId,
                CalculationDate = _calculationDate.Value,
                PoolId = string.IsNullOrWhiteSpace(_poolId) ? null : _poolId,
                OilRoyaltyRate = _oilRoyaltyRate,
                GasRoyaltyRate = _gasRoyaltyRate,
                OilPrice = _oilPrice,
                GasPrice = _gasPrice
            };

            var succeeded = await ApiClient.PostAsync(
                "/api/accounting/royalty/calculate",
                request);

            if (!succeeded)
            {
                Snackbar.Add("Error calculating royalties.", Severity.Error);
                return;
            }

            Snackbar.Add("Royalty calculation completed successfully", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error calculating royalties: {ex.Message}", Severity.Error);
        }
    }
}
