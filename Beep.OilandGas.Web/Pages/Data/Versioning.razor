@page "/data/versioning"
@inject ApiClient ApiClient
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager

<PageTitle>Manage Data Versions</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @if (_loading) { <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" /> }

    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Manage Data Versions</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Create and compare snapshots of PPDM39 data — track who changed what</MudText>
        </MudStack>
        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.Security"
                       OnClick='() => NavigationManager.NavigateTo("/data/audit")'>
                View Access Audit
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.AddCircle"
                       OnClick="CreateSnapshot">
                New Snapshot
            </MudButton>
        </MudStack>
    </MudStack>

    @* Table selector + snapshot trigger *@
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="12" md="4">
            <MudPaper Elevation="1" Class="pa-4">
                <MudText Typo="Typo.subtitle1" Class="mb-3">Snapshot Settings</MudText>
                <MudSelect T="string" @bind-Value="_selectedTable" Label="Table" Variant="Variant.Outlined" Class="mb-3">
                    @foreach (var t in _tables)
                    {
                        <MudSelectItem Value="@t">@t</MudSelectItem>
                    }
                </MudSelect>
                <MudTextField @bind-Value="_snapshotLabel" Label="Label" Variant="Variant.Outlined"
                              Placeholder="e.g. Pre-migration baseline" />
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="8">
            <MudPaper Elevation="1" Class="pa-4">
                <MudText Typo="Typo.subtitle1" Class="mb-3">Snapshot History</MudText>
                <MudDataGrid T="SnapshotRow" Items="@_snapshots" Dense="true" Hover="true" Striped="true">
                    <Columns>
                        <PropertyColumn Property="x => x.Label" Title="Label" />
                        <PropertyColumn Property="x => x.Table" Title="Table" />
                        <PropertyColumn Property="x => x.CreatedBy" Title="Created by" />
                        <PropertyColumn Property="x => x.CreatedAt" Title="Date" Format="dd MMM yyyy HH:mm" />
                        <PropertyColumn Property="x => x.RowCount" Title="Rows" />
                        <TemplateColumn Title="">
                            <CellTemplate>
                                <MudIconButton Icon="@Icons.Material.Filled.Compare"
                                               Size="Size.Small"
                                               Title="Compare with current"
                                               OnClick="@(() => CompareSnapshot(context.Item))" />
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                </MudDataGrid>
            </MudPaper>
        </MudItem>
    </MudGrid>

</MudContainer>

@code {
    private List<string> _tables = new() { "WELL", "WELL_STATUS", "FACILITY", "POOL", "PDEN", "PROSPECT" };
    private string _selectedTable = "WELL";
    private string _snapshotLabel = string.Empty;
    private bool   _loading = false;
    private List<SnapshotRow> _snapshots = new();

    protected override async Task OnInitializedAsync() => await LoadSnapshotsAsync();

    private async Task LoadSnapshotsAsync()
    {
        if (string.IsNullOrWhiteSpace(_selectedTable)) return;
        _loading = true;
        try
        {
            var data = await ApiClient.GetAsync<List<SnapshotApiDto>>(
                $"api/ppdm39/versioning/snapshots?table={Uri.EscapeDataString(_selectedTable)}");
            _snapshots = data?
                .Select(s => new SnapshotRow(s.Label ?? s.Table, s.Table, s.CreatedBy, s.CreatedAt, s.RowCount))
                .ToList() ?? new();
        }
        catch (Exception) { Snackbar.Add("Could not load snapshots.", Severity.Error); }
        finally { _loading = false; }
    }

    private async Task CreateSnapshot()
    {
        if (string.IsNullOrWhiteSpace(_selectedTable)) return;
        var label = string.IsNullOrWhiteSpace(_snapshotLabel)
            ? $"{_selectedTable} — {DateTime.Now:dd MMM yyyy HH:mm}"
            : _snapshotLabel;
        try
        {
            var payload = new { TableName = _selectedTable, Label = label };
            var result  = await ApiClient.PostAsync<object, SnapshotResultDto>(
                "api/ppdm39/versioning/snapshots", payload);
            if (result != null)
            {
                _snapshots.Insert(0, new SnapshotRow(label, _selectedTable, "current.user", DateTime.Now, 0));
                _snapshotLabel = string.Empty;
                Snackbar.Add($"Snapshot '{label}' created.", Severity.Success);
            }
        }
        catch (Exception) { Snackbar.Add("Snapshot failed.", Severity.Error); }
    }

    private void CompareSnapshot(SnapshotRow row) =>
        Snackbar.Add($"Comparing '{row.Label}' with current {row.Table} data…", Severity.Info);

    private class SnapshotApiDto
    {
        public string? Label     { get; set; }
        public string  Table     { get; set; } = string.Empty;
        public string  CreatedBy { get; set; } = string.Empty;
        public DateTime CreatedAt { get; set; }
        public int     RowCount  { get; set; }
    }

    private class SnapshotResultDto
    {
        public bool    Success   { get; set; }
        public string? VersionId { get; set; }
        public string? Message   { get; set; }
    }

    internal record SnapshotRow(string Label, string Table, string CreatedBy, DateTime CreatedAt, int RowCount);
}
