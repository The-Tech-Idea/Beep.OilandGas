@page "/dashboard"
@inject NavigationManager NavigationManager
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject ISnackbar Snackbar
@inject Beep.OilandGas.Web.Theme.IThemeProvider ThemeProvider
@using Beep.OilandGas.Web.Theme

<PageTitle>Dashboard - @(_branding.AppName ?? "Beep Oil & Gas")</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-4">

    @* ── Header ──────────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-6">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Monitor Field Operations</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Asset performance at a glance</MudText>
        </MudStack>
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Explore"
                       OnClick="@(() => NavigationManager.NavigateTo("/ppdm39/production/fields"))">View Fields</MudButton>
            <MudChip T="string" Color="Color.Primary" Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small">
                @(_branding.AppName ?? "Beep Oil &amp; Gas")
            </MudChip>
        </MudStack>
    </MudStack>

    @* ── KPI Row ─────────────────────────────────────────────────────────── *@
    <MudGrid Spacing="3" Class="mb-6">
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Total Wells"
                     Value="@_totalWells.ToString("N0")"
                     ValueColor="Color.Primary"
                     Icon="@Icons.Material.Filled.OilBarrel"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat"
                     TrendColor="Color.Default"
                     TrendText="No change today" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Active Fields"
                     Value="@_activeFields.ToString()"
                     ValueColor="Color.Success"
                     Icon="@Icons.Material.Filled.Explore"
                     TrendIcon="@Icons.Material.Filled.TrendingUp"
                     TrendColor="Color.Success"
                     TrendText="+2 this quarter" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Daily Production"
                     Value="@_dailyProduction.ToString("N0")"
                     Unit="bbl/d"
                     ValueColor="Color.Info"
                     Icon="@Icons.Material.Filled.TrendingUp"
                     TrendIcon="@Icons.Material.Filled.TrendingUp"
                     TrendColor="Color.Success"
                     TrendText="+3.2% vs yesterday" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Facilities"
                     Value="@_facilities.ToString()"
                     ValueColor="Color.Warning"
                     Icon="@Icons.Material.Filled.Factory"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat"
                     TrendColor="Color.Default"
                     TrendText="No change" />
        </MudItem>
    </MudGrid>

    @* ── Workflow Entry Points ────────────────────────────────────────────── *@
    <MudText Typo="Typo.h6" Class="mb-3">Start Work</MudText>
    <MudGrid Spacing="3" Class="mb-6">
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Elevation="1" Class="pa-3 d-flex flex-column align-center gap-2 workflow-card" @onclick='() => NavigationManager.NavigateTo("/exploration")'>
                <img src="/imgs/icons/process/exploration.svg" class="og-icon og-icon-xl" alt="Exploration" />
                <MudText Typo="Typo.caption" Align="Align.Center">Exploration</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Elevation="1" Class="pa-3 d-flex flex-column align-center gap-2 workflow-card" @onclick='() => NavigationManager.NavigateTo("/development")'>
                <img src="/imgs/icons/process/drilling-rig.svg" class="og-icon og-icon-xl" alt="Development" />
                <MudText Typo="Typo.caption" Align="Align.Center">Development</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Elevation="1" Class="pa-3 d-flex flex-column align-center gap-2 workflow-card" @onclick='() => NavigationManager.NavigateTo("/production")'>
                <img src="/imgs/icons/process/wellhead.svg" class="og-icon og-icon-xl" alt="Production" />
                <MudText Typo="Typo.caption" Align="Align.Center">Production</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Elevation="1" Class="pa-3 d-flex flex-column align-center gap-2 workflow-card" @onclick='() => NavigationManager.NavigateTo("/reservoir")'>
                <img src="/imgs/icons/process/reservoir.svg" class="og-icon og-icon-xl" alt="Reservoir" />
                <MudText Typo="Typo.caption" Align="Align.Center">Reservoir</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Elevation="1" Class="pa-3 d-flex flex-column align-center gap-2 workflow-card" @onclick='() => NavigationManager.NavigateTo("/economics/afe")'>
                <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Size="Size.Large" Color="Color.Primary" Class="my-1" />
                <MudText Typo="Typo.caption" Align="Align.Center">Economics</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Elevation="1" Class="pa-3 d-flex flex-column align-center gap-2 workflow-card" @onclick='() => NavigationManager.NavigateTo("/ppdm39/data-management")'>
                <MudIcon Icon="@Icons.Material.Filled.Storage" Size="Size.Large" Color="Color.Secondary" Class="my-1" />
                <MudText Typo="Typo.caption" Align="Align.Center">Data Mgmt</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* ── Recent Activity ─────────────────────────────────────────────────── *@
    <MudText Typo="Typo.h6" Class="mb-3">Recent Activity</MudText>
    <MudPaper Elevation="2" Class="pa-4">
        <MudDataGrid Items="@_recentActivities" Hover="true" Dense="true" ReadOnly="true">
            <Columns>
                <PropertyColumn Property="@(x => x.Type)" Title="Type" />
                <PropertyColumn Property="@(x => x.Description)" Title="Description" />
                <TemplateColumn Title="Date">
                    <CellTemplate>
                        <MudText>@context.Item.Timestamp.ToString("MMM dd, yyyy HH:mm")</MudText>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>
    </MudPaper>

</MudContainer>
@code {
    private BrandingConfig _branding = new();
    private int _totalWells = 0;
    private int _activeFields = 0;
    private decimal _dailyProduction = 0;
    private int _facilities = 0;
    
    private List<ActivityItem> _recentActivities = new();
    
    protected override void OnInitialized()
    {
        _branding = ThemeProvider.GetBranding();
    }
    
    protected override async Task OnInitializedAsync()
    {
        // Check authentication
        try
        {
            var authToken = await LocalStorage.GetItemAsync<string>("auth-token");
            if (string.IsNullOrEmpty(authToken))
            {
                NavigationManager.NavigateTo("/");
                return;
            }
        }
        catch
        {
            NavigationManager.NavigateTo("/");
            return;
        }
        
        // Load dashboard data (placeholder - replace with actual API calls)
        await LoadDashboardData();
    }
    
    private async Task LoadDashboardData()
    {
        // TODO: Replace with actual API calls
        _totalWells = 1247;
        _activeFields = 45;
        _dailyProduction = 125000;
        _facilities = 23;
        
        _recentActivities = new List<ActivityItem>
        {
            new() { Type = "Well", Description = "New well added: WELL-2024-001", Timestamp = DateTime.Now.AddHours(-2) },
            new() { Type = "Production", Description = "Production report generated", Timestamp = DateTime.Now.AddHours(-5) },
            new() { Type = "Data", Description = "PPDM39 table updated: FIELD", Timestamp = DateTime.Now.AddDays(-1) },
            new() { Type = "Field", Description = "Field status changed: ACTIVE", Timestamp = DateTime.Now.AddDays(-2) }
        };
    }
    
    private class ActivityItem
    {
        public string Type { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public DateTime Timestamp { get; set; }
    }
}

