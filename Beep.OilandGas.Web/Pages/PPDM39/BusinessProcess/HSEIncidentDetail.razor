@page "/ppdm39/hse/incidents/{Id}"
@attribute [Authorize(Roles = "SafetyOfficer,Manager,Admin,User")]
@inject Beep.OilandGas.Web.Services.IBusinessProcessServiceClient BusinessProcessClient
@inject Beep.OilandGas.Web.Services.IHSEServiceClient HSEClient
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>HSE Incident — @Id</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="pa-4">

    @* ── Header ──────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                       OnClick='() => NavigationManager.NavigateTo("/ppdm39/hse/incidents")' />
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">@_incidentType — @_description</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <HSEIncidentSeverityBadge Tier="@_tier" />
                <StatusBadge Status="@_status" />
                <MudText Typo="Typo.caption" Color="Color.Secondary">@_incidentDate.ToString("dd-MMM-yyyy HH:mm") · @_location · @_reportedBy</MudText>
            </MudStack>
        </MudStack>
    </MudStack>

    <MudDivider Class="mb-4" />

    @if (!_workflowAvailable && !string.IsNullOrWhiteSpace(_workflowWarning))
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mb-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap">
                <MudText Typo="Typo.body2">@_workflowWarning</MudText>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Warning"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Sync"
                           Disabled="@_ensuringWorkflow"
                           OnClick="EnsureWorkflowAsync">
                    @(_ensuringWorkflow ? "Creating Workflow..." : "Create Workflow")
                </MudButton>
            </MudStack>
        </MudAlert>
    }

    <MudGrid Spacing="3">

        @* ── Incident details ─────────────────────────────────────────── *@
        <MudItem xs="12" md="5">
            <MudCard Elevation="2" Class="mb-3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1">Incident Details</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudSimpleTable Dense="true">
                        <tbody>
                            <tr><td><MudText Typo="Typo.caption">Date/Time</MudText></td>
                                <td><MudText Typo="Typo.body2">@_incidentDate.ToString("dd-MMM-yyyy HH:mm")</MudText></td></tr>
                            <tr><td><MudText Typo="Typo.caption">Type</MudText></td>
                                <td><MudText Typo="Typo.body2">@_incidentType</MudText></td></tr>
                            <tr><td><MudText Typo="Typo.caption">Tier</MudText></td>
                                <td><HSEIncidentSeverityBadge Tier="@_tier" /></td></tr>
                            <tr><td><MudText Typo="Typo.caption">Location</MudText></td>
                                <td><MudText Typo="Typo.body2">@_location</MudText></td></tr>
                            <tr><td><MudText Typo="Typo.caption">Reported By</MudText></td>
                                <td><MudText Typo="Typo.body2">@_reportedBy</MudText></td></tr>
                        </tbody>
                    </MudSimpleTable>
                </MudCardContent>
            </MudCard>

            @* RCA section *@
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudIcon Icon="@Icons.Material.Filled.Search" Color="Color.Info" />
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1">Root Cause Analysis</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @if (string.IsNullOrWhiteSpace(_rcaSummary))
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">RCA not yet submitted.</MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Class="mb-3">@_rcaSummary</MudText>
                    }
                    @if (_canEditRca)
                    {
                        <MudTextField @bind-Value="_rcaDraft" Label="RCA Summary"
                                      Lines="4" Variant="Variant.Outlined" Class="mb-2" />
                        <MudButton Variant="Variant.Filled" Color="Color.Info"
                                   StartIcon="@Icons.Material.Filled.Save"
                                   Disabled="@(!_workflowAvailable)"
                                   OnClick="SubmitRcaAsync">
                            Submit RCA
                        </MudButton>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        @* ── Corrective actions ───────────────────────────────────────── *@
        <MudItem xs="12" md="7">
            <MudCard Elevation="2" Class="mb-3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1">Corrective Actions</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudButton Size="Size.Small" Variant="Variant.Text"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   Disabled="@(!_workflowAvailable)"
                                   OnClick="AddActionAsync">
                            Add
                        </MudButton>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    <MudDataGrid T="ActionRow" Items="@_correctiveActions" Dense="true" Hover="true" Striped="true">
                        <Columns>
                            <PropertyColumn Property="a => a.Description" Title="Action" />
                            <PropertyColumn Property="a => a.AssignedTo"  Title="Assigned To" />
                            <PropertyColumn Property="a => a.DueDate"     Title="Due"    Format="dd-MMM-yy" />
                            <TemplateColumn Title="Status" Sortable="false">
                                <CellTemplate>
                                    <StatusBadge Status="@context.Item.Status" />
                                </CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="" Sortable="false">
                                <CellTemplate>
                                    @if (context.Item.Status != "COMPLETED")
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.CheckCircle"
                                                       Size="Size.Small" Color="Color.Success"
                                                       Disabled="@(!_workflowAvailable)"
                                                       OnClick='@(() => CloseActionAsync(context.Item.ActionId))' />
                                    }
                                </CellTemplate>
                            </TemplateColumn>
                        </Columns>
                    </MudDataGrid>
                </MudCardContent>
            </MudCard>

            @* Close-out *@
            @if (_status != "CLOSED" && _canClose)
            {
                <MudCard Elevation="2">
                    <MudCardContent>
                        <MudTextField @bind-Value="_closeNotes" Label="Close-out Notes"
                                      Lines="2" Variant="Variant.Outlined" Class="mb-2" />
                        <MudButton Variant="Variant.Filled" Color="Color.Success"
                                   StartIcon="@Icons.Material.Filled.CheckCircle"
                                   Disabled="@(!_workflowAvailable || _correctiveActions.Any(a => a.Status != "COMPLETED"))"
                                   OnClick="CloseIncidentAsync">
                            Close Incident
                        </MudButton>
                    </MudCardContent>
                </MudCard>
            }
        </MudItem>

    </MudGrid>

</MudContainer>

@* ── Add Corrective Action dialog ──────────────────────────────────────────── *@
<MudDialog @bind-IsVisible="_showAddActionDialog">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Add" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Add Corrective Action</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_caDescription" Label="Description"
                          Variant="Variant.Outlined" Lines="2" Required="true" />
            <MudSelect @bind-Value="_caType" Label="Type" Variant="Variant.Outlined">
                <MudSelectItem Value='"CORRECTIVE"'>Corrective</MudSelectItem>
                <MudSelectItem Value='"PREVENTIVE"'>Preventive</MudSelectItem>
                <MudSelectItem Value='"IMMEDIATE"'>Immediate</MudSelectItem>
                <MudSelectItem Value='"LONG_TERM"'>Long-term</MudSelectItem>
            </MudSelect>
            <MudDatePicker @bind-Date="_caDueDateNullable" Label="Due Date" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="_caResponsibleBaId" Label="Responsible Person / BA ID"
                          Variant="Variant.Outlined" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showAddActionDialog = false)" Disabled="@_addingAction">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Save"
                   Disabled="@_addingAction"
                   OnClick="SubmitAddActionAsync">
            @(_addingAction ? "Saving…" : "Add Action")
        </MudButton>
    </DialogActions>
</MudDialog>

@using Microsoft.AspNetCore.Authorization
@using Beep.OilandGas.Models.Processes
@using Beep.OilandGas.Models.Data.HSE

@code {
    [Parameter] public string Id { get; set; } = string.Empty;

    private string   _loadedId     = string.Empty;
    private string   _incidentType = string.Empty;
    private string   _description  = string.Empty;
    private string   _tier         = "3";
    private string   _status       = "OPEN";
    private string   _location     = string.Empty;
    private string   _reportedBy   = string.Empty;
    private DateTime _incidentDate = DateTime.Today;
    private string   _rcaSummary   = string.Empty;
    private string   _rcaDraft     = string.Empty;
    private string   _closeNotes   = string.Empty;
    private bool     _canEditRca   = true;
    private bool     _canClose     = true;
    private bool     _workflowAvailable = true;
    private string   _workflowWarning = string.Empty;
    private bool     _ensuringWorkflow = false;

    private List<ActionRow> _correctiveActions = new();

    protected override async Task OnInitializedAsync()
    {
        _loadedId = Id;
        await LoadDetailAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Id == _loadedId) return;
        _loadedId = Id;
        await LoadDetailAsync();
    }

    private async Task LoadDetailAsync()
    {
        try
        {
            _workflowAvailable = true;
            _workflowWarning = string.Empty;

            var incidentTask = HSEClient.GetIncidentAsync(Id);
            var causesTask = HSEClient.GetIncidentCausesAsync(Id);
            var correctiveActionsTask = HSEClient.GetIncidentCorrectiveActionsAsync(Id);
            var processTask = TryGetWorkflowIncidentAsync(Id);

            await Task.WhenAll(incidentTask, causesTask, correctiveActionsTask, processTask);

            var incident = await incidentTask;
            var causes = await causesTask;
            var correctiveActions = await correctiveActionsTask;
            var inst = await processTask;

            if (incident != null)
            {
                _incidentType = incident.IncidentType;
                _description = incident.Description;
                _tier = incident.Tier.ToString();
                _status = incident.CurrentState;
                _location = incident.Location;
                _incidentDate = incident.IncidentDate;
                _reportedBy = inst?.StartedBy ?? incident.InvestigatorId ?? string.Empty;
                _canEditRca = _workflowAvailable
                    && !string.Equals(incident.CurrentState, IncidentState.Closed, StringComparison.OrdinalIgnoreCase)
                    && !string.Equals(incident.CurrentState, IncidentState.Cancelled, StringComparison.OrdinalIgnoreCase);
                _canClose = _workflowAvailable
                    && !string.Equals(incident.CurrentState, IncidentState.Closed, StringComparison.OrdinalIgnoreCase)
                    && !string.Equals(incident.CurrentState, IncidentState.Cancelled, StringComparison.OrdinalIgnoreCase);
            }

            _correctiveActions = correctiveActions
                .OrderBy(action => action.StepSeq)
                .Select(action => new ActionRow(
                    action.StepSeq.ToString(),
                    action.Description,
                    action.ResponsiblePerson ?? string.Empty,
                    action.DueDate,
                    action.Status))
                .ToList();

            _rcaSummary = causes
                .Where(cause => string.Equals(cause.CauseType, CauseType.Root, StringComparison.OrdinalIgnoreCase))
                .Select(cause => cause.Description)
                .FirstOrDefault(description => !string.IsNullOrWhiteSpace(description))
                ?? string.Empty;

            if (string.IsNullOrWhiteSpace(_rcaDraft))
            {
                _rcaDraft = _rcaSummary;
            }
        }
        catch
        {
            Snackbar.Add("Could not load incident detail.", Severity.Warning);
        }
    }

    private async Task<ProcessInstance?> TryGetWorkflowIncidentAsync(string incidentId)
    {
        try
        {
            return await BusinessProcessClient.GetHseIncidentAsync(incidentId);
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
        {
            _workflowAvailable = false;
            _workflowWarning = "No workflow instance was found for this incident. The PPDM incident record is still available, but workflow actions are disabled for this page.";
            return null;
        }
    }

    private async Task EnsureWorkflowAsync()
    {
        _ensuringWorkflow = true;

        try
        {
            var instance = await BusinessProcessClient.EnsureHseIncidentWorkflowAsync(Id);
            await LoadDetailAsync();
            Snackbar.Add(
                instance == null
                    ? "Workflow was not created."
                    : "Workflow created for this incident.",
                instance == null ? Severity.Warning : Severity.Success);
        }
        catch
        {
            Snackbar.Add("Could not create workflow for this incident.", Severity.Error);
        }
        finally
        {
            _ensuringWorkflow = false;
        }
    }

    private async Task SubmitRcaAsync()
    {
        try
        {
            var req = new HSEIncidentUpdateRequest
            {
                RcaSummary = _rcaDraft,
                RcaCauseCategory = CauseCategory.Process
            };
            await BusinessProcessClient.SubmitHseIncidentRcaAsync(Id, req);
            await LoadDetailAsync();
            Snackbar.Add("RCA submitted.", Severity.Success);
        }
        catch { Snackbar.Add("Could not submit RCA.", Severity.Error); }
    }

    private async Task CloseActionAsync(string actionId)
    {
        try
        {
            var req = new CorrectiveActionCloseRequest
            {
                Notes = "Marked completed from incident detail."
            };
            await BusinessProcessClient.CloseHseCorrectiveActionAsync(Id, actionId, req);
            await LoadDetailAsync();
            Snackbar.Add("Action closed.", Severity.Success);
        }
        catch { Snackbar.Add("Could not close action.", Severity.Error); }
    }

    private async Task CloseIncidentAsync()
    {
        try
        {
            var req = new IncidentCloseRequest
            {
                Reason = _closeNotes
            };
            await BusinessProcessClient.CloseHseIncidentAsync(Id, req);
            _status = "CLOSED";
            Snackbar.Add("Incident closed.", Severity.Success);
            NavigationManager.NavigateTo("/ppdm39/hse/incidents");
        }
        catch { Snackbar.Add("Could not close incident.", Severity.Error); }
    }

    private record ActionRow(string ActionId, string Description, string AssignedTo, DateTime DueDate, string Status);

    // ── Add-action dialog state ─────────────────────────────────────────
    private bool     _showAddActionDialog = false;
    private bool     _addingAction        = false;
    private string   _caDescription       = string.Empty;
    private string   _caType              = "CORRECTIVE";
    private DateTime _caDueDate           = DateTime.Today.AddDays(30);
    private DateTime? _caDueDateNullable  { get => _caDueDate; set => _caDueDate = value ?? DateTime.Today.AddDays(30); }
    private string   _caResponsibleBaId   = string.Empty;

    private async Task AddActionAsync()
    {
        _caDescription     = string.Empty;
        _caType            = "CORRECTIVE";
        _caDueDate         = DateTime.Today.AddDays(30);
        _caResponsibleBaId = string.Empty;
        _showAddActionDialog = true;
        await Task.CompletedTask;
    }

    private async Task SubmitAddActionAsync()
    {
        if (string.IsNullOrWhiteSpace(_caDescription))
        {
            Snackbar.Add("Description is required.", Severity.Warning);
            return;
        }
        _addingAction = true;
        try
        {
            var request = new HSEIncidentUpdateRequest
            {
                AssignedToUserId = _caResponsibleBaId,
                CorrectiveActions = new List<string> { _caDescription },
                CorrectiveActionType = _caType,
                CorrectiveActionDueDate = _caDueDate
            };

            await BusinessProcessClient.RaiseHseCorrectiveActionsAsync(Id, request);
            await LoadDetailAsync();
            _showAddActionDialog = false;
            Snackbar.Add("Corrective action added.", Severity.Success);
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to add action.", Severity.Error);
        }
        finally { _addingAction = false; }
    }
}
