@page "/ppdm39/process/definitions/{Id}"
@inject ApiClient ApiClient
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Process Definition — @_def?.ProcessName</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="pa-4">

    @* ── Header ──────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                       OnClick='() => NavigationManager.NavigateTo("/ppdm39/process/definitions")' />
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">@(_def?.ProcessName ?? "Loading…")</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudChip T="string" Size="Size.Small" Color="Color.Primary">@_def?.ProcessType</MudChip>
                <MudChip T="string" Size="Size.Small" Color="Color.Info">@_def?.EntityType</MudChip>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@_fieldName</MudText>
            </MudStack>
        </MudStack>
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.PlayArrow"
                   OnClick="StartInstanceAsync">
            Start Instance
        </MudButton>
    </MudStack>

    <MudDivider Class="mb-4" />

    @if (_def == null)
    {
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="200px" />
    }
    else
    {
        <MudGrid Spacing="3">

            @* ── Overview ─────────────────────────────────────────────── *@
            <MudItem xs="12" md="4">
                <MudCard Elevation="2" Class="h-100">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.subtitle1">Overview</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body2" Class="mb-3">@_def.Description</MudText>
                        <MudSimpleTable Dense="true">
                            <tbody>
                                <tr><td><MudText Typo="Typo.caption">Process ID</MudText></td>
                                    <td><MudText Typo="Typo.body2">@_def.ProcessId</MudText></td></tr>
                                <tr><td><MudText Typo="Typo.caption">Type</MudText></td>
                                    <td><MudText Typo="Typo.body2">@_def.ProcessType</MudText></td></tr>
                                <tr><td><MudText Typo="Typo.caption">Entity</MudText></td>
                                    <td><MudText Typo="Typo.body2">@_def.EntityType</MudText></td></tr>
                                <tr><td><MudText Typo="Typo.caption">Steps</MudText></td>
                                    <td><MudText Typo="Typo.body2">@_def.Steps.Count</MudText></td></tr>
                                <tr><td><MudText Typo="Typo.caption">Created</MudText></td>
                                    <td><MudText Typo="Typo.body2">@_def.CreatedDate.ToString("dd-MMM-yyyy")</MudText></td></tr>
                            </tbody>
                        </MudSimpleTable>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            @* ── Step list ─────────────────────────────────────────────── *@
            <MudItem xs="12" md="8">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.subtitle1">Process Steps</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent Class="pa-0">
                        <MudDataGrid T="StepRow" Items="@_steps" Dense="true" Hover="true" Striped="true">
                            <Columns>
                                <PropertyColumn Property="s => s.Seq"      Title="#" />
                                <PropertyColumn Property="s => s.StepName" Title="Step" />
                                <PropertyColumn Property="s => s.StepType" Title="Type" />
                                <TemplateColumn Title="PPDM Tables" Sortable="false">
                                    <CellTemplate>
                                        @foreach (var tbl in context.Item.PpdmTables)
                                        {
                                            <PPDMTableLink TableName="@tbl" />
                                            <MudText Typo="Typo.caption"> </MudText>
                                        }
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn Title="Approval" Sortable="false">
                                    <CellTemplate>
                                        @if (context.Item.RequiresApproval)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.HowToReg"
                                                     Color="Color.Warning" Size="Size.Small" />
                                        }
                                    </CellTemplate>
                                </TemplateColumn>
                            </Columns>
                        </MudDataGrid>
                    </MudCardContent>
                </MudCard>
            </MudItem>

        </MudGrid>
    }

</MudContainer>

@* ── Start Instance dialog ─────────────────────────────────────────────── *@
<MudDialog @bind-IsVisible="_showStartDialog">
    <TitleContent>
        <MudText Typo="Typo.h6">Start Process Instance</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_startEntityId"
                          Label="Entity ID (UWI, Facility ID, Prospect ID…)"
                          Variant="Variant.Outlined"
                          Required="true" />
            <MudTextField @bind-Value="_startEntityType"
                          Label="Entity Type"
                          Variant="Variant.Outlined" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showStartDialog = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="@_starting"
                   OnClick="ConfirmStartInstanceAsync">
            @(_starting ? "Starting…" : "Start")
        </MudButton>
    </DialogActions>
</MudDialog>

@using Beep.OilandGas.LifeCycle.Models.Processes
@using Beep.OilandGas.Models.Data

@code {
    [Parameter] public string Id { get; set; } = string.Empty;

    private string _loadedId  = string.Empty;
    private string _fieldName = string.Empty;
    private ProcessDefinition? _def;
    private List<StepRow> _steps = new();

    // ── Start-instance dialog state ──────────────────────────────────────
    private bool   _showStartDialog = false;
    private string _startEntityId   = string.Empty;
    private string _startEntityType = string.Empty;
    private bool   _starting        = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summary = await ApiClient.GetAsync<FieldLifecycleSummary>("/api/field/current/summary");
            if (summary != null)
                _fieldName = summary.FieldName ?? _fieldName;
        }
        catch { /* field name is non-critical */ }

        _loadedId = Id;
        await LoadDefinitionAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Id == _loadedId) return;
        _loadedId = Id;
        await LoadDefinitionAsync();
    }

    private async Task LoadDefinitionAsync()
    {
        try
        {
            _def = await ApiClient.GetAsync<ProcessDefinition>($"/api/field/current/process/definitions/{Uri.EscapeDataString(Id)}");
            if (_def != null)
            {
                _steps = (_def.Steps ?? new())
                    .OrderBy(s => s.SequenceNumber)
                    .Select(s => new StepRow(
                        s.SequenceNumber, s.StepName, s.StepType, s.RequiresApproval,
                        GetPpdmTablesForStepType(s.StepType)
                    )).ToList();
            }
        }
        catch
        {
            Snackbar.Add("Could not load process definition.", Severity.Warning);
        }
    }

    private async Task StartInstanceAsync()
    {
        _startEntityId   = string.Empty;
        _startEntityType = _def?.EntityType ?? string.Empty;
        _showStartDialog = true;
    }

    private async Task ConfirmStartInstanceAsync()
    {
        if (string.IsNullOrWhiteSpace(_startEntityId))
        {
            Snackbar.Add("Entity ID is required.", Severity.Warning);
            return;
        }

        _starting = true;
        try
        {
            var request = new
            {
                ProcessId  = Id,
                EntityId   = _startEntityId,
                EntityType = _startEntityType
            };
            var instance = await ApiClient.PostAsync<object, ProcessInstanceSummary>(
                "/api/field/current/process/instances", request);
            _showStartDialog = false;
            Snackbar.Add("Process instance started.", Severity.Success);
            if (instance != null)
                NavigationManager.NavigateTo($"/ppdm39/process/instances/{Uri.EscapeDataString(instance.InstanceId)}");
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to start instance.", Severity.Error);
        }
        finally { _starting = false; }
    }

    private static List<string> GetPpdmTablesForStepType(string stepType) =>
        stepType switch
        {
            "APPROVAL" => new() { "PROJECT_STEP_BA", "BA_AUTHORITY" },
            "ACTION"   => new() { "PROJECT_STEP", "PROJECT_PLAN" },
            _          => new() { "PROJECT_STEP" }
        };

    private record StepRow(int Seq, string StepName, string StepType, bool RequiresApproval, List<string> PpdmTables);
}
