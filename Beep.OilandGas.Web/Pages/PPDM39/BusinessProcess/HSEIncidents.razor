@page "/ppdm39/hse/incidents"
@using Beep.OilandGas.Models.Data
@using Beep.OilandGas.Models.Data.HSE
@inject Beep.OilandGas.Web.Services.IBusinessProcessServiceClient BusinessProcessClient
@inject Beep.OilandGas.Web.Services.IHSEServiceClient HSEClient
@inject ILifeCycleService LifeCycleService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Manage HSE Incidents</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @* ── Header ──────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Manage HSE Incidents</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Report, track, and close-out field incidents</MudText>
        </MudStack>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.AddAlert"
                   Disabled="@_requiresLogin"
                   OnClick="OpenReportDialogAsync">
            Report Incident
        </MudButton>
    </MudStack>

    @if (!string.IsNullOrWhiteSpace(_loadWarning))
    {
        <MudAlert Severity="@(_requiresLogin ? Severity.Info : Severity.Warning)"
                  Variant="Variant.Outlined"
                  Class="mb-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap">
                <MudText Typo="Typo.body2">@_loadWarning</MudText>
                @if (_requiresLogin)
                {
                    <MudButton Variant="Variant.Text"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Login"
                               Href="@BuildLoginUrl()">
                        Sign In
                    </MudButton>
                }
            </MudStack>
        </MudAlert>
    }

    @* ── KPI chips ───────────────────────────────────────────────────── *@
    <MudStack Row="true" Spacing="2" Class="mb-4" Wrap="Wrap.Wrap">
        <MudChip T="string" Color="Color.Error"    Icon="@Icons.Material.Filled.Error">Tier 1: @_tier1Count fatal/PTD</MudChip>
        <MudChip T="string" Color="Color.Warning"  Icon="@Icons.Material.Filled.Warning">Tier 2: @_tier2Count LTI</MudChip>
        <MudChip T="string" Color="Color.Info"     Icon="@Icons.Material.Filled.Info">Tier 3: @_tier3Count MTC/RWC</MudChip>
        <MudChip T="string" Color="Color.Success"  Icon="@Icons.Material.Filled.CheckCircle">Tier 4: @_tier4Count First Aid</MudChip>
        <MudDivider Vertical="true" FlexItem="true" />
        <MudChip T="string" Color="Color.Default">Open: @_openCount</MudChip>
        <MudChip T="string" Color="Color.Success">Closed: @_closedCount</MudChip>
        @if (_missingWorkflowCount > 0)
        {
            <MudChip T="string" Color="Color.Warning" Icon="@Icons.Material.Filled.SyncProblem">
                Missing Workflow: @_missingWorkflowCount
            </MudChip>
        }
    </MudStack>

    @* ── Severity filter ─────────────────────────────────────────────── *@
    <MudPaper Elevation="1" Class="pa-3 mb-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Wrap="Wrap.Wrap">
            <MudTextField @bind-Value="_search" Placeholder="Search incidents…"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true" />
            <MudSelect T="string" @bind-Value="_tierFilter" Label="API RP 754 Tier">
                <MudSelectItem Value='""'>All Tiers</MudSelectItem>
                <MudSelectItem Value='"1"'>Tier 1 — Fatal/PTD</MudSelectItem>
                <MudSelectItem Value='"2"'>Tier 2 — LTI</MudSelectItem>
                <MudSelectItem Value='"3"'>Tier 3 — MTC/RWC</MudSelectItem>
                <MudSelectItem Value='"4"'>Tier 4 — First Aid</MudSelectItem>
            </MudSelect>
            <MudSelect T="string" @bind-Value="_statusFilter" Label="Status">
                <MudSelectItem Value='""'>All</MudSelectItem>
                <MudSelectItem Value='"OPEN"'>Open</MudSelectItem>
                <MudSelectItem Value='"UNDER INVESTIGATION"'>Under Investigation</MudSelectItem>
                <MudSelectItem Value='"RCA IN PROGRESS"'>RCA In Progress</MudSelectItem>
                <MudSelectItem Value='"CLOSED"'>Closed</MudSelectItem>
            </MudSelect>
        </MudStack>
    </MudPaper>

    @* ── Grid ────────────────────────────────────────────────────────── *@
    <MudDataGrid T="IncidentRow"
                 Items="@FilteredIncidents"
                 Dense="true"
                 Hover="true"
                 Striped="true"
                 Sortable="true"
                 RowClick="@(e => NavigationManager.NavigateTo($"/ppdm39/hse/incidents/{Uri.EscapeDataString(e.Item.IncidentId)}"))">
        <Columns>
            <PropertyColumn Property="r => r.IncidentDate" Title="Date"         Format="dd-MMM-yy" />
            <PropertyColumn Property="r => r.IncidentType" Title="Type" />
            <PropertyColumn Property="r => r.Description"  Title="Description" />
            <PropertyColumn Property="r => r.Location"     Title="Location" />
            <TemplateColumn Title="Tier" Sortable="false">
                <CellTemplate>
                    <HSEIncidentSeverityBadge Tier="@context.Item.Tier" />
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Status" Sortable="false">
                <CellTemplate>
                    <StatusBadge Status="@context.Item.Status" />
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Workflow" Sortable="false">
                <CellTemplate>
                    <MudChip T="string"
                             Variant="Variant.Outlined"
                             Size="Size.Small"
                             Color="@(context.Item.HasWorkflow ? Color.Success : Color.Warning)">
                        @context.Item.WorkflowStatus
                    </MudChip>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="r => r.ReportedBy"  Title="Reported By" />
            <TemplateColumn Title="" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                        @if (!context.Item.HasWorkflow)
                        {
                            <MudButton Variant="Variant.Text"
                                       Size="Size.Small"
                                       Color="Color.Warning"
                                       StartIcon="@Icons.Material.Filled.Sync"
                                       Disabled="@(_ensuringWorkflowIncidentId == context.Item.IncidentId)"
                                       OnClick='@(() => EnsureWorkflowAsync(context.Item.IncidentId))'>
                                @(_ensuringWorkflowIncidentId == context.Item.IncidentId ? "Creating..." : "Create Workflow")
                            </MudButton>
                        }

                        <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                       Size="Size.Small" Color="Color.Primary"
                                       OnClick='@(() => NavigationManager.NavigateTo($"/ppdm39/hse/incidents/{Uri.EscapeDataString(context.Item.IncidentId)}"))' />
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="IncidentRow" />
        </PagerContent>
    </MudDataGrid>

</MudContainer>

@* ── Report Incident dialog ───────────────────────────────────────────────── *@
<MudDialog @bind-IsVisible="_showReportDialog">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.AddAlert" Color="Color.Error" />
            <MudText Typo="Typo.h6">Report Incident</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudSelect @bind-Value="_rIncidentType" Label="Incident Type" Variant="Variant.Outlined" Required="true">
                <MudSelectItem Value='"SPILL"'>Spill / Release</MudSelectItem>
                <MudSelectItem Value='"FIRE"'>Fire / Explosion</MudSelectItem>
                <MudSelectItem Value='"INJURY"'>Personal Injury</MudSelectItem>
                <MudSelectItem Value='"NEAR_MISS"'>Near Miss</MudSelectItem>
                <MudSelectItem Value='"ENVIRONMENTAL"'>Environmental</MudSelectItem>
                <MudSelectItem Value='"PROPERTY_DAMAGE"'>Property Damage</MudSelectItem>
                <MudSelectItem Value='"PROCESS_SAFETY"'>Process Safety</MudSelectItem>
            </MudSelect>
            <MudSelect @bind-Value="_rTier" T="int" Label="API RP 754 Tier" Variant="Variant.Outlined">
                <MudSelectItem Value="1">Tier 1 — Fatality / PTD</MudSelectItem>
                <MudSelectItem Value="2">Tier 2 — Lost Time Injury</MudSelectItem>
                <MudSelectItem Value="3">Tier 3 — MTC / RWC</MudSelectItem>
                <MudSelectItem Value="4">Tier 4 — First Aid / Near Miss</MudSelectItem>
            </MudSelect>
            <MudDatePicker @bind-Date="_rIncidentDateNullable" Label="Incident Date" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="_rLocation" Label="Location" Variant="Variant.Outlined" Required="true" />
            <MudTextField @bind-Value="_rDescription" Label="Description" Variant="Variant.Outlined"
                          Lines="3" Required="true" />
            <MudTextField @bind-Value="_rJurisdiction" Label="Jurisdiction" Variant="Variant.Outlined" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showReportDialog = false)" Disabled="@_reporting">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.Send"
                   Disabled="@_reporting"
                   OnClick="SubmitReportAsync">
            @(_reporting ? "Submitting…" : "Submit Report")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private string _fieldName = string.Empty;
    private string _search       = string.Empty;
    private string _tierFilter   = string.Empty;
    private string _statusFilter = string.Empty;

    private int _tier1Count = 0;
    private int _tier2Count = 0;
    private int _tier3Count = 0;
    private int _tier4Count = 0;
    private int _openCount  = 0;
    private int _closedCount = 0;
    private int _missingWorkflowCount = 0;
    private string? _loadWarning;
    private bool _requiresLogin;

    private List<IncidentRow> _incidents = new();

    private IEnumerable<IncidentRow> FilteredIncidents => _incidents.Where(i =>
        (string.IsNullOrWhiteSpace(_search) ||
            i.Description.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
            i.IncidentType.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
            i.WorkflowStatus.Contains(_search, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrWhiteSpace(_tierFilter)   || i.Tier   == _tierFilter) &&
        (string.IsNullOrWhiteSpace(_statusFilter) || i.Status.Equals(_statusFilter, StringComparison.OrdinalIgnoreCase)));

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summary = await LifeCycleService.GetFieldLifecycleSummaryAsync();
            if (summary != null)
                _fieldName = summary.FieldName ?? _fieldName;
        }
        catch
        {
            // Field name is helpful for the header but non-blocking for incident operations.
        }

        await LoadIncidentsAsync();
    }

    private async Task LoadIncidentsAsync()
    {
        try
        {
            var incidentsTask = HSEClient.GetIncidentsAsync();
            var workflowsTask = BusinessProcessClient.GetHseIncidentsAsync();

            await Task.WhenAll(incidentsTask, workflowsTask);

            var incidents = await incidentsTask;
            var workflows = (await workflowsTask)
                .Where(workflow => !string.IsNullOrWhiteSpace(workflow.EntityId) && !string.IsNullOrWhiteSpace(workflow.InstanceId))
                .GroupBy(workflow => workflow.EntityId, StringComparer.OrdinalIgnoreCase)
                .ToDictionary(
                    grouping => grouping.Key,
                    grouping => grouping.OrderByDescending(workflow => workflow.StartedAt).First(),
                    StringComparer.OrdinalIgnoreCase);

            _incidents = incidents
                .Select(incident =>
                {
                    workflows.TryGetValue(incident.IncidentId, out var workflow);
                    var hasWorkflow = workflow != null;
                    var reportedBy = hasWorkflow && !string.IsNullOrWhiteSpace(workflow?.StartedBy)
                        ? workflow.StartedBy
                        : incident.InvestigatorId ?? string.Empty;

                    return new IncidentRow(
                        incident.IncidentId,
                        incident.IncidentDate,
                        incident.IncidentType,
                        incident.Description,
                        incident.Location,
                        incident.Tier.ToString(),
                        incident.CurrentState,
                        hasWorkflow,
                        hasWorkflow ? "Linked" : "Missing",
                        reportedBy);
                })
                .OrderByDescending(incident => incident.IncidentDate)
                .ToList();

            _tier1Count = _incidents.Count(i => i.Tier == "1");
            _tier2Count = _incidents.Count(i => i.Tier == "2");
            _tier3Count = _incidents.Count(i => i.Tier == "3");
            _tier4Count = _incidents.Count(i => i.Tier == "4");
            _openCount   = _incidents.Count(i => !string.Equals(i.Status, "CLOSED", StringComparison.OrdinalIgnoreCase));
            _closedCount = _incidents.Count(i => string.Equals(i.Status, "CLOSED", StringComparison.OrdinalIgnoreCase));
            _missingWorkflowCount = _incidents.Count(i => !i.HasWorkflow);
            _loadWarning = null;
            _requiresLogin = false;
        }
        catch (HttpRequestException ex) when (ex.StatusCode is System.Net.HttpStatusCode.Unauthorized or System.Net.HttpStatusCode.Forbidden)
        {
            _incidents = new();
            _tier1Count = 0;
            _tier2Count = 0;
            _tier3Count = 0;
            _tier4Count = 0;
            _openCount = 0;
            _closedCount = 0;
            _missingWorkflowCount = 0;
            _requiresLogin = true;
            _loadWarning = "Sign in to load HSE incidents and workflow status for the current field.";
        }
        catch
        {
            _requiresLogin = false;
            _loadWarning = "Could not load HSE incidents.";
            Snackbar.Add("Could not load HSE incidents.", Severity.Warning);
        }
    }

    private string BuildLoginUrl()
    {
        var returnUrl = Uri.EscapeDataString(NavigationManager.Uri);
        return $"/login?returnUrl={returnUrl}";
    }

    // ── Report-incident dialog state ─────────────────────────────────────
    private bool     _showReportDialog  = false;
    private bool     _reporting         = false;
    private string   _ensuringWorkflowIncidentId = string.Empty;
    private string   _rIncidentType     = "SPILL";
    private int      _rTier             = 4;
    private DateTime _rIncidentDate     = DateTime.Today;
    private string   _rLocation         = string.Empty;
    private string   _rDescription      = string.Empty;
    private string   _rJurisdiction     = "USA";

    // MudDatePicker requires DateTime?
    private DateTime? _rIncidentDateNullable
    {
        get => _rIncidentDate;
        set => _rIncidentDate = value ?? DateTime.Today;
    }

    private async Task OpenReportDialogAsync()
    {
        _rIncidentType = "SPILL";
        _rTier         = 4;
        _rIncidentDate = DateTime.Today;
        _rLocation     = string.Empty;
        _rDescription  = string.Empty;
        _rJurisdiction = "USA";
        _showReportDialog = true;
        await Task.CompletedTask;
    }

    private async Task SubmitReportAsync()
    {
        if (string.IsNullOrWhiteSpace(_rDescription) || string.IsNullOrWhiteSpace(_rLocation))
        {
            Snackbar.Add("Description and location are required.", Severity.Warning);
            return;
        }
        _reporting = true;
        try
        {
            var request = new HSEIncidentReportRequest
            {
                IncidentType = _rIncidentType,
                Severity = MapTierToSeverity(_rTier),
                IncidentDateTime = _rIncidentDate,
                LocationDescription = _rLocation,
                Description = _rDescription
            };
            var result = await BusinessProcessClient.ReportHseIncidentAsync(request);
            _showReportDialog = false;
            await LoadIncidentsAsync();
            Snackbar.Add("Incident reported.", Severity.Success);
            if (result != null && !string.IsNullOrWhiteSpace(result.EntityId))
                NavigationManager.NavigateTo($"/ppdm39/hse/incidents/{Uri.EscapeDataString(result.EntityId)}");
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to report incident.", Severity.Error);
        }
        finally { _reporting = false; }
    }

    private async Task EnsureWorkflowAsync(string incidentId)
    {
        _ensuringWorkflowIncidentId = incidentId;

        try
        {
            var instance = await BusinessProcessClient.EnsureHseIncidentWorkflowAsync(incidentId);
            await LoadIncidentsAsync();

            Snackbar.Add(
                instance == null
                    ? "Workflow was not created for the incident."
                    : "Workflow created for the incident.",
                instance == null ? Severity.Warning : Severity.Success);
        }
        catch
        {
            Snackbar.Add("Could not create workflow for the incident.", Severity.Error);
        }
        finally
        {
            _ensuringWorkflowIncidentId = string.Empty;
        }
    }

    private static string MapTierToSeverity(int tier) => tier switch
    {
        1 => "TIER1",
        2 => "TIER2",
        3 => "TIER3",
        _ => "TIER4"
    };

    private record IncidentRow(
        string IncidentId, DateTime IncidentDate, string IncidentType,
        string Description, string Location, string Tier,
        string Status, bool HasWorkflow, string WorkflowStatus, string ReportedBy);
}
