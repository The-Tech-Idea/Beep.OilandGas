@page "/ppdm39/process/instances"
@inject Beep.OilandGas.Web.Services.IBusinessProcessServiceClient BusinessProcessClient
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Process Instances</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @* ── Header ──────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Monitor Process Instances</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — All active and completed instances</MudText>
        </MudStack>
        <MudButton Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   OnClick='() => NavigationManager.NavigateTo("/ppdm39/process")'>
            Dashboard
        </MudButton>
    </MudStack>

    @* ── Filters ─────────────────────────────────────────────────────── *@
    <MudPaper Elevation="1" Class="pa-3 mb-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Wrap="Wrap.Wrap">
            <MudTextField @bind-Value="_search"
                          Placeholder="Search by process name or entity…"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true" />
            <MudSelect T="string" @bind-Value="_statusFilter" Label="Status">
                <MudSelectItem Value='""'>All Statuses</MudSelectItem>
                <MudSelectItem Value='"NOT_STARTED"'>Not Started</MudSelectItem>
                <MudSelectItem Value='"IN_PROGRESS"'>In Progress</MudSelectItem>
                <MudSelectItem Value='"COMPLETED"'>Completed</MudSelectItem>
                <MudSelectItem Value='"SUSPENDED"'>Suspended</MudSelectItem>
                <MudSelectItem Value='"FAILED"'>Failed</MudSelectItem>
                <MudSelectItem Value='"CANCELLED"'>Cancelled</MudSelectItem>
            </MudSelect>
            <MudSelect T="string" @bind-Value="_typeFilter" Label="Type">
                <MudSelectItem Value='""'>All Types</MudSelectItem>
                <MudSelectItem Value='"EXPLORATION"'>Exploration</MudSelectItem>
                <MudSelectItem Value='"DEVELOPMENT"'>Development</MudSelectItem>
                <MudSelectItem Value='"PRODUCTION"'>Production</MudSelectItem>
                <MudSelectItem Value='"DECOMMISSIONING"'>Decommissioning</MudSelectItem>
            </MudSelect>
        </MudStack>
    </MudPaper>

    @* ── Grid ────────────────────────────────────────────────────────── *@
    <MudDataGrid T="InstanceRow"
                 Items="@FilteredInstances"
                 Dense="true"
                 Hover="true"
                 Striped="true"
                 Sortable="true"
                 RowClick="@(e => NavigationManager.NavigateTo($"/ppdm39/process/instances/{Uri.EscapeDataString(e.Item.InstanceId)}"))">
        <Columns>
            <PropertyColumn Property="r => r.ProcessName"    Title="Process" />
            <PropertyColumn Property="r => r.ProcessType"    Title="Type" />
            <PropertyColumn Property="r => r.EntityId"       Title="Entity" />
            <PropertyColumn Property="r => r.CurrentStepName" Title="Current Step" />
            <TemplateColumn Title="Status" Sortable="false">
                <CellTemplate>
                    <ProcessStatusBadge Status="@context.Item.Status" />
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="r => r.StartedAt"   Title="Started"   Format="dd-MMM-yy" />
            <PropertyColumn Property="r => r.StartedBy"   Title="Started By" />
            <TemplateColumn Title="" Sortable="false">
                <CellTemplate>
                    <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   OnClick='@(() => NavigationManager.NavigateTo($"/ppdm39/process/instances/{Uri.EscapeDataString(context.Item.InstanceId)}"))' />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="InstanceRow" />
        </PagerContent>
    </MudDataGrid>

</MudContainer>

@code {
    private string _fieldName = string.Empty;
    private string _search        = string.Empty;
    private string _statusFilter  = string.Empty;
    private string _typeFilter    = string.Empty;

    private List<InstanceRow> _instances = new();

    private IEnumerable<InstanceRow> FilteredInstances => _instances.Where(i =>
        (string.IsNullOrWhiteSpace(_search) ||
            i.ProcessName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
            i.EntityId.Contains(_search, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrWhiteSpace(_statusFilter) || i.Status == _statusFilter) &&
        (string.IsNullOrWhiteSpace(_typeFilter)   || i.ProcessType == _typeFilter));

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var data = await BusinessProcessClient.GetInstancesAsync();
            if (data.Count > 0)
            {
                _instances = data.Select(i => new InstanceRow(
                    i.InstanceId,
                    string.IsNullOrWhiteSpace(i.ProcessName) ? i.ProcessId : i.ProcessName,
                    i.ProcessType,
                    i.EntityId,
                    i.CurrentStepName,
                    i.Status,
                    i.StartedAt,
                    i.StartedBy
                )).ToList();
            }
            else
            {
                _instances = new();
            }
        }
        catch
        {
            Snackbar.Add("Could not load process instances.", Severity.Warning);
        }
    }

    private record InstanceRow(
        string InstanceId, string ProcessName, string ProcessType,
        string EntityId, string CurrentStepName, string Status,
        DateTime StartedAt, string StartedBy);
}
