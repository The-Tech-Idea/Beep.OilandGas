@page "/ppdm39/compliance/obligations"
@inject ApiClient ApiClient
@inject Beep.OilandGas.Web.Services.IComplianceServiceClient ComplianceClient
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Compliance Obligations</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @* ── Header ──────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Track Compliance Obligations</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Regulatory obligations calendar and overdue alerts</MudText>
        </MudStack>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.PostAdd"
                   OnClick='() => NavigationManager.NavigateTo("/ppdm39/compliance/report")'>
            Submit Report
        </MudButton>
    </MudStack>

    @* ── Alert: overdue count ────────────────────────────────────────── *@
    @if (_overdueCount > 0)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4" Icon="@Icons.Material.Filled.Error">
            <MudText Typo="Typo.body2"><strong>@_overdueCount obligation(s) are overdue.</strong> Immediate action required.</MudText>
        </MudAlert>
    }

    <MudGrid Spacing="3">

        @* ── Due within 30 days ───────────────────────────────────────── *@
        <MudItem xs="12" md="5">
            <MudCard Elevation="2" Class="h-100">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Color="Color.Warning" />
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1">Due Within 30 Days</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <ObligationCalendar Items="@_dueSoon" />
                </MudCardContent>
            </MudCard>
        </MudItem>

        @* ── All obligations table ────────────────────────────────────── *@
        <MudItem xs="12" md="7">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1">All Obligations</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <JurisdictionFilterChips @bind-SelectedJurisdiction="_jurisdiction" />
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    <MudDataGrid T="ObligationRow"
                                 Items="@FilteredObligations"
                                 Dense="true"
                                 Hover="true"
                                 Striped="true"
                                 Sortable="true">
                        <Columns>
                            <PropertyColumn Property="o => o.ObligationType"  Title="Type" />
                            <PropertyColumn Property="o => o.JurisdictionTag" Title="Jurisdiction" />
                            <PropertyColumn Property="o => o.DueDate"         Title="Due"    Format="dd-MMM-yy" />
                            <TemplateColumn Title="Days Left" Sortable="false">
                                <CellTemplate>
                                    @{
                                        var days = context.Item.DaysUntilDue;
                                        var color = days < 0 ? Color.Error : days <= 14 ? Color.Warning : Color.Success;
                                    }
                                    <MudChip T="string" Size="Size.Small" Color="@color">
                                        @(days < 0 ? $"{Math.Abs(days)}d OD" : $"{days}d")
                                    </MudChip>
                                </CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="Status" Sortable="false">
                                <CellTemplate>
                                    <StatusBadge Status="@context.Item.Status" />
                                </CellTemplate>
                            </TemplateColumn>
                            <PropertyColumn Property="o => o.AssignedTo"      Title="Assigned To" />
                        </Columns>
                        <PagerContent>
                            <MudDataGridPager T="ObligationRow" />
                        </PagerContent>
                    </MudDataGrid>
                </MudCardContent>
            </MudCard>
        </MudItem>

    </MudGrid>

</MudContainer>

@using Beep.OilandGas.Models.Data.Compliance
@using Beep.OilandGas.Models.Data

@code {
    private string _fieldName = string.Empty;
    private string _jurisdiction = "ALL";
    private int    _overdueCount = 0;

    private List<ObligationRow>            _obligations = new();
    private List<ComplianceObligationSummary> _dueSoon  = new();

    private IEnumerable<ObligationRow> FilteredObligations => _obligations.Where(o =>
        _jurisdiction == "ALL" || o.JurisdictionTag == _jurisdiction);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summaryTask = ApiClient.GetAsync<FieldLifecycleSummary>("/api/field/current/summary");
            var obligationsTask = ComplianceClient.GetAllObligationsAsync(DateTime.Today.Year);
            var upcomingTask = ComplianceClient.GetUpcomingObligationsAsync(30);

            await Task.WhenAll(summaryTask, obligationsTask, upcomingTask);

            _fieldName = summaryTask.Result?.FieldName ?? _fieldName;

            var obligations = obligationsTask.Result;
            if (obligations.Count > 0)
            {
                _obligations = obligations.Select(o => new ObligationRow(
                    o.ObligationId,
                    o.ObligType,
                    o.Jurisdiction,
                    o.DueDate,
                    o.Status,
                    string.Empty,
                    o.DaysUntilDue
                )).ToList();

                _overdueCount = _obligations.Count(o => o.DaysUntilDue < 0);
                _dueSoon = upcomingTask.Result.Select(o => new ComplianceObligationSummary
                {
                    ObligationId = o.ObligationId,
                    ObligationType = o.ObligType,
                    JurisdictionTag = o.Jurisdiction,
                    DueDate = o.DueDate,
                    Status = o.Status,
                    AssignedTo = string.Empty,
                    DaysUntilDue = o.DaysUntilDue
                }).ToList();
            }
            else
            {
                _obligations = new();
                _overdueCount = 0;
                _dueSoon = new();
            }
        }
        catch
        {
            Snackbar.Add("Could not load compliance obligations.", Severity.Warning);
        }
    }

    private record ObligationRow(
        string ObligationId, string ObligationType, string JurisdictionTag,
        DateTime DueDate, string Status, string AssignedTo, int DaysUntilDue);
}
