@page "/ppdm39/process/instances/{Id}"
@inject ApiClient ApiClient
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Process Instance — @Id</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="pa-4">

    @* ── Header ──────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                       OnClick='() => NavigationManager.NavigateTo("/ppdm39/process/instances")' />
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">@_processName</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <ProcessStatusBadge Status="@_status" />
                <MudText Typo="Typo.caption" Color="Color.Secondary">Entity: @_entityId · Started: @_startedAt.ToString("dd-MMM-yyyy") by @_startedBy</MudText>
            </MudStack>
        </MudStack>
    </MudStack>

    <MudDivider Class="mb-4" />

    <MudGrid Spacing="3">

        @* ── Left: step timeline ─────────────────────────────────────── *@
        <MudItem xs="12" md="4">
            <MudCard Elevation="2" Class="h-100">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1">Process Steps</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <ProcessStepTimeline Steps="@_steps"
                                         CurrentStepId="@_currentStepId"
                                         CompletedStepIds="@_completedStepIds" />
                </MudCardContent>
            </MudCard>
        </MudItem>

        @* ── Right: current step + transitions ───────────────────────── *@
        <MudItem xs="12" md="8">

            <MudCard Elevation="2" Class="mb-3">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudIcon Icon="@Icons.Material.Filled.PlayCircle" Color="Color.Primary" />
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1">Current Step: @_currentStepName</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@_currentStepType</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2" Class="mb-3">Available transitions:</MudText>
                    <StateTransitionPanel InstanceId="@Id"
                                          Transitions="@_transitions"
                                          OnTransitioned="OnTransitionedAsync" />
                </MudCardContent>
            </MudCard>

            @* History *@
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1">History</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    <MudDataGrid T="HistoryRow" Items="@_history" Dense="true" Hover="true" Striped="true">
                        <Columns>
                            <PropertyColumn Property="h => h.Timestamp" Title="When"      Format="dd-MMM-yy HH:mm" />
                            <PropertyColumn Property="h => h.Action"    Title="Action" />
                            <PropertyColumn Property="h => h.Notes"     Title="Notes" />
                            <PropertyColumn Property="h => h.By"        Title="By" />
                        </Columns>
                    </MudDataGrid>
                </MudCardContent>
            </MudCard>
        </MudItem>

    </MudGrid>

</MudContainer>

@using Beep.OilandGas.LifeCycle.Models.Processes

@code {
    [Parameter] public string Id { get; set; } = string.Empty;

    private string _loadedId         = string.Empty;
    private string _processName     = string.Empty;
    private string _entityId        = string.Empty;
    private string _status          = "IN_PROGRESS";
    private string _currentStepId   = string.Empty;
    private string _currentStepName = string.Empty;
    private string _currentStepType = string.Empty;
    private DateTime _startedAt     = DateTime.Today;
    private string _startedBy       = string.Empty;

    private List<ProcessStepDefinition>  _steps           = new();
    private HashSet<string>              _completedStepIds = new();
    private List<ProcessTransition>      _transitions      = new();
    private List<HistoryRow>             _history          = new();

    protected override async Task OnInitializedAsync()
    {
        _loadedId = Id;
        await LoadInstanceAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Id == _loadedId) return;
        _loadedId = Id;
        await LoadInstanceAsync();
    }

    private async Task LoadInstanceAsync()
    {
        try
        {
            var inst = await ApiClient.GetAsync<ProcessInstance>($"/api/field/current/process/instances/{Uri.EscapeDataString(Id)}");
            if (inst != null)
            {
                _processName     = inst.ProcessId;
                _entityId        = inst.EntityId;
                _status          = inst.Status.ToString();
                _currentStepId   = inst.CurrentStepId;
                _startedAt       = inst.StartDate;
                _startedBy       = inst.StartedBy;

                if (inst.StepInstances?.Count > 0)
                {
                    _completedStepIds = inst.StepInstances
                        .Where(s => s.Status == StepStatus.COMPLETED)
                        .Select(s => s.StepId)
                        .ToHashSet();
                }

                // Rebuild step list from definition if available via history; otherwise leave empty
                _steps = new();
            }

            var history = await ApiClient.GetAsync<List<ProcessHistoryEntry>>($"/api/field/current/process/instances/{Uri.EscapeDataString(Id)}/history") ?? new();            if (history != null)
            {
                _history = history.Select(h => new HistoryRow(h.Timestamp, h.Action, h.Notes, h.PerformedBy)).ToList();
            }
        }
        catch
        {
            Snackbar.Add("Could not load process instance.", Severity.Warning);
        }
    }

    private async Task OnTransitionedAsync()
    {
        Snackbar.Add("Instance updated.", Severity.Success);
        await LoadInstanceAsync();
        StateHasChanged();
    }

    private record HistoryRow(DateTime Timestamp, string Action, string Notes, string By);
}
