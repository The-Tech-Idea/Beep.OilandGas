@page "/ppdm39/hse/incident/{IncidentId}"
@inject NavigationManager NavigationManager

<PageTitle>HSE Incident</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="pa-6">
    <MudPaper Elevation="1" Class="pa-6">
        <MudStack Spacing="2" AlignItems="AlignItems.Center">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Redirecting to the workflow-backed incident detail page…</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Legacy incident detail routes now use the unified HSE workflow experience.
            </MudText>
        </MudStack>
    </MudPaper>
</MudContainer>

@code {
    [Parameter] public string IncidentId { get; set; } = string.Empty;

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender)
            return;

        var incidentId = Uri.EscapeDataString(IncidentId ?? string.Empty);
        NavigationManager.NavigateTo($"/ppdm39/hse/incidents/{incidentId}", replace: true);
    }
}