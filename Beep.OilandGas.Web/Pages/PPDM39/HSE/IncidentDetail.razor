@page "/ppdm39/hse/incident/{IncidentId}"
@using Beep.OilandGas.Models.Data.HSE
@using Beep.OilandGas.Web.Services
@inject ApiClient ApiClient
@inject IHSEServiceClient HSEClient
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Incident @IncidentId</PageTitle>

<MudStack Spacing="3">

    @* ── Header ───────────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIconButton Icon="@Icons.Material.Outlined.ArrowBack"
                           Href="/ppdm39/hse" Size="Size.Small" />
            <MudStack Spacing="0">
                <MudText Typo="Typo.h6">@(_incident?.IncidentType ?? "Incident")</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@IncidentId</MudText>
            </MudStack>
        </MudStack>

        @if (_incident is not null)
        {
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudChip T="string" Color="@TierColor(_incident.Tier)"
                         Value="@("Tier " + _incident.Tier)">
                    Tier @_incident.Tier
                </MudChip>
                <MudChip T="string" Color="@StateColor(_incident.CurrentState)"
                         Value="@_incident.CurrentState">
                    @_incident.CurrentState.Replace("_", " ")
                </MudChip>
                @if (_triggers.Count > 0)
                {
                    <MudMenu Label="Transition" EndIcon="@Icons.Material.Outlined.ArrowDropDown"
                             Variant="Variant.Filled" Color="Color.Primary">
                        @foreach (var t in _triggers)
                        {
                            <MudMenuItem OnClick="@(() => TransitionAsync(t))">
                                @t.Replace("_", " ")
                            </MudMenuItem>
                        }
                    </MudMenu>
                }
            </MudStack>
        }
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_incident is not null)
    {
        <MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" Class="mt-1">

            @* ── Overview ─────────────────────────────────────────────── *@
            <MudTabPanel Text="Overview" Icon="@Icons.Material.Outlined.Info">
                <MudGrid Spacing="2" Class="pa-2">
                    <MudItem xs="12" md="6">
                        <MudPaper Elevation="1" Class="pa-3">
                            <MudText Typo="Typo.subtitle2" Class="mb-2">Incident Details</MudText>
                            <MudStack Spacing="1">
                                <MudStack Row="true">
                                    <MudText Typo="Typo.subtitle2" Class="mr-2">Date</MudText>
                                    <MudText Typo="Typo.caption">@_incident.IncidentDate.ToString("dd-MMM-yyyy")</MudText>
                                </MudStack>
                                <MudStack Row="true">
                                    <MudText Typo="Typo.subtitle2" Class="mr-2">Location</MudText>
                                    <MudText Typo="Typo.caption">@_incident.Location</MudText>
                                </MudStack>
                                <MudStack Row="true">
                                    <MudText Typo="Typo.subtitle2" Class="mr-2">Jurisdiction</MudText>
                                    <MudText Typo="Typo.caption">@_incident.Jurisdiction</MudText>
                                </MudStack>
                                <MudStack Row="true">
                                    <MudText Typo="Typo.subtitle2" Class="mr-2">Investigator</MudText>
                                    <MudText Typo="Typo.caption">@(_incident.InvestigatorId ?? "Not assigned")</MudText>
                                </MudStack>
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudPaper Elevation="1" Class="pa-3">
                            <MudText Typo="Typo.subtitle2" Class="mb-2">Description</MudText>
                            <MudText Typo="Typo.body2">@_incident.Description</MudText>
                        </MudPaper>
                    </MudItem>

                    @* Barrier Summary *@
                    @if (_barrierSummary is not null)
                    {
                        <MudItem xs="12">
                            <MudPaper Elevation="1" Class="pa-3">
                                <MudText Typo="Typo.subtitle2" Class="mb-2">
                                    Barrier Summary
                                    @if (_barrierSummary.API754TierInfluence < _incident.Tier)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Class="ml-2"
                                                 Value="@("⚠ API RP 754 suggests Tier " + _barrierSummary.API754TierInfluence)">
                                            ⚠ API RP 754 suggests Tier @_barrierSummary.API754TierInfluence
                                        </MudChip>
                                    }
                                </MudText>
                                <MudStack Row="true" Spacing="3">
                                    <MudText Typo="Typo.caption">
                                        Total: <strong>@_barrierSummary.TotalBarriers</strong>
                                    </MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Error">
                                        Failed: <strong>@_barrierSummary.FailedBarriers</strong>
                                    </MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Warning">
                                        Degraded: <strong>@_barrierSummary.DegradedBarriers</strong>
                                    </MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Success">
                                        Effective: <strong>@_barrierSummary.EffectiveBarriers</strong>
                                    </MudText>
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            </MudTabPanel>

            @* ── RCA ──────────────────────────────────────────────────── *@
            <MudTabPanel Text="Root Cause Analysis" Icon="@Icons.Material.Outlined.AccountTree">
                <MudPaper Elevation="0" Class="pa-3">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                        <MudText Typo="Typo.subtitle2">5-Why Cause Chain</MudText>
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                            @if (_rcaComplete)
                            {
                                <MudChip T="string" Color="Color.Success" Size="Size.Small"
                                         Value="@("RCA Complete")">✓ RCA Complete</MudChip>
                            }
                            <MudButton Size="Size.Small" StartIcon="@Icons.Material.Outlined.Add"
                                       OnClick="OpenAddCauseDialog">Add Cause</MudButton>
                        </MudStack>
                    </MudStack>

                    @if (_causes.Count == 0)
                    {
                        <MudText Color="Color.Secondary">No cause findings yet.</MudText>
                    }
                    else
                    {
                        @foreach (var cause in _causes.OrderBy(c => c.Seq))
                        {
                            <MudPaper Elevation="1" Class="pa-2 mb-2">
                                <MudGrid Spacing="1">
                                    <MudItem xs="1">
                                        <MudText Typo="Typo.body2"><strong>Why @cause.Seq</strong></MudText>
                                    </MudItem>
                                    <MudItem xs="2">
                                        <MudChip T="string" Size="Size.Small"
                                                 Color="@CauseTypeColor(cause.CauseType)"
                                                 Value="@cause.CauseType">
                                            @cause.CauseType
                                        </MudChip>
                                    </MudItem>
                                    <MudItem xs="2">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@cause.Category</MudText>
                                    </MudItem>
                                    <MudItem xs="7">
                                        <MudText Typo="Typo.body2">@cause.Description</MudText>
                                    </MudItem>
                                </MudGrid>
                            </MudPaper>
                        }
                    }
                </MudPaper>
            </MudTabPanel>

            @* ── Corrective Actions ────────────────────────────────────── *@
            <MudTabPanel Text="Corrective Actions" Icon="@Icons.Material.Outlined.AssignmentTurnedIn">
                <MudPaper Elevation="0" Class="pa-3">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
                        <MudText Typo="Typo.subtitle2">Corrective Actions</MudText>
                        <MudButton Size="Size.Small" StartIcon="@Icons.Material.Outlined.Add"
                                   OnClick="OpenAddCADialog">Add CA</MudButton>
                    </MudStack>

                    @if (_cas.Count == 0)
                    {
                        <MudText Color="Color.Secondary">No corrective actions.</MudText>
                    }
                    else
                    {
                        <MudTable Items="_cas" Dense="true" Hover="true" Elevation="0">
                            <HeaderContent>
                                <MudTh>#</MudTh>
                                <MudTh>Description</MudTh>
                                <MudTh>Type</MudTh>
                                <MudTh>Due</MudTh>
                                <MudTh>Status</MudTh>
                                <MudTh></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.StepSeq</MudTd>
                                <MudTd>@context.Description</MudTd>
                                <MudTd><MudText Typo="Typo.caption">@context.CAType</MudText></MudTd>
                                <MudTd>
                                    <MudText Color="@(context.IsOverdue ? Color.Error : Color.Default)"
                                             Typo="Typo.caption">
                                        @context.DueDate.ToString("dd-MMM-yyyy")
                                        @if (context.IsOverdue) { <text> ⚠</text> }
                                    </MudText>
                                </MudTd>
                                <MudTd>
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@(context.Status == "COMPLETED" ? Color.Success : Color.Default)"
                                             Value="@context.Status">
                                        @context.Status
                                    </MudChip>
                                </MudTd>
                                <MudTd>
                                    @if (context.Status != "COMPLETED")
                                    {
                                        <MudIconButton Icon="@Icons.Material.Outlined.CheckCircle"
                                                       Size="Size.Small" Color="Color.Success"
                                                       Title="Mark Complete"
                                                       OnClick="@(async () => await CompleteCAAsync(context.StepSeq))" />
                                    }
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudPaper>
            </MudTabPanel>

        </MudTabs>
    }

    @if (!string.IsNullOrEmpty(_error))
    {
        <MudAlert Severity="Severity.Error" ShowCloseIcon="true"
                  CloseIconClicked="@(() => _error = null)">@_error</MudAlert>
    }

</MudStack>

@* ── Add Cause Dialog ──────────────────────────────────────────────────────── *@
<MudDialog @bind-IsVisible="_showAddCause"
           Options="@(new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true })">
    <TitleContent><MudText Typo="Typo.h6">Add Cause Finding</MudText></TitleContent>
    <DialogContent>
        <MudGrid Spacing="2">
            <MudItem xs="12" md="6">
                <MudSelect T="string" Label="Cause Type" @bind-Value="_newCauseType">
                    <MudSelectItem Value="@CauseType.Immediate">Immediate</MudSelectItem>
                    <MudSelectItem Value="@CauseType.Contributing">Contributing</MudSelectItem>
                    <MudSelectItem Value="@CauseType.Root">Root Cause</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudSelect T="string" Label="Category" @bind-Value="_newCauseCategory">
                    <MudSelectItem Value="@CauseCategory.Human">Human</MudSelectItem>
                    <MudSelectItem Value="@CauseCategory.Equipment">Equipment</MudSelectItem>
                    <MudSelectItem Value="@CauseCategory.Process">Process</MudSelectItem>
                    <MudSelectItem Value="@CauseCategory.Environment">Environment</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_newCauseDesc" Label="Description"
                              Lines="3" Required="true" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showAddCause = false)">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SubmitCauseAsync">Add</MudButton>
    </DialogActions>
</MudDialog>

@* ── Add CA Dialog ─────────────────────────────────────────────────────────── *@
<MudDialog @bind-IsVisible="_showAddCA"
           Options="@(new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent><MudText Typo="Typo.h6">Add Corrective Action</MudText></TitleContent>
    <DialogContent>
        <MudGrid Spacing="2">
            <MudItem xs="12">
                <MudTextField @bind-Value="_newCADesc" Label="Description" Lines="2" Required="true" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudSelect T="string" Label="CA Type" @bind-Value="_newCAType">
                    <MudSelectItem Value="@("ENGINEERING")">Engineering</MudSelectItem>
                    <MudSelectItem Value="@("PROCEDURAL")">Procedural</MudSelectItem>
                    <MudSelectItem Value="@("TRAINING")">Training</MudSelectItem>
                    <MudSelectItem Value="@("MANAGEMENT")">Management</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudDatePicker Label="Due Date" @bind-Date="_newCADue" DateFormat="dd-MMM-yyyy" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showAddCA = false)">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SubmitCAAsync">Add</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public string IncidentId { get; set; } = string.Empty;

    private HSEIncidentRecord?  _incident;
    private List<CauseFinding>  _causes         = new();
    private List<CAStatus>      _cas            = new();
    private BarrierSummary?     _barrierSummary;
    private List<string>        _triggers       = new();
    private bool                _rcaComplete;
    private bool                _loading;
    private string?             _error;
    private string              _loadedId = string.Empty;

    // Add cause dialog
    private bool    _showAddCause;
    private string  _newCauseType     = CauseType.Contributing;
    private string  _newCauseCategory = CauseCategory.Human;
    private string  _newCauseDesc     = string.Empty;

    // Add CA dialog
    private bool      _showAddCA;
    private string    _newCADesc = string.Empty;
    private string    _newCAType = "ENGINEERING";
    private DateTime? _newCADue  = DateTime.Today.AddDays(30);

    protected override async Task OnParametersSetAsync()
    {
        if (IncidentId == _loadedId) return;
        _loadedId = IncidentId;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error   = null;
        try
        {
            _incident       = await HSEClient.GetIncidentAsync(IncidentId);
            _causes         = await HSEClient.GetIncidentCausesAsync(IncidentId);
            _cas            = await HSEClient.GetIncidentCorrectiveActionsAsync(IncidentId);
            _barrierSummary = await HSEClient.GetIncidentBarrierSummaryAsync(IncidentId);
            _rcaComplete    = await HSEClient.IsIncidentRcaCompleteAsync(IncidentId);

            if (_incident is not null)
            {
                var stateKey = _incident.CurrentState;
                _triggers = stateKey switch
                {
                    IncidentState.Reported                => new() { "investigate" },
                    IncidentState.UnderInvestigation      => new() { "rca_start", "cancel" },
                    IncidentState.PendingRCA              => new() { "rca_complete", "cancel" },
                    IncidentState.PendingCorrectiveAction => new() { "ca_done", "cancel" },
                    IncidentState.PendingCloseOut         => new() { "close" },
                    _                                     => new(),
                };
            }
        }
        catch (Exception) { _error = "Failed to load incident."; Snackbar.Add(_error, Severity.Error); }
        finally { _loading = false; }
    }

    private async Task TransitionAsync(string trigger)
    {
        try
        {
            var transitioned = await HSEClient.TransitionIncidentAsync(
                IncidentId,
                new TransitionIncidentRequest { Trigger = trigger });

            if (!transitioned)
                throw new InvalidOperationException("Transition failed.");

            await LoadAsync();
        }
        catch (Exception) { _error = "Transition failed."; Snackbar.Add(_error, Severity.Error); }
    }

    private void OpenAddCauseDialog()
    {
        _newCauseType     = CauseType.Contributing;
        _newCauseCategory = CauseCategory.Human;
        _newCauseDesc     = string.Empty;
        _showAddCause     = true;
    }

    private async Task SubmitCauseAsync()
    {
        if (string.IsNullOrWhiteSpace(_newCauseDesc)) return;
        try
        {
            var added = await HSEClient.AddIncidentCauseAsync(
                IncidentId,
                new AddCauseRequest(_newCauseType, _newCauseDesc, _newCauseCategory, _causes.Count + 1));

            if (!added)
                throw new InvalidOperationException("Failed to add cause.");

            _showAddCause = false;
            _causes = await HSEClient.GetIncidentCausesAsync(IncidentId);
            _rcaComplete = await HSEClient.IsIncidentRcaCompleteAsync(IncidentId);
        }
        catch (Exception) { _error = "Failed to add cause."; Snackbar.Add(_error, Severity.Error); }
    }

    private void OpenAddCADialog()
    {
        _newCADesc = string.Empty;
        _newCAType = "ENGINEERING";
        _newCADue  = DateTime.Today.AddDays(30);
        _showAddCA = true;
    }

    private async Task SubmitCAAsync()
    {
        if (string.IsNullOrWhiteSpace(_newCADesc)) return;
        try
        {
            var request = new AddCARequest(
                _newCADesc, _newCAType,
                _newCADue ?? DateTime.Today.AddDays(30),
                string.Empty);

            var added = await HSEClient.AddIncidentCorrectiveActionAsync(IncidentId, request);
            if (!added)
                throw new InvalidOperationException("Failed to add corrective action.");

            _showAddCA = false;
            _cas = await HSEClient.GetIncidentCorrectiveActionsAsync(IncidentId);
        }
        catch (Exception) { _error = "Failed to add CA."; Snackbar.Add(_error, Severity.Error); }
    }

    private async Task CompleteCAAsync(int stepSeq)
    {
        try
        {
            var completed = await HSEClient.CompleteIncidentCorrectiveActionAsync(IncidentId, stepSeq);
            if (!completed)
                throw new InvalidOperationException("Failed to complete corrective action.");

            _cas = await HSEClient.GetIncidentCorrectiveActionsAsync(IncidentId);
        }
        catch (Exception) { _error = "Failed to complete CA."; Snackbar.Add(_error, Severity.Error); }
    }

    private static Color TierColor(int tier) => tier switch
    {
        1 => Color.Error,
        2 => Color.Warning,
        3 => Color.Info,
        _ => Color.Default,
    };

    private static Color StateColor(string state) => state switch
    {
        IncidentState.Closed    => Color.Success,
        IncidentState.Cancelled => Color.Error,
        IncidentState.PendingRCA => Color.Info,
        _                       => Color.Warning,
    };

    private static Color CauseTypeColor(string type) => type switch
    {
        CauseType.Root         => Color.Error,
        CauseType.Contributing => Color.Warning,
        _                      => Color.Default,
    };
}
