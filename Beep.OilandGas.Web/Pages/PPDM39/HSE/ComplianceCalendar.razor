@page "/hse/compliance"
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject ApiClient ApiClient
@inject IComplianceServiceClient ComplianceClient
@inject ILifeCycleService LifeCycleService
@using Beep.OilandGas.Models.Data.Compliance

<PageTitle>Compliance Calendar</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @if (_loading) { <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" /> }

    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Track Compliance Deadlines</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Regulatory &amp; permit compliance schedule</MudText>
        </MudStack>
        <MudStack Row="true" Spacing="2">
            @if (!string.IsNullOrWhiteSpace(ReturnTo))
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           Href="@ReturnTo">
                    Back
                </MudButton>
            }
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Add" OnClick="AddObligation">
                Add Obligation
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Download" OnClick="ExportCalendar">
                Export
            </MudButton>
        </MudStack>
    </MudStack>

    @* KPIs *@
    <MudGrid Class="mb-4" Spacing="3">
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Due This Month" Value="@_dueThisMonth.ToString()" Unit="items"
                     ValueColor="Color.Warning" Icon="@Icons.Material.Filled.CalendarMonth"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default" TrendText="April 2026" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Overdue" Value="@_obligations.Count(o => o.Status == "OVERDUE").ToString()"
                     ValueColor="Color.Error" Icon="@Icons.Material.Filled.ErrorOutline"
                     TrendIcon="@Icons.Material.Filled.TrendingUp" TrendColor="Color.Error" TrendText="Immediate action" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Compliance Rate (YTD)" Value="@_complianceRate.ToString("N0")" Unit="%"
                     ValueColor="@(_complianceRate >= 95 ? Color.Success : Color.Warning)"
                     Icon="@Icons.Material.Filled.VerifiedUser"
                     TrendIcon="@Icons.Material.Filled.TrendingUp" TrendColor="Color.Success" TrendText="vs 95% target" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Open Permits" Value="@_obligations.Count(o => o.ObligationType == "Permit" && o.Status != "COMPLETE").ToString()"
                     ValueColor="Color.Info" Icon="@Icons.Material.Filled.Badge"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default" TrendText="Active" />
        </MudItem>
    </MudGrid>

    <MudGrid Spacing="3">

        @* Upcoming obligations *@
        <MudItem xs="12" md="8">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.subtitle1">Compliance Obligations</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">@_filter</MudChip>
                        </MudStack>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudSelect T="string" @bind-Value="_filter" Label="Filter" Variant="Variant.Text" Dense="true" Class="og-select-sm">
                            <MudSelectItem Value="@("All")">All</MudSelectItem>
                            <MudSelectItem Value="@("Overdue")">Overdue</MudSelectItem>
                            <MudSelectItem Value="@("Due Soon")">Due Soon</MudSelectItem>
                            <MudSelectItem Value="@("Permit")">Permits</MudSelectItem>
                            <MudSelectItem Value="@("Reporting")">Reporting</MudSelectItem>
                        </MudSelect>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    <MudDataGrid T="ObligationDto" Items="@FilteredObligations" Dense="true" Hover="true"
                                 SortMode="SortMode.Single">
                        <Columns>
                            <PropertyColumn Property="o => o.ObligationId" Title="Obligation ID" />
                            <PropertyColumn Property="o => o.ObligationType" Title="Type" />
                            <PropertyColumn Property="o => o.JurisdictionTag" Title="Jurisdiction" />
                            <PropertyColumn Property="o => o.DueDate" Title="Due Date" Sortable="true" />
                            <TemplateColumn Title="Status">
                                <CellTemplate>
                                    <StatusBadge Status="@context.Item.Status" />
                                </CellTemplate>
                            </TemplateColumn>
                            <PropertyColumn Property="o => o.AssignedTo" Title="Assigned To" />
                        </Columns>
                    </MudDataGrid>
                </MudCardContent>
            </MudCard>
        </MudItem>

        @* Calendar timeline *@
        <MudItem xs="12" md="4">
            <MudStack Spacing="3">

                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent><MudText Typo="Typo.subtitle1">April 2026 — Upcoming</MudText></CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent Class="pa-0">
                        <MudTimeline TimelineAlign="TimelineAlign.Start" TimelinePosition="TimelinePosition.Start">
                            @foreach (var ev in UpcomingEvents)
                            {
                                <MudTimelineItem Color="@ObligationColor(ev.Status)" Variant="Variant.Filled" Size="Size.Small">
                                    <ItemContent>
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.body2"><strong>@ev.DueDate</strong> — @ev.ObligationId</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@ev.ObligationType</MudText>
                                        </MudStack>
                                    </ItemContent>
                                </MudTimelineItem>
                            }
                        </MudTimeline>
                    </MudCardContent>
                </MudCard>

                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent><MudText Typo="Typo.subtitle1">Compliance by Category</MudText></CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudChart T="double" ChartType="ChartType.Donut"
                                  Series="@(new double[] { _obligations.Count(o => o.Status == "Complete"), _obligations.Count(o => o.Status != "Complete" && o.Status != "Overdue"), _obligations.Count(o => o.Status == "Overdue") })"
                                  Width="100%" Height="180px" />
                        <MudStack Row="true" Justify="Justify.SpaceEvenly" Class="mt-1">
                            <MudText Typo="Typo.caption">Complete</MudText>
                            <MudText Typo="Typo.caption">Due Soon</MudText>
                            <MudText Typo="Typo.caption">Overdue</MudText>
                        </MudStack>
                    </MudCardContent>
                </MudCard>

            </MudStack>
        </MudItem>

    </MudGrid>
</MudContainer>

@* ── Add Obligation dialog ────────────────────────────────────────────────── *@
<MudDialog @bind-IsVisible="_showAddObligationDialog">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.AddTask" Color="Color.Primary" />
            <MudText Typo="Typo.h6">New Compliance Obligation</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudSelect @bind-Value="_newObligType" Label="Obligation Type" Variant="Variant.Outlined" Required="true">
                <MudSelectItem Value='@("Permit")'>Permit / Lease Regulatory Review</MudSelectItem>
                <MudSelectItem Value="@ObligationType.OnrrProductionReport">ONRR Production Report</MudSelectItem>
                <MudSelectItem Value="@ObligationType.OnrrRoyaltyPayment">ONRR Royalty Payment</MudSelectItem>
                <MudSelectItem Value="@ObligationType.BseeSemsAudit">BSEE SEMS Audit</MudSelectItem>
                <MudSelectItem Value="@ObligationType.BseeIncidentReport">BSEE Incident Report</MudSelectItem>
                <MudSelectItem Value="@ObligationType.EpaGhgReportFlare">EPA GHG Report (Flare)</MudSelectItem>
                <MudSelectItem Value="@ObligationType.AerSt39Report">AER ST39 Report</MudSelectItem>
                <MudSelectItem Value="@ObligationType.AlbertaCrownRoyalty">Alberta Crown Royalty</MudSelectItem>
                <MudSelectItem Value="@ObligationType.NrcReport">NRC Report</MudSelectItem>
                <MudSelectItem Value="@ObligationType.OsparReport">OSPAR Report</MudSelectItem>
            </MudSelect>
            <MudTextField @bind-Value="_newObligJurisdiction" Label="Jurisdiction" Variant="Variant.Outlined" Required="true" />
            <MudTextField @bind-Value="_newObligDescription" Label="Description" Variant="Variant.Outlined" Lines="2" />
            <MudDatePicker @bind-Date="_newObligDueDate" Label="Due Date" Variant="Variant.Outlined" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showAddObligationDialog = false)" Disabled="@_addingObligation">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Save"
                   Disabled="@_addingObligation"
                   OnClick="SubmitObligationAsync">
            @(_addingObligation ? "Saving…" : "Add Obligation")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [SupplyParameterFromQuery(Name = "openCreate")]
    public bool OpenCreate { get; set; }

    [SupplyParameterFromQuery(Name = "obligType")]
    public string? PrefillObligType { get; set; }

    [SupplyParameterFromQuery(Name = "jurisdiction")]
    public string? PrefillJurisdiction { get; set; }

    [SupplyParameterFromQuery(Name = "description")]
    public string? PrefillDescription { get; set; }

    [SupplyParameterFromQuery(Name = "leaseId")]
    public string? LeaseId { get; set; }

    [SupplyParameterFromQuery(Name = "leaseNumber")]
    public string? LeaseNumber { get; set; }

    [SupplyParameterFromQuery(Name = "leaseName")]
    public string? LeaseName { get; set; }

    [SupplyParameterFromQuery(Name = "sourceProcess")]
    public string? SourceProcess { get; set; }

    [SupplyParameterFromQuery(Name = "returnTo")]
    public string? ReturnTo { get; set; }

    [SupplyParameterFromQuery(Name = "wellId")]
    public string? WellId { get; set; }

    [SupplyParameterFromQuery(Name = "abandonmentId")]
    public string? AbandonmentId { get; set; }

    [SupplyParameterFromQuery(Name = "processInstanceId")]
    public string? ProcessInstanceId { get; set; }

    [SupplyParameterFromQuery(Name = "handoffReason")]
    public string? HandoffReason { get; set; }

    private string _fieldName = string.Empty;
    private string _filter = "All";
    private bool _loading = true;
    private string? _prefillKey;

    private List<ObligationDto> _obligations = new();

    private record ObligationDto(
        string ObligationId, string ObligationType, string JurisdictionTag,
        string DueDate, string Status, string AssignedTo);

    private IEnumerable<ObligationDto> FilteredObligations => _filter switch
    {
        "Overdue"   => _obligations.Where(o => o.Status == "Overdue"),
        "Due Soon"  => _obligations.Where(o => o.Status == "Active" || o.Status == "Open"),
        "Permit"    => _obligations.Where(o => o.ObligationType == "Permit"),
        "Reporting" => _obligations.Where(o => o.ObligationType == "Reporting"),
        _           => _obligations,
    };

    private int _dueThisMonth => _obligations.Count(o =>
    {
        if (DateTime.TryParse(o.DueDate, out var dt))
            return dt.Year == DateTime.Today.Year && dt.Month == DateTime.Today.Month;
        return false;
    });

    private double _complianceRate => _obligations.Count == 0 ? 100 :
        Math.Round(_obligations.Count(o => o.Status == "Complete") * 100.0 / _obligations.Count, 1);

    private IEnumerable<ObligationDto> UpcomingEvents => _obligations
        .Where(o => DateTime.TryParse(o.DueDate, out _))
        .OrderBy(o => DateTime.Parse(o.DueDate))
        .Take(8);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summary = await LifeCycleService.GetFieldLifecycleSummaryAsync();
            if (summary != null)
                _fieldName = summary.FieldName ?? _fieldName;
        }
        catch { /* field name is non-critical */ }

        _loading = true;
        try
        {
            var obligations = await ComplianceClient.GetAllObligationsAsync();
            _obligations = obligations.Select(r => new ObligationDto(
                r.ObligationId,
                r.ObligType,
                r.Jurisdiction,
                r.DueDate.ToLocalTime().ToString("dd MMM yyyy"),
                r.Status,
                string.Empty)).ToList();
        }
        catch (Exception) { Snackbar.Add("Failed to load obligations.", Severity.Warning); }
        finally { _loading = false; }

        ApplyQueryPrefill();
    }

    protected override void OnParametersSet()
    {
        ApplyQueryPrefill();
    }

    private Color ObligationColor(string status) => status switch
    {
        "Overdue"  => Color.Error,
        "Active" or "Open" => Color.Warning,
        "Complete" => Color.Success,
        _          => Color.Default,
    };

    // ── Add Obligation dialog state ─────────────────────────────────────────────
    private bool      _showAddObligationDialog = false;
    private bool      _addingObligation        = false;
    private string    _newObligType            = ObligationType.OnrrProductionReport;
    private string    _newObligJurisdiction    = string.Empty;
    private string    _newObligDescription     = string.Empty;
    private DateTime? _newObligDueDate         = DateTime.Today.AddMonths(1);

    private void AddObligation()
    {
        _newObligType         = ObligationType.OnrrProductionReport;
        _newObligJurisdiction = string.Empty;
        _newObligDescription  = string.Empty;
        _newObligDueDate      = DateTime.Today.AddMonths(1);
        _showAddObligationDialog = true;
    }

    private async Task SubmitObligationAsync()
    {
        if (string.IsNullOrWhiteSpace(_newObligJurisdiction))
        {
            Snackbar.Add("Jurisdiction is required.", Severity.Warning);
            return;
        }
        _addingObligation = true;
        try
        {
            var fieldInfo = await LifeCycleService.GetCurrentFieldAsync();
            var req = new CreateObligationRequest(
                FieldId:     fieldInfo?.FieldId ?? string.Empty,
                ObligType:   _newObligType,
                DueDate:     _newObligDueDate ?? DateTime.Today.AddMonths(1),
                Jurisdiction: _newObligJurisdiction,
                Description: _newObligDescription,
                CreatedByProcess: ResolveCreatedByProcess());
            var id = await ComplianceClient.CreateObligationAsync(req);
            var newRow = new ObligationDto(
                id ?? Guid.NewGuid().ToString(),
                _newObligType, _newObligJurisdiction,
                (_newObligDueDate ?? DateTime.Today.AddMonths(1)).ToString("dd MMM yyyy"),
                ObligationStatus.Pending, string.Empty);
            _obligations.Add(newRow);
            _showAddObligationDialog = false;
            Snackbar.Add("Obligation added.", Severity.Success);

            if (!string.IsNullOrWhiteSpace(id) && HasWorkflowHandoffContext())
            {
                NavigationManager.NavigateTo(BuildObligationDetailHref(id));
                return;
            }
        }
        catch (Exception) { Snackbar.Add("Error adding obligation.", Severity.Error); }
        finally { _addingObligation = false; }
    }

    private void ExportCalendar()  => Snackbar.Add("Calendar export queued", Severity.Success);

    private void ApplyQueryPrefill()
    {
        var key = string.Join("|",
            OpenCreate,
            PrefillObligType ?? string.Empty,
            PrefillJurisdiction ?? string.Empty,
            PrefillDescription ?? string.Empty,
            LeaseId ?? string.Empty,
            LeaseNumber ?? string.Empty,
            LeaseName ?? string.Empty,
            SourceProcess ?? string.Empty,
            WellId ?? string.Empty,
            AbandonmentId ?? string.Empty,
            ProcessInstanceId ?? string.Empty,
            HandoffReason ?? string.Empty,
            ReturnTo ?? string.Empty);

        if (!OpenCreate || string.Equals(_prefillKey, key, StringComparison.Ordinal))
            return;

        _newObligType = string.IsNullOrWhiteSpace(PrefillObligType) ? "Permit" : PrefillObligType;
        _newObligJurisdiction = PrefillJurisdiction ?? string.Empty;
        _newObligDescription = !string.IsNullOrWhiteSpace(PrefillDescription)
            ? PrefillDescription
            : BuildWorkflowObligationDescription();
        _newObligDueDate = DateTime.Today.AddMonths(1);
        _showAddObligationDialog = true;
        _prefillKey = key;
    }

    private bool HasLeaseHandoffContext()
    {
        return !string.IsNullOrWhiteSpace(LeaseId)
            || !string.IsNullOrWhiteSpace(LeaseNumber)
            || !string.IsNullOrWhiteSpace(LeaseName)
            || string.Equals(SourceProcess, "LEASE_ACQUISITION", StringComparison.OrdinalIgnoreCase);
    }

    private bool HasDecommissioningHandoffContext()
    {
        return !string.IsNullOrWhiteSpace(WellId)
            || !string.IsNullOrWhiteSpace(AbandonmentId)
            || !string.IsNullOrWhiteSpace(ProcessInstanceId)
            || string.Equals(SourceProcess, "DECOMMISSIONING", StringComparison.OrdinalIgnoreCase);
    }

    private bool HasWorkflowHandoffContext() => HasLeaseHandoffContext() || HasDecommissioningHandoffContext();

    private string? ResolveCreatedByProcess()
    {
        if (!string.IsNullOrWhiteSpace(SourceProcess))
            return SourceProcess;

        return HasLeaseHandoffContext() ? "LEASE_ACQUISITION" : null;
    }

    private string BuildObligationDetailHref(string obligationId)
    {
        var detailPath = $"/ppdm39/compliance/obligation/{Uri.EscapeDataString(obligationId)}";
        var query = new List<string>();

        if (!string.IsNullOrWhiteSpace(ReturnTo))
            query.Add($"returnTo={Uri.EscapeDataString(ReturnTo)}");

        var continueTo = BuildDevelopmentPlanHref(obligationId);
        if (!string.IsNullOrWhiteSpace(continueTo))
            query.Add($"continueTo={Uri.EscapeDataString(continueTo)}");

        return query.Count == 0
            ? detailPath
            : detailPath + "?" + string.Join("&", query);
    }

    private string? BuildDevelopmentPlanHref(string obligationId)
    {
        if (!HasLeaseHandoffContext())
            return null;

        var detailPath = $"/ppdm39/compliance/obligation/{Uri.EscapeDataString(obligationId)}";
        var query = new List<string>();

        if (!string.IsNullOrWhiteSpace(_newObligJurisdiction))
            query.Add($"jurisdiction={Uri.EscapeDataString(_newObligJurisdiction)}");

        if (!string.IsNullOrWhiteSpace(_newObligType))
            query.Add($"permitList={Uri.EscapeDataString(_newObligType)}");

        var notes = BuildDevelopmentRegulatoryNotes();
        if (!string.IsNullOrWhiteSpace(notes))
            query.Add($"regulatoryNotes={Uri.EscapeDataString(notes)}");

        query.Add($"returnTo={Uri.EscapeDataString(detailPath)}");

        return "/development/fdp/new?" + string.Join("&", query);
    }

    private string BuildDevelopmentRegulatoryNotes()
    {
        if (!string.IsNullOrWhiteSpace(_newObligDescription))
            return _newObligDescription;

        return BuildLeaseObligationDescription();
    }

    private string BuildWorkflowObligationDescription()
    {
        if (HasDecommissioningHandoffContext())
            return BuildDecommissioningObligationDescription();

        return BuildLeaseObligationDescription();
    }

    private string BuildLeaseObligationDescription()
    {
        var label = !string.IsNullOrWhiteSpace(LeaseNumber)
            ? LeaseNumber
            : LeaseId;

        if (!string.IsNullOrWhiteSpace(LeaseName) && !string.IsNullOrWhiteSpace(label))
            return $"Regulatory review and permit setup for lease {label} - {LeaseName}";

        if (!string.IsNullOrWhiteSpace(LeaseName))
            return $"Regulatory review and permit setup for lease {LeaseName}";

        if (!string.IsNullOrWhiteSpace(label))
            return $"Regulatory review and permit setup for lease {label}";

        return "Regulatory review and permit setup for lease acquisition";
    }

    private string BuildDecommissioningObligationDescription()
    {
        var label = !string.IsNullOrWhiteSpace(WellId)
            ? WellId
            : AbandonmentId;

        var description = !string.IsNullOrWhiteSpace(label)
            ? $"Plug and abandonment compliance closeout for well {label}"
            : "Plug and abandonment compliance closeout";

        if (!string.IsNullOrWhiteSpace(AbandonmentId) && !string.Equals(label, AbandonmentId, StringComparison.OrdinalIgnoreCase))
            description += $" ({AbandonmentId})";

        if (!string.IsNullOrWhiteSpace(HandoffReason))
            description += $". Trigger: {HandoffReason}";

        return description;
    }
}
