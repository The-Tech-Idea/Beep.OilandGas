@page "/ppdm39/hse"
@inject NavigationManager NavigationManager

<PageTitle>HSE Incidents</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="pa-6">
    <MudPaper Elevation="1" Class="pa-6">
        <MudStack Spacing="2" AlignItems="AlignItems.Center">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Redirecting to the workflow-backed HSE incidents page…</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Legacy HSE routes now use the unified incident workflow experience.
            </MudText>
        </MudStack>
    </MudPaper>
</MudContainer>

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender)
            return;

        NavigationManager.NavigateTo("/ppdm39/hse/incidents", replace: true);
    }
}
