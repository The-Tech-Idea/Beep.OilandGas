@page "/ppdm39/data-management"
@inject ApiClient ApiClient
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager

<PageTitle>PPDM39 Data Management</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-0">
    <MudGrid>
        <MudItem xs="12" md="3">
            <MudPaper Class="ma-2" Elevation="2" Style="height: calc(100vh - 100px); overflow-y: auto;">
                <MudText Typo="Typo.h6" Class="pa-3">PPDM39 Tables</MudText>
                <PPDMTreeView OnTableSelected="OnTableSelected"
                              OnCategorySelected="OnCategorySelected" />
            </MudPaper>
        </MudItem>
        
        <MudItem xs="12" md="9">
            <MudPaper Class="ma-2" Elevation="2" Style="height: calc(100vh - 100px); overflow-y: auto;">
                @if (_selectedTable == null && _selectedCategoryTables == null)
                {
                    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="height:100%;" Class="pa-8">
                        <MudIcon Icon="@Icons.Material.Filled.AccountTree" Style="font-size:4rem;" Color="Color.Default" />
                        <MudText Typo="Typo.h6" Class="mud-text-secondary">Select a table or browse a category from the tree</MudText>
                    </MudStack>
                }
                else
                {
                    <GenericCrudPage @key="@_crudPageKey"
                                     TableNode="@_selectedTable"
                                     CategoryId="@_selectedCategoryId"
                                     CategoryName="@_selectedCategoryName"
                                     CategoryTables="@_selectedCategoryTables" />
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private PPDMTreeNode? _selectedTable;
    private int _selectedCategoryId;
    private string? _selectedCategoryName;
    private List<string>? _selectedCategoryTables;
    private string _crudPageKey = "default";

    protected override void OnInitialized()
    {
        var uri = new Uri(NavigationManager.Uri);
        var queryParams = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        if (queryParams.TryGetValue("table", out var tableName) && !string.IsNullOrWhiteSpace(tableName))
        {
            _selectedTable = new PPDMTreeNode
            {
                Id = tableName,
                Text = tableName,
                NodeType = PPDMTreeNodeType.Table,
                IsSelected = true
            };
            _crudPageKey = tableName!;
        }
    }

    private async Task OnTableSelected(PPDMTreeNode tableNode)
    {
        if (tableNode.NodeType == PPDMTreeNodeType.Table)
        {
            _selectedTable = tableNode;
            _selectedCategoryTables = null; // leave category info cleared so breadcrumb works if set later
            _crudPageKey = tableNode.Text ?? tableNode.Id ?? Guid.NewGuid().ToString();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnCategorySelected((int CategoryId, string CategoryName, List<string> Tables) info)
    {
        _selectedCategoryId = info.CategoryId;
        _selectedCategoryName = info.CategoryName;
        _selectedCategoryTables = info.Tables;
        _selectedTable = null;
        _crudPageKey = $"CAT_{info.CategoryId}";
        await InvokeAsync(StateHasChanged);
    }
}
