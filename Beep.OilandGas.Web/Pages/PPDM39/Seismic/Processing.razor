@page "/ppdm39/seismic/processing"
@using Beep.OilandGas.PPDM39.Models
@inject ApiClient ApiClient
@inject ILifeCycleService LifeCycleService
@inject ISnackbar Snackbar

<PageTitle>Review Seismic Processing Sets</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @* ─── Header *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Review Seismic Processing Sets</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Seismic data processing workflows</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Info"
                         Icon="@Icons.Material.Filled.GraphicEq">Exploration</MudChip>
            </MudStack>
        </MudStack>
        <MudButton Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Add">Add Processing Set</MudButton>
    </MudStack>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }

    @* ─── KPI Row *@
    <MudGrid Class="mb-4" Spacing="3">
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Processing Sets" Value="@((_processing?.Count ?? 0).ToString())"
                     ValueColor="Color.Info" Icon="@Icons.Material.Filled.GraphicEq"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default"
                     TrendText="All processing sets" />
        </MudItem>
    </MudGrid>

    @* ─── Grid *@
    <MudCard Elevation="2">
        <MudCardContent Class="pa-0">
            @if (_processing != null && _processing.Any())
            {
                <MudDataGrid T="SEIS_PROC_SET" Items="@_processing" Dense="true" Hover="true" Striped="true"
                             SortMode="SortMode.Multiple" Filterable="true">
                    <Columns>
                        <PropertyColumn Property="p => p.SEIS_PROC_SET_ID" Title="Processing Set ID" />
                        <TemplateColumn Title="Active">
                            <CellTemplate>
                                <MudChip T="string" Size="Size.Small"
                                         Color="@(context.Item.ACTIVE_IND == "Y" ? Color.Success : Color.Default)">
                                    @(context.Item.ACTIVE_IND == "Y" ? "Active" : "Inactive")
                                </MudChip>
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                    <NoRecordsContent>
                        <MudStack AlignItems="AlignItems.Center" Class="pa-6">
                            <MudIcon Icon="@Icons.Material.Filled.GraphicEq" Color="Color.Secondary" Class="og-icon-xl" />
                            <MudText Typo="Typo.body1">No processing sets match the current filter</MudText>
                        </MudStack>
                    </NoRecordsContent>
                </MudDataGrid>
            }
            else if (!_isLoading)
            {
                <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                    <MudIcon Icon="@Icons.Material.Filled.GraphicEq" Color="Color.Secondary" Class="og-icon-xl" />
                    <MudText Typo="Typo.h6">No processing sets found</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Processing data will appear here once loaded.</MudText>
                </MudStack>
            }
        </MudCardContent>
    </MudCard>

</MudContainer>

@code {
    private string _fieldName = string.Empty;
    private List<SEIS_PROC_SET>? _processing;
    private bool _isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summary = await LifeCycleService.GetFieldLifecycleSummaryAsync();
            if (summary != null)
                _fieldName = summary.FieldName ?? _fieldName;
        }
        catch { /* field name is non-critical */ }

        await LoadProcessing();
    }

    private async Task LoadProcessing()
    {
        _isLoading = true;
        try
        {
            _processing = await ApiClient.GetAsync<List<SEIS_PROC_SET>>("/api/datamanagement/SEIS_PROC_SET") ?? new();        }
        catch (Exception)
        {
            Snackbar.Add("Error loading seismic processing.", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string GetPropertyValue(object obj, string propertyName)
    {
        var prop = obj.GetType().GetProperty(propertyName);
        return prop?.GetValue(obj)?.ToString() ?? "N/A";
    }
}



