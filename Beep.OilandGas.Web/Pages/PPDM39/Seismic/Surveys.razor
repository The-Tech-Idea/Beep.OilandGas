@page "/ppdm39/seismic/surveys"
@using Beep.OilandGas.PPDM39.Models
@inject ApiClient ApiClient
@inject ISnackbar Snackbar

<PageTitle>Manage Seismic Surveys</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @* ─── Header *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Manage Seismic Surveys</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Seismic acquisition survey records</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Info"
                         Icon="@Icons.Material.Filled.Waves">Exploration</MudChip>
            </MudStack>
        </MudStack>
        <MudButton Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Add">Add Survey</MudButton>
    </MudStack>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }

    @* ─── KPI Row *@
    <MudGrid Class="mb-4" Spacing="3">
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Total Surveys" Value="@((_surveys?.Count ?? 0).ToString())"
                     ValueColor="Color.Info" Icon="@Icons.Material.Filled.Waves"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default"
                     TrendText="All seismic surveys" />
        </MudItem>
    </MudGrid>

    @* ─── Grid *@
    <MudCard Elevation="2">
        <MudCardContent Class="pa-0">
            @if (_surveys != null && _surveys.Any())
            {
                <MudDataGrid T="SEIS_ACQTN_SURVEY" Items="@_surveys" Dense="true" Hover="true" Striped="true"
                             SortMode="SortMode.Multiple" Filterable="true">
                    <Columns>
                        <PropertyColumn Property="s => s.SEIS_ACQTN_SURVEY_ID" Title="Survey ID" />
                        <PropertyColumn Property="s => s.ACQTN_SURVEY_NAME" Title="Survey Name" />
                    </Columns>
                    <NoRecordsContent>
                        <MudStack AlignItems="AlignItems.Center" Class="pa-6">
                            <MudIcon Icon="@Icons.Material.Filled.Waves" Color="Color.Secondary" Class="og-icon-xl" />
                            <MudText Typo="Typo.body1">No surveys match the current filter</MudText>
                        </MudStack>
                    </NoRecordsContent>
                </MudDataGrid>
            }
            else if (!_isLoading)
            {
                <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                    <MudIcon Icon="@Icons.Material.Filled.Waves" Color="Color.Secondary" Class="og-icon-xl" />
                    <MudText Typo="Typo.h6">No seismic surveys found</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Surveys will appear here once acquisition data is loaded.</MudText>
                </MudStack>
            }
        </MudCardContent>
    </MudCard>

</MudContainer>

@code {
    private string _fieldName = string.Empty;
    private List<SEIS_ACQTN_SURVEY>? _surveys;
    private bool _isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summary = await ApiClient.GetAsync<FieldLifecycleSummary>("/api/field/current/summary");
            if (summary != null)
                _fieldName = summary.FieldName ?? _fieldName;
        }
        catch { /* field name is non-critical */ }

        await LoadSurveys();
    }

    private async Task LoadSurveys()
    {
        _isLoading = true;
        try
        {
            _surveys = await ApiClient.GetAsync<List<SEIS_ACQTN_SURVEY>>("/api/datamanagement/SEIS_ACQTN_SURVEY") ?? new();        }
        catch (Exception)
        {
            Snackbar.Add("Error loading seismic surveys.", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string GetPropertyValue(object obj, string propertyName)
    {
        var prop = obj.GetType().GetProperty(propertyName);
        return prop?.GetValue(obj)?.ToString() ?? "N/A";
    }
}



