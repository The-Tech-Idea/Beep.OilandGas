@page "/economics/evaluation"
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject ApiClient ApiClient

<PageTitle>Run Economic Evaluation</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @if (_loading) { <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" /> }
    @if (_evaluating) { <MudProgressLinear Indeterminate="true" Color="Color.Warning" Class="mb-2" /> }

    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Run Economic Evaluation</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — DCF &amp; sensitivity analysis</MudText>
        </MudStack>
        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh"
                       OnClick="RunEvaluation">
                Recalculate
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.SaveAlt"
                       OnClick="SaveEvaluation">
                Save Evaluation
            </MudButton>
        </MudStack>
    </MudStack>

    @* Assumptions panel *@
    <MudCard Elevation="2" Class="mb-4">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.subtitle1">Economic Assumptions</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6" md="2">
                    <MudNumericField T="double" @bind-Value="_oilPrice" Label="Oil Price ($/bbl)"
                                     Variant="Variant.Outlined" Format="N1" Step="1" />
                </MudItem>
                <MudItem xs="12" sm="6" md="2">
                    <MudNumericField T="double" @bind-Value="_discountRate" Label="Discount Rate %"
                                     Variant="Variant.Outlined" Format="N1" Step="0.5" />
                </MudItem>
                <MudItem xs="12" sm="6" md="2">
                    <MudNumericField T="double" @bind-Value="_opexBbl" Label="OPEX ($/bbl)"
                                     Variant="Variant.Outlined" Format="N1" Step="0.5" />
                </MudItem>
                <MudItem xs="12" sm="6" md="2">
                    <MudNumericField T="double" @bind-Value="_royaltyPct" Label="Royalty %"
                                     Variant="Variant.Outlined" Format="N1" Step="1" />
                </MudItem>
                <MudItem xs="12" sm="6" md="2">
                    <MudNumericField T="double" @bind-Value="_taxRatePct" Label="Tax Rate %"
                                     Variant="Variant.Outlined" Format="N1" Step="1" />
                </MudItem>
                <MudItem xs="12" sm="6" md="2">
                    <MudNumericField T="double" @bind-Value="_capexMm" Label="Remaining CAPEX ($MM)"
                                     Variant="Variant.Outlined" Format="N1" Step="1" />
                </MudItem>
            </MudGrid>
        </MudCardContent>
    </MudCard>

    @* KPI results *@
    <MudGrid Class="mb-4" Spacing="3">
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="NPV10" Value="@_npv10.ToString("N0")" Unit="$MM"
                     ValueColor="@(_npv10 > 0 ? Color.Success : Color.Error)"
                     Icon="@Icons.Material.Filled.TrendingUp"
                     TrendIcon="@Icons.Material.Filled.TrendingUp" TrendColor="Color.Success" TrendText="Base case" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="IRR" Value="@_irr.ToString("N1")" Unit="%"
                     ValueColor="@(_irr > _discountRate ? Color.Success : Color.Warning)"
                     Icon="@Icons.Material.Filled.Percent"
                     TrendIcon="@Icons.Material.Filled.TrendingUp" TrendColor="Color.Success" TrendText="vs Hurdle rate" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Payback Period" Value="@_paybackYears.ToString("N1")" Unit="yrs"
                     ValueColor="Color.Info" Icon="@Icons.Material.Filled.AccessTime"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default" TrendText="From first oil" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="P/I Ratio" Value="@_piRatio.ToString("N2")" Unit="x"
                     ValueColor="@(_piRatio > 1 ? Color.Success : Color.Error)"
                     Icon="@Icons.Material.Filled.BarChart"
                     TrendIcon="@Icons.Material.Filled.TrendingUp" TrendColor="Color.Success" TrendText="Profitability index" />
        </MudItem>
    </MudGrid>

    <MudGrid Spacing="3">

        @* Annual cashflow chart *@
        <MudItem xs="12" md="8">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1">Annual Cash Flow</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudChart T="double" ChartType="ChartType.Bar"
                              Series="@_cashflowSeries"
                              XAxisLabels="@_cashflowYears"
                              Width="100%" Height="220px" />
                    @if (!_cashflowSeries.Any())
                    {
                        <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">Set inputs and click Run Evaluation to compute annual cash flows.</MudAlert>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        @* Sensitivity spider *@
        <MudItem xs="12" md="4">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1">Sensitivity: NPV10 Impact</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudStack Spacing="2">
                        @foreach (var s in _sensitivities)
                        {
                            <MudStack Spacing="0">
                                <MudStack Row="true" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2">@s.Driver</MudText>
                                    <MudText Typo="Typo.caption">@(s.Low.ToString("N0")) / @(s.High.ToString("N0")) $MM</MudText>
                                </MudStack>
                                <MudProgressLinear Color="Color.Primary" Value="@s.Range" />
                            </MudStack>
                        }
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>

        @* Scenario comparison *@
        <MudItem xs="12" md="6">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1">Scenario Comparison</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    <MudDataGrid T="ScenarioRow" Items="@_scenarios" Dense="true" Hover="true" Striped="true">
                        <Columns>
                            <PropertyColumn Property="sc => sc.Name" Title="Scenario" />
                            <TemplateColumn Title="Oil Price">
                                <CellTemplate><MudText Typo="Typo.body2">$@context.Item.OilPrice/bbl</MudText></CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="NPV10 ($MM)" SortBy="sc => sc.Npv10">
                                <CellTemplate>
                                    <MudText Color="@(context.Item.Npv10 > 0 ? Color.Success : Color.Error)">
                                        <strong>@context.Item.Npv10.ToString("N0")</strong>
                                    </MudText>
                                </CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="IRR (%)">
                                <CellTemplate><MudText Typo="Typo.body2">@context.Item.Irr.ToString("N1")%</MudText></CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="Go/No-Go">
                                <CellTemplate><StatusBadge Status="@GetGoNoGoStatus(context.Item.Npv10)" /></CellTemplate>
                            </TemplateColumn>
                        </Columns>
                    </MudDataGrid>
                </MudCardContent>
            </MudCard>
        </MudItem>

        @* Cumulative NPV curve *@
        <MudItem xs="12" md="6">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1">Cumulative Discounted Cash Flow</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudChart T="double" ChartType="ChartType.Line"
                              Series="@_cumulativeSeries"
                              XAxisLabels="@_cashflowYears"
                              Width="100%" Height="180px" />
                    @if (!_cumulativeSeries.Any())
                    {
                        <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">Cumulative DCF will populate after running evaluation.</MudAlert>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

    </MudGrid>
</MudContainer>

@code {
    private string _fieldName = string.Empty;
    private double _oilPrice = 75.0;
    private double _discountRate = 10.0;
    private double _opexBbl = 18.0;
    private double _royaltyPct = 12.5;
    private double _taxRatePct = 30.0;
    private double _capexMm = 85.0;
    private double _grossRevenue;      // loaded from accounting API (annual USD)
    private bool _loading = true;
    private bool _evaluating;

    // Computed KPI outputs (set from API after RunEvaluation)
    private double _npv10;
    private double _irr;
    private double _paybackYears;
    private double _piRatio;

    private List<ChartSeries<double>> _cashflowSeries = new();
    private string[] _cashflowYears = Array.Empty<string>();
    private List<ChartSeries<double>> _cumulativeSeries = new();

    internal record SensitivityItem(string Driver, double Low, double High)
    {
        public double Range => Math.Abs(High - Low) / 5;
    }
    // Standard petroleum economics sensitivity drivers — reference ranges, not DB records
    private List<SensitivityItem> _sensitivities = new()
    {
        new("Oil Price ±$15/bbl", 279, 405),
        new("2P Reserves ±15%",   295, 389),
        new("OPEX ±25%",          308, 376),
        new("CAPEX ±20%",         318, 366),
        new("Discount Rate ±3%",  315, 371),
    };

    internal record ScenarioRow(string Name, double OilPrice, double Npv10, double Irr);
    private List<ScenarioRow> _scenarios = new()
    {
        new("High Case",  90, 0, 0),
        new("Base Case",  75, 0, 0),
        new("Low Case",   60, 0, 0),
        new("Downside",   50, 0, 0),
        new("Stress",     40, 0, 0),
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summary = await ApiClient.GetAsync<FieldLifecycleSummary>("/api/field/current/summary");
            if (summary != null)
                _fieldName = summary.FieldName ?? _fieldName;
        }
        catch { /* field name is non-critical */ }

        _loading = true;
        try
        {
            var summary = await ApiClient.GetAsync<AccountingSummaryDto>("api/field/current/accounting/production-summary");
            if (summary != null)
                _grossRevenue = summary.GrossRevenue;
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to load revenue context.", Severity.Warning);
        }
        finally { _loading = false; }
    }

    private class AccountingSummaryDto
    {
        public double GrossRevenue  { get; set; }
        public double TotalOpex     { get; set; }
        public double NetRevenue    { get; set; }
        public double OpenInvoices  { get; set; }
        public double OutstandingUsd { get; set; }
    }

    private class AnalyzeRequest
    {
        public List<double>? CashFlows    { get; set; }
        public double        DISCOUNT_RATE { get; set; }
        public double        FinanceRate  { get; set; }
        public double        ReinvestRate { get; set; }
    }

    private class EconomicResultDto
    {
        public double NPV               { get; set; }
        public double IRR               { get; set; }
        public double MIRR              { get; set; }
        public double ProfitabilityIndex { get; set; }
        public double PaybackPeriod     { get; set; }
    }

    private void RunEvaluation()
    {
        _ = RunEvaluationAsync();
    }

    private async Task RunEvaluationAsync()
    {
        _evaluating = true;
        try
        {
            // Annualise: production-summary covers ~6 months, so multiply by 2
            double annualRevUsd = _grossRevenue > 0 ? _grossRevenue * 2 : _oilPrice * 500_000;
            double price = _oilPrice > 0 ? _oilPrice : 75.0;

            var years = new List<int>();
            var cashFlows = new List<double>();
            var revSeries   = new List<double>();
            var opexSeries  = new List<double>();
            var capexSeries = new List<double>();
            var netSeries   = new List<double>();
            var cumDcf      = new List<double>();

            cashFlows.Add(-_capexMm);  // Year 0 investment

            int baseYear = DateTime.UtcNow.Year;
            double cumulative = -_capexMm;
            for (int y = 1; y <= 10; y++)
            {
                years.Add(baseYear + y);
                double decline = Math.Pow(1 - 0.08, y - 1);
                double revM   = annualRevUsd * decline / 1_000_000;
                double royM   = revM * _royaltyPct / 100;
                double opexM  = revM * (_opexBbl / price);
                double ebit   = revM - royM - opexM;
                double tax    = ebit > 0 ? ebit * _taxRatePct / 100 : 0;
                double netCf  = ebit - tax;
                // Trailing CAPEX
                double capexM = y <= 2 ? _capexMm * 0.1 : 0;

                cashFlows.Add(netCf);
                revSeries.Add(Math.Round(revM, 1));
                opexSeries.Add(Math.Round(opexM + royM, 1));
                capexSeries.Add(Math.Round(capexM, 1));
                netSeries.Add(Math.Round(netCf, 1));
                double discounted = netCf / Math.Pow(1 + _discountRate / 100, y);
                cumulative += discounted;
                cumDcf.Add(Math.Round(cumulative, 1));
            }

            var request = new AnalyzeRequest
            {
                CashFlows    = cashFlows,
                DISCOUNT_RATE = _discountRate / 100,
                FinanceRate  = _discountRate / 100,
                ReinvestRate = (_discountRate + 5) / 100,
            };

            var result = await ApiClient.PostAsync<AnalyzeRequest, EconomicResultDto>(
                "api/EconomicAnalysis/analyze", request);

            if (result != null)
            {
                _npv10       = Math.Round(result.NPV, 1);
                _irr         = Math.Round(result.IRR * 100, 1);
                _paybackYears = Math.Round(result.PaybackPeriod, 1);
                _piRatio     = Math.Round(result.ProfitabilityIndex, 2);
            }

            _cashflowYears = years.Select(y => y.ToString()).ToArray();
            _cashflowSeries = new List<ChartSeries<double>>
            {
                new ChartSeries<double> { Name = "Revenue ($MM)", Data = revSeries.ToArray() },
                new ChartSeries<double> { Name = "OPEX+Royalty",  Data = opexSeries.ToArray() },
                new ChartSeries<double> { Name = "CAPEX ($MM)",   Data = capexSeries.ToArray() },
                new ChartSeries<double> { Name = "Net CF ($MM)",  Data = netSeries.ToArray() },
            };
            _cumulativeSeries = new List<ChartSeries<double>>
            {
                new ChartSeries<double> { Name = "Cum. DCF ($MM)", Data = cumDcf.ToArray() },
                new ChartSeries<double> { Name = "Break-even",     Data = Enumerable.Repeat(0.0, 10).ToArray() },
            };

            // Recompute scenarios from base NPV
            if (_npv10 != 0)
            {
                _scenarios = new()
                {
                    new("High Case",  90, Math.Round(_npv10 * 1.18, 1), Math.Round(_irr * 1.18, 1)),
                    new("Base Case",  _oilPrice, _npv10, _irr),
                    new("Low Case",   60, Math.Round(_npv10 * 0.82, 1), Math.Round(_irr * 0.73, 1)),
                    new("Downside",   50, Math.Round(_npv10 * 0.53, 1), Math.Round(_irr * 0.50, 1)),
                    new("Stress",     40, Math.Round(_npv10 * 0.17, 1), Math.Round(_irr * 0.27, 1)),
                };
            }

            Snackbar.Add("Economic model recalculated", Severity.Success);
        }
        catch (Exception)
        {
            Snackbar.Add("Evaluation failed.", Severity.Error);
        }
        finally
        {
            _evaluating = false;
            StateHasChanged();
        }
    }

    private async Task SaveEvaluation()
    {
        try
        {
            var payload = new
            {
                AnalysisId = $"EVAL-{DateTime.UtcNow:yyyyMMdd-HHmmss}",
                Result = new EconomicResultDto
                {
                    NPV              = _npv10,
                    IRR              = _irr / 100,
                    ProfitabilityIndex = _piRatio,
                    PaybackPeriod    = _paybackYears,
                },
            };
            await ApiClient.PostAsync<object, object>("api/EconomicAnalysis/result", payload);
            Snackbar.Add("Economic evaluation saved", Severity.Success);
        }
        catch (Exception)
        {
            Snackbar.Add("Save failed.", Severity.Error);
        }
    }

    private static string GetGoNoGoStatus(double npv10) => npv10 > 0 ? "APPROVED" : "REJECTED";
}
