@page "/economics/afe"
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject ApiClient ApiClient
@inject IAfeServiceClient AfeClient
@inject ILifeCycleService LifeCycleService
@using Beep.OilandGas.Models.Data.ProductionAccounting

<PageTitle>Manage Authorities for Expenditure</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @if (_loading) { <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" /> }

    @if (_selectedAfe is null)
    {
        @* List View *@
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
            <MudStack Spacing="0">
                <MudText Typo="Typo.h5">Manage Authorities for Expenditure</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Authority for Expenditure tracking</MudText>
            </MudStack>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                @if (!string.IsNullOrWhiteSpace(ReturnTo))
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.ArrowBack"
                               Href="@ReturnTo">
                        Back
                    </MudButton>
                }
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="CreateAfe">
                    New AFE
                </MudButton>
            </MudStack>
        </MudStack>

        @* Summary KPIs *@
        <MudGrid Class="mb-4" Spacing="3">
            <MudItem xs="12" sm="6" md="3">
                <KpiCard Label="Active AFEs" Value="@_afes.Count(a => a.Status == "ACTIVE").ToString()"
                         ValueColor="Color.Primary" Icon="@Icons.Material.Filled.Assignment"
                         TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default" TrendText="Open" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <KpiCard Label="Total Approved" Value="@_afes.Where(a => a.Status is "ACTIVE" or "COMPLETE").Sum(a => a.ApprovedUsd / 1e6).ToString("N1")" Unit="$M"
                         ValueColor="Color.Success" Icon="@Icons.Material.Filled.AttachMoney"
                         TrendIcon="@Icons.Material.Filled.TrendingUp" TrendColor="Color.Success" TrendText="YTD" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <KpiCard Label="Total Committed" Value="@_afes.Where(a => a.Status is "ACTIVE" or "COMPLETE").Sum(a => a.CommittedUsd / 1e6).ToString("N1")" Unit="$M"
                         ValueColor="Color.Warning" Icon="@Icons.Material.Filled.AccountBalance"
                         TrendIcon="@Icons.Material.Filled.TrendingUp" TrendColor="Color.Warning" TrendText="Actuals" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <KpiCard Label="Pending Approval" Value="@_afes.Count(a => a.Status == "PENDING").ToString()"
                         ValueColor="Color.Error" Icon="@Icons.Material.Filled.Pending"
                         TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default" TrendText="Awaiting sign-off" />
            </MudItem>
        </MudGrid>

        @* AFE Grid *@
        <MudCard Elevation="2">
            <MudCardContent Class="pa-0">
                <MudDataGrid T="AfeItem" Items="@_afes" Dense="true" Hover="true" Striped="true"
                             RowClick="@OnAfeSelected" SortMode="SortMode.Multiple" Filterable="true">
                    <Columns>
                        <PropertyColumn Property="a => a.AfeNumber" Title="AFE #" Sortable="true" />
                        <PropertyColumn Property="a => a.Description" Title="Description" />
                        <PropertyColumn Property="a => a.WellId" Title="Well" />
                        <PropertyColumn Property="a => a.Category" Title="Category" />
                        <PropertyColumn Property="a => a.ApprovedUsd" Title="Approved ($)" Format="N0" Sortable="true" />
                        <PropertyColumn Property="a => a.CommittedUsd" Title="Committed ($)" Format="N0" />
                        <TemplateColumn Title="% Spent" Sortable="false">
                            <CellTemplate>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudProgressLinear Color="@SpentColor(context.Item)" Value="@SpentPercent(context.Item)" Class="flex-1" />
                                    <MudText Typo="Typo.caption">@SpentPercent(context.Item).ToString("N0")%</MudText>
                                </MudStack>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Status">
                            <CellTemplate>
                                <StatusBadge Status="@context.Item.Status" />
                            </CellTemplate>
                        </TemplateColumn>
                        <PropertyColumn Property="a => a.Approver" Title="Approver" />
                    </Columns>
                </MudDataGrid>
            </MudCardContent>
        </MudCard>
    }
    else
    {
        @* Detail View *@
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="BackToList" Title="Back to AFE list" />
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h5">@_selectedAfe.AfeNumber — @_selectedAfe.Description</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@_selectedAfe.WellId · @_selectedAfe.Category</MudText>
                </MudStack>
            </MudStack>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                @if (!string.IsNullOrWhiteSpace(ReturnTo))
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.ArrowBack"
                               Href="@ReturnTo">
                        Back
                    </MudButton>
                }
                <StatusBadge Status="@_selectedAfe.Status" />
                @if (_selectedAfe.Status == "PENDING")
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="RejectAfe">Reject</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="ApproveAfe">Approve AFE</MudButton>
                }
            </MudStack>
        </MudStack>

        <MudGrid Spacing="3">

            @* Cost summary *@
            <MudItem xs="12" md="4">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.subtitle1">Cost Summary</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudStack Spacing="2">
                            <MudStack Row="true" Justify="Justify.SpaceBetween">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Approved</MudText>
                                <MudText Typo="Typo.body1"><strong>$@_selectedAfe.ApprovedUsd.ToString("N0")</strong></MudText>
                            </MudStack>
                            <MudStack Row="true" Justify="Justify.SpaceBetween">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Committed</MudText>
                                <MudText Typo="Typo.body1" Color="Color.Warning">$@_selectedAfe.CommittedUsd.ToString("N0")</MudText>
                            </MudStack>
                            <MudStack Row="true" Justify="Justify.SpaceBetween">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Remaining</MudText>
                                <MudText Typo="Typo.body1" Color="Color.Success">$@((_selectedAfe.ApprovedUsd - _selectedAfe.CommittedUsd).ToString("N0"))</MudText>
                            </MudStack>
                            <MudDivider />
                            <MudProgressLinear Color="@SpentColor(_selectedAfe)" Value="@SpentPercent(_selectedAfe)"
                                               Rounded="true" Size="Size.Large" Class="mt-1">
                                <MudText Typo="Typo.caption" Color="Color.Surface">@SpentPercent(_selectedAfe).ToString("N0")% spent</MudText>
                            </MudProgressLinear>
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            @* Cost by category bar chart *@
            <MudItem xs="12" md="8">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.subtitle1">Cost Breakdown</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudAlert Severity="Severity.Info" Dense="true">Cost breakdown chart will display once line-item detail is available for the selected AFE.</MudAlert>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            @* Line items *@
            <MudItem xs="12">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.subtitle1">AFE Line Items</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent Class="pa-0">
                        <MudDataGrid T="AfeLineItem" Items="@_lineItems" Dense="true" Hover="true" Striped="true">
                            <Columns>
                                <PropertyColumn Property="l => l.Code"        Title="Cost Code" />
                                <PropertyColumn Property="l => l.Description" Title="Description" />
                                <PropertyColumn Property="l => l.Vendor"      Title="Vendor" />
                                <PropertyColumn Property="l => l.EstimatedUsd" Title="Estimated ($)" Format="N0" />
                                <PropertyColumn Property="l => l.ActualUsd"   Title="Actual ($)" Format="N0" />
                                <TemplateColumn Title="Variance">
                                    <CellTemplate>
                                        @{
                                            var v = context.Item.ActualUsd - context.Item.EstimatedUsd;
                                        }
                                        <MudText Typo="Typo.body2" Color="@(v > 0 ? Color.Error : Color.Success)">
                                            @(v >= 0 ? "+" : "")@v.ToString("N0")
                                        </MudText>
                                    </CellTemplate>
                                </TemplateColumn>
                            </Columns>
                        </MudDataGrid>
                    </MudCardContent>
                </MudCard>
            </MudItem>

        </MudGrid>
    }

</MudContainer>

@* ── New AFE dialog ─────────────────────────────────────────────────────────── *@
<MudDialog @bind-IsVisible="_showCreateAfeDialog">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Add" Color="Color.Primary" />
            <MudText Typo="Typo.h6">New AFE</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_newAfeNumber"      Label="AFE Number"    Variant="Variant.Outlined" Required="true" />
            <MudTextField @bind-Value="_newAfeName"        Label="Description"   Variant="Variant.Outlined" />
            <MudTextField @bind-Value="_newAfePropertyId"  Label="Well / Property ID" Variant="Variant.Outlined" />
            <MudNumericField @bind-Value="_newAfeEstimate" Label="Estimated Budget (USD)" Variant="Variant.Outlined" Format="N0" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showCreateAfeDialog = false)" Disabled="@_savingAfe">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Save"
                   Disabled="@_savingAfe"
                   OnClick="SubmitCreateAfeAsync">
            @(_savingAfe ? "Saving…" : "Create AFE")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [SupplyParameterFromQuery(Name = "wellId")]
    public string? WellId { get; set; }

    [SupplyParameterFromQuery(Name = "openCreate")]
    public bool OpenCreate { get; set; }

    [SupplyParameterFromQuery(Name = "description")]
    public string? SuggestedDescription { get; set; }

    [SupplyParameterFromQuery(Name = "budgetUsd")]
    public double? SuggestedBudgetUsd { get; set; }

    [SupplyParameterFromQuery(Name = "afeNumber")]
    public string? SelectedAfeNumber { get; set; }

    [SupplyParameterFromQuery(Name = "returnTo")]
    public string? ReturnTo { get; set; }

    private string _fieldName = string.Empty;
    private AfeItem? _selectedAfe;
    private bool _loading = true;

    private record AfeItem(string AfeId, string AfeNumber, string Description, string WellId, string Category,
        double ApprovedUsd, double CommittedUsd, string Status, string Approver);

    private List<AfeItem> _afes = new();

    private record AfeLineItem(string Code, string Description, string Vendor, double EstimatedUsd, double ActualUsd);
    private List<AfeLineItem> _lineItems = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summary = await LifeCycleService.GetFieldLifecycleSummaryAsync();
            if (summary != null)
                _fieldName = summary.FieldName ?? _fieldName;
        }
        catch { /* field name is non-critical */ }

        await LoadAfesAsync();

        if (OpenCreate)
        {
            OpenCreateAfeFromRecommendation();
            return;
        }

        if (!string.IsNullOrWhiteSpace(SelectedAfeNumber))
        {
            _selectedAfe = _afes.FirstOrDefault(a => string.Equals(a.AfeNumber, SelectedAfeNumber, StringComparison.OrdinalIgnoreCase));
            if (_selectedAfe is null)
                Snackbar.Add($"AFE {SelectedAfeNumber} was not found in the current field list.", Severity.Warning);
        }
    }

    private async Task LoadAfesAsync()
    {
        _loading = true;
        try
        {
            var afes = await AfeClient.GetAfesAsync();
            _afes = afes.Select(r => new AfeItem(
                r.AfeId,
                r.AfeNumber ?? r.AfeId,
                r.AfeName ?? r.AfeNumber ?? r.AfeId,
                r.PropertyId ?? "N/A",
                "AFE",
                (double)(r.EstimatedCost ?? 0m),
                0,
                r.Status ?? "ACTIVE",
                string.Empty)).ToList();
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to load AFEs.", Severity.Warning);
        }
        finally
        {
            _loading = false;
        }
    }

    private void OnAfeSelected(DataGridRowClickEventArgs<AfeItem> args) =>
        _selectedAfe = args.Item;

    private void BackToList() => _selectedAfe = null;

    // ── Create AFE dialog state ────────────────────────────────────────────────
    private bool   _showCreateAfeDialog = false;
    private bool   _savingAfe           = false;
    private string _newAfeNumber        = string.Empty;
    private string _newAfeName          = string.Empty;
    private string _newAfePropertyId    = string.Empty;
    private double _newAfeEstimate      = 0;

    private void CreateAfe()
    {
        _newAfeNumber     = string.Empty;
        _newAfeName       = string.Empty;
        _newAfePropertyId = string.Empty;
        _newAfeEstimate   = 0;
        _showCreateAfeDialog = true;
    }

    private void OpenCreateAfeFromRecommendation()
    {
        _newAfeNumber     = string.Empty;
        _newAfeName       = SuggestedDescription ?? string.Empty;
        _newAfePropertyId = WellId ?? string.Empty;
        _newAfeEstimate   = SuggestedBudgetUsd ?? 0;
        _showCreateAfeDialog = true;
    }

    private async Task SubmitCreateAfeAsync()
    {
        if (string.IsNullOrWhiteSpace(_newAfeNumber))
        {
            Snackbar.Add("AFE Number is required.", Severity.Warning);
            return;
        }
        _savingAfe = true;
        try
        {
            var payload = new CreateAFERequest
            {
                AfeNumber = _newAfeNumber,
                AfeName = _newAfeName,
                PropertyId = _newAfePropertyId,
                BudgetAmount = (decimal)_newAfeEstimate,
                EffectiveDate = (DateTime?)DateTime.UtcNow
            };
            var result = await AfeClient.CreateAfeAsync(payload);
            var newRow = new AfeItem(
                result?.AfeId ?? Guid.NewGuid().ToString(),
                result?.AfeNumber ?? _newAfeNumber,
                _newAfeName,
                _newAfePropertyId,
                "AFE",
                _newAfeEstimate,
                0,
                "ACTIVE",
                string.Empty);
            _afes.Add(newRow);
            _showCreateAfeDialog = false;
            Snackbar.Add($"AFE {_newAfeNumber} created.", Severity.Success);
        }
        catch (Exception) { Snackbar.Add("Error creating AFE.", Severity.Error); }
        finally { _savingAfe = false; }
    }

    private async Task ApproveAfe()
    {
        if (_selectedAfe == null) return;
        try
        {
            await AfeClient.ApproveAfeAsync(_selectedAfe.AfeId);
            await LoadAfesAsync();
            Snackbar.Add($"{_selectedAfe.AfeNumber} approved", Severity.Success);
            _selectedAfe = null;
        }
        catch (Exception) { Snackbar.Add("Approval failed.", Severity.Error); }
    }

    private async Task RejectAfe()
    {
        if (_selectedAfe == null) return;
        try
        {
            await AfeClient.RejectAfeAsync(_selectedAfe.AfeId);
            await LoadAfesAsync();
            Snackbar.Add($"{_selectedAfe.AfeNumber} returned for revision", Severity.Warning);
            _selectedAfe = null;
        }
        catch (Exception) { Snackbar.Add("Rejection failed.", Severity.Error); }
    }

    private double SpentPercent(AfeItem a) =>
        a.ApprovedUsd > 0 ? Math.Min(a.CommittedUsd / a.ApprovedUsd * 100, 100) : 0;

    private Color SpentColor(AfeItem a) => SpentPercent(a) switch
    {
        >= 90 => Color.Error,
        >= 75 => Color.Warning,
        _     => Color.Success,
    };
}
