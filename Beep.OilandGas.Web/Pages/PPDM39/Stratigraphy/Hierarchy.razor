@page "/ppdm39/stratigraphy/hierarchy"
@using Beep.OilandGas.PPDM39.Models
@inject ApiClient ApiClient
@inject ISnackbar Snackbar

<PageTitle>Review Stratigraphic Unit Hierarchy</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @* ── Header *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Review Stratigraphic Unit Hierarchy</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Parent-child stratigraphic relationships</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Secondary"
                         Icon="@Icons.Material.Filled.AccountTree">Geology</MudChip>
            </MudStack>
        </MudStack>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Add">Add Relationship</MudButton>
    </MudStack>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }

    @* ── KPI Row *@
    <MudGrid Class="mb-4" Spacing="3">
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Total Relationships" Value="@((_hierarchy?.Count ?? 0).ToString())"
                     ValueColor="Color.Primary" Icon="@Icons.Material.Filled.AccountTree"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default"
                     TrendText="All hierarchy links" />
        </MudItem>
    </MudGrid>

    @* ── Hierarchy Grid *@
    <MudCard Elevation="2">
        <MudCardContent Class="pa-0">
            @if (_hierarchy != null && _hierarchy.Any())
            {
                <MudDataGrid T="STRAT_HIERARCHY" Items="@_hierarchy" Dense="true" Hover="true" Striped="true"
                             SortMode="SortMode.Multiple" Filterable="true">
                    <Columns>
                        <TemplateColumn Title="Parent Unit">
                            <CellTemplate>
                                <MudText Typo="Typo.body2">@GetStratUnitName(context.Item.PARENT_STRAT_UNIT_ID)</MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Child Unit">
                            <CellTemplate>
                                <MudText Typo="Typo.body2" Color="Color.Primary">
                                    @GetStratUnitName(context.Item.CHILD_STRAT_UNIT_ID)
                                </MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Hierarchy Type">
                            <CellTemplate>
                                <MudText Typo="Typo.body2">@GetPropertyValue(context.Item, "STRAT_HIERARCHY_TYPE")</MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Active">
                            <CellTemplate>
                                <MudChip T="string"
                                         Color="@(context.Item.ACTIVE_IND == "Y" ? Color.Success : Color.Default)"
                                         Size="Size.Small">
                                    @context.Item.ACTIVE_IND
                                </MudChip>
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                    <NoRecordsContent>
                        <MudStack AlignItems="AlignItems.Center" Class="pa-6">
                            <MudIcon Icon="@Icons.Material.Filled.AccountTree" Color="Color.Secondary" Class="og-icon-xl" />
                            <MudText Typo="Typo.body1">No relationships match the current filter</MudText>
                        </MudStack>
                    </NoRecordsContent>
                </MudDataGrid>
            }
            else if (!_isLoading)
            {
                <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                    <MudIcon Icon="@Icons.Material.Filled.AccountTree" Color="Color.Secondary" Class="og-icon-xl" />
                    <MudText Typo="Typo.h6">No hierarchy data found</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">No stratigraphic hierarchy records loaded.</MudText>
                </MudStack>
            }
        </MudCardContent>
    </MudCard>

</MudContainer>

@code {
    private string _fieldName = string.Empty;
    private List<STRAT_HIERARCHY>? _hierarchy;
    private Dictionary<string, string> _stratUnitNames = new();
    private bool _isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summary = await ApiClient.GetAsync<FieldLifecycleSummary>("/api/field/current/summary");
            if (summary != null)
                _fieldName = summary.FieldName ?? _fieldName;
        }
        catch { /* field name is non-critical */ }

        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;
        try
        {
            // Load hierarchy and strat units in parallel
            var hierarchyTask = ApiClient.GetAsync<List<STRAT_HIERARCHY>>("/api/stratigraphy/hierarchy");
            var unitsTask = ApiClient.GetAsync<List<STRAT_UNIT>>("/api/stratigraphy/units");
            
            await Task.WhenAll(hierarchyTask, unitsTask);
            
            _hierarchy = await hierarchyTask;
            var units = await unitsTask;
            
            // Create lookup dictionary for strat unit names
            if (units != null)
            {
                _stratUnitNames = units.ToDictionary(
                    u => u.STRAT_UNIT_ID ?? string.Empty,
                    u => !string.IsNullOrWhiteSpace(u.SHORT_NAME) ? u.SHORT_NAME : 
                         !string.IsNullOrWhiteSpace(u.LONG_NAME) ? u.LONG_NAME : 
                         u.STRAT_UNIT_ID ?? "N/A"
                );
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Error loading data.", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string GetStratUnitName(string? unitId)
    {
        if (string.IsNullOrWhiteSpace(unitId))
            return "N/A";
        
        return _stratUnitNames.TryGetValue(unitId, out var name) ? name : unitId;
    }

    private string GetPropertyValue(STRAT_HIERARCHY hierarchy, string propertyName)
    {
        var prop = hierarchy.GetType().GetProperty(propertyName);
        return prop?.GetValue(hierarchy)?.ToString() ?? "N/A";
    }
}

