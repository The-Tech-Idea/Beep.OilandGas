@page "/ppdm39/stratigraphy/units"
@using Beep.OilandGas.PPDM39.Models
@inject ApiClient ApiClient
@inject ILifeCycleService LifeCycleService
@inject ISnackbar Snackbar

<PageTitle>Browse Stratigraphic Formation Units</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @* ── Header *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Browse Stratigraphic Formation Units</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — PPDM stratigraphic unit registry</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Secondary"
                         Icon="@Icons.Material.Filled.Layers">Geology</MudChip>
            </MudStack>
        </MudStack>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Add">Add Unit</MudButton>
    </MudStack>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }

    @* ── KPI Row *@
    <MudGrid Class="mb-4" Spacing="3">
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Total Units" Value="@((_units?.Count ?? 0).ToString())"
                     ValueColor="Color.Primary" Icon="@Icons.Material.Filled.Layers"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default"
                     TrendText="All strat units" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Active"
                     Value="@((_units?.Count(u => u.ACTIVE_IND == "Y") ?? 0).ToString())"
                     ValueColor="Color.Success" Icon="@Icons.Material.Filled.CheckCircle"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default"
                     TrendText="Active units" />
        </MudItem>
    </MudGrid>

    @* ── Units Grid *@
    <MudCard Elevation="2">
        <MudCardContent Class="pa-0">
            @if (_units != null && _units.Any())
            {
                <MudDataGrid T="STRAT_UNIT" Items="@_units" Dense="true" Hover="true" Striped="true"
                             SortMode="SortMode.Multiple" Filterable="true">
                    <Columns>
                        <PropertyColumn Property="u => u.STRAT_UNIT_ID" Title="Unit ID" />
                        <TemplateColumn Title="Unit Name">
                            <CellTemplate>
                                <MudText Typo="Typo.body2" Color="Color.Primary">
                                    @(!string.IsNullOrWhiteSpace(context.Item.SHORT_NAME)
                                        ? context.Item.SHORT_NAME
                                        : !string.IsNullOrWhiteSpace(context.Item.LONG_NAME)
                                            ? context.Item.LONG_NAME
                                            : context.Item.STRAT_UNIT_ID ?? "—")
                                </MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Status">
                            <CellTemplate>
                                <MudChip T="string"
                                         Color="@(context.Item.ACTIVE_IND == "Y" ? Color.Success : Color.Default)"
                                         Size="Size.Small">
                                    @context.Item.ACTIVE_IND
                                </MudChip>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="" Sortable="false">
                            <CellTemplate>
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary" Title="Edit unit" />
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                    <NoRecordsContent>
                        <MudStack AlignItems="AlignItems.Center" Class="pa-6">
                            <MudIcon Icon="@Icons.Material.Filled.Layers" Color="Color.Secondary" Class="og-icon-xl" />
                            <MudText Typo="Typo.body1">No units match the current filter</MudText>
                        </MudStack>
                    </NoRecordsContent>
                </MudDataGrid>
            }
            else if (!_isLoading)
            {
                <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                    <MudIcon Icon="@Icons.Material.Filled.Layers" Color="Color.Secondary" Class="og-icon-xl" />
                    <MudText Typo="Typo.h6">No stratigraphic units found</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">No strat unit records loaded for this session.</MudText>
                </MudStack>
            }
        </MudCardContent>
    </MudCard>

</MudContainer>

@code {
    private string _fieldName = string.Empty;
    private List<STRAT_UNIT>? _units;
    private bool _isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summary = await LifeCycleService.GetFieldLifecycleSummaryAsync();
            if (summary != null)
                _fieldName = summary.FieldName ?? _fieldName;
        }
        catch { /* field name is non-critical */ }

        await LoadUnits();
    }

    private async Task LoadUnits()
    {
        _isLoading = true;
        try
        {
            _units = await ApiClient.GetAsync<List<STRAT_UNIT>>("/api/stratigraphy/units") ?? new();        }
        catch (Exception)
        {
            Snackbar.Add("Error loading units.", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string GetPropertyValue(STRAT_UNIT unit, string propertyName)
    {
        var prop = unit.GetType().GetProperty(propertyName);
        return prop?.GetValue(unit)?.ToString() ?? "N/A";
    }
}

