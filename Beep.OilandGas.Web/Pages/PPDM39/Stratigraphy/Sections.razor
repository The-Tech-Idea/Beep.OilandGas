@page "/ppdm39/stratigraphy/sections"
@using Beep.OilandGas.PPDM39.Models
@inject ApiClient ApiClient
@inject ISnackbar Snackbar

<PageTitle>Map Well Stratigraphic Sections</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @* ── Header *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Map Well Stratigraphic Sections</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Formation tops and depths per well</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Secondary"
                         Icon="@Icons.Material.Filled.TableRows">Geology</MudChip>
            </MudStack>
        </MudStack>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.FileDownload">Export Sections</MudButton>
    </MudStack>

    @* ── UWI Search *@
    <MudCard Elevation="1" Class="mb-4">
        <MudCardContent>
            <MudTextField @bind-Value="_searchUwi"
                          Label="Well UWI"
                          Placeholder="Enter well identifier"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.End"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          OnAdornmentClick="SearchSections" />
        </MudCardContent>
    </MudCard>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }

    @* ── Sections Grid *@
    <MudCard Elevation="2">
        <MudCardContent Class="pa-0">
            @if (_sections != null && _sections.Any())
            {
                <MudDataGrid T="STRAT_WELL_SECTION" Items="@_sections" Dense="true" Hover="true" Striped="true"
                             SortMode="SortMode.Multiple" Filterable="true">
                    <Columns>
                        <PropertyColumn Property="s => s.UWI" Title="UWI" />
                        <TemplateColumn Title="Section ID">
                            <CellTemplate>
                                <MudText Typo="Typo.body2">@GetPropertyValue(context.Item, "STRAT_WELL_SECTION_ID")</MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Strat Unit">
                            <CellTemplate>
                                <MudText Typo="Typo.body2" Color="Color.Primary">
                                    @GetStratUnitName(context.Item.STRAT_UNIT_ID)
                                </MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Top Depth">
                            <CellTemplate>
                                <MudText Typo="Typo.body2">@GetPropertyValue(context.Item, "TOP_DEPTH")</MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Base Depth">
                            <CellTemplate>
                                <MudText Typo="Typo.body2">@GetPropertyValue(context.Item, "BASE_DEPTH")</MudText>
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                    <NoRecordsContent>
                        <MudStack AlignItems="AlignItems.Center" Class="pa-6">
                            <MudIcon Icon="@Icons.Material.Filled.TableRows" Color="Color.Secondary" Class="og-icon-xl" />
                            <MudText Typo="Typo.body1">No sections match the current filter</MudText>
                        </MudStack>
                    </NoRecordsContent>
                </MudDataGrid>
            }
            else if (!_isLoading)
            {
                <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                    <MudIcon Icon="@Icons.Material.Filled.TableRows" Color="Color.Secondary" Class="og-icon-xl" />
                    <MudText Typo="Typo.h6">Enter a UWI to view stratigraphic sections</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Use the search box above to look up a well.</MudText>
                </MudStack>
            }
        </MudCardContent>
    </MudCard>

</MudContainer>

@code {
    private string _fieldName = "Current Field";
    private string _searchUwi = string.Empty;
    private List<STRAT_WELL_SECTION>? _sections;
    private Dictionary<string, string> _stratUnitNames = new();
    private bool _isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadStratUnits();
        await LoadSections();
    }

    private async Task LoadStratUnits()
    {
        try
        {
            var units = await ApiClient.GetAsync<List<STRAT_UNIT>>("/api/stratigraphy/units");
            if (units != null)
            {
                _stratUnitNames = units.ToDictionary(
                    u => u.STRAT_UNIT_ID ?? string.Empty,
                    u => !string.IsNullOrWhiteSpace(u.SHORT_NAME) ? u.SHORT_NAME : 
                         !string.IsNullOrWhiteSpace(u.LONG_NAME) ? u.LONG_NAME : 
                         u.STRAT_UNIT_ID ?? "N/A"
                );
            }
        }
        catch
        {
            // Silently fail - we'll just show IDs if lookup fails
        }
    }

    private async Task LoadSections()
    {
        _isLoading = true;
        try
        {
            _sections = await ApiClient.GetAsync<List<STRAT_WELL_SECTION>>("/api/stratigraphy/well-sections");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading sections: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SearchSections()
    {
        if (string.IsNullOrWhiteSpace(_searchUwi))
        {
            await LoadSections();
            return;
        }

        _isLoading = true;
        try
        {
            _sections = await ApiClient.GetAsync<List<STRAT_WELL_SECTION>>($"/api/stratigraphy/well-sections/well/{_searchUwi}");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error searching sections: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string GetStratUnitName(string? unitId)
    {
        if (string.IsNullOrWhiteSpace(unitId))
            return "N/A";
        
        return _stratUnitNames.TryGetValue(unitId, out var name) ? name : unitId;
    }

    private string GetPropertyValue(STRAT_WELL_SECTION section, string propertyName)
    {
        var prop = section.GetType().GetProperty(propertyName);
        return prop?.GetValue(section)?.ToString() ?? "N/A";
    }
}

