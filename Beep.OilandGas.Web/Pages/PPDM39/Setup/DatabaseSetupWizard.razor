@page "/ppdm39/setup"
@implements IDisposable
@using Beep.OilandGas.Web.Services
@using Beep.OilandGas.Models.Data
@inject IFirstRunService FirstRunService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IDataManagementService DataManagementService

<PageTitle>Database Setup — Beep Oil &amp; Gas</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Class="pa-6" Elevation="4">

        <MudStack Row="false" AlignItems="AlignItems.Center" Class="mb-4">
            <MudIcon Icon="@Icons.Material.Filled.Storage"
                     Color="Color.Primary"
                     Size="Size.Large" />
            <MudText Typo="Typo.h5" Class="mt-2">Database Setup</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Configure your PPDM39 database to get started.
            </MudText>
        </MudStack>

        <MudStepper @bind-ActiveIndex="_step" Linear="true" Color="Color.Primary">

            <!-- ─────────────── Step 0 — Choose database type ─────────────── -->
            <MudStep Title="Choose Database" Icon="@Icons.Material.Filled.Storage">
                <MudText Typo="Typo.body1" Class="mb-4">
                    Select the database type for your PPDM39 data store.
                </MudText>

                <MudRadioGroup @bind-Value="_dbType" T="string" Class="mb-4">
                    <MudRadio Value="@("sqlite")" Color="Color.Primary">
                        <MudStack Row="true" AlignItems="AlignItems.Center">
                            <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Size="Size.Small" />
                            <MudText>SQLite — local file-based database (recommended for development)</MudText>
                        </MudStack>
                    </MudRadio>
                    <MudRadio Value="@("external")" Color="Color.Primary" Disabled="true">
                        <MudStack Row="true" AlignItems="AlignItems.Center">
                            <MudIcon Icon="@Icons.Material.Filled.Dns" Size="Size.Small" />
                            <MudText>External — SQL Server / PostgreSQL (coming soon)</MudText>
                        </MudStack>
                    </MudRadio>
                </MudRadioGroup>

                <MudDivider Class="mb-4" />

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           EndIcon="@Icons.Material.Filled.ArrowForward"
                           OnClick="GoToStep1"
                           Disabled="@string.IsNullOrEmpty(_dbType)">
                    Next
                </MudButton>
            </MudStep>

            <!-- ─────────────── Step 1 — Configure SQLite ─────────────────── -->
            <MudStep Title="Configure" Icon="@Icons.Material.Filled.Settings">
                <MudText Typo="Typo.body1" Class="mb-4">
                    Enter connection details for your SQLite database.
                </MudText>

                <MudTextField @bind-Value="_connectionName"
                              Label="Connection Name"
                              HelperText="Internal name used to identify this database"
                              Required="true"
                              Class="mb-3" />

                <MudTextField @bind-Value="_fileName"
                              Label="Database File Name"
                              HelperText="e.g. ppdm39.db — the .db extension will be added automatically"
                              Required="true"
                              Class="mb-3" />

                <MudTextField @bind-Value="_savePath"
                              Label="Save Path (optional)"
                              HelperText="Leave blank to use the default application data folder"
                              Class="mb-4" />

                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Text"
                               StartIcon="@Icons.Material.Filled.ArrowBack"
                               OnClick="() => _step = 0">
                        Back
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               EndIcon="@Icons.Material.Filled.ArrowForward"
                               OnClick="CreateSqliteAsync"
                               Disabled="@(_isBusy || string.IsNullOrWhiteSpace(_connectionName) || string.IsNullOrWhiteSpace(_fileName))">
                        @if (_isBusy && _step == 1)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        Create Database
                    </MudButton>
                </MudStack>
            </MudStep>

            <!-- ─────────────── Step 2 — Create Schema ────────────────────── -->
            <MudStep Title="Create Schema" Icon="@Icons.Material.Filled.TableChart">
                <MudText Typo="Typo.body1" Class="mb-4">
                    Apply the PPDM39 schema to your new database. This will create all required tables.
                </MudText>

                @if (!string.IsNullOrEmpty(_createDbMessage))
                {
                    <MudAlert Severity="@_createDbSeverity" Class="mb-4" Dense="true">
                        @_createDbMessage
                    </MudAlert>
                }

                <MudText Typo="Typo.body2" Class="mb-4">
                    Connection: <strong>@_connectionName</strong>
                </MudText>

                @if (_schemaPlan != null)
                {
                    <MudPaper Class="pa-4 mb-4" Outlined="true">
                        <MudText Typo="Typo.subtitle2">Migration Plan Review</MudText>
                        <MudText Typo="Typo.body2">Plan ID: @_schemaPlan.PlanId</MudText>
                        <MudText Typo="Typo.body2">Plan Hash: @_schemaPlan.PlanHash</MudText>
                        <MudText Typo="Typo.body2">Policy Decision: @_schemaPlan.PolicyDecision</MudText>
                        <MudText Typo="Typo.body2">Pending Operations: @_schemaPlan.PendingOperationCount</MudText>
                        <MudText Typo="Typo.body2">Tables To Create: @_schemaPlan.TablesToCreate</MudText>
                        <MudText Typo="Typo.body2">Columns To Add: @_schemaPlan.ColumnsToAdd</MudText>

                        @if (!_schemaPlan.CanApply)
                        {
                            <MudAlert Severity="Severity.Error" Dense="true" Class="mt-3 mb-3">
                                This plan has blocking CI or preflight findings and cannot be applied yet.
                            </MudAlert>
                        }

                        @if (_schemaPlan.PreflightChecks.Count > 0)
                        {
                            <MudText Typo="Typo.subtitle2" Class="mt-3">Preflight</MudText>
                            @foreach (var check in _schemaPlan.PreflightChecks)
                            {
                                <MudText Typo="Typo.body2">@($"{check.Decision}: {check.Code} - {check.Message}")</MudText>
                            }
                        }

                        @if (_schemaPlan.CiGates.Count > 0)
                        {
                            <MudText Typo="Typo.subtitle2" Class="mt-3">CI Gates</MudText>
                            @foreach (var gate in _schemaPlan.CiGates)
                            {
                                <MudText Typo="Typo.body2">@($"{gate.Decision}: {gate.Gate} - {gate.Message}")</MudText>
                            }
                        }

                        @if (_schemaArtifacts != null)
                        {
                            <MudExpansionPanels Elevation="0" Variant="Variant.Outlined" MultiExpansion="true" Class="mt-4">
                                <MudExpansionPanel Text="Approval Summary" Icon="@Icons.Material.Filled.FactCheck">
                                    <pre>@PreviewArtifact(_schemaArtifacts.ApprovalSummaryMarkdown)</pre>
                                </MudExpansionPanel>
                                <MudExpansionPanel Text="Dry Run Evidence" Icon="@Icons.Material.Filled.Preview">
                                    <pre>@PreviewArtifact(_schemaArtifacts.DryRunJson)</pre>
                                </MudExpansionPanel>
                                <MudExpansionPanel Text="Preflight Evidence" Icon="@Icons.Material.Filled.HealthAndSafety">
                                    <pre>@PreviewArtifact(_schemaArtifacts.PreflightJson)</pre>
                                </MudExpansionPanel>
                                <MudExpansionPanel Text="CI Validation" Icon="@Icons.Material.Filled.RuleFolder">
                                    <pre>@PreviewArtifact(_schemaArtifacts.CiValidationJson)</pre>
                                </MudExpansionPanel>
                                <MudExpansionPanel Text="Rollback Readiness" Icon="@Icons.Material.Filled.Restore">
                                    <pre>@PreviewArtifact(_schemaArtifacts.RollbackReadinessJson)</pre>
                                </MudExpansionPanel>
                            </MudExpansionPanels>
                        }
                    </MudPaper>
                }

                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Text"
                               StartIcon="@Icons.Material.Filled.ArrowBack"
                               OnClick="() => _step = 1"
                               Disabled="@_isBusy">
                        Back
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               EndIcon="@Icons.Material.Filled.Preview"
                               OnClick="BuildSchemaPlanAsync"
                               Disabled="@_isBusy">
                        @if (_isBusy && _step == 2 && _schemaPlan == null)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        @(_schemaPlan == null ? "Review Plan" : "Rebuild Plan")
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               EndIcon="@Icons.Material.Filled.PlayArrow"
                               OnClick="ExecuteSchemaPlanAsync"
                               Disabled="@(_isBusy || _schemaPlan == null || !_schemaPlan.CanApply)">
                        @if (_isBusy && _step == 2 && _schemaPlan != null)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        Approve And Apply Schema
                    </MudButton>
                </MudStack>

                @if (_schemaProgress > 0)
                {
                    <MudProgressLinear Value="@_schemaProgress" Color="Color.Primary" Striped="true" Class="mt-4" />
                    <MudText Typo="Typo.caption" Class="mt-1">@_schemaStatusText</MudText>
                }
            </MudStep>

            <!-- ─────────────── Step 3 — Ready ───────────────────────────── -->
            <MudStep Title="Ready"
                     Icon="@Icons.Material.Filled.CheckCircle"
                     CompletedIcon="@Icons.Material.Filled.CheckCircle">
                <MudStack AlignItems="AlignItems.Center" Class="pa-4">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                             Color="Color.Success"
                             Size="Size.Large" />
                    <MudText Typo="Typo.h6" Class="mt-2">Setup Complete!</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                        Your PPDM39 database is ready. Tables created: <strong>@_tablesCreated</strong>
                    </MudText>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.PlayArrow"
                               OnClick="FinishAndNavigate">
                        Seed Reference Data →
                    </MudButton>
                    <MudButton Variant="Variant.Text"
                               Color="Color.Default"
                               StartIcon="@Icons.Material.Filled.Home"
                               OnClick="SkipToApp">
                        Skip — Go to Dashboard
                    </MudButton>
                </MudStack>
            </MudStep>

        </MudStepper>

    </MudPaper>
</MudContainer>

@code {
    // ── State ─────────────────────────────────────────────────────────────────
    private int _step = 0;
    private bool _isBusy = false;

    // Step 0 — DB type
    private string _dbType = "sqlite";

    // Step 1 — Connection config
    private string _connectionName = "PPDM39";
    private string _fileName = "ppdm39";
    private string _savePath = "";

    // Step 2 — Schema progress
    private string? _createDbMessage;
    private Severity _createDbSeverity = Severity.Info;
    private double _schemaProgress = 0;
    private string _schemaStatusText = "";
    private int _tablesCreated = 0;
    private SchemaMigrationPlanResult? _schemaPlan;
    private SchemaMigrationArtifactsResult? _schemaArtifacts;
    private string? _schemaExecutionToken;
    private System.Threading.Timer? _schemaProgressTimer;

    // ── Lifecycle ─────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        // If setup already done, redirect away
        var required = await FirstRunService.IsSetupRequiredAsync();
        if (!required)
        {
            NavigationManager.NavigateTo("/", forceLoad: false);
        }
    }

    public void Dispose()
    {
        _schemaProgressTimer?.Dispose();
    }

    // ── Step navigation ───────────────────────────────────────────────────────
    private void GoToStep1() => _step = 1;

    // ── Create SQLite database ────────────────────────────────────────────────
    private async Task CreateSqliteAsync()
    {
        _isBusy = true;
        StateHasChanged();
        try
        {
            var response = await DataManagementService.CreateSqliteAsync(new CreateSqliteRequest
            {
                ConnectionName = _connectionName,
                FileName = _fileName,
                SavePath = string.IsNullOrWhiteSpace(_savePath) ? null : _savePath
            });

            if (response.Success)
            {
                _createDbMessage = response.Message ?? $"Database created for connection '{_connectionName}'.";
                _createDbSeverity = Severity.Success;
                _schemaPlan = null;
                _schemaArtifacts = null;
                _schemaExecutionToken = null;
                _schemaProgress = 0;
                _schemaStatusText = string.Empty;
                _step = 2;
            }
            else
            {
                _createDbMessage = response.Message ?? "Failed to create database.";
                _createDbSeverity = Severity.Error;
                Snackbar.Add(_createDbMessage, Severity.Error);
            }
        }
        catch (Exception)
        {
            _createDbMessage = "An error occurred.";
            _createDbSeverity = Severity.Error;
            Snackbar.Add(_createDbMessage, Severity.Error);
        }
        finally
        {
            _isBusy = false;
            StateHasChanged();
        }
    }

    // ── Apply PPDM39 schema via MigrationManager ──────────────────────────────
    private async Task BuildSchemaPlanAsync()
    {
        _isBusy = true;
        _schemaProgress = 10;
        _schemaStatusText = "Building migration plan…";
        StateHasChanged();

        try
        {
            _schemaArtifacts = null;
            _schemaPlan = await DataManagementService.PlanSchemaMigrationAsync(new SchemaMigrationPlanRequest
            {
                ConnectionName = _connectionName,
                BackupConfirmed = true,
                RestoreTestEvidenceProvided = true,
                RestoreTestEvidence = "First-run setup wizard"
            });

            if (_schemaPlan.Success)
            {
                _schemaArtifacts = await DataManagementService.GetSchemaMigrationArtifactsAsync(_schemaPlan.PlanId);
                _schemaProgress = 45;
                _schemaStatusText = _schemaPlan.CanApply
                    ? "Plan ready for approval and execution."
                    : "Plan generated with blocking findings.";

                if (_schemaArtifacts is { Success: false })
                {
                    Snackbar.Add(_schemaArtifacts.Message ?? "Could not load schema migration artifacts.", Severity.Warning);
                    _schemaArtifacts = null;
                }
            }
            else
            {
                _schemaProgress = 0;
                _schemaStatusText = string.Empty;
                _createDbMessage = _schemaPlan.Message ?? "Schema migration plan failed.";
                _createDbSeverity = Severity.Error;
                Snackbar.Add(_createDbMessage, Severity.Error);
            }

            StateHasChanged();
        }
        catch (Exception)
        {
            _schemaProgress = 0;
            _schemaStatusText = string.Empty;
            Snackbar.Add("Schema migration plan failed.", Severity.Error);
        }
        finally
        {
            _isBusy = false;
            StateHasChanged();
        }
    }

    private async Task ExecuteSchemaPlanAsync()
    {
        if (_schemaPlan == null)
            return;

        _isBusy = true;
        _schemaProgress = 55;
        _schemaStatusText = "Recording plan approval…";
        StateHasChanged();

        try
        {
            var approval = await DataManagementService.ApproveSchemaMigrationAsync(new SchemaMigrationApprovalRequest
            {
                PlanId = _schemaPlan.PlanId,
                ApprovedBy = "setup-wizard",
                Notes = "Approved from first-run setup wizard."
            });

            if (!approval.Success)
            {
                _schemaProgress = 0;
                _schemaStatusText = string.Empty;
                _createDbMessage = approval.Message ?? "Schema migration approval failed.";
                _createDbSeverity = Severity.Error;
                Snackbar.Add(_createDbMessage, Severity.Error);
                return;
            }

            _schemaProgress = 65;
            _schemaStatusText = "Starting schema execution…";
            StateHasChanged();

            var startResult = await DataManagementService.StartSchemaMigrationExecutionAsync(new SchemaMigrationExecuteRequest
            {
                PlanId = _schemaPlan.PlanId,
                ExecutedBy = "setup-wizard"
            });

            if (startResult.Success && !string.IsNullOrWhiteSpace(startResult.OperationId))
            {
                _schemaExecutionToken = startResult.OperationId;
                _schemaProgress = 75;
                _schemaStatusText = "Schema execution started. Monitoring progress…";
                _schemaProgressTimer?.Dispose();
                _schemaProgressTimer = new System.Threading.Timer(async _ => await PollSchemaProgress(), null, 1000, 2000);
            }
            else
            {
                _isBusy = false;
                _schemaProgress = 0;
                _schemaStatusText = "";
                _createDbMessage = startResult.Message ?? "Schema migration failed.";
                _createDbSeverity = Severity.Error;
                Snackbar.Add(_createDbMessage, Severity.Error);
            }
        }
        catch (Exception)
        {
            _isBusy = false;
            _schemaProgress = 0;
            _schemaStatusText = "";
            Snackbar.Add("Schema migration failed.", Severity.Error);
        }
        finally
        {
            StateHasChanged();
        }
    }

    private async Task PollSchemaProgress()
    {
        if (string.IsNullOrWhiteSpace(_schemaExecutionToken))
            return;

        try
        {
            var progress = await DataManagementService.GetSchemaMigrationProgressAsync(_schemaExecutionToken);
            if (!progress.Success)
                return;

            var totalSteps = Math.Max(1, progress.TotalSteps);
            var completedSteps = Math.Max(0, progress.CompletedSteps);
            _schemaProgress = Math.Min(99, 75 + (completedSteps * 24d / totalSteps));
            _schemaStatusText = progress.HasFailed
                ? (progress.FailureReason ?? "Schema migration failed.")
                : progress.IsCompleted
                    ? "Schema created successfully"
                    : $"Applying schema… {completedSteps}/{progress.TotalSteps} steps completed.";

            if (progress.IsCompleted)
            {
                _schemaProgressTimer?.Dispose();
                _schemaProgressTimer = null;
                _tablesCreated = _schemaPlan?.TablesToCreate ?? 0;
                _schemaProgress = 100;
                _isBusy = false;
                await FirstRunService.MarkSetupCompleteAsync(_connectionName);
                _step = 3;
            }
            else if (progress.HasFailed)
            {
                _schemaProgressTimer?.Dispose();
                _schemaProgressTimer = null;
                _isBusy = false;
                _createDbMessage = progress.FailureReason ?? progress.Message ?? "Schema migration failed.";
                _createDbSeverity = Severity.Error;
            }

            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            // Ignore transient polling errors; next interval will retry.
        }
    }

    private static string PreviewArtifact(string? content, int maxLength = 4000)
    {
        if (string.IsNullOrWhiteSpace(content))
            return "No artifact content available.";

        if (content.Length <= maxLength)
            return content;

        return content[..maxLength] + Environment.NewLine + Environment.NewLine + "...artifact truncated for preview...";
    }

    // ── Finish ────────────────────────────────────────────────────────────────
    private void FinishAndNavigate()
    {
        NavigationManager.NavigateTo("/ppdm39/setup/seed", forceLoad: false);
    }

    private void SkipToApp()
    {
        NavigationManager.NavigateTo("/dashboard", forceLoad: true);
    }
}
