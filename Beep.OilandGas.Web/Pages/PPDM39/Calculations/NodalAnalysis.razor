@page "/ppdm39/calculations/nodalanalysis"
@using Beep.OilandGas.Models.Data
@using Beep.OilandGas.Models.Data.NodalAnalysis
@using Beep.OilandGas.Client.App
@using System.Security.Claims
@inject ISnackbar Snackbar
@inject ICalculationServiceClient CalculationService
@inject AuthenticationStateProvider AuthStateProvider
@inject ApiClient ApiClient

<PageTitle>Perform Nodal Analysis</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @* ─── Header *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Perform Nodal Analysis</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Inflow and outflow performance analysis</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Primary"
                         Icon="@Icons.Material.Filled.Hub">Well</MudChip>
            </MudStack>
        </MudStack>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.PlayArrow"
                   OnClick="OpenAnalysisDialog">Perform Analysis</MudButton>
    </MudStack>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }

    @* ─── KPI Row *@
    <MudGrid Class="mb-4" Spacing="3">
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Analyses" Value="@((_analysisHistory?.Count ?? 0).ToString())"
                     ValueColor="Color.Primary" Icon="@Icons.Material.Filled.Hub"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default"
                     TrendText="All analysis runs" />
        </MudItem>
    </MudGrid>

    @* ─── History Grid *@
    <MudCard Elevation="2">
        <MudCardContent Class="pa-0">
            @if (_analysisHistory != null && _analysisHistory.Any())
            {
                <MudDataGrid T="NodalAnalysisRunResult" Items="@_analysisHistory" Dense="true" Hover="true" Striped="true"
                             SortMode="SortMode.Multiple" Filterable="true">
                    <Columns>
                        <PropertyColumn Property="a => a.AnalysisId" Title="Analysis ID" />
                        <PropertyColumn Property="a => a.WellUWI" Title="Well UWI" />
                        <TemplateColumn Title="Analysis Date">
                            <CellTemplate>
                                <MudText Typo="Typo.body2">@context.Item.AnalysisDate.ToString("dd MMM yyyy")</MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Optimal Flow Rate">
                            <CellTemplate>
                                <MudText Typo="Typo.body2">@context.Item.OptimalFlowRate.ToString("F2")</MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Status">
                            <CellTemplate>
                                <StatusBadge Status="@(context.Item.Status ?? "Active")" />
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                    <NoRecordsContent>
                        <MudStack AlignItems="AlignItems.Center" Class="pa-6">
                            <MudIcon Icon="@Icons.Material.Filled.Hub" Color="Color.Secondary" Class="og-icon-xl" />
                            <MudText Typo="Typo.body1">No results match the current filter</MudText>
                        </MudStack>
                    </NoRecordsContent>
                </MudDataGrid>
            }
            else if (!_isLoading)
            {
                <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                    <MudIcon Icon="@Icons.Material.Filled.Hub" Color="Color.Secondary" Class="og-icon-xl" />
                    <MudText Typo="Typo.h6">No analysis results yet</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Perform an analysis to see inflow/outflow results here.</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.PlayArrow"
                               OnClick="OpenAnalysisDialog" Class="mt-2">Perform Analysis</MudButton>
                </MudStack>
            }
        </MudCardContent>
    </MudCard>

</MudContainer>

@code {
    private string _fieldName = string.Empty;
    private List<NodalAnalysisRunResult>? _analysisHistory;
    private bool _isLoading = false;
    private string? _currentUserId;
    private string? _selectedWellUWI;
    private List<WellOptionDto> _wells = new();

    private class WellOptionDto
    {
        public string? UWI      { get; set; }
        public string? WellName { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summary = await ApiClient.GetAsync<FieldLifecycleSummary>("/api/field/current/summary");
            if (summary != null)
                _fieldName = summary.FieldName ?? _fieldName;
        }
        catch { /* field name is non-critical */ }

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _currentUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "system";
        try
        {
            var wells = await ApiClient.GetAsync<List<WellOptionDto>>("api/field/current/development/wells") ?? new();            _wells = wells ?? new();
            _selectedWellUWI = _wells.FirstOrDefault()?.UWI;
            if (!string.IsNullOrEmpty(_selectedWellUWI))
                _analysisHistory = await CalculationService.GetNodalAnalysisHistoryAsync(_selectedWellUWI);
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to load wells.", Severity.Warning);
        }
    }

    private async Task OpenAnalysisDialog()
    {
        await PerformAnalysis();
    }

    private async Task PerformAnalysis()
    {
        if (string.IsNullOrEmpty(_selectedWellUWI))
        {
            Snackbar.Add("Please select a well", Severity.Warning);
            return;
        }

        _isLoading = true;
        try
        {
            var parameters = new NodalAnalysisParameters();

            var result = await CalculationService.PerformNodalAnalysisAsync(_selectedWellUWI, parameters);
            
            // Save the result
            await CalculationService.SaveNodalAnalysisResultAsync(result, _currentUserId);
            
            Snackbar.Add("Nodal analysis completed successfully", Severity.Success);
            
            // Reload history
            _analysisHistory = await CalculationService.GetNodalAnalysisHistoryAsync(_selectedWellUWI);
        }
        catch (Exception)
        {
            Snackbar.Add("Error performing nodal analysis.", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }
}

