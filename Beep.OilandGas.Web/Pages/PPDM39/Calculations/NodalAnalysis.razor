@page "/ppdm39/calculations/nodalanalysis"
@using Beep.OilandGas.Models.Data
@using Beep.OilandGas.Models.Data.NodalAnalysis
@using Beep.OilandGas.PPDM39.Models
@using System.Security.Claims
@using Microsoft.Extensions.Logging
@inject ISnackbar Snackbar
@inject ILogger<NodalAnalysis> Logger
@inject ICalculationServiceClient CalculationService
@inject AuthenticationStateProvider AuthStateProvider
@inject IDevelopmentServiceClient DevelopmentClient
@inject ILifeCycleService LifeCycleService

<PageTitle>Perform Nodal Analysis</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @* ─── Header *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Perform Nodal Analysis</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Inflow and outflow performance analysis</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Primary"
                         Icon="@Icons.Material.Filled.Hub">Well</MudChip>
            </MudStack>
        </MudStack>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.PlayArrow"
                   Disabled="@(!_initializationFinished || _wells.Count == 0)"
                   OnClick="OpenAnalysisDialog">Perform Analysis</MudButton>
    </MudStack>

    @if (_initializationFinished && _wells.Count == 0 && !_isLoading)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-4">
            No wells with a valid UWI were returned for this field. Nodal analysis requires a well identifier.
        </MudAlert>
    }

    @if (_wells.Count > 0)
    {
        <MudSelect T="string"
                   Label="Well"
                   Variant="Variant.Outlined"
                   Dense="true"
                   Class="mb-4"
                   Value="@_selectedWellUWI"
                   ValueChanged="OnWellUwiChangedAsync"
                   AnchorOrigin="Origin.BottomCenter">
            @foreach (var w in _wells)
            {
                var label = string.IsNullOrWhiteSpace(w.WellName) ? w.UWI : $"{w.WellName} ({w.UWI})";
                <MudSelectItem Value="@w.UWI">@label</MudSelectItem>
            }
        </MudSelect>
    }

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }

    @* ─── KPI Row *@
    <MudGrid Class="mb-4" Spacing="3">
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Analyses" Value="@((_analysisHistory?.Count ?? 0).ToString())"
                     ValueColor="Color.Primary" Icon="@Icons.Material.Filled.Hub"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default"
                     TrendText="All analysis runs" />
        </MudItem>
    </MudGrid>

    @* ─── History Grid *@
    <MudCard Elevation="2">
        <MudCardContent Class="pa-0">
            @if (_analysisHistory != null && _analysisHistory.Any())
            {
                <MudDataGrid T="NodalAnalysisRunResult" Items="@_analysisHistory" Dense="true" Hover="true" Striped="true"
                             SortMode="SortMode.Multiple" Filterable="true">
                    <Columns>
                        <PropertyColumn Property="a => a.AnalysisId" Title="Analysis ID" />
                        <PropertyColumn Property="a => a.WellUWI" Title="Well UWI" />
                        <TemplateColumn Title="Analysis Date">
                            <CellTemplate>
                                <MudText Typo="Typo.body2">@context.Item.AnalysisDate.ToString("dd MMM yyyy")</MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Optimal Flow Rate">
                            <CellTemplate>
                                <MudText Typo="Typo.body2">@context.Item.OptimalFlowRate.ToString("F2")</MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Status">
                            <CellTemplate>
                                <StatusBadge Status="@(context.Item.Status ?? "Active")" />
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                    <NoRecordsContent>
                        <MudStack AlignItems="AlignItems.Center" Class="pa-6">
                            <MudIcon Icon="@Icons.Material.Filled.Hub" Color="Color.Secondary" Class="og-icon-xl" />
                            <MudText Typo="Typo.body1">No results match the current filter</MudText>
                        </MudStack>
                    </NoRecordsContent>
                </MudDataGrid>
            }
            else if (!_isLoading)
            {
                <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                    <MudIcon Icon="@Icons.Material.Filled.Hub" Color="Color.Secondary" Class="og-icon-xl" />
                    <MudText Typo="Typo.h6">No analysis results yet</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Perform an analysis to see inflow/outflow results here.</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.PlayArrow"
                               Disabled="@(!_initializationFinished || _wells.Count == 0)"
                               OnClick="OpenAnalysisDialog" Class="mt-2">Perform Analysis</MudButton>
                </MudStack>
            }
        </MudCardContent>
    </MudCard>

</MudContainer>

@code {
    private string _fieldName = string.Empty;
    private List<NodalAnalysisRunResult>? _analysisHistory;
    private bool _isLoading = false;
    private bool _initializationFinished;
    private string? _currentUserId;
    private string? _selectedWellUWI;
    private List<WellOptionDto> _wells = new();

    private class WellOptionDto
    {
        public string? UWI      { get; set; }
        public string? WellName { get; set; }
    }

    private static WellOptionDto MapWell(WELL well)
    {
        return new WellOptionDto
        {
            UWI = well.UWI,
            WellName = well.WELL_NAME
        };
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            try
            {
                var summary = await LifeCycleService.GetFieldLifecycleSummaryAsync();
                if (summary != null)
                    _fieldName = summary.FieldName ?? _fieldName;
            }
            catch (OperationCanceledException)
            {
                // Navigation or token cancellation during header load.
            }
            catch (Exception ex)
            {
                Logger.LogDebug(ex, "Field lifecycle summary unavailable for nodal analysis header");
            }

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            _currentUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "system";
            try
            {
                _wells = (await DevelopmentClient.GetWellsAsync()).Select(MapWell)
                    .Where(w => !string.IsNullOrWhiteSpace(w.UWI))
                    .ToList();
                _selectedWellUWI = _wells.FirstOrDefault()?.UWI;
                await ReloadHistoryForSelectedWellAsync();
            }
            catch (OperationCanceledException)
            {
                // Navigation or token cancellation during well/history load.
            }
            catch (Exception ex)
            {
                Logger.LogDebug(ex, "Failed to load wells for nodal analysis page");
                Snackbar.Add("Failed to load wells.", Severity.Warning);
            }
        }
        finally
        {
            _initializationFinished = true;
        }
    }

    private async Task OpenAnalysisDialog()
    {
        await PerformAnalysis();
    }

    private async Task OnWellUwiChangedAsync(string? uwi)
    {
        _selectedWellUWI = uwi;
        await ReloadHistoryForSelectedWellAsync();
    }

    private async Task ReloadHistoryForSelectedWellAsync()
    {
        if (string.IsNullOrWhiteSpace(_selectedWellUWI))
        {
            _analysisHistory = null;
            return;
        }

        _isLoading = true;
        try
        {
            _analysisHistory = await CalculationService.GetNodalAnalysisHistoryAsync(_selectedWellUWI);
        }
        catch (ArgumentException ex)
        {
            Logger.LogWarning(ex, "Invalid request loading nodal history for well {WellUWI}", _selectedWellUWI);
            Snackbar.Add(ex.Message, Severity.Warning);
            _analysisHistory = null;
        }
        catch (OperationCanceledException)
        {
            // Navigation or token cancellation; avoid misleading warning snackbars.
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load nodal analysis history for well {WellUWI}", _selectedWellUWI);
            Snackbar.Add("Failed to load analysis history.", Severity.Warning);
            _analysisHistory = null;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task PerformAnalysis()
    {
        if (string.IsNullOrWhiteSpace(_selectedWellUWI))
        {
            Snackbar.Add("Please select a well", Severity.Warning);
            return;
        }

        _isLoading = true;
        try
        {
            var parameters = new NodalAnalysisParameters();

            var result = await CalculationService.PerformNodalAnalysisAsync(_selectedWellUWI, parameters);

            var saved = await CalculationService.SaveNodalAnalysisResultAsync(result, _currentUserId);
            if (!saved)
            {
                Logger.LogWarning("Nodal analysis finished but save returned false for well {WellUWI}", _selectedWellUWI);
                Snackbar.Add("Analysis finished but saving results failed. Check connectivity and permissions.", Severity.Warning);
            }
            else
            {
                Snackbar.Add("Nodal analysis completed successfully", Severity.Success);
            }

            await ReloadHistoryForSelectedWellAsync();
        }
        catch (ArgumentException ex)
        {
            Logger.LogWarning(ex, "Nodal analysis request invalid for well {WellUWI}", _selectedWellUWI);
            Snackbar.Add(ex.Message, Severity.Warning);
        }
        catch (InvalidOperationException ex)
        {
            Logger.LogWarning(ex, "Nodal analysis operation failed for well {WellUWI}", _selectedWellUWI);
            Snackbar.Add(ex.Message, Severity.Warning);
        }
        catch (OperationCanceledException)
        {
            // Navigation or token cancellation; avoid error snackbars.
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Nodal analysis or save failed for well {WellUWI}", _selectedWellUWI);
            Snackbar.Add("Error performing nodal analysis.", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }
}

