@page "/ppdm39/calculations/gaslift"
@using Beep.OilandGas.Models.Data
@using Beep.OilandGas.Models.Data.GasLift
@using Beep.OilandGas.PPDM39.Models
@inject ISnackbar Snackbar
@inject ICalculationServiceClient CalculationService
@inject ApiClient ApiClient
@inject IDevelopmentServiceClient DevelopmentClient
@inject ILifeCycleService LifeCycleService
@inject NavigationManager NavigationManager

<PageTitle>Analyse Gas Lift Performance</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Analyse Gas Lift Performance</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Gas lift potential and valve design</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Info" Icon="@Icons.Material.Filled.BubbleChart">Artificial Lift</MudChip>
            </MudStack>
        </MudStack>
    </MudStack>

    <MudGrid>
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-4">Analyze Gas Lift Potential</MudText>
                <MudStack Spacing="3">
                    <MudTextField @bind-Value="@_wellUWI" Label="Well UWI" Variant="Variant.Outlined" />
                    <MudNumericField @bind-Value="@_minGasInjectionRate" Label="Min Gas Injection Rate (MCF/D)" Variant="Variant.Outlined" />
                    <MudNumericField @bind-Value="@_maxGasInjectionRate" Label="Max Gas Injection Rate (MCF/D)" Variant="Variant.Outlined" />
                    <MudNumericField @bind-Value="@_numberOfPoints" Label="Number of Points" Variant="Variant.Outlined" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AnalyzePotential" Disabled="@_isAnalyzing">
                        Analyze Potential
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-4">Design Gas Lift Valves</MudText>
                <MudStack Spacing="3">
                    <MudTextField @bind-Value="@_designWellUWI" Label="Well UWI" Variant="Variant.Outlined" />
                    <MudNumericField @bind-Value="@_gasInjectionPressure" Label="Gas Injection Pressure (PSI)" Variant="Variant.Outlined" />
                    <MudNumericField @bind-Value="@_numberOfValves" Label="Number of Valves" Variant="Variant.Outlined" />
                    <MudCheckBox @bind-Value="@_useSIUnits" Label="Use SI Units" />
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="DesignValves" Disabled="@_isDesigning">
                        Design Valves
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mt-4" />
    }

    @if (_potentialResult != null || _valveDesignResult != null)
    {
        <LiftRecommendationCard Title="Lift Workflow Recommendation"
                                Subtitle="Gas lift candidate review"
                                Icon="@Icons.Material.Filled.BubbleChart"
                                IconColor="Color.Info"
                                Headline="@GetGasLiftRecommendationHeadline()"
                                Summary="@GetGasLiftRecommendationSummary()"
                                ImpactText="@GetGasLiftRecommendationImpactText()"
                                Severity="@GetGasLiftRecommendationSeverity()"
                                Facts="@GetGasLiftRecommendationFacts()"
                                Class="mt-4">
            <Actions>
                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.AutoGraph"
                           Href="@GetWellPerformanceUrl()">
                    Open Well Performance Optimizer
                </MudButton>
                @if (_potentialResult != null && _valveDesignResult == null)
                {
                    <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.Tune"
                               OnClick="DesignValves"
                               Disabled="@_isDesigning">
                        Run Valve Design
                    </MudButton>
                }
            </Actions>
        </LiftRecommendationCard>
    }
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "wellId")]
    public string? WellId { get; set; }

    private string _fieldName = string.Empty;
    private string _wellUWI = string.Empty;
    private decimal _minGasInjectionRate = 100;
    private decimal _maxGasInjectionRate = 1000;
    private int _numberOfPoints = 50;
    private string _designWellUWI = string.Empty;
    private decimal _gasInjectionPressure = 1000;
    private int _numberOfValves = 5;
    private bool _useSIUnits = false;
    private bool _isAnalyzing = false;
    private bool _isDesigning = false;
    private bool _isLoading = false;
    private GAS_LIFT_POTENTIAL_RESULT? _potentialResult;
    private GAS_LIFT_VALVE_DESIGN_RESULT? _valveDesignResult;

    private sealed class WellDto
    {
        public string UWI { get; set; } = string.Empty;
        public string? WELL_NAME { get; set; }
        public decimal? FINAL_TD { get; set; }
        public string? ASSIGNED_FIELD { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        try
        {
            try
            {
                var summary = await LifeCycleService.GetFieldLifecycleSummaryAsync();
                if (summary != null)
                    _fieldName = summary.FieldName ?? _fieldName;
            }
            catch { /* field name is non-critical */ }

            try
            {
                var wells = (await DevelopmentClient.GetWellsAsync()).Select(MapWell).ToList();
                if (wells.Count > 0)
                {
                    var preferredWellId = wells.Any(well => string.Equals(well.UWI, WellId, StringComparison.OrdinalIgnoreCase))
                        ? WellId!
                        : wells[0].UWI;

                    var selectedWell = wells.First(well => string.Equals(well.UWI, preferredWellId, StringComparison.OrdinalIgnoreCase));
                    _fieldName = selectedWell.ASSIGNED_FIELD ?? _fieldName;
                    _wellUWI = selectedWell.UWI;
                    _designWellUWI = selectedWell.UWI;
                }
            }
            catch (Exception)
            {
                Snackbar.Add("Error loading wells.", Severity.Warning);
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task<GAS_LIFT_WELL_PROPERTIES> LoadWellPropertiesAsync(string uwi)
    {
        try
        {
            var well = MapWell(await DevelopmentClient.GetWellAsync(uwi));
            return new GAS_LIFT_WELL_PROPERTIES
            {
                WELL_DEPTH = well?.FINAL_TD ?? 5000,
                TUBING_DIAMETER = 3,
                WELLHEAD_PRESSURE = 100,
                BOTTOM_HOLE_PRESSURE = 2000,
                GAS_OIL_RATIO = 500
            };
        }
        catch
        {
            return new GAS_LIFT_WELL_PROPERTIES
            {
                WELL_DEPTH = 5000,
                TUBING_DIAMETER = 3,
                WELLHEAD_PRESSURE = 100,
                BOTTOM_HOLE_PRESSURE = 2000,
                GAS_OIL_RATIO = 500
            };
        }
    }

    private static WellDto MapWell(WELL? well)
    {
        if (well == null)
        {
            return new WellDto();
        }

        return new WellDto
        {
            UWI = well.UWI,
            WELL_NAME = well.WELL_NAME,
            FINAL_TD = well.FINAL_TD,
            ASSIGNED_FIELD = well.ASSIGNED_FIELD
        };
    }

    private async Task AnalyzePotential()
    {
        if (string.IsNullOrEmpty(_wellUWI))
        {
            Snackbar.Add("Please enter a Well UWI", Severity.Warning);
            return;
        }

        _isAnalyzing = true;
        try
        {
            var wellProperties = await LoadWellPropertiesAsync(_wellUWI);
            _valveDesignResult = null;
            _potentialResult = await CalculationService.AnalyzeGasLiftPotentialAsync(
                wellProperties, _minGasInjectionRate, _maxGasInjectionRate, _numberOfPoints);
            _designWellUWI = _wellUWI;
            Snackbar.Add("Gas lift potential analysis completed", Severity.Success);
        }
        catch (Exception)
        {
            Snackbar.Add("Error analyzing gas lift potential.", Severity.Error);
        }
        finally
        {
            _isAnalyzing = false;
        }
    }

    private async Task DesignValves()
    {
        if (string.IsNullOrEmpty(_designWellUWI))
        {
            Snackbar.Add("Please enter a Well UWI", Severity.Warning);
            return;
        }

        _isDesigning = true;
        try
        {
            var wellProperties = await LoadWellPropertiesAsync(_designWellUWI);
            _valveDesignResult = await CalculationService.DesignGasLiftValvesAsync(
                wellProperties, _gasInjectionPressure, _numberOfValves, _useSIUnits);
            Snackbar.Add("Gas lift valve design completed", Severity.Success);
        }
        catch (Exception)
        {
            Snackbar.Add("Error designing gas lift valves.", Severity.Error);
        }
        finally
        {
            _isDesigning = false;
        }
    }

    private IReadOnlyList<RecommendationFactItem> GetGasLiftRecommendationFacts()
    {
        var facts = new List<RecommendationFactItem>();

        if (_potentialResult != null)
        {
            facts.Add(new RecommendationFactItem
            {
                Label = "Optimal Injection",
                Value = $"{FormatNullableDecimal(_potentialResult.OPTIMAL_GAS_INJECTION_RATE, 1)} MCF/D",
                ValueColor = Color.Info
            });
            facts.Add(new RecommendationFactItem
            {
                Label = "Maximum Production",
                Value = $"{FormatNullableDecimal(_potentialResult.MAXIMUM_PRODUCTION_RATE, 1)} BBL/D",
                ValueColor = Color.Success
            });
            facts.Add(new RecommendationFactItem
            {
                Label = "Gas/Liquid Ratio",
                Value = FormatNullableDecimal(_potentialResult.OPTIMAL_GAS_LIQUID_RATIO, 2),
                ValueColor = Color.Primary
            });
        }

        if (_valveDesignResult != null)
        {
            facts.Add(new RecommendationFactItem
            {
                Label = "Expected Production",
                Value = $"{_valveDesignResult.EXPECTED_PRODUCTION_RATE.ToString("N1")} BBL/D",
                ValueColor = Color.Success
            });
            facts.Add(new RecommendationFactItem
            {
                Label = "Valve Injection",
                Value = $"{_valveDesignResult.TOTAL_GAS_INJECTION_RATE.ToString("N1")} MCF/D",
                ValueColor = Color.Warning
            });
        }

        return facts;
    }

    private string GetGasLiftRecommendationHeadline()
    {
        if (_valveDesignResult != null)
            return "Advance gas lift design to operating review";

        return "Evaluate gas lift as a lift candidate";
    }

    private string GetGasLiftRecommendationSummary()
    {
        var parts = new List<string>();

        if (_potentialResult != null)
        {
            parts.Add($"Potential analysis indicates up to {FormatNullableDecimal(_potentialResult.MAXIMUM_PRODUCTION_RATE, 1)} BBL/D at an optimal gas injection rate of {FormatNullableDecimal(_potentialResult.OPTIMAL_GAS_INJECTION_RATE, 1)} MCF/D.");
        }

        if (_valveDesignResult != null)
        {
            parts.Add($"Valve design projects {_valveDesignResult.EXPECTED_PRODUCTION_RATE.ToString("N1")} BBL/D using {_valveDesignResult.TOTAL_GAS_INJECTION_RATE.ToString("N1")} MCF/D total injection.");
        }

        return string.Join(" ", parts);
    }

    private string GetGasLiftRecommendationImpactText()
    {
        return "Workflow handoff: compare this gas-lift candidate against the current production gap before intervention planning.";
    }

    private Severity GetGasLiftRecommendationSeverity()
    {
        if (_valveDesignResult != null)
            return Severity.Success;

        if (_potentialResult?.MAXIMUM_PRODUCTION_RATE > 0)
            return Severity.Info;

        return Severity.Warning;
    }

    private string GetWellPerformanceUrl()
    {
        var wellId = !string.IsNullOrWhiteSpace(_designWellUWI) ? _designWellUWI : _wellUWI;
        return string.IsNullOrWhiteSpace(wellId)
            ? "/production/well-performance"
            : $"/production/well-performance?wellId={Uri.EscapeDataString(wellId)}";
    }

    private static string FormatNullableDecimal(decimal? value, int decimals = 1)
    {
        return value.HasValue ? value.Value.ToString($"N{decimals}") : "N/A";
    }
}

