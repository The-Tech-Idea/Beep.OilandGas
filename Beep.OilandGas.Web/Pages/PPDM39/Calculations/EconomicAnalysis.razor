@page "/ppdm39/calculations/economicanalysis"
@using Beep.OilandGas.Models.Data.Accounting
@using Beep.OilandGas.Models.Data.EconomicAnalysis
@inject ICalculationServiceClient CalculationServiceClient
@inject ISnackbar Snackbar
@inject ApiClient ApiClient
@inject IAccountingServiceClient AccountingClient
@inject ILifeCycleService LifeCycleService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Run Economic Analysis</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Run Economic Analysis</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — NPV, IRR and cash-flow projections</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Info" Icon="@Icons.Material.Filled.Calculate">Economics</MudChip>
            </MudStack>
        </MudStack>
    </MudStack>

    <MudGrid>
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-4">NPV Calculation</MudText>
                <MudStack Spacing="3">
                    <MudNumericField @bind-Value="@_discountRate" Label="Discount Rate (%)" Variant="Variant.Outlined" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CalculateNPV" Disabled="@_isCalculating">
                        Calculate NPV
                    </MudButton>
                    @if (_npv.HasValue)
                    {
                        <MudAlert Severity="Severity.Success">NPV: $@_npv.Value.ToString("N2")</MudAlert>
                    }
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-4">IRR Calculation</MudText>
                <MudStack Spacing="3">
                    <MudNumericField @bind-Value="@_initialGuess" Label="Initial Guess (%)" Variant="Variant.Outlined" />
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="CalculateIRR" Disabled="@_isCalculating">
                        Calculate IRR
                    </MudButton>
                    @if (_irr.HasValue)
                    {
                        <MudAlert Severity="Severity.Success">IRR: @(_irr.Value * 100).ToString("F2")%</MudAlert>
                    }
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudPaper Class="pa-4 mt-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
            <MudText Typo="Typo.h6">Comprehensive Economic Analysis</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="PerformComprehensiveAnalysis" Disabled="@_isCalculating">
                Perform Analysis
            </MudButton>
        </MudStack>

        @if (_economicResult != null)
        {
            <MudStack Spacing="2">
                <MudText>NPV: $@_economicResult.NPV.ToString("N2")</MudText>
                <MudText>IRR: @(_economicResult.IRR * 100).ToString("F2")%</MudText>
                <MudText>Payback Period: @_economicResult.PaybackPeriod.ToString("F2") years</MudText>
            </MudStack>
        }
    </MudPaper>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mt-4" />
    }
</MudContainer>

@code {
    private string _fieldName = string.Empty;
    private double _discountRate = 10.0;
    private double _initialGuess = 10.0;
    private bool _isCalculating = false;
    private bool _isLoading = false;
    private double? _npv;
    private double? _irr;
    private EconomicResult? _economicResult;
    private CashFlow[] _cashFlows = Array.Empty<CashFlow>();
    private string? _currentUserId;

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        try
        {
            try
            {
                var summary = await LifeCycleService.GetFieldLifecycleSummaryAsync();
                if (summary != null)
                    _fieldName = summary.FieldName ?? _fieldName;
            }
            catch { /* field name is non-critical */ }

            try
            {
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                _currentUserId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "system";

                var summary = await AccountingClient.GetProductionSummaryAsync();
                if (summary != null && summary.NetRevenue > 0)
                {
                    // Net revenue covers last 6 months; annualise and build a 5-year project model
                    var annualRevenue = (double)(summary.NetRevenue * 2);
                    var annualOpex    = annualRevenue * 0.30;
                    var annualNcf     = annualRevenue - annualOpex;
                    var capex         = annualRevenue * 3.0;  // 3-year payback estimate

                    _cashFlows = new CashFlow[]
                    {
                        new CashFlow { Period = 0, Amount = -capex },
                        new CashFlow { Period = 1, Amount = annualNcf },
                        new CashFlow { Period = 2, Amount = annualNcf * 0.90 },
                        new CashFlow { Period = 3, Amount = annualNcf * 0.81 },
                        new CashFlow { Period = 4, Amount = annualNcf * 0.73 },
                        new CashFlow { Period = 5, Amount = annualNcf * 0.66 },
                    };
                }
            }
            catch (Exception)
            {
                Snackbar.Add("Error loading production data.", Severity.Warning);
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task CalculateNPV()
    {
        if (_cashFlows.Length == 0)
        {
            Snackbar.Add("Please provide cash flows", Severity.Warning);
            return;
        }

        _isCalculating = true;
        try
        {
            _npv = await CalculationServiceClient.CalculateNPVAsync(_cashFlows, _discountRate);
        }
        catch (Exception)
        {
            Snackbar.Add("Error calculating NPV.", Severity.Error);
        }
        finally
        {
            _isCalculating = false;
        }
    }

    private async Task CalculateIRR()
    {
        if (_cashFlows.Length == 0)
        {
            Snackbar.Add("Please provide cash flows", Severity.Warning);
            return;
        }

        _isCalculating = true;
        try
        {
            _irr = await CalculationServiceClient.CalculateIRRAsync(_cashFlows, _initialGuess);
        }
        catch (Exception)
        {
            Snackbar.Add("Error calculating IRR.", Severity.Error);
        }
        finally
        {
            _isCalculating = false;
        }
    }

    private async Task PerformComprehensiveAnalysis()
    {
        if (_cashFlows.Length == 0)
        {
            Snackbar.Add("Please provide cash flows", Severity.Warning);
            return;
        }

        _isCalculating = true;
        try
        {
            _economicResult = await CalculationServiceClient.AnalyzeEconomicAsync(_cashFlows, _discountRate);

            var analysisId = Guid.NewGuid().ToString();
            var saved = await CalculationServiceClient.SaveEconomicAnalysisResultAsync(analysisId, _economicResult, _currentUserId);
            if (saved)
            {
                Snackbar.Add("Economic analysis completed and saved", Severity.Success);
            }
            else
            {
                Snackbar.Add("Economic analysis completed, but saving failed.", Severity.Warning);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Error performing economic analysis.", Severity.Error);
        }
        finally
        {
            _isCalculating = false;
        }
    }
}

