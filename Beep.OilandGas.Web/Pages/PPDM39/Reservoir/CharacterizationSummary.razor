@page "/reservoir/characterization"
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject ApiClient ApiClient

<PageTitle>Characterise Reservoir Properties</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @if (_loading) { <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" /> }

    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Characterise Reservoir Properties</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Integrated geological &amp; petrophysical summary</MudText>
        </MudStack>
        <MudStack Row="true" Spacing="2">
            <MudChip T="string" Color="Color.Info" Size="Size.Small">Last Update: @_lastUpdate</MudChip>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Download"
                       OnClick="ExportReport">
                Export Report
            </MudButton>
        </MudStack>
    </MudStack>

    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" Class="mb-4">

        @* Tab 1: Structural *@
        <MudTabPanel Text="Structural" Icon="@Icons.Material.Filled.Layers">
            <MudGrid Class="pa-4" Spacing="3">
                <MudItem xs="12" md="6">
                    <MudCard Elevation="1">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle1">Depth Structure Map</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudPaper Elevation="0" Class="pa-8 d-flex align-center justify-center og-placeholder-panel--dashed">
                                <MudStack AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.Map" Size="Size.Large" Color="Color.Secondary" />
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Depth map renders from simulation model</MudText>
                                    <MudButton Size="Size.Small" Variant="Variant.Outlined"
                                               OnClick='@(() => Snackbar.Add("Opening simulation viewer...", Severity.Info))'>
                                        Open Sim Viewer
                                    </MudButton>
                                </MudStack>
                            </MudPaper>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudCard Elevation="1">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle1">Structural Parameters</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudDataGrid T="StructParam" Items="@_structuralParams" Dense="true" Hover="true">
                                <Columns>
                                    <PropertyColumn Property="p => p.Label" Title="Parameter" />
                                    <PropertyColumn Property="p => p.Value" Title="Value" />
                                    <PropertyColumn Property="p => p.Unit" Title="Unit" />
                                </Columns>
                            </MudDataGrid>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        @* Tab 2: Petrophysics *@
        <MudTabPanel Text="Petrophysics" Icon="@Icons.Material.Filled.StackedBarChart">
            <MudGrid Class="pa-4" Spacing="3">
                <MudItem xs="12" md="8">
                    <MudCard Elevation="1">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle1">Porosity &amp; Permeability Cross-Plot</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudAlert Severity="Severity.Info" Dense="true">Petrophysics cross-plot will render once zone-level log data is available.</MudAlert>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudCard Elevation="1">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle1">Petrophysical Cutoffs</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudStack Spacing="1">
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="og-label-xs">Parameter</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Cutoff</MudText>
                                </MudStack>
                                <MudDivider />
                                <MudStack Row="true" Spacing="2">
                                    <MudText Typo="Typo.body2" Class="og-label-xs">Porosity</MudText>
                                    <MudText Typo="Typo.body2">&gt; 8%</MudText>
                                </MudStack>
                                <MudStack Row="true" Spacing="2">
                                    <MudText Typo="Typo.body2" Class="og-label-xs">Vsh</MudText>
                                    <MudText Typo="Typo.body2">&lt; 50%</MudText>
                                </MudStack>
                                <MudStack Row="true" Spacing="2">
                                    <MudText Typo="Typo.body2" Class="og-label-xs">Sw</MudText>
                                    <MudText Typo="Typo.body2">&lt; 65%</MudText>
                                </MudStack>
                                <MudStack Row="true" Spacing="2">
                                    <MudText Typo="Typo.body2" Class="og-label-xs">Net/Gross</MudText>
                                    <MudText Typo="Typo.body2">&gt; 0.35</MudText>
                                </MudStack>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        @* Tab 3: Fluid *@
        <MudTabPanel Text="Fluid Properties" Icon="@Icons.Material.Filled.Water">
            <MudGrid Class="pa-4" Spacing="3">
                <MudItem xs="12" md="6">
                    <MudCard Elevation="1">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle1">PVT Data Summary</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudDataGrid T="PvtEntry" Items="@_pvtData" Dense="true" Hover="true">
                                <Columns>
                                    <PropertyColumn Property="p => p.Pressure" Title="Pressure (psi)" Format="N0" />
                                    <PropertyColumn Property="p => p.Bo"       Title="Bo (RB/STB)" Format="N3" />
                                    <PropertyColumn Property="p => p.Rs"       Title="Rs (scf/STB)" Format="N0" />
                                    <PropertyColumn Property="p => p.Uo"       Title="µo (cp)" Format="N2" />
                                    <PropertyColumn Property="p => p.Bg"       Title="Bg (RCF/SCF)" Format="N4" />
                                </Columns>
                            </MudDataGrid>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudCard Elevation="1">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle1">Formation Volume Factor (Bo)</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudAlert Severity="Severity.Info" Dense="true">Bo vs. pressure chart will render once PVT laboratory data is entered.</MudAlert>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        @* Tab 4: Well Correlation *@
        <MudTabPanel Text="Well Correlation" Icon="@Icons.Material.Filled.LinearScale">
            <MudGrid Class="pa-4" Spacing="3">
                <MudItem xs="12">
                    <MudCard Elevation="1">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle1">Stratigraphic Correlation Panel</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudDataGrid T="CorrelationEntry" Items="@_correlations" Dense="true" Hover="true" Striped="true">
                                <Columns>
                                    <PropertyColumn Property="c => c.WellId"    Title="Well" />
                                    <PropertyColumn Property="c => c.TopDepth"  Title="Top (ft ss)" Format="N0" />
                                    <PropertyColumn Property="c => c.BaseDepth" Title="Base (ft ss)" Format="N0" />
                                    <PropertyColumn Property="c => c.NetPay"    Title="Net Pay (ft)" Format="N0" />
                                    <PropertyColumn Property="c => c.Porosity"  Title="Avg Por %" Format="N1" />
                                    <PropertyColumn Property="c => c.Fluid"     Title="Fluid" />
                                    <TemplateColumn Title="Quality">
                                        <CellTemplate>
                                            <StatusBadge Status="@context.Item.Quality" />
                                        </CellTemplate>
                                    </TemplateColumn>
                                </Columns>
                            </MudDataGrid>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

    </MudTabs>

</MudContainer>

@code {
    private string _fieldName = string.Empty;
    private string _lastUpdate = DateTime.UtcNow.ToString("dd MMM yyyy");
    private bool _loading = true;

    private record StructParam(string Label, string Value, string Unit);
    private List<StructParam> _structuralParams = new()
    {
        new("Closure Area",      "—", "acres"),
        new("Structural Relief", "—", "ft"),
        new("Dip Angle",         "—", "degrees"),
        new("Fault System",      "—", "type"),
        new("Trap Style",        "—", ""),
        new("GRV",               "—", "MM cu ft"),
    };

    private record PvtEntry(double Pressure, double Bo, double Rs, double Uo, double Bg);
    private List<PvtEntry> _pvtData = new();

    private record CorrelationEntry(string WellId, double TopDepth, double BaseDepth, double NetPay,
        double Porosity, string Fluid, string Quality);
    private List<CorrelationEntry> _correlations = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summary = await ApiClient.GetAsync<FieldLifecycleSummary>("/api/field/current/summary");
            if (summary != null)
                _fieldName = summary.FieldName ?? _fieldName;
        }
        catch { /* field name is non-critical */ }

        _loading = true;
        try
        {
            var wells = await ApiClient.GetAsync<List<WellDto>>("api/field/current/development/wells") ?? new();            if (wells != null)
                _correlations = wells.Select(w => new CorrelationEntry(
                    w.UWI ?? "Unknown",
                    0,
                    (double)(w.FINAL_TD ?? 0),
                    0,
                    0,
                    "Oil",
                    w.ACTIVE_IND == "Y" ? "COMPLETE" : "IN PROGRESS")).ToList();
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to load well data.", Severity.Warning);
        }
        finally { _loading = false; }
    }

    private class WellDto
    {
        public string?  UWI        { get; set; }
        public string?  WELL_NAME  { get; set; }
        public decimal? FINAL_TD   { get; set; }
        public string?  ACTIVE_IND { get; set; }
    }

    private void ExportReport() =>
        Snackbar.Add("Characterization report export queued", Severity.Success);
}
