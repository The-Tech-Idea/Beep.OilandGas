@page "/reservoir"
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject ILifeCycleService LifeCycleService
@inject IProductionServiceClient ProductionServiceClient
@using Beep.OilandGas.Models.Data.Production

<PageTitle>Review Reservoir Performance</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @* Header *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Review Reservoir Performance</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Active Field: @_fieldName</MudText>
        </MudStack>
        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Science"
                       OnClick='@(() => NavigationManager.NavigateTo("/reservoir/eor"))'>
                EOR Screening
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.BarChart"
                       OnClick='@(() => NavigationManager.NavigateTo("/reservoir/reserves"))'>
                Classify Reserves
            </MudButton>
        </MudStack>
    </MudStack>

    @* KPI Row *@
    <MudGrid Class="mb-4" Spacing="3">
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="OOIP" Value="@(_summary?.OoipMmbbl > 0 ? _summary.OoipMmbbl.ToString("N0") : "\u2014")" Unit="MMBbl"
                     ValueColor="Color.Primary" Icon="@Icons.Material.Filled.Layers" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Recovery Factor" Value="@(_summary?.RecoveryFactorPct > 0 ? _summary.RecoveryFactorPct.ToString("N1") : "\u2014")" Unit="%"
                     ValueColor="Color.Success" Icon="@Icons.Material.Filled.Percent" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="2P Reserves" Value="@(_summary?.Reserves2PMmbbl > 0 ? _summary.Reserves2PMmbbl.ToString("N1") : "\u2014")" Unit="MMBbl"
                     ValueColor="Color.Info" Icon="@Icons.Material.Filled.Inventory" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Active Pools" Value="@(_summary?.ActivePoolCount.ToString() ?? "\u2014")" Unit="pools"
                     ValueColor="Color.Warning" Icon="@Icons.Material.Filled.Layers" />
        </MudItem>
    </MudGrid>

    <MudGrid Spacing="3">

        @* Reservoir zones *@
        <MudItem xs="12" md="7">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1">Reservoir Zones</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudButton Size="Size.Small" Variant="Variant.Text"
                                   OnClick='@(() => NavigationManager.NavigateTo("/reservoir/characterization"))'>
                            Full Characterization
                        </MudButton>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    @if (_loading)
                    {
                        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                    }
                    else if (_pools.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-3">No pools found for the active field.</MudText>
                    }
                    else
                    {
                        <MudDataGrid T="ReservoirPoolDto" Items="@_pools" Dense="true" Hover="true" Striped="true">
                            <Columns>
                                <PropertyColumn Property="p => p.PoolId"    Title="Pool ID" />
                                <PropertyColumn Property="p => p.PoolName"  Title="Pool Name" />
                                <PropertyColumn Property="p => p.Formation" Title="Formation" />
                                <TemplateColumn Title="Status">
                                    <CellTemplate>
                                        <StatusBadge Status="@context.Item.Status" />
                                    </CellTemplate>
                                </TemplateColumn>
                            </Columns>
                        </MudDataGrid>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        @* Pressure support & depletion *@
        <MudItem xs="12" md="5">
            <MudStack Spacing="3">

                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.subtitle1">Pressure Depletion</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Pressure depletion history requires PDEN data. Connect production test records to view pressure trends over time.
                        </MudText>
                    </MudCardContent>
                </MudCard>

                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.subtitle1">Drive Mechanism</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Drive mechanism analysis requires reservoir simulation data. Run EOR Screening to assess drive types for this field.
                        </MudText>
                    </MudCardContent>
                </MudCard>

            </MudStack>
        </MudItem>

        @* Fluid contacts & PVT summary *@
        <MudItem xs="12" md="5">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1">Fluid Contacts &amp; PVT</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Fluid contact and PVT data is managed in the Well Test module. Record PVT analyses to populate this view.
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        @* Simulation model status *@
        <MudItem xs="12" md="7">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1">Model &amp; Study Status</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-3">
                        Simulation model and study records are tracked in the Reservoir Characterization module.
                    </MudText>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" Class="ma-2"
                               OnClick='@(() => NavigationManager.NavigateTo("/reservoir/characterization"))'>
                        Open Characterization
                    </MudButton>
                </MudCardContent>
            </MudCard>
        </MudItem>

    </MudGrid>
</MudContainer>

@code {
    private string _fieldName = string.Empty;
    private bool _loading = true;

    private ReservoirDashboardSummary? _summary;
    private List<ReservoirPoolDto> _pools = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summary = await LifeCycleService.GetFieldLifecycleSummaryAsync();
            if (summary != null)
                _fieldName = summary.FieldName ?? _fieldName;
        }
        catch { /* field name is non-critical */ }

        _loading = true;
        try
        {
            _summary = await ProductionServiceClient.GetReservoirDashboardSummaryAsync();
            _pools = await ProductionServiceClient.GetReservoirPoolsAsync();
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to load reservoir data.", Severity.Warning);
        }
        finally { _loading = false; }
    }

}
