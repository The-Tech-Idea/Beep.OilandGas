@page "/ppdm39/wells/compare"
@using Beep.OilandGas.Models.Data
@using Beep.OilandGas.Web.Services
@inject ApiClient ApiClient
@inject ISnackbar Snackbar
@inject IClientFileExportService ExportService

<PageTitle>Compare Well Properties</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @* ─── Header ─── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Compare Well Properties</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Side-by-side well attribute comparison</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Primary"
                         Icon="@Icons.Material.Filled.CompareArrows">Well</MudChip>
            </MudStack>
        </MudStack>
        <MudButton Variant="Variant.Outlined" Color="Color.Default"
                   StartIcon="@Icons.Material.Filled.Download"
                   OnClick="ExportComparisonAsync"
                   Disabled="@(_comparison == null)">
            Export
        </MudButton>
    </MudStack>

    @* ─── UWI Input ─── *@
    <MudCard Elevation="1" Class="mb-4">
        <MudCardContent>
            <MudGrid Spacing="2">
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_well1Uwi" Label="Well 1 UWI" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_well2Uwi" Label="Well 2 UWI" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_well3Uwi" Label="Well 3 UWI (Optional)" Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.CompareArrows"
                       OnClick="PerformComparison"
                       Disabled="@_isLoading" Class="mt-3">Compare Wells</MudButton>
        </MudCardContent>
    </MudCard>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }

    @* ─── Results Grid ─── *@
    @if (_comparison != null)
    {
        <ComparisonGridCard TItem="ComparisonField"
                            Items="@_comparison.ComparisonFields"
                            Title="Comparison Results"
                            TitleTypo="Typo.h6">
            <ColumnContent>
                <PropertyColumn T="ComparisonField" TProperty="string" Property="f => f.DisplayLabel" Title="Field" />
                @foreach (var well in _comparison.Wells)
                {
                    var w = well;
                    <TemplateColumn T="ComparisonField" Title="@w.WellName">
                        <CellTemplate>
                            <MudText Typo="Typo.body2">
                                @(w.FieldValues.ContainsKey(context.Item.FieldName)
                                    ? w.FieldValues[context.Item.FieldName]?.ToString() ?? "—"
                                    : "—")
                            </MudText>
                        </CellTemplate>
                    </TemplateColumn>
                }
                <TemplateColumn T="ComparisonField" Title="Differences">
                    <CellTemplate>
                        <MudChip T="string" Size="Size.Small"
                                 Color="@(context.Item.HasDifferences ? Color.Warning : Color.Success)">
                            @(context.Item.HasDifferences ? "Different" : "Same")
                        </MudChip>
                    </CellTemplate>
                </TemplateColumn>
            </ColumnContent>
        </ComparisonGridCard>
    }

</MudContainer>

@code {
    private string _fieldName = string.Empty;
    private string _well1Uwi = string.Empty;
    private string _well2Uwi = string.Empty;
    private string _well3Uwi = string.Empty;
    private WellComparisonData? _comparison;
    private bool _isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summary = await ApiClient.GetAsync<FieldLifecycleSummary>("/api/field/current/summary");
            if (summary != null)
                _fieldName = summary.FieldName ?? _fieldName;
        }
        catch { /* field name is non-critical */ }
    }

    private async Task PerformComparison()
    {
        var wellIdentifiers = new List<string>();
        if (!string.IsNullOrWhiteSpace(_well1Uwi)) wellIdentifiers.Add(_well1Uwi);
        if (!string.IsNullOrWhiteSpace(_well2Uwi)) wellIdentifiers.Add(_well2Uwi);
        if (!string.IsNullOrWhiteSpace(_well3Uwi)) wellIdentifiers.Add(_well3Uwi);

        if (wellIdentifiers.Count < 2)
        {
            Snackbar.Add("Please enter at least 2 UWIs to compare", Severity.Warning);
            return;
        }

        _isLoading = true;
        try
        {
            var request = new { WellIdentifiers = wellIdentifiers, FieldNames = (List<string>?)null };
            _comparison = await ApiClient.PostAsync<object, WellComparisonData>("/api/well/compare", request);
            
            if (_comparison != null)
            {
                Snackbar.Add($"Compared {_comparison.Wells.Count} wells", Severity.Success);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Error comparing wells.", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ExportComparisonAsync()
    {
        if (_comparison == null)
        {
            Snackbar.Add("Run a comparison before exporting.", Severity.Warning);
            return;
        }

        var payload = new
        {
            ExportType = "WellComparisonPackage",
            ExportedAtUtc = DateTime.UtcNow,
            FieldName = _fieldName,
            RequestedWells = new[] { _well1Uwi, _well2Uwi, _well3Uwi }
                .Where(value => !string.IsNullOrWhiteSpace(value))
                .ToArray(),
            Wells = _comparison.Wells.Select(well => new
            {
                well.WellIdentifier,
                well.WellName,
                well.DataSource,
                FieldValues = well.FieldValues.ToDictionary(entry => entry.Key, entry => entry.Value?.ToString())
            }).ToList(),
            ComparisonFields = _comparison.ComparisonFields.Select(field => new
            {
                field.FieldName,
                field.DisplayLabel,
                field.HasDifferences
            }).ToList()
        };

        await ExportService.DownloadJsonAsync($"well-comparison-{DateTime.UtcNow:yyyyMMdd-HHmmss}", payload);
        Snackbar.Add("Well comparison package exported.", Severity.Success);
    }
}

