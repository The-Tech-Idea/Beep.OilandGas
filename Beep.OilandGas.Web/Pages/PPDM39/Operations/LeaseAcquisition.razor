@page "/ppdm39/operations/leaseacquisition"
@using Beep.OilandGas.Models.Data.Lease
@using Beep.OilandGas.Client.App
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IOperationsServiceClient OperationsService
@inject ApiClient ApiClient
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Manage Lease Acquisitions</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @* ─── Header *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Manage Lease Acquisitions</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Lease portfolio</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                         Icon="@Icons.Material.Filled.Assignment">Operations</MudChip>
            </MudStack>
        </MudStack>
        <MudButton Variant="Variant.Filled" Color="Color.Warning"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenCreateDialog">Create Lease Acquisition</MudButton>
    </MudStack>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }

    @* ─── KPI Row *@
    <MudGrid Class="mb-4" Spacing="3">
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Total Leases" Value="@((_leases?.Count ?? 0).ToString())"
                     ValueColor="Color.Primary" Icon="@Icons.Material.Filled.Assignment"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default"
                     TrendText="All lease records" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Active"
                     Value="@((_leases?.Count(l => l.Status == "Active" || l.Status == "ACTIVE") ?? 0).ToString())"
                     ValueColor="Color.Success" Icon="@Icons.Material.Filled.CheckCircle"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default"
                     TrendText="Active leases" />
        </MudItem>
    </MudGrid>

    @* ─── Leases Grid *@
    <MudCard Elevation="2">
        <MudCardContent Class="pa-0">
            @if (_leases != null && _leases.Any())
            {
                <MudDataGrid T="LeaseSummary" Items="@_leases" Dense="true" Hover="true" Striped="true"
                             SortMode="SortMode.Multiple" Filterable="true">
                    <Columns>
                        <PropertyColumn Property="l => l.LeaseNumber" Title="Lease Number" />
                        <PropertyColumn Property="l => l.LeaseName" Title="Lease Name" />
                        <TemplateColumn Title="Status">
                            <CellTemplate>
                                <StatusBadge Status="@(context.Item.Status ?? "Unknown")" />
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="" Sortable="false">
                            <CellTemplate>
                                <MudStack Row="true" Spacing="1">
                                    <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Info"
                                               StartIcon="@Icons.Material.Filled.Info"
                                               OnClick="@(() => EvaluateLease(context.Item.LeaseId))">Evaluate</MudButton>
                                    <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Warning"
                                               StartIcon="@Icons.Material.Filled.Edit"
                                               OnClick="@(() => UpdateLeaseStatus(context.Item.LeaseId))">Update Status</MudButton>
                                </MudStack>
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                    <NoRecordsContent>
                        <MudStack AlignItems="AlignItems.Center" Class="pa-6">
                            <MudIcon Icon="@Icons.Material.Filled.Assignment" Color="Color.Secondary" Class="og-icon-xl" />
                            <MudText Typo="Typo.body1">No leases match the current filter</MudText>
                        </MudStack>
                    </NoRecordsContent>
                </MudDataGrid>
            }
            else if (!_isLoading)
            {
                <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                    <MudIcon Icon="@Icons.Material.Filled.Assignment" Color="Color.Secondary" Class="og-icon-xl" />
                    <MudText Typo="Typo.h6">No leases found</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Create the first lease acquisition for this field.</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Warning"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="OpenCreateDialog" Class="mt-2">Create Lease Acquisition</MudButton>
                </MudStack>
            }
        </MudCardContent>
    </MudCard>

</MudContainer>

@code {
    private string _fieldName = string.Empty;
    private List<LeaseSummary>? _leases;
    private bool _isLoading = false;
    private string? _currentUserId;

    private sealed class FieldResponse
    {
        public string? FieldId { get; set; }
        public string? FieldName { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _currentUserId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "system";

        try
        {
            var field = await ApiClient.GetAsync<FieldResponse>("api/field/current");
            if (field != null)
                _fieldName = field.FieldName ?? string.Empty;
        }
        catch { /* field name is cosmetic; swallow */ }

        await LoadLeases();
    }

    private async Task LoadLeases()
    {
        _isLoading = true;
        try
        {
            _leases = await OperationsService.GetAvailableLeasesAsync();
        }
        catch (Exception)
        {
            Snackbar.Add("Error loading leases.", Severity.Error);
            _leases = new List<LeaseSummary>();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OpenCreateDialog()
    {
        // Create lease acquisition using service client
        try
        {
            var leaseRequest = new CreateLeaseAcquisition
            {
                PropertyId = Guid.NewGuid().ToString(), // Would come from dialog
                LeaseNumber = "L-" + DateTime.Now.ToString("yyyyMMdd"),
                LeaseName = "New Lease",
                EffectiveDate = DateTime.Now,
                ExpirationDate = DateTime.Now.AddYears(5),
                WorkingInterest = 100,
                NetRevenueInterest = 75,
                RoyaltyRate = 12.5m
            };

            var leaseId = await OperationsService.CreateLeaseAcquisitionAsync(leaseRequest, _currentUserId);
            Snackbar.Add("Lease acquisition created successfully", Severity.Success);
            await LoadLeases();
        }
        catch (Exception)
        {
            Snackbar.Add("Error creating lease acquisition.", Severity.Error);
        }
    }

    private async Task EvaluateLease(string leaseId)
    {
        try
        {
            var evaluation = await OperationsService.EvaluateLeaseAsync(leaseId);
            Snackbar.Add($"Lease evaluation completed for {evaluation.LeaseName}", Severity.Success);
        }
        catch (Exception)
        {
            Snackbar.Add("Error evaluating lease.", Severity.Error);
        }
    }

    private async Task UpdateLeaseStatus(string leaseId)
    {
        var result = await DialogService.ShowMessageBoxAsync(
            "Update Lease Status",
            "Enter new status:",
            yesText: "Update", cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                var updated = await OperationsService.UpdateLeaseStatusAsync(leaseId, "Active", _currentUserId);
                if (updated)
                {
                    Snackbar.Add("Lease status updated successfully", Severity.Success);
                    await LoadLeases();
                }
                else
                {
                    Snackbar.Add("Failed to update lease status", Severity.Warning);
                }
            }
            catch (Exception)
            {
                Snackbar.Add("Error updating lease status.", Severity.Error);
            }
        }
    }
}

