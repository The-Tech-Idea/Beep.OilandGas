@page "/ppdm39/properties/heatmap"
@using Beep.OilandGas.HeatMap
@using Beep.OilandGas.Models.Data
@using Beep.OilandGas.Models.Data.HeatMap
@using Beep.OilandGas.Client.App
@inject ISnackbar Snackbar
@inject IPropertiesServiceClient PropertiesService
@inject ApiClient ApiClient
@inject ILifeCycleService LifeCycleService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Generate Field Heat Map</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Generate Field Heat Map</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Spatial property visualisation from data points</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Icon="@Icons.Material.Filled.Map">Visualisation</MudChip>
            </MudStack>
        </MudStack>
    </MudStack>

    <MudGrid>
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-4">Generate Heat Map from Data Points</MudText>
                <MudStack Spacing="3">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GenerateHeatMap" Disabled="@_isGenerating">
                        Generate Heat Map
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-4">Generate Production Heat Map</MudText>
                <MudStack Spacing="3">
                    <MudTextField @bind-Value="@_fieldId" Label="Field ID" Variant="Variant.Outlined" />
                    <MudDatePicker @bind-Date="@_startDate" Label="Start Date" Variant="Variant.Outlined" />
                    <MudDatePicker @bind-Date="@_endDate" Label="End Date" Variant="Variant.Outlined" />
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="GenerateProductionHeatMap" Disabled="@_isGenerating">
                        Generate Production Heat Map
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mt-4" />
    }

    @if (_heatMapResult != null)
    {
        <MudPaper Class="pa-4 mt-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-4">Heat Map Generated</MudText>
            <MudAlert Severity="Severity.Success">Heat map has been generated successfully.</MudAlert>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4" OnClick="SaveConfiguration">
                Save Configuration
            </MudButton>
        </MudPaper>
    }
</MudContainer>

@code {
    private string _fieldName = string.Empty;
    private string _fieldId = string.Empty;
    private DateTime? _startDate = DateTime.Now.AddMonths(-6);
    private DateTime? _endDate = DateTime.Now;
    private bool _isGenerating = false;
    private bool _isLoading = false;
    private HeatMapResult? _heatMapResult;
    private string? _currentUserId;

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            _currentUserId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "system";

            var field = await LifeCycleService.GetCurrentFieldAsync();
            if (field != null)
            {
                _fieldId = field.FieldId ?? string.Empty;
                _fieldName = field.FieldName ?? string.Empty;
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Error loading field.", Severity.Warning);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task GenerateHeatMap()
    {
        if (string.IsNullOrEmpty(_fieldId))
        {
            Snackbar.Add("No active field loaded. Please set an active field first.", Severity.Warning);
            return;
        }

        if (!_startDate.HasValue || !_endDate.HasValue)
        {
            Snackbar.Add("Please select start and end dates", Severity.Warning);
            return;
        }

        _isGenerating = true;
        try
        {
            _heatMapResult = await PropertiesService.GenerateProductionHeatMapAsync(
                _fieldId, _startDate.Value, _endDate.Value);
            Snackbar.Add("Heat map generated successfully", Severity.Success);
        }
        catch (Exception)
        {
            Snackbar.Add("Error generating heat map.", Severity.Error);
        }
        finally
        {
            _isGenerating = false;
        }
    }

    private async Task GenerateProductionHeatMap()
    {
        if (string.IsNullOrEmpty(_fieldId))
        {
            Snackbar.Add("Please enter a Field ID", Severity.Warning);
            return;
        }

        if (!_startDate.HasValue || !_endDate.HasValue)
        {
            Snackbar.Add("Please select start and end dates", Severity.Warning);
            return;
        }

        _isGenerating = true;
        try
        {
            _heatMapResult = await PropertiesService.GenerateProductionHeatMapAsync(_fieldId, _startDate.Value, _endDate.Value);
            Snackbar.Add("Production heat map generated successfully", Severity.Success);
        }
        catch (Exception)
        {
            Snackbar.Add("Error generating production heat map.", Severity.Error);
        }
        finally
        {
            _isGenerating = false;
        }
    }

    private async Task SaveConfiguration()
    {
        try
        {
            var configuration = new HeatMapConfigurationRecord
            {
                ConfigurationId = Guid.NewGuid().ToString(),
                ConfigurationName = $"Production Heat Map — {_fieldName}"
            };

            var heatMapId = await PropertiesService.SaveHeatMapConfigurationAsync(configuration, _currentUserId);
            Snackbar.Add("Heat map configuration saved successfully", Severity.Success);
        }
        catch (Exception)
        {
            Snackbar.Add("Error saving configuration.", Severity.Error);
        }
    }
}


