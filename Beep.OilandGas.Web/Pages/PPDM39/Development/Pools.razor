@page "/ppdm39/development/pools"
@using Beep.OilandGas.PPDM39.Models
@inject ApiClient ApiClient
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Plan Reservoir Development Pools</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @* ── Header ──────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Plan Reservoir Development Pools</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Pool inventory</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                         Icon="@Icons.Material.Filled.Construction">Development</MudChip>
            </MudStack>
        </MudStack>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog">
            Add Pool
        </MudButton>
    </MudStack>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }

    @* ── KPI Row ─────────────────────────────────────────────────────── *@
    <MudGrid Class="mb-4" Spacing="3">
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Total Pools" Value="@((_pools?.Count ?? 0).ToString())"
                     ValueColor="Color.Primary" Icon="@Icons.Material.Filled.Layers"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default"
                     TrendText="All pools" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Active"
                     Value="@((_pools?.Count(p => GetPropertyValue(p, "POOL_STATUS") == "ACTIVE") ?? 0).ToString())"
                     ValueColor="Color.Success" Icon="@Icons.Material.Filled.CheckCircle"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Success"
                     TrendText="Producing" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="In Design"
                     Value="@((_pools?.Count(p => GetPropertyValue(p, "POOL_STATUS") == "DESIGN") ?? 0).ToString())"
                     ValueColor="Color.Warning" Icon="@Icons.Material.Filled.Architecture"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Warning"
                     TrendText="Planning phase" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Inactive"
                     Value="@((_pools?.Count(p => GetPropertyValue(p, "POOL_STATUS") == "INACTIVE" || GetPropertyValue(p, "POOL_STATUS") == "ABANDONED") ?? 0).ToString())"
                     ValueColor="Color.Default" Icon="@Icons.Material.Filled.DoNotDisturb"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default"
                     TrendText="Not active" />
        </MudItem>
    </MudGrid>

    @* ── Pools Grid ──────────────────────────────────────────────────── *@
    <MudCard Elevation="2">
        <MudCardContent Class="pa-0">
            @if (_pools != null && _pools.Any())
            {
                <MudDataGrid T="POOL" Items="@_pools" Dense="true" Hover="true" Striped="true"
                             SortMode="SortMode.Multiple" Filterable="true">
                    <Columns>
                        <TemplateColumn Title="Pool ID">
                            <CellTemplate>
                                <MudText Typo="Typo.body2">@GetPropertyValue(context.Item, "POOL_ID")</MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Pool Name">
                            <CellTemplate>
                                <MudText Typo="Typo.body2" Color="Color.Primary">
                                    @GetPropertyValue(context.Item, "POOL_NAME")
                                </MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Type">
                            <CellTemplate>
                                <MudText Typo="Typo.body2">@GetPropertyValue(context.Item, "POOL_TYPE")</MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Status">
                            <CellTemplate>
                                <StatusBadge Status="@GetPropertyValue(context.Item, "POOL_STATUS")" />
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Actions" Sortable="false">
                            <CellTemplate>
                                <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Edit"
                                           OnClick="@(() => OpenEditDialog(context.Item))">
                                    Edit
                                </MudButton>
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                    <NoRecordsContent>
                        <MudStack AlignItems="AlignItems.Center" Class="pa-6">
                            <MudIcon Icon="@Icons.Material.Filled.Layers" Color="Color.Secondary"
                                     Class="og-icon-xl" />
                            <MudText Typo="Typo.body1">No pools match the current filter</MudText>
                        </MudStack>
                    </NoRecordsContent>
                </MudDataGrid>
            }
            else if (!_isLoading)
            {
                <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                    <MudIcon Icon="@Icons.Material.Filled.Layers" Color="Color.Secondary"
                             Class="og-icon-xl" />
                    <MudText Typo="Typo.h6">No pools defined</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Define the first reservoir pool for this field.
                    </MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="OpenCreateDialog" Class="mt-2">
                        Add First Pool
                    </MudButton>
                </MudStack>
            }
        </MudCardContent>
    </MudCard>

</MudContainer>

@code {
    private string _fieldName = "Current Field";
    private List<POOL>? _pools;
    private bool _isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadPools();
    }

    private async Task LoadPools()
    {
        _isLoading = true;
        try
        {
            _pools = await ApiClient.GetAsync<List<POOL>>("/api/field/current/development/pools");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading pools: {ex.Message}", Severity.Error);
            _pools = new List<POOL>();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OpenCreateDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<PoolEditDialog>("Create Pool", options);
        var result = await dialog.Result;

        if (result?.Canceled == false && result.Data is Dictionary<string, object> poolData)
        {
            try
            {
                var created = await ApiClient.PostAsync<object, Dictionary<string, object>>(
                    "/api/field/current/development/pools",
                    poolData);
                
                Snackbar.Add("Pool created successfully", Severity.Success);
                await LoadPools();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error creating pool: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task OpenEditDialog(object pool)
    {
        var poolId = GetPropertyValue(pool, "POOL_ID");
        if (string.IsNullOrEmpty(poolId))
            return;

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var parameters = new DialogParameters { ["Pool"] = pool };
        var dialog = await DialogService.ShowAsync<PoolEditDialog>("Edit Pool", parameters, options);
        var result = await dialog.Result;

        if (result?.Canceled == false && result.Data is Dictionary<string, object> poolData)
        {
            try
            {
                var updated = await ApiClient.PutAsync<object, Dictionary<string, object>>(
                    $"/api/field/current/development/pools/{poolId}",
                    poolData);
                
                Snackbar.Add("Pool updated successfully", Severity.Success);
                await LoadPools();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error updating pool: {ex.Message}", Severity.Error);
            }
        }
    }

    private string GetPropertyValue(object obj, string propertyName)
    {
        if (obj is IDictionary<string, object> dict && dict.ContainsKey(propertyName))
        {
            return dict[propertyName]?.ToString() ?? "N/A";
        }
        return "N/A";
    }
}
