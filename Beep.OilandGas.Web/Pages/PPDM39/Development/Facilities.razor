@page "/ppdm39/development/facilities"
@using Beep.OilandGas.Models.Data
@using Beep.OilandGas.PPDM39.Models
@inject ApiClient ApiClient
@inject IDevelopmentServiceClient DevelopmentServiceClient
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Manage Surface Facilities</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @* ── Header ──────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Manage Surface Facilities</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Surface facility register</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                         Icon="@Icons.Material.Filled.Factory">Development</MudChip>
            </MudStack>
        </MudStack>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog">
            Add Facility
        </MudButton>
    </MudStack>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }

    @* ── KPI Row ─────────────────────────────────────────────────────── *@
    <MudGrid Class="mb-4" Spacing="3">
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Total Facilities" Value="@((_facilities?.Count ?? 0).ToString())"
                     ValueColor="Color.Primary" Icon="@Icons.Material.Filled.Factory"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default"
                     TrendText="All facilities" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Operational"
                     Value="@((_facilities?.Count(IsOperationalFacility) ?? 0).ToString())"
                     ValueColor="Color.Success" Icon="@Icons.Material.Filled.CheckCircle"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Success"
                     TrendText="In service" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Under Construction"
                     Value="@((_facilities?.Count(IsFacilityUnderConstruction) ?? 0).ToString())"
                     ValueColor="Color.Warning" Icon="@Icons.Material.Filled.Construction"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Warning"
                     TrendText="Being built" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Decommissioned"
                     Value="@((_facilities?.Count(IsDecommissionedFacility) ?? 0).ToString())"
                     ValueColor="Color.Default" Icon="@Icons.Material.Filled.Archive"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default"
                     TrendText="No longer active" />
        </MudItem>
    </MudGrid>

    @* ── Facilities Grid ─────────────────────────────────────────────── *@
    <MudCard Elevation="2">
        <MudCardContent Class="pa-0">
            @if (_facilities != null && _facilities.Any())
            {
                <MudDataGrid T="FACILITY" Items="@_facilities" Dense="true" Hover="true" Striped="true"
                             SortMode="SortMode.Multiple" Filterable="true">
                    <Columns>
                        <TemplateColumn Title="Facility ID">
                            <CellTemplate>
                                <MudText Typo="Typo.body2">@context.Item.FACILITY_ID</MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Facility Name">
                            <CellTemplate>
                                <MudText Typo="Typo.body2" Color="Color.Primary">
                                    @GetFacilityName(context.Item)
                                </MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Type">
                            <CellTemplate>
                                <MudText Typo="Typo.body2">@context.Item.FACILITY_TYPE</MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Status">
                            <CellTemplate>
                                <StatusBadge Status="@GetFacilityStatus(context.Item)" />
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Actions" Sortable="false">
                            <CellTemplate>
                                <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Edit"
                                           OnClick="@(() => OpenEditDialog(context.Item))">
                                    Edit
                                </MudButton>
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                    <NoRecordsContent>
                        <MudStack AlignItems="AlignItems.Center" Class="pa-6">
                            <MudIcon Icon="@Icons.Material.Filled.Factory" Color="Color.Secondary"
                                     Class="og-icon-xl" />
                            <MudText Typo="Typo.body1">No facilities match the current filter</MudText>
                        </MudStack>
                    </NoRecordsContent>
                </MudDataGrid>
            }
            else if (!_isLoading)
            {
                <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                    <MudIcon Icon="@Icons.Material.Filled.Factory" Color="Color.Secondary"
                             Class="og-icon-xl" />
                    <MudText Typo="Typo.h6">No facilities registered</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Register the first surface facility for this field.
                    </MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="OpenCreateDialog" Class="mt-2">
                        Add First Facility
                    </MudButton>
                </MudStack>
            }
        </MudCardContent>
    </MudCard>

</MudContainer>

@code {
    private string _fieldName = string.Empty;
    private List<FACILITY>? _facilities;
    private bool _isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summary = await ApiClient.GetAsync<FieldLifecycleSummary>("/api/field/current/summary");
            if (summary != null)
                _fieldName = summary.FieldName ?? _fieldName;
        }
        catch { /* field name is non-critical */ }

        await LoadFacilities();
    }

    private async Task LoadFacilities()
    {
        _isLoading = true;
        try
        {
            _facilities = await DevelopmentServiceClient.GetFacilitiesAsync();
        }
        catch (Exception)
        {
            Snackbar.Add("Error loading facilities.", Severity.Error);
            _facilities = new List<FACILITY>();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OpenCreateDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<FacilityEditDialog>("Create Facility", options);
        var result = await dialog.Result;

        if (result?.Canceled == false && result.Data is Dictionary<string, object> facilityData)
        {
            try
            {
                await DevelopmentServiceClient.CreateFacilityAsync(ToFacilityRequest(facilityData));
                
                Snackbar.Add("Facility created successfully", Severity.Success);
                await LoadFacilities();
            }
            catch (Exception)
            {
                Snackbar.Add("Error creating facility.", Severity.Error);
            }
        }
    }

    private async Task OpenEditDialog(object facility)
    {
        if (facility is not FACILITY f) return;

        var parameters = new DialogParameters<FacilityEditDialog>
        {
            { d => d.Facility, new Dictionary<string, object>
                {
                    { "FACILITY_NAME",   GetFacilityName(f) },
                    { "FACILITY_TYPE",   f.FACILITY_TYPE ?? string.Empty },
                    { "FACILITY_STATUS", GetFacilityStatus(f) },
                    { "DESCRIPTION",     f.DESCRIPTION ?? string.Empty }
                }
            }
        };

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<FacilityEditDialog>("Edit Facility", parameters, options);
        var result = await dialog.Result;

        if (result?.Canceled == false && result.Data is Dictionary<string, object> updated)
        {
            try
            {
                await DevelopmentServiceClient.UpdateFacilityAsync(f.FACILITY_ID ?? string.Empty, ToFacilityRequest(updated, f));
                Snackbar.Add("Facility updated.", Severity.Success);
                await LoadFacilities();
            }
            catch (Exception)
            {
                Snackbar.Add("Error updating facility.", Severity.Error);
            }
        }
    }

    private static FacilityRequest ToFacilityRequest(Dictionary<string, object> facilityData, FACILITY? existingFacility = null)
    {
        return new FacilityRequest
        {
            FacilityId = existingFacility?.FACILITY_ID,
            FieldId = existingFacility?.PRIMARY_FIELD_ID,
            FacilityName = GetDialogValue(facilityData, "FACILITY_NAME"),
            FacilityType = GetDialogValue(facilityData, "FACILITY_TYPE"),
            Status = GetDialogValue(facilityData, "FACILITY_STATUS"),
            Description = GetDialogValue(facilityData, "DESCRIPTION")
        };
    }

    private static string GetDialogValue(Dictionary<string, object> values, string key)
    {
        return values.TryGetValue(key, out var value)
            ? value?.ToString() ?? string.Empty
            : string.Empty;
    }

    private static string GetFacilityName(FACILITY facility)
    {
        return facility.FACILITY_LONG_NAME ?? facility.FACILITY_SHORT_NAME ?? facility.FACILITY_ID ?? string.Empty;
    }

    private static string GetFacilityStatus(FACILITY facility)
    {
        if (!string.IsNullOrWhiteSpace(facility.REMARK))
        {
            return facility.REMARK;
        }

        return string.Equals(facility.ACTIVE_IND, "Y", StringComparison.OrdinalIgnoreCase)
            ? "OPERATIONAL"
            : "PLANNED";
    }

    private static bool IsOperationalFacility(FACILITY facility)
    {
        return string.Equals(GetFacilityStatus(facility), "OPERATIONAL", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsFacilityUnderConstruction(FACILITY facility)
    {
        var status = GetFacilityStatus(facility);
        return string.Equals(status, "CONSTRUCTION", StringComparison.OrdinalIgnoreCase) ||
               string.Equals(status, "DESIGN", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsDecommissionedFacility(FACILITY facility)
    {
        var status = GetFacilityStatus(facility);
        return string.Equals(status, "INACTIVE", StringComparison.OrdinalIgnoreCase) ||
               string.Equals(status, "DECOMMISSIONED", StringComparison.OrdinalIgnoreCase) ||
               string.Equals(status, "ABANDONED", StringComparison.OrdinalIgnoreCase);
    }
}
