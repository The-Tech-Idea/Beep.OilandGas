@page "/development"
@inject ApiClient ApiClient
@inject NavigationManager NavigationManager

<PageTitle>Review Development Status</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @* ── Header ──────────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Review Development Status</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Discovery to first oil — project status overview</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Icon="@Icons.Material.Filled.Construction">Development</MudChip>
            </MudStack>
        </MudStack>
        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Description"
                       OnClick='() => NavigationManager.NavigateTo("/development/fdp")'>
                View FDP
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick='() => NavigationManager.NavigateTo("/development/well-design/new")'>
                Add Well to Program
            </MudButton>
        </MudStack>
    </MudStack>

    @* ── KPI Row ─────────────────────────────────────────────────────────── *@
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="12" sm="6" md="3" lg="2">
            <MudCard Elevation="2" Class="pa-3">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="kpi-label">Project Phase</MudText>
                <MudChip T="string" Color="Color.Info" Size="Size.Medium" Class="mt-1">@_projectPhase</MudChip>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="3" lg="2">
            <KpiCard Label="Wells Drilled"
                     Value="@_wellsDrilled.ToString()"
                     Unit="@($"/ {_wellsTotal} planned")"
                     Icon="@Icons.Material.Filled.OilBarrel"
                     ValueColor="Color.Primary" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3" lg="3">
            <KpiCard Label="Schedule Progress"
                     Value="@_scheduleProgress.ToString("F0")"
                     Unit="%"
                     Icon="@Icons.Material.Filled.Schedule"
                     ValueColor="@(_scheduleProgress >= 80 ? Color.Success : _scheduleProgress >= 60 ? Color.Warning : Color.Error)" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3" lg="2">
            <KpiCard Label="Spend vs Budget"
                     Value="@_spendRatio.ToString("F0")"
                     Unit="%"
                     Icon="@Icons.Material.Filled.AttachMoney"
                     ValueColor="@(_spendRatio <= 100 ? Color.Success : Color.Error)" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3" lg="3">
            <KpiCard Label="Days to First Oil"
                     Value="@_daysToFirstOil.ToString()"
                     Unit="days"
                     Icon="@Icons.Material.Filled.DateRange"
                     ValueColor="Color.Info" />
        </MudItem>
    </MudGrid>

    <MudGrid Spacing="3">

        @* LEFT COLUMN — Milestones + Budget chart *@
        <MudItem xs="12" lg="7">
            <MudStack Spacing="3">

                @* Project Milestone Timeline *@
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.subtitle1">Project Milestones</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                           OnClick='() => NavigationManager.NavigateTo("/development/construction")'
                                           Title="Full construction tracker" />
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudTimeline TimelinePosition="TimelinePosition.Left" Class="pa-0">
                            @foreach (var m in _milestones)
                            {
                                <MudTimelineItem Color="@MilestoneColor(m)"
                                                 Icon="@MilestoneIcon(m)"
                                                 Size="Size.Small">
                                    <ItemOpposite>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@m.TargetDate</MudText>
                                    </ItemOpposite>
                                    <ItemContent>
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.body2"><strong>@m.Name</strong></MudText>
                                            @if (!string.IsNullOrEmpty(m.Note))
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@m.Note</MudText>
                                            }
                                        </MudStack>
                                    </ItemContent>
                                </MudTimelineItem>
                            }
                        </MudTimeline>
                    </MudCardContent>
                </MudCard>

                @* Budget vs Actual chart *@
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.subtitle1">Budget vs Actual (USD MM)</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudChart ChartType="ChartType.Bar"
                                  ChartSeries="@_budgetSeries"
                                  XAxisLabels="@_budgetLabels"
                                  Width="100%"
                                  Height="220px" />
                    </MudCardContent>
                </MudCard>

            </MudStack>
        </MudItem>

        @* RIGHT COLUMN — Active wells + Punch items *@
        <MudItem xs="12" lg="5">
            <MudStack Spacing="3">

                @* Active Well Programs *@
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.subtitle1">Active Well Programs</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                                       OnClick='() => NavigationManager.NavigateTo("/development/well-design")'>
                                View All
                            </MudButton>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent Class="pa-0">
                        <MudList T="DevWell" Dense="true">
                            @foreach (var w in _activeWells)
                            {
                                <MudListItem T="DevWell" Value="w"
                                             OnClick='() => NavigationManager.NavigateTo($"/development/well-design/{w.Id}")'>
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="pr-2">
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.body2"><strong>@w.WellName</strong></MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@w.Type · @w.CurrentDepthM m / @w.TargetDepthM m TD</MudText>
                                        </MudStack>
                                        <StatusBadge Status="@w.Status" Size="Size.Small" />
                                    </MudStack>
                                </MudListItem>
                                <MudDivider />
                            }
                        </MudList>
                    </MudCardContent>
                </MudCard>

                @* Open Punch Items *@
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.subtitle1">Open Action Items</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudChip T="string" Color="Color.Warning" Size="Size.Small">@_punchItems.Count open</MudChip>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent Class="pa-0">
                        <MudList T="PunchItem" Dense="true">
                            @foreach (var item in _punchItems.Take(5))
                            {
                                <MudListItem T="PunchItem" Value="item">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="pr-2">
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.body2">@item.Description</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@item.Owner · Due @item.DueDate</MudText>
                                        </MudStack>
                                        <MudChip T="string" Size="Size.Small"
                                                 Color="@(item.Priority == "High" ? Color.Error : item.Priority == "Medium" ? Color.Warning : Color.Default)">
                                            @item.Priority
                                        </MudChip>
                                    </MudStack>
                                </MudListItem>
                                <MudDivider />
                            }
                        </MudList>
                    </MudCardContent>
                </MudCard>

            </MudStack>
        </MudItem>

    </MudGrid>
</MudContainer>

@code {
    private string _fieldName = "Current Field";
    private string _projectPhase = "Execution";
    private int _wellsDrilled = 2;
    private int _wellsTotal = 6;
    private double _scheduleProgress = 68;
    private double _spendRatio = 103;
    private int _daysToFirstOil = 247;

    private List<Milestone> _milestones = new()
    {
        new("FID (Final Investment Decision)", "Mar 2024", true,  false, "Approved"),
        new("Engineering Complete",            "Sep 2024", true,  false, "Delivered on schedule"),
        new("Procurement Complete",            "Jan 2025", true,  false, ""),
        new("Fabrication Complete",            "Mar 2026", false, true,  "68% complete — on track"),
        new("Installation",                    "Aug 2026", false, false, ""),
        new("Hook-up & Commissioning",         "Nov 2026", false, false, ""),
        new("First Oil",                       "Dec 2026", false, false, "Target date"),
    };

    private List<DevWell> _activeWells = new()
    {
        new("1", "Dev-A1",  "Producer",   "DRILLING",    2_850, 3_500),
        new("2", "Dev-A2",  "Producer",   "PLANNED",     0,     3_450),
        new("3", "Dev-B1",  "Injector",   "COMPLETE",    3_200, 3_200),
    };

    private List<PunchItem> _punchItems = new()
    {
        new("Finalize manifold piping spec",       "John Smith",   "May 2026", "High"),
        new("Submit environmental permit update",  "Sarah Lee",    "Jun 2026", "High"),
        new("Review vendor inspection report",     "Mike Torres",  "May 2026", "Medium"),
        new("Update project schedule baseline",    "Anna Webb",    "Jun 2026", "Medium"),
        new("Close NCR #142 — weld repair",        "John Smith",   "Apr 2026", "High"),
        new("Issue Rev D P&ID to contractor",      "Anna Webb",    "Jul 2026", "Low"),
    };

    private List<ChartSeries<double>> _budgetSeries = new()
    {
        new ChartSeries<double> { Name = "Budget",  Data = new double[] { 45, 80, 120, 180, 250, 310 } },
        new ChartSeries<double> { Name = "Actual",  Data = new double[] { 46, 82, 118, 187, 0,   0   } },
    };
    private string[] _budgetLabels = { "Q2'24", "Q3'24", "Q4'24", "Q1'25", "Q2'25", "Q3'25" };

    private Color MilestoneColor(Milestone m) =>
        m.IsCompleted ? Color.Success : m.IsActive ? Color.Primary : Color.Default;

    private string MilestoneIcon(Milestone m) =>
        m.IsCompleted ? Icons.Material.Filled.CheckCircle
        : m.IsActive  ? Icons.Material.Filled.RadioButtonChecked
        : Icons.Material.Outlined.RadioButtonUnchecked;

    private record Milestone(string Name, string TargetDate, bool IsCompleted, bool IsActive, string Note);
    private record DevWell(string Id, string WellName, string Type, string Status, int CurrentDepthM, int TargetDepthM);
    private record PunchItem(string Description, string Owner, string DueDate, string Priority);
}
