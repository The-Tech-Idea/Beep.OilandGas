@page "/development"
@using Beep.OilandGas.Models.Data.Production
@inject ApiClient ApiClient
@inject IDevelopmentServiceClient DevelopmentServiceClient
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Review Development Status</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @* ── Header ──────────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Review Development Status</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Discovery to first oil — project status overview</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Icon="@Icons.Material.Filled.Construction">Development</MudChip>
            </MudStack>
        </MudStack>
        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Description"
                       OnClick='() => NavigationManager.NavigateTo("/development/fdp")'>
                View FDP
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick='() => NavigationManager.NavigateTo("/development/well-design/new")'>
                Add Well to Program
            </MudButton>
        </MudStack>
    </MudStack>

    @* ── KPI Row ─────────────────────────────────────────────────────────── *@
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="12" sm="6" md="3" lg="2">
            <MudCard Elevation="2" Class="pa-3">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="kpi-label">Well Summary</MudText>
                @if (_loading)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-1" />
                }
                else
                {
                    <MudChip T="string" Color="Color.Info" Size="Size.Medium" Class="mt-1">@_totalWells wells</MudChip>
                }
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="3" lg="2">
            <KpiCard Label="Drilling"
                     Value="@_drillingWells.ToString()"
                     Unit="wells"
                     Icon="@Icons.Material.Filled.OilBarrel"
                     ValueColor="Color.Primary" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3" lg="3">
            <KpiCard Label="Completed"
                     Value="@_completedWells.ToString()"
                     Unit="wells"
                     Icon="@Icons.Material.Filled.CheckCircle"
                     ValueColor="Color.Success" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3" lg="2">
            <KpiCard Label="Planned"
                     Value="@_plannedWells.ToString()"
                     Unit="wells"
                     Icon="@Icons.Material.Filled.Schedule"
                     ValueColor="Color.Default" />
        </MudItem>
    </MudGrid>

    <MudGrid Spacing="3">

        @* LEFT COLUMN — Milestones + Budget chart *@
        <MudItem xs="12" lg="7">
            <MudStack Spacing="3">

                @* Project Milestone Timeline *@
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.subtitle1">Project Milestones</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                           OnClick='() => NavigationManager.NavigateTo("/development/construction")'
                                           Title="Full construction tracker" />
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (_loading)
                        {
                            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Project milestone data is managed in the Field Development Plan. View the FDP for the full milestone schedule.</MudText>
                            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" Class="mt-2"
                                       OnClick='() => NavigationManager.NavigateTo("/development/fdp")'>
                                Open FDP
                            </MudButton>
                        }
                    </MudCardContent>
                </MudCard>

                @* Budget vs Actual chart *@
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.subtitle1">Budget vs Actual (USD MM)</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (_loading)
                        {
                            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Budget vs Actual data is available through the Accounting module. Connect to the Economics dashboard to view spend tracking.</MudText>
                        }
                    </MudCardContent>
                </MudCard>

            </MudStack>
        </MudItem>

        @* RIGHT COLUMN — Active wells + Punch items *@
        <MudItem xs="12" lg="5">
            <MudStack Spacing="3">

                @* Active Well Programs *@
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.subtitle1">Active Well Programs</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                                       OnClick='() => NavigationManager.NavigateTo("/development/well-design")'>
                                View All
                            </MudButton>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent Class="pa-0">
                        @if (_loading)
                        {
                            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                        }
                        else if (_activeWells.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-3">No development wells found for the active field.</MudText>
                        }
                        else
                        {
                            <MudList T="DevelopmentWellStatusDto" Dense="true">
                                @foreach (var w in _activeWells)
                                {
                                    <MudListItem T="DevelopmentWellStatusDto" Value="w"
                                                 OnClick='() => NavigationManager.NavigateTo($"/development/well-design/{Uri.EscapeDataString(w.WellId)}")'>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="pr-2">
                                            <MudStack Spacing="0">
                                                <MudText Typo="Typo.body2"><strong>@w.WellName</strong></MudText>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@w.WellType · @w.CurrentDepthM.ToString("N0") m / @w.TargetDepthM.ToString("N0") m TD</MudText>
                                            </MudStack>
                                            <StatusBadge Status="@w.DrillingStatus" Size="Size.Small" />
                                        </MudStack>
                                    </MudListItem>
                                    <MudDivider />
                                }
                            </MudList>
                        }
                    </MudCardContent>
                </MudCard>

                @* Open Punch Items *@
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.subtitle1">Open Action Items</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudChip T="string" Color="Color.Warning" Size="Size.Small">@(_loading ? "—" : "from activities")</MudChip>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent Class="pa-0">
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-3">
                            Action items are tracked via Well Activities. Use the Construction Tracker to manage open punch items for this field.
                        </MudText>
                        <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" Class="ma-2"
                                   OnClick='() => NavigationManager.NavigateTo("/development/construction")'>
                            Open Construction Tracker
                        </MudButton>
                    </MudCardContent>
                </MudCard>

            </MudStack>
        </MudItem>

    </MudGrid>
</MudContainer>

@code {
    private string _fieldName = string.Empty;
    private bool _loading = true;

    private int _totalWells;
    private int _drillingWells;
    private int _completedWells;
    private int _plannedWells;

    private List<DevelopmentWellStatusDto> _activeWells = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summary = await ApiClient.GetAsync<FieldLifecycleSummary>("/api/field/current/summary");
            if (summary != null)
                _fieldName = summary.FieldName ?? _fieldName;
        }
        catch { /* field name is non-critical */ }

        _loading = true;
        try
        {
            var summary = await DevelopmentServiceClient.GetDashboardSummaryAsync();
            if (summary != null)
            {
                _totalWells    = summary.TotalWells;
                _drillingWells = summary.DrillingWells;
                _completedWells = summary.CompletedWells;
                _plannedWells  = summary.PlannedWells;
            }

            _activeWells = await DevelopmentServiceClient.GetDashboardWellsAsync();
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to load development data.", Severity.Warning);
        }
        finally { _loading = false; }
    }
}
