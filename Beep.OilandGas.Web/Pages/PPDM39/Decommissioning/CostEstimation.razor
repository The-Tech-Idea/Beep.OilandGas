@page "/ppdm39/decommissioning/cost-estimation"
@inject ApiClient ApiClient
@inject ISnackbar Snackbar

<PageTitle>Estimate Decommissioning Costs</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Estimate Decommissioning Costs</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — P&amp;A and facility removal cost forecasting</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Error" Icon="@Icons.Material.Filled.DeleteForever">Decommissioning</MudChip>
            </MudStack>
        </MudStack>
    </MudStack>

    <MudPaper Class="pa-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
            <MudText Typo="Typo.h6">Cost Estimation — @_fieldName</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Calculate" OnClick="EstimateCosts">
                Estimate Costs
            </MudButton>
        </MudStack>

        @if (_isLoading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
        }
        else if (_costEstimate != null)
        {
            <MudGrid Class="mt-4">
                <MudItem xs="12" md="6">
                    <MudCard Elevation="2">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">Cost Summary</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudStack Spacing="2">
                                <MudStack Row="true" Spacing="2">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="og-label-3xl">Total Estimated Cost</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Error">@GetPropertyValue(_costEstimate, "EstimatedTotalCost")</MudText>
                                </MudStack>
                                <MudStack Row="true" Spacing="2">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="og-label-3xl">Well Abandonment Cost</MudText>
                                    <MudText Typo="Typo.body2">@GetPropertyValue(_costEstimate, "WellAbandonmentCost")</MudText>
                                </MudStack>
                                <MudStack Row="true" Spacing="2">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="og-label-3xl">Facility Decommissioning Cost</MudText>
                                    <MudText Typo="Typo.body2">@GetPropertyValue(_costEstimate, "FacilityDecommissioningCost")</MudText>
                                </MudStack>
                                <MudStack Row="true" Spacing="2">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="og-label-3xl">Environmental Restoration Cost</MudText>
                                    <MudText Typo="Typo.body2">@GetPropertyValue(_costEstimate, "EnvironmentalRestorationCost")</MudText>
                                </MudStack>
                                <MudStack Row="true" Spacing="2">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="og-label-3xl">Abandoned Well Count</MudText>
                                    <MudText Typo="Typo.body2">@GetPropertyValue(_costEstimate, "AbandonedWellCount")</MudText>
                                </MudStack>
                                <MudStack Row="true" Spacing="2">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="og-label-3xl">Decommissioned Facility Count</MudText>
                                    <MudText Typo="Typo.body2">@GetPropertyValue(_costEstimate, "DecommissionedFacilityCount")</MudText>
                                </MudStack>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        }
        else
        {
            <MudAlert Severity="Severity.Info">Click "Estimate Costs" to generate a cost estimation for the current field.</MudAlert>
        }
    </MudPaper>
</MudContainer>

@code {
    private string _fieldName = "Current Field";
    private object? _costEstimate;
    private bool _isLoading = false;

    private async Task EstimateCosts()
    {
        _isLoading = true;
        try
        {
            _costEstimate = await ApiClient.PostAsync<object, object>("/api/field/current/decommissioning/cost-estimation", new { });
            Snackbar.Add("Cost estimation completed successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error estimating costs: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string GetPropertyValue(object obj, string propertyName)
    {
        if (obj is IDictionary<string, object> dict && dict.ContainsKey(propertyName))
        {
            var value = dict[propertyName];
            if (value is decimal dec)
                return dec.ToString("C");
            return value?.ToString() ?? "N/A";
        }
        return "N/A";
    }
}
