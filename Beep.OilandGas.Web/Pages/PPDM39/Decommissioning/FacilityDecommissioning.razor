@page "/decommissioning/facility"
@inject ISnackbar Snackbar
@inject ApiClient ApiClient
@inject IDecommissioningServiceClient DecommissioningService
@inject ILifeCycleService LifeCycleService

<PageTitle>Facility Decommissioning</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @if (_loading) { <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" /> }

    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Decommission Field Facilities</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Facility decommissioning project management</MudText>
        </MudStack>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Download"
                   OnClick='@(() => Snackbar.Add("Report export queued", Severity.Success))'>
            Export Report
        </MudButton>
    </MudStack>

    @* KPIs *@
    <MudGrid Class="mb-4" Spacing="3">
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Total Facilities" Value="@_facilities.Count.ToString()" Unit="units"
                     ValueColor="Color.Default" Icon="@Icons.Material.Filled.Apartment"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default" TrendText="In programme" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="In Execution" Value="@_facilities.Count(f => IsExecutionPhase(f.Phase)).ToString()" Unit="units"
                     ValueColor="Color.Warning" Icon="@Icons.Material.Filled.BuildCircle"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default" TrendText="Active" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Total DECOM Cost" Value="@_totalCostMm.ToString("N0")" Unit="$MM"
                     ValueColor="Color.Info" Icon="@Icons.Material.Filled.AttachMoney"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default" TrendText="Committed + est." />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Regulatory Submissions" Value="@_facilities.Count(f => IsRegulatoryPhase(f.Phase)).ToString()" Unit="pending"
                     ValueColor="Color.Error" Icon="@Icons.Material.Filled.Policy"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default" TrendText="Awaiting approval" />
        </MudItem>
    </MudGrid>

    <MudGrid Spacing="3">

        @* Facilities table *@
        <MudItem xs="12" md="8">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent><MudText Typo="Typo.subtitle1">Facility Decommissioning Projects</MudText></CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    <MudDataGrid T="FacilityItem" Items="@_facilities" Dense="true" Hover="true" Striped="true"
                                 RowClick="OnFacilitySelected">
                        <Columns>
                            <PropertyColumn Property="f => f.FacilityId"   Title="Facility" />
                            <PropertyColumn Property="f => f.FacilityType" Title="Type" />
                            <PropertyColumn Property="f => f.DecomStart"   Title="DECOM Start" />
                            <PropertyColumn Property="f => f.DecomEnd"     Title="Target Complete" />
                            <PropertyColumn Property="f => f.CostMm"       Title="Cost ($MM)" Format="N1" />
                            <TemplateColumn Title="Phase">
                                <CellTemplate><StatusBadge Status="@context.Item.Phase" /></CellTemplate>
                            </TemplateColumn>
                            <PropertyColumn Property="f => f.PctComplete"  Title="% Done" Format="N0" />
                        </Columns>
                    </MudDataGrid>
                </MudCardContent>
            </MudCard>
        </MudItem>

        @* Right panel — cost chart / detail *@
        <MudItem xs="12" md="4">
            <MudStack Spacing="3">

                @if (_selectedFacility is not null)
                {
                    <MudCard Elevation="2">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.subtitle1">@_selectedFacility.FacilityId</MudText>
                                    <StatusBadge Status="@_selectedFacility.Phase" />
                                </MudStack>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudStack Spacing="2">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Overall Progress</MudText>
                                    <MudProgressLinear Value="@_selectedFacility.PctComplete"
                                                       Color="Color.Primary" Class="mb-1" />
                                    <MudText Typo="Typo.body2">@_selectedFacility.PctComplete.ToString("N0")% Complete</MudText>
                                </MudStack>
                                @foreach (var act in _decomActivities)
                                {
                                    <MudStack Spacing="0">
                                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                                            <MudText Typo="Typo.caption">@act.Name</MudText>
                                            <StatusBadge Status="@act.Status" />
                                        </MudStack>
                                        <MudProgressLinear Value="@act.Pct"
                                                           Color="@ActivityColor(act.Status)" />
                                    </MudStack>
                                }
                            </MudStack>
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Outlined" FullWidth="true"
                                       OnClick='@(() => _selectedFacility = null)'>
                                Back to List
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                }
                else
                {
                    <MudCard Elevation="2">
                        <MudCardHeader>
                            <CardHeaderContent><MudText Typo="Typo.subtitle1">Cost by Phase ($MM)</MudText></CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudAlert Severity="Severity.Info" Dense="true">
                                Cost by phase loads from the Accounting module once cost records are linked to these facilities.
                            </MudAlert>
                        </MudCardContent>
                    </MudCard>
                }

                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent><MudText Typo="Typo.subtitle1">Regulatory Submissions</MudText></CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent Class="pa-2">
                        <MudList T="string" Dense="true">
                            @foreach (var sub in _regulatoryItems)
                            {
                                <MudListItem T="string">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                        <MudText Typo="Typo.body2">@sub.Name</MudText>
                                        <StatusBadge Status="@sub.Status" />
                                    </MudStack>
                                </MudListItem>
                            }
                        </MudList>
                    </MudCardContent>
                </MudCard>

            </MudStack>
        </MudItem>

    </MudGrid>
</MudContainer>

@code {
    private string _fieldName = string.Empty;
    private FacilityItem? _selectedFacility;
    private double _totalCostMm;
    private bool _loading = true;

    private record FacilityItem(string DecommissioningId, string FacilityId, string FacilityType, string DecomStart,
        string DecomEnd, double CostMm, string Phase, double PctComplete);

    private List<FacilityItem> _facilities = new();

    private record DecomActivity(string Name, string Status, double Pct);
    private List<DecomActivity> _decomActivities = new()
    {
        new("Isolate & Depressure",  "COMPLETE",    100),
        new("Clean & Flush Lines",   "COMPLETE",    100),
        new("Remove Equipment",      "IN PROGRESS",  55),
        new("Structural Demolition", "PLANNED",       0),
        new("Site Remediation",      "PLANNED",       0),
        new("Final Survey",          "PLANNED",       0),
    };

    private record RegulatorySubmission(string Name, string Status);
    private List<RegulatorySubmission> _regulatoryItems = new()
    {
        new("DECOM Programme",      "IN PROGRESS"),
        new("Marine Survey Permit", "IN PROGRESS"),
        new("Waste Disposal Plan",  "ACTIVE"),
        new("Final Closure Report", "PLANNED"),
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summary = await LifeCycleService.GetFieldLifecycleSummaryAsync();
            if (summary != null)
                _fieldName = summary.FieldName ?? _fieldName;
        }
        catch { /* field name is non-critical */ }

        _loading = true;
        try
        {
            var raw = await DecommissioningService.GetDecommissionedFacilitiesAsync();
            var estimate = await DecommissioningService.EstimateCostsAsync();

            _facilities = raw.Select(r => new FacilityItem(
                r.DecommissioningId,
                r.FacilityId ?? r.DecommissioningId,
                r.DecommissioningType ?? "Facility",
                FormatMonth(r.DecommissioningStartDate, "—"),
                FormatMonth(r.DecommissioningEndDate, "TBD"),
                (double)(r.TotalCost ?? r.DecommissioningCost ?? 0m) / 1_000_000d,
                r.Status ?? "PLANNED",
                EstimateCompletionPct(r.Status))).ToList();

            var actualCostMm = _facilities.Sum(f => f.CostMm);
            var estimatedCostMm = (double)(estimate?.EstimatedFacilityDecommissioningCost ?? 0m) / 1_000_000d;
            _totalCostMm = actualCostMm > 0 ? actualCostMm : estimatedCostMm;

            if (_selectedFacility is not null)
            {
                _selectedFacility = _facilities.FirstOrDefault(f => f.DecommissioningId == _selectedFacility.DecommissioningId);
                if (_selectedFacility is not null)
                {
                    _decomActivities = BuildDecomActivities(_selectedFacility.Phase);
                }
            }
        }
        catch (Exception) { Snackbar.Add("Failed to load facilities.", Severity.Warning); }
        finally { _loading = false; }
    }

    private void OnFacilitySelected(DataGridRowClickEventArgs<FacilityItem> args)
    {
        _selectedFacility = args.Item;
        _decomActivities = BuildDecomActivities(args.Item.Phase);
    }

    private Color ActivityColor(string status) => status switch
    {
        "COMPLETE"    => Color.Success,
        "IN PROGRESS" => Color.Primary,
        _             => Color.Default,
    };

    private static string FormatMonth(DateTime? value, string fallback) =>
        value?.ToLocalTime().ToString("MMM yyyy") ?? fallback;

    private static bool IsExecutionPhase(string? phase)
    {
        var normalized = NormalizePhase(phase);
        return normalized is "EXECUTION" or "INPROGRESS" or "ACTIVE";
    }

    private static bool IsRegulatoryPhase(string? phase)
    {
        var normalized = NormalizePhase(phase);
        return normalized is "APPROVAL" or "PLANNING" or "PLANNED" or "PENDINGAPPROVAL";
    }

    private static int EstimateCompletionPct(string? phase)
    {
        return NormalizePhase(phase) switch
        {
            "COMPLETE" or "COMPLETED" or "CLOSED" => 100,
            "EXECUTION" or "INPROGRESS" or "ACTIVE" => 60,
            "APPROVAL" or "PENDINGAPPROVAL" => 35,
            "PLANNING" or "PLANNED" => 10,
            _ => 0,
        };
    }

    private static string NormalizePhase(string? phase) =>
        string.IsNullOrWhiteSpace(phase)
            ? string.Empty
            : phase.Trim().Replace(" ", string.Empty).Replace("_", string.Empty).ToUpperInvariant();

    private static List<DecomActivity> BuildDecomActivities(string? phase)
    {
        var activityDefinitions = new[]
        {
            "Isolate & Depressure",
            "Clean & Flush Lines",
            "Remove Equipment",
            "Structural Demolition",
            "Site Remediation",
            "Final Survey",
        };

        var normalized = NormalizePhase(phase);
        var currentIndex = normalized switch
        {
            "COMPLETE" or "COMPLETED" or "CLOSED" => activityDefinitions.Length,
            "EXECUTION" or "INPROGRESS" or "ACTIVE" => 3,
            "APPROVAL" or "PENDINGAPPROVAL" => 1,
            _ => 0,
        };

        return activityDefinitions
            .Select((name, index) =>
            {
                var status = index < currentIndex
                    ? "COMPLETE"
                    : index == currentIndex && currentIndex < activityDefinitions.Length
                        ? "IN PROGRESS"
                        : "PLANNED";
                var pct = status switch
                {
                    "COMPLETE" => 100d,
                    "IN PROGRESS" => 55d,
                    _ => 0d,
                };

                return new DecomActivity(name, status, pct);
            })
            .ToList();
    }
}
