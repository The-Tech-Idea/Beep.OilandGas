@page "/production/well-performance"
@using Beep.OilandGas.Models.Data.WorkOrder
@using Beep.OilandGas.Models.Data.Production
@using Beep.OilandGas.Web.Services
@inject ApiClient ApiClient
@inject ILifeCycleService LifeCycleService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IClientFileExportService ExportService
@inject IDevelopmentServiceClient DevelopmentService
@inject IProductionServiceClient ProductionService
@using System.Security.Claims

<PageTitle>Optimise Well Performance</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @if (_loading) { <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" /> }

    @* ── Header ──────────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Optimise Well Performance</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Analyse performance, identify deviation, and recommend action</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.OilBarrel">Production</MudChip>
            </MudStack>
        </MudStack>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Download"
                   OnClick="ExportAnalysisAsync">Export Analysis</MudButton>
    </MudStack>

    @* ── Well selector bar ───────────────────────────────────────────────── *@
    <MudPaper Elevation="1" Class="pa-3 mb-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Wrap="Wrap.Wrap">
            <MudSelect T="string" Label="Select Well"
                       Value="@_selectedWellId"
                       ValueChanged="OnWellChanged"
                       Variant="Variant.Outlined" Class="og-select-xl">
                @foreach (var w in _wellOptions)
                {
                    <MudSelectItem Value="@w.Id">@w.Name</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="string" Label="Period" @bind-Value="_period" Variant="Variant.Outlined" Class="og-select-md">
                <MudSelectItem Value="@("30d")">Last 30 days</MudSelectItem>
                <MudSelectItem Value="@("90d")">Last 90 days</MudSelectItem>
                <MudSelectItem Value="@("180d")">Last 180 days</MudSelectItem>
                <MudSelectItem Value="@("1y")">Last 12 months</MudSelectItem>
            </MudSelect>
            <StatusBadge Status="@_selectedWell.Status" />
        </MudStack>
    </MudPaper>

    @* ── Well KPIs ────────────────────────────────────────────────────────── *@
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Actual Rate" Value="@_selectedWell.OilRate.ToString("N0")" Unit="BOPD"
                     ValueColor="Color.Success" Icon="@Icons.Material.Filled.OilBarrel"
                     TrendIcon="@(PotentialGapBopd > 0 ? Icons.Material.Filled.TrendingDown : Icons.Material.Filled.TrendingFlat)"
                     TrendColor="@(PotentialGapBopd > 0 ? Color.Warning : Color.Success)" TrendText="@ActualRateTrendText" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Potential Rate" Value="@_selectedWell.PotentialRate.ToString("N0")" Unit="BOPD"
                     ValueColor="Color.Primary" Icon="@Icons.Material.Filled.Speed"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default" TrendText="Stable" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Efficiency" Value="@EfficiencyPct" Unit="%"
                     ValueColor="Color.Warning" Icon="@Icons.Material.Filled.Percent"
                     TrendIcon="@Icons.Material.Filled.TrendingDown" TrendColor="Color.Warning" TrendText="Target: 95%" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Cumulative Oil" Value="@CumOilDisplay" Unit="MBBL"
                     ValueColor="Color.Default" Icon="@Icons.Material.Filled.Storage"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default" TrendText="Since first oil" />
        </MudItem>
    </MudGrid>

    @* ── Main Content ─────────────────────────────────────────────────────── *@
    <MudGrid Spacing="3">

        @* LEFT — Charts + DCA (8 cols) *@
        <MudItem xs="12" lg="8">
            <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true">

                <MudTabPanel Text="Rate vs Potential">
                    <MudPaper Elevation="0" Class="pa-3">
                        <MudChart ChartType="ChartType.Line"
                                  ChartSeries="@_rateSeries"
                                  XAxisLabels="@_rateLabels"
                                  Width="100%"
                                  Height="280px" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                            BOPD — Actual (blue) vs Potential (dashed) vs Target (green)
                        </MudText>
                    </MudPaper>
                </MudTabPanel>

                <MudTabPanel Text="Pressure & GOR">
                    <MudPaper Elevation="0" Class="pa-3">
                        <MudChart ChartType="ChartType.Line"
                                  ChartSeries="@_pressureSeries"
                                  XAxisLabels="@_rateLabels"
                                  Width="100%"
                                  Height="280px" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                            Gas test-rate trend (Mscf/d)
                        </MudText>
                    </MudPaper>
                </MudTabPanel>

                <MudTabPanel Text="Decline Analysis">
                    <MudPaper Elevation="0" Class="pa-3">
                        <MudChart ChartType="ChartType.Line"
                                  ChartSeries="@_dcaSeries"
                                  XAxisLabels="@_dcaLabels"
                                  Width="100%"
                                  Height="280px" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                            DCA fit: Di=@_dcaDi%/yr, b=@_dcaB — @_dcaEur MBBL EUR
                        </MudText>
                    </MudPaper>
                </MudTabPanel>

                <MudTabPanel Text="Water Cut Trend">
                    <MudPaper Elevation="0" Class="pa-3">
                        <MudChart ChartType="ChartType.Line"
                                  ChartSeries="@_wcSeries"
                                  XAxisLabels="@_rateLabels"
                                  Width="100%"
                                  Height="280px" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                            Water cut % — rising trend indicates aquifer breakthrough
                        </MudText>
                    </MudPaper>
                </MudTabPanel>

            </MudTabs>
        </MudItem>

        @* RIGHT — Performance diagnosis + actions (4 cols) *@
        <MudItem xs="12" lg="4">
            <MudStack Spacing="3">

                @* Performance diagnosis *@
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Filled.Psychology" Color="Color.Info" Size="Size.Small" />
                                <MudText Typo="Typo.subtitle1">Performance Diagnosis</MudText>
                            </MudStack>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudStack Spacing="2">
                            @foreach (var finding in _findings)
                            {
                                <MudPaper Elevation="0" Class="@FindingFullClass(finding.Severity)">
                                    <MudStack Row="true" AlignItems="AlignItems.Start" Spacing="2">
                                        <MudIcon Icon="@FindingIcon(finding.Severity)"
                                                 Color="@FindingColor(finding.Severity)"
                                                 Size="Size.Small"
                                                 Class="mt-1" />
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.body2"><strong>@finding.Title</strong></MudText>
                                            <MudText Typo="Typo.caption">@finding.Detail</MudText>
                                        </MudStack>
                                    </MudStack>
                                </MudPaper>
                            }
                        </MudStack>
                    </MudCardContent>
                </MudCard>

                <LiftRecommendationCard Title="Recommended Action"
                                        Subtitle="Artificial-lift and intervention workflow"
                                        Icon="@Icons.Material.Filled.AutoGraph"
                                        IconColor="Color.Warning"
                                        Headline="@(_recommendation?.Action ?? "Review current well state")"
                                        Summary="@(_recommendation?.Rationale ?? "Run a performance analysis to generate a recommendation.")"
                                        ImpactText="@GetRecommendationImpactText()"
                                        Severity="@GetRecommendationSeverity()"
                                        Facts="@GetRecommendationFacts()">
                    <Actions>
                        <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Build"
                                   OnClick="CreateInterventionFromRecommendation">
                            Create Intervention
                        </MudButton>
                        <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Secondary"
                                   StartIcon="@Icons.Material.Filled.AutoGraph"
                                   Href="@GetLiftStudyHref()">
                            @GetLiftStudyLabel()
                        </MudButton>
                        @if (HasOperationalFollowUp())
                        {
                            <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Info"
                                       StartIcon="@Icons.Material.Filled.Assignment"
                                       Href="@GetWorkOrderIntakeHref()">
                                Open Work Order Intake
                            </MudButton>
                            <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Success"
                                       StartIcon="@Icons.Material.Filled.RequestQuote"
                                       Href="@GetAfeIntakeHref()">
                                Open AFE Intake
                            </MudButton>
                        }
                        <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Default"
                                   StartIcon="@Icons.Material.Filled.AssignmentLate"
                                   Disabled="@(_loggingDeviation || string.IsNullOrWhiteSpace(_selectedWellId) || _analysis is null)"
                                   OnClick="LogDeviation">
                            @(_loggingDeviation ? "Logging Deviation..." : "Log Deviation Only")
                        </MudButton>
                    </Actions>
                </LiftRecommendationCard>

                @* Recent activities *@
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.subtitle1">Well History (Recent)</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent Class="pa-0">
                        <MudList T="WellHistoryItem" Dense="true">
                            @foreach (var item in _history)
                            {
                                <MudListItem T="WellHistoryItem" Value="item">
                                    <MudStack Row="true" AlignItems="AlignItems.Start" Spacing="2">
                                        <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" Color="Color.Secondary" Class="mt-1" />
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.body2">@item.Event</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@item.Date · @item.User</MudText>
                                        </MudStack>
                                    </MudStack>
                                </MudListItem>
                                <MudDivider />
                            }
                        </MudList>
                    </MudCardContent>
                </MudCard>

            </MudStack>
        </MudItem>

    </MudGrid>

</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "wellId")]
    public string? WellId { get; set; }

    private string _fieldName = string.Empty;
    private string _selectedWellId = string.Empty;
    private string _period = "30d";
    private string _dcaDi = "18";
    private string _dcaB = "0.5";
    private string _dcaEur = "—";
    private bool   _loading = true;
    private bool   _loggingDeviation;

    private record WellOption(string Id, string Name);
    private List<WellOption> _wellOptions = new();

    private record WellDetail(string WellId, string Status, double OilRate, double PotentialRate, double CumOil);
    private WellDetail _selectedWell = new(string.Empty, "UNKNOWN", 0, 0, 0);

    private List<PerformanceFinding> _findings   = new();
    private Recommendation?          _recommendation;
    private WellPerformanceAnalysisResponse? _analysis;

    private record Recommendation(string Action, string Rationale, int UpliftBopd);
    private List<WellHistoryItem> _history = new();

    private List<ChartSeries<double>> _rateSeries     = new();
    private string[]                  _rateLabels      = Array.Empty<string>();
    private List<ChartSeries<double>> _pressureSeries  = new();
    private List<ChartSeries<double>> _dcaSeries       = new();
    private string[]                  _dcaLabels       = Array.Empty<string>();
    private List<ChartSeries<double>> _wcSeries        = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summary = await LifeCycleService.GetFieldLifecycleSummaryAsync();
            if (summary != null)
                _fieldName = summary.FieldName ?? _fieldName;
        }
        catch { /* field name is non-critical */ }

        _loading = true;
        try
        {
            // Load well list for the selector
            var wells = await DevelopmentService.GetWellsAsync();
            if (wells.Count > 0)
            {
                _wellOptions = wells
                    .Select(w => new WellOption(w.UWI ?? string.Empty, w.WELL_NAME ?? w.UWI ?? "Unknown"))
                    .Where(o => !string.IsNullOrEmpty(o.Id))
                    .ToList();
            }

            // Use query-string wellId, or first well in list
            _selectedWellId = !string.IsNullOrWhiteSpace(WellId)
                ? WellId
                : _wellOptions.FirstOrDefault()?.Id ?? string.Empty;

            if (!string.IsNullOrEmpty(_selectedWellId))
                await LoadWellPerformanceAsync(_selectedWellId);
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to load well list.", Severity.Warning);
        }
        finally { _loading = false; }
    }

    private async Task OnWellChanged(string wellId)
    {
        _selectedWellId = wellId;
        await LoadWellPerformanceAsync(wellId);
    }

    private async Task LoadWellPerformanceAsync(string wellId)
    {
        if (string.IsNullOrEmpty(wellId)) return;
        try
        {
            var perf = await ProductionService.GetWellPerformanceAsync(wellId);
            var analysis = await ProductionService.GetWellPerformanceAnalysisAsync(wellId);
            if (perf == null) return;

            _selectedWell = new WellDetail(perf.WellId, perf.Status,
                perf.OilRate, perf.PotentialRate, perf.CumOil);
            _analysis = analysis;

            _findings = (analysis?.Findings ?? new List<WellPerformanceFinding>())
                .Select(finding => new PerformanceFinding(finding.Title, finding.Detail, finding.Severity))
                .ToList();

            var serverRecommendation = analysis?.Recommendation;
            _recommendation = serverRecommendation == null
                ? null
                : new Recommendation(
                    serverRecommendation.Action,
                    serverRecommendation.Rationale,
                    serverRecommendation.UpliftBopd);

            _history = (analysis?.History ?? new List<WellPerformanceHistoryItem>())
                .Select(item => new WellHistoryItem(
                    item.Event,
                    FormatHistoryDate(item.EventDate),
                    string.IsNullOrWhiteSpace(item.User) ? "—" : item.User))
                .ToList();

            // ── Build chart series from well tests ────────────────────────
            var orderedTests = (perf.WellTests ?? new())
                .Where(t => t.TestDate.HasValue || t.TestStartDate.HasValue || t.TestEndDate.HasValue)
                .OrderBy(t => t.TestDate ?? t.TestStartDate ?? t.TestEndDate ?? DateTime.MinValue)
                .ToList();

            if (orderedTests.Count >= 2)
            {
                _rateLabels = orderedTests
                    .Select(t => (t.TestDate ?? t.TestStartDate ?? t.TestEndDate ?? DateTime.MinValue).ToString("MMM''yy"))
                    .ToArray();
                _rateSeries = new()
                {
                    new ChartSeries<double>
                    {
                        Name = "Actual",
                        Data = orderedTests.Select(t => (double)(t.OilFlowAmount ?? 0m)).ToArray()
                    },
                    new ChartSeries<double> { Name = "Potential",
                        Data = Enumerable.Repeat(perf.PotentialRate, orderedTests.Count).ToArray() },
                };
                _pressureSeries = new()
                {
                    new ChartSeries<double>
                    {
                        Name = "Gas Rate",
                        Data = orderedTests.Select(t => (double)(t.GasFlowAmount ?? 0m)).ToArray()
                    }
                };
                _dcaLabels = _rateLabels;
                _dcaSeries = new()
                {
                    new ChartSeries<double>
                    {
                        Name = "Tests",
                        Data = orderedTests.Select(t => (double)(t.OilFlowAmount ?? 0m)).ToArray()
                    },
                };
                _wcSeries = new()
                {
                    new ChartSeries<double>
                    {
                        Name = "Water Cut",
                        Data = orderedTests.Select(t => (double)(t.BswPercent ?? t.WaterCutPercent ?? 0m)).ToArray()
                    },
                };
            }
            else
            {
                _rateSeries    = new();
                _rateLabels    = Array.Empty<string>();
                _pressureSeries= new();
                _dcaSeries     = new();
                _dcaLabels     = Array.Empty<string>();
                _wcSeries      = new();
            }

            // Update DCA display fields
            if (perf.PotentialRate > 0)
                _dcaEur = $"{perf.PotentialRate * 365 / 1_000:N0} MBBL/yr";
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to load performance data.", Severity.Warning);
        }
    }

    private void CreateInterventionFromRecommendation() =>
        NavigationManager.NavigateTo($"/production/intervention?wellId={Uri.EscapeDataString(_selectedWellId)}&type=INTERVENTION&returnTo={Uri.EscapeDataString(GetReturnToHref())}");

    private async Task LogDeviation()
    {
        if (string.IsNullOrWhiteSpace(_selectedWellId) || _analysis == null)
        {
            Snackbar.Add("Load a well analysis before logging a deviation.", Severity.Warning);
            return;
        }

        _loggingDeviation = true;
        try
        {
            var request = new PerformanceDeviationRequest
            {
                Note = "Deviation logged from the well performance optimizer.",
                RecommendationAction = _analysis.Recommendation?.Action,
                RecommendationRationale = _analysis.Recommendation?.Rationale,
                EstimatedUpliftBopd = _analysis.Recommendation?.UpliftBopd ?? 0,
                Severity = _analysis.Findings.OrderBy(finding => SeverityRank(finding.Severity)).FirstOrDefault()?.Severity,
                Findings = _analysis.Findings.Select(finding => finding.Title).ToList()
            };

            var result = await ProductionService.LogPerformanceDeviationAsync(_selectedWellId, request);
            await LoadWellPerformanceAsync(_selectedWellId);
            Snackbar.Add(result.Message ?? "Deviation logged for review.", Severity.Success);
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to log performance deviation.", Severity.Error);
        }
        finally
        {
            _loggingDeviation = false;
        }
    }

    private async Task ExportAnalysisAsync()
    {
        if (string.IsNullOrWhiteSpace(_selectedWellId))
        {
            Snackbar.Add("Select a well before exporting analysis.", Severity.Warning);
            return;
        }

        var payload = new
        {
            ExportType = "WellPerformanceRecommendationPackage",
            ExportedAtUtc = DateTime.UtcNow,
            FieldName = _fieldName,
            SelectedWellId = _selectedWellId,
            SelectedWell = new
            {
                _selectedWell.WellId,
                _selectedWell.Status,
                _selectedWell.OilRate,
                _selectedWell.PotentialRate,
                _selectedWell.CumOil,
                EfficiencyPct
            },
            AnalysisContext = new
            {
                Period = _period,
                DcaInitialDeclinePct = _dcaDi,
                DcaBFactor = _dcaB,
                DcaEstimatedEur = _dcaEur
            },
            Findings = _findings.Select(finding => new
            {
                finding.Title,
                finding.Detail,
                finding.Severity
            }).ToList(),
            Recommendation = _recommendation is null
                ? null
                : new
                {
                    _recommendation.Action,
                    _recommendation.Rationale,
                    _recommendation.UpliftBopd,
                    ImpactText = GetRecommendationImpactText(),
                    Severity = GetRecommendationSeverity().ToString()
                },
            FollowUps = new
            {
                LiftStudy = GetLiftStudyHref(),
                Intervention = HasOperationalFollowUp()
                    ? $"/production/intervention?wellId={Uri.EscapeDataString(_selectedWellId)}&type=INTERVENTION&returnTo={Uri.EscapeDataString(GetReturnToHref())}"
                    : null,
                WorkOrder = HasOperationalFollowUp() ? GetWorkOrderIntakeHref() : null,
                Afe = HasOperationalFollowUp() ? GetAfeIntakeHref() : null,
                ReturnTo = GetReturnToHref()
            },
            History = _history.Select(item => new
            {
                item.Event,
                item.Date,
                item.User
            }).ToList()
        };

        await ExportService.DownloadJsonAsync($"well-performance-analysis-{DateTime.UtcNow:yyyyMMdd-HHmmss}", payload);
        Snackbar.Add("Analysis package exported.", Severity.Success);
    }

    private bool HasOperationalFollowUp()
    {
        return _analysis?.Recommendation?.HasOperationalFollowUp ?? (_recommendation?.UpliftBopd > 0);
    }

    private Severity GetRecommendationSeverity()
    {
        return _recommendation?.UpliftBopd > 0 ? Severity.Warning : Severity.Success;
    }

    private string GetRecommendationImpactText()
    {
        if (_recommendation == null)
            return "Run a performance analysis to generate an intervention and lift recommendation.";

        return _recommendation.UpliftBopd > 0
            ? $"Estimated uplift: {_recommendation.UpliftBopd:N0} BOPD. Validate the lift study before approving intervention work."
            : "No material uplift identified. Keep the well on scheduled surveillance unless conditions change.";
    }

    private IReadOnlyList<RecommendationFactItem> GetRecommendationFacts()
    {
        var potentialGap = Math.Max(_selectedWell.PotentialRate - _selectedWell.OilRate, 0);
        var liftStudyLabel = _analysis?.Recommendation?.RecommendedLiftStudy;

        return new RecommendationFactItem[]
        {
            new() { Label = "Potential Gap", Value = $"{potentialGap:N0} BOPD", ValueColor = potentialGap > 0 ? Color.Warning : Color.Success },
            new() { Label = "Well Efficiency", Value = EfficiencyPct + "%", ValueColor = potentialGap > 0 ? Color.Warning : Color.Success },
            new() { Label = "Lift Study", Value = (liftStudyLabel ?? GetLiftStudyLabel()).Replace("Run ", string.Empty), ValueColor = Color.Info }
        };
    }

    private string GetLiftStudyLabel()
    {
        return _analysis?.Recommendation?.RecommendedLiftStudy
            ?? (ShouldRecommendGasLiftStudy() ? "Run Gas Lift Study" : "Run ESP Analysis");
    }

    private string GetLiftStudyHref()
    {
        var basePath = ShouldRecommendGasLiftStudy() ? "/ppdm39/calculations/gaslift" : "/analysis/pump-performance";
        return string.IsNullOrWhiteSpace(_selectedWellId)
            ? basePath
            : $"{basePath}?wellId={Uri.EscapeDataString(_selectedWellId)}";
    }

    private string GetWorkOrderIntakeHref()
    {
        return BuildFollowUpHref(
            "/ppdm39/workorder",
            ("wellId", _selectedWellId),
            ("openCreate", "true"),
            ("linkAfe", HasOperationalFollowUp() ? "true" : null),
            ("returnTo", GetReturnToHref()),
            ("subType", GetRecommendedWorkOrderSubType()),
            ("title", _recommendation?.Action),
            ("description", _recommendation?.Rationale));
    }

    private string GetAfeIntakeHref()
    {
        return BuildFollowUpHref(
            "/economics/afe",
            ("wellId", _selectedWellId),
            ("openCreate", "true"),
            ("returnTo", GetReturnToHref()),
            ("description", _recommendation?.Action),
            ("budgetUsd", GetSuggestedAfeBudgetUsd()));
    }

    private string GetReturnToHref()
    {
        return string.IsNullOrWhiteSpace(_selectedWellId)
            ? "/production/well-performance"
            : $"/production/well-performance?wellId={Uri.EscapeDataString(_selectedWellId)}";
    }

    private string GetRecommendedWorkOrderSubType()
    {
        if (!string.IsNullOrWhiteSpace(_analysis?.Recommendation?.SuggestedWorkOrderSubType))
            return _analysis.Recommendation.SuggestedWorkOrderSubType;

        return HasOperationalFollowUp()
            ? WorkOrderSubType.Corrective
            : WorkOrderSubType.Preventive;
    }

    private string? GetSuggestedAfeBudgetUsd()
    {
        if (_analysis?.Recommendation?.SuggestedAfeBudgetUsd is decimal suggestedBudget && suggestedBudget > 0)
            return suggestedBudget.ToString("F0");

        if (!HasOperationalFollowUp())
            return null;

        var budget = Math.Max(_recommendation?.UpliftBopd ?? 0, 0) * 1000;
        return budget > 0 ? budget.ToString("F0") : null;
    }

    private static string BuildFollowUpHref(string basePath, params (string Key, string? Value)[] parameters)
    {
        var query = parameters
            .Where(parameter => !string.IsNullOrWhiteSpace(parameter.Value))
            .Select(parameter => $"{parameter.Key}={Uri.EscapeDataString(parameter.Value!)}")
            .ToArray();

        return query.Length == 0
            ? basePath
            : $"{basePath}?{string.Join("&", query)}";
    }

    private bool ShouldRecommendGasLiftStudy()
    {
        return _findings.Any(finding => finding.Title.Contains("GOR", StringComparison.OrdinalIgnoreCase));
    }

    private static string FormatHistoryDate(DateTime? value)
    {
        return value.HasValue && value.Value != DateTime.MinValue
            ? value.Value.ToString("dd MMM yyyy")
            : "—";
    }

    private static int SeverityRank(string? severity)
    {
        return severity?.ToUpperInvariant() switch
        {
            "HIGH" => 0,
            "MEDIUM" => 1,
            _ => 2
        };
    }

    private string EfficiencyPct => _selectedWell.PotentialRate > 0
        ? (_selectedWell.OilRate / _selectedWell.PotentialRate * 100).ToString("N0")
        : "0";

    private double PotentialGapBopd => Math.Max(_selectedWell.PotentialRate - _selectedWell.OilRate, 0);

    private string ActualRateTrendText => PotentialGapBopd > 0
        ? $"{PotentialGapBopd:N0} BOPD below potential"
        : "At current tested potential";

    private string CumOilDisplay => _selectedWell.CumOil > 0
        ? _selectedWell.CumOil.ToString("N0")
        : "—";

    private string FindingFullClass(string sev) => $"pa-2 {FindingClass(sev)}";

    private string FindingIcon(string sev) => sev switch
    {
        "HIGH"   => Icons.Material.Filled.Error,
        "MEDIUM" => Icons.Material.Filled.Warning,
        _        => Icons.Material.Filled.CheckCircle,
    };

    private Color FindingColor(string sev) => sev switch
    {
        "HIGH"   => Color.Error,
        "MEDIUM" => Color.Warning,
        _        => Color.Success,
    };

    private string FindingClass(string sev) => sev switch
    {
        "HIGH"   => "finding-high",
        "MEDIUM" => "finding-medium",
        _        => "finding-low",
    };

    private record PerformanceFinding(string Title, string Detail, string Severity);
    private record WellHistoryItem(string Event, string Date, string User);
}
