@page "/production/well-performance"
@inject ApiClient ApiClient
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@using System.Security.Claims

<PageTitle>Optimise Well Performance</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @if (_loading) { <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" /> }

    @* ── Header ──────────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Optimise Well Performance</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Analyse performance, identify deviation, and recommend action</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.OilBarrel">Production</MudChip>
            </MudStack>
        </MudStack>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Download">Export Analysis</MudButton>
    </MudStack>

    @* ── Well selector bar ───────────────────────────────────────────────── *@
    <MudPaper Elevation="1" Class="pa-3 mb-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Wrap="Wrap.Wrap">
            <MudSelect T="string" Label="Select Well"
                       Value="@_selectedWellId"
                       ValueChanged="OnWellChanged"
                       Variant="Variant.Outlined" Class="og-select-xl">
                @foreach (var w in _wellOptions)
                {
                    <MudSelectItem Value="@w.Id">@w.Name</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="string" Label="Period" @bind-Value="_period" Variant="Variant.Outlined" Class="og-select-md">
                <MudSelectItem Value="@("30d")">Last 30 days</MudSelectItem>
                <MudSelectItem Value="@("90d")">Last 90 days</MudSelectItem>
                <MudSelectItem Value="@("180d")">Last 180 days</MudSelectItem>
                <MudSelectItem Value="@("1y")">Last 12 months</MudSelectItem>
            </MudSelect>
            <StatusBadge Status="@_selectedWell.Status" />
        </MudStack>
    </MudPaper>

    @* ── Well KPIs ────────────────────────────────────────────────────────── *@
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Actual Rate" Value="@_selectedWell.OilRate.ToString("N0")" Unit="BOPD"
                     ValueColor="Color.Success" Icon="@Icons.Material.Filled.OilBarrel"
                     TrendIcon="@Icons.Material.Filled.TrendingDown" TrendColor="Color.Warning" TrendText="-4% vs potential" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Potential Rate" Value="@_selectedWell.PotentialRate.ToString("N0")" Unit="BOPD"
                     ValueColor="Color.Primary" Icon="@Icons.Material.Filled.Speed"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default" TrendText="Stable" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Efficiency" Value="@EfficiencyPct" Unit="%"
                     ValueColor="Color.Warning" Icon="@Icons.Material.Filled.Percent"
                     TrendIcon="@Icons.Material.Filled.TrendingDown" TrendColor="Color.Warning" TrendText="Target: 95%" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Cumulative Oil" Value="@_selectedWell.CumOil.ToString("N0")" Unit="MBBL"
                     ValueColor="Color.Default" Icon="@Icons.Material.Filled.Storage"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default" TrendText="Since first oil" />
        </MudItem>
    </MudGrid>

    @* ── Main Content ─────────────────────────────────────────────────────── *@
    <MudGrid Spacing="3">

        @* LEFT — Charts + DCA (8 cols) *@
        <MudItem xs="12" lg="8">
            <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true">

                <MudTabPanel Text="Rate vs Potential">
                    <MudPaper Elevation="0" Class="pa-3">
                        <MudChart ChartType="ChartType.Line"
                                  ChartSeries="@_rateSeries"
                                  XAxisLabels="@_rateLabels"
                                  Width="100%"
                                  Height="280px" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                            BOPD — Actual (blue) vs Potential (dashed) vs Target (green)
                        </MudText>
                    </MudPaper>
                </MudTabPanel>

                <MudTabPanel Text="Pressure & GOR">
                    <MudPaper Elevation="0" Class="pa-3">
                        <MudChart ChartType="ChartType.Line"
                                  ChartSeries="@_pressureSeries"
                                  XAxisLabels="@_rateLabels"
                                  Width="100%"
                                  Height="280px" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                            Wellhead pressure (psi) and GOR (scf/bbl)
                        </MudText>
                    </MudPaper>
                </MudTabPanel>

                <MudTabPanel Text="Decline Analysis">
                    <MudPaper Elevation="0" Class="pa-3">
                        <MudChart ChartType="ChartType.Line"
                                  ChartSeries="@_dcaSeries"
                                  XAxisLabels="@_dcaLabels"
                                  Width="100%"
                                  Height="280px" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                            DCA fit: Di=@_dcaDi%/yr, b=@_dcaB — @_dcaEur MBBL EUR
                        </MudText>
                    </MudPaper>
                </MudTabPanel>

                <MudTabPanel Text="Water Cut Trend">
                    <MudPaper Elevation="0" Class="pa-3">
                        <MudChart ChartType="ChartType.Line"
                                  ChartSeries="@_wcSeries"
                                  XAxisLabels="@_rateLabels"
                                  Width="100%"
                                  Height="280px" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                            Water cut % — rising trend indicates aquifer breakthrough
                        </MudText>
                    </MudPaper>
                </MudTabPanel>

            </MudTabs>
        </MudItem>

        @* RIGHT — Performance diagnosis + actions (4 cols) *@
        <MudItem xs="12" lg="4">
            <MudStack Spacing="3">

                @* Performance diagnosis *@
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Filled.Psychology" Color="Color.Info" Size="Size.Small" />
                                <MudText Typo="Typo.subtitle1">Performance Diagnosis</MudText>
                            </MudStack>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudStack Spacing="2">
                            @foreach (var finding in _findings)
                            {
                                <MudPaper Elevation="0" Class="@FindingFullClass(finding.Severity)">
                                    <MudStack Row="true" AlignItems="AlignItems.Start" Spacing="2">
                                        <MudIcon Icon="@FindingIcon(finding.Severity)"
                                                 Color="@FindingColor(finding.Severity)"
                                                 Size="Size.Small"
                                                 Class="mt-1" />
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.body2"><strong>@finding.Title</strong></MudText>
                                            <MudText Typo="Typo.caption">@finding.Detail</MudText>
                                        </MudStack>
                                    </MudStack>
                                </MudPaper>
                            }
                        </MudStack>
                    </MudCardContent>
                </MudCard>

                @* Recommended action *@
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.subtitle1">Recommended Action</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudAlert Severity="Severity.Warning" Class="mb-3">
                            <strong>@_recommendation?.Action</strong><br/>
                            @_recommendation?.Rationale
                        </MudAlert>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                            Estimated uplift: <strong>@_recommendation?.UpliftBopd BOPD</strong>
                        </MudText>
                        <MudStack Spacing="2">
                            <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Build"
                                       OnClick="CreateInterventionFromRecommendation">
                                Create Intervention
                            </MudButton>
                            <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Default"
                                       StartIcon="@Icons.Material.Filled.AssignmentLate"
                                       OnClick="LogDeviation">
                                Log Deviation Only
                            </MudButton>
                        </MudStack>
                    </MudCardContent>
                </MudCard>

                @* Recent activities *@
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.subtitle1">Well History (Recent)</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent Class="pa-0">
                        <MudList T="WellHistoryItem" Dense="true">
                            @foreach (var item in _history)
                            {
                                <MudListItem T="WellHistoryItem" Value="item">
                                    <MudStack Row="true" AlignItems="AlignItems.Start" Spacing="2">
                                        <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" Color="Color.Secondary" Class="mt-1" />
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.body2">@item.Event</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@item.Date · @item.User</MudText>
                                        </MudStack>
                                    </MudStack>
                                </MudListItem>
                                <MudDivider />
                            }
                        </MudList>
                    </MudCardContent>
                </MudCard>

            </MudStack>
        </MudItem>

    </MudGrid>

</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "wellId")]
    public string? WellId { get; set; }

    private string _fieldName = string.Empty;
    private string _selectedWellId = string.Empty;
    private string _period = "30d";
    private string _dcaDi = "18";
    private string _dcaB = "0.5";
    private string _dcaEur = "—";
    private bool   _loading = true;

    private record WellOption(string Id, string Name);
    private List<WellOption> _wellOptions = new();

    private record WellDetail(string WellId, string Status, double OilRate, double PotentialRate, double CumOil);
    private WellDetail _selectedWell = new(string.Empty, "UNKNOWN", 0, 0, 0);

    private List<PerformanceFinding> _findings   = new();
    private Recommendation?          _recommendation;

    private record Recommendation(string Action, string Rationale, int UpliftBopd);
    private List<WellHistoryItem> _history = new();

    private List<ChartSeries<double>> _rateSeries     = new();
    private string[]                  _rateLabels      = Array.Empty<string>();
    private List<ChartSeries<double>> _pressureSeries  = new();
    private List<ChartSeries<double>> _dcaSeries       = new();
    private string[]                  _dcaLabels       = Array.Empty<string>();
    private List<ChartSeries<double>> _wcSeries        = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summary = await ApiClient.GetAsync<FieldLifecycleSummary>("/api/field/current/summary");
            if (summary != null)
                _fieldName = summary.FieldName ?? _fieldName;
        }
        catch { /* field name is non-critical */ }

        _loading = true;
        try
        {
            // Load well list for the selector
            var wells = await ApiClient.GetAsync<List<WellListDto>>("api/field/current/development/wells") ?? new();            if (wells != null && wells.Count > 0)
            {
                _wellOptions = wells
                    .Select(w => new WellOption(w.UWI ?? string.Empty, w.WellName ?? w.UWI ?? "Unknown"))
                    .Where(o => !string.IsNullOrEmpty(o.Id))
                    .ToList();
            }

            // Use query-string wellId, or first well in list
            _selectedWellId = !string.IsNullOrWhiteSpace(WellId)
                ? WellId
                : _wellOptions.FirstOrDefault()?.Id ?? string.Empty;

            if (!string.IsNullOrEmpty(_selectedWellId))
                await LoadWellPerformanceAsync(_selectedWellId);
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to load well list.", Severity.Warning);
        }
        finally { _loading = false; }
    }

    private async Task OnWellChanged(string wellId)
    {
        _selectedWellId = wellId;
        await LoadWellPerformanceAsync(wellId);
    }

    private async Task LoadWellPerformanceAsync(string wellId)
    {
        if (string.IsNullOrEmpty(wellId)) return;
        try
        {
            var perf = await ApiClient.GetAsync<WellPerformanceSummaryDto>(
                $"api/field/current/production/wells/{Uri.EscapeDataString(wellId)}/performance");
            if (perf == null) return;

            _selectedWell = new WellDetail(perf.WellId, perf.Status,
                perf.OilRate, perf.PotentialRate, perf.CumOil);

            // ── Derive findings from performance numbers ──────────────────
            _findings = new();
            if (perf.PotentialRate > 0 && perf.OilRate < perf.PotentialRate * 0.9)
            {
                var gap = (int)(perf.PotentialRate - perf.OilRate);
                var pct = (int)(100 - perf.OilRate / perf.PotentialRate * 100);
                _findings.Add(new($"Rate {pct}% below potential",
                    $"Current rate {perf.OilRate:N0} BOPD vs {perf.PotentialRate:N0} BOPD potential. Gap of {gap:N0} BOPD.",
                    pct >= 40 ? "HIGH" : "MEDIUM"));
            }
            if (perf.WaterRate > 0 && perf.OilRate > 0)
            {
                var wc = perf.WaterRate / (perf.OilRate + perf.WaterRate) * 100;
                if (wc > 60)
                    _findings.Add(new($"High water cut ({wc:N0}%)",
                        $"Water rate {perf.WaterRate:N0} BWPD against oil rate {perf.OilRate:N0} BOPD.",
                        wc > 80 ? "HIGH" : "MEDIUM"));
            }
            if (perf.GasRate > 0 && perf.OilRate > 0)
            {
                var gor = perf.GasRate * 1000 / perf.OilRate; // scf/bbl
                if (gor > 1000)
                    _findings.Add(new($"Elevated GOR ({gor:N0} scf/bbl)",
                        $"Gas-oil ratio suggests possible gas breakthrough or reservoir depletion.", "MEDIUM"));
            }
            if (_findings.Count == 0)
                _findings.Add(new("Well performing within expected range",
                    "No significant deviations detected. Continue routine monitoring.", "LOW"));

            // ── Derive recommendation ─────────────────────────────────────
            var highFindings = _findings.Where(f => f.Severity == "HIGH").ToList();
            if (highFindings.Count > 0)
            {
                var uplift = (int)(perf.PotentialRate - perf.OilRate);
                _recommendation = new("Well Intervention Required",
                    string.Join(" ", highFindings.Select(f => f.Detail)),
                    uplift > 0 ? uplift : 0);
            }
            else
            {
                _recommendation = new("Continue Production Monitoring",
                    "Well is operating within expected parameters. Maintain current settings and review at next scheduled test.",
                    0);
            }

            // ── Build history from well tests ─────────────────────────────
            _history = (perf.WellTests ?? new())
                .OrderByDescending(t => t.TestDate ?? DateTime.MinValue)
                .Select(t => new WellHistoryItem(
                    string.IsNullOrWhiteSpace(t.TestName)
                        ? $"Well test — {t.TestType ?? "routine"}"
                        : t.TestName,
                    (t.TestDate ?? t.TestStartDate)?.ToString("dd MMM yyyy") ?? "—",
                    t.CreateUser ?? "—"))
                .ToList();

            // ── Build chart series from well tests ────────────────────────
            var orderedTests = (perf.WellTests ?? new())
                .Where(t => t.TestDate.HasValue)
                .OrderBy(t => t.TestDate)
                .ToList();

            if (orderedTests.Count >= 2)
            {
                _rateLabels = orderedTests.Select(t => t.TestDate!.Value.ToString("MMM''yy")).ToArray();
                // Rate series: actual vs potential (no per-test rate in WellTestResponse; show 0-based)
                _rateSeries = new()
                {
                    new ChartSeries<double> { Name = "Potential",
                        Data = Enumerable.Repeat(perf.PotentialRate, orderedTests.Count).ToArray() },
                };
                _dcaLabels = _rateLabels;
                _dcaSeries = new()
                {
                    new ChartSeries<double> { Name = "Tests", Data = Enumerable.Repeat(perf.OilRate, orderedTests.Count).ToArray() },
                };
            }
            else
            {
                _rateSeries    = new();
                _rateLabels    = Array.Empty<string>();
                _pressureSeries= new();
                _dcaSeries     = new();
                _dcaLabels     = Array.Empty<string>();
                _wcSeries      = new();
            }

            // Update DCA display fields
            if (perf.PotentialRate > 0)
                _dcaEur = $"{perf.PotentialRate * 365 / 1_000:N0} MBBL/yr";
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to load performance data.", Severity.Warning);
        }
    }

    private class WellListDto
    {
        public string? UWI      { get; set; }
        public string? WellName { get; set; }
    }

    private class WellPerformanceSummaryDto
    {
        public string  WellId        { get; set; } = string.Empty;
        public string  Status        { get; set; } = string.Empty;
        public double  OilRate       { get; set; }
        public double  GasRate       { get; set; }
        public double  WaterRate     { get; set; }
        public double  PotentialRate { get; set; }
        public double  CumOil        { get; set; }
        public List<WellTestDto> WellTests { get; set; } = new();
    }

    private class WellTestDto
    {
        public string?   TestName      { get; set; }
        public string?   TestType      { get; set; }
        public DateTime? TestDate      { get; set; }
        public DateTime? TestStartDate { get; set; }
        public string?   CreateUser    { get; set; }
    }

    private void CreateInterventionFromRecommendation() =>
        NavigationManager.NavigateTo($"/production/intervention?wellId={Uri.EscapeDataString(_selectedWellId)}&type=INTERVENTION");

    private void LogDeviation() =>
        Snackbar.Add("Deviation logged for review", Severity.Success);

    private string EfficiencyPct => _selectedWell.PotentialRate > 0
        ? (_selectedWell.OilRate / _selectedWell.PotentialRate * 100).ToString("N0")
        : "0";

    private string FindingFullClass(string sev) => $"pa-2 {FindingClass(sev)}";

    private string FindingIcon(string sev) => sev switch
    {
        "HIGH"   => Icons.Material.Filled.Error,
        "MEDIUM" => Icons.Material.Filled.Warning,
        _        => Icons.Material.Filled.CheckCircle,
    };

    private Color FindingColor(string sev) => sev switch
    {
        "HIGH"   => Color.Error,
        "MEDIUM" => Color.Warning,
        _        => Color.Success,
    };

    private string FindingClass(string sev) => sev switch
    {
        "HIGH"   => "finding-high",
        "MEDIUM" => "finding-medium",
        _        => "finding-low",
    };

    private record PerformanceFinding(string Title, string Detail, string Severity);
    private record WellHistoryItem(string Event, string Date, string User);
}
