@page "/production/intervention"
@using Beep.OilandGas.Models.Data.WorkOrder
@inject ApiClient ApiClient
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IProductionServiceClient ProductionService

<PageTitle>Decide Well Interventions</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @if (_isLoading) { <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" /> }

    @* ── Header ──────────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Decide Well Interventions</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Authorise workover and stimulation operations</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.Build">Production</MudChip>
            </MudStack>
        </MudStack>
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            @if (!string.IsNullOrWhiteSpace(ReturnTo))
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           Href="@ReturnTo">
                    Back to Optimizer
                </MudButton>
            }
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenNewIntervention">
                New Intervention
            </MudButton>
        </MudStack>
    </MudStack>

    @* ── View: candidate list vs detail ─────────────────────────────────── *@
    @if (_selectedIntervention == null)
    {
        @* ── Candidate list ────────────────────────────────────────────── *@
        <MudGrid Spacing="3">
            <MudItem xs="12">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.subtitle1">Active Intervention Candidates</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent Class="pa-0">
                        <MudDataGrid T="InterventionCandidate" Items="@_candidates" Dense="true"
                                     Hover="true" RowClick="@OnCandidateClick" ReadOnly="true">
                            <Columns>
                                <PropertyColumn Property="c => c.WellName" Title="Well" />
                                <TemplateColumn Title="Type">
                                    <CellTemplate>
                                        <MudChip T="string" Size="Size.Small"
                                                 Color="@TypeColor(context.Item.InterventionType)">
                                            @context.Item.InterventionType
                                        </MudChip>
                                    </CellTemplate>
                                </TemplateColumn>
                                <PropertyColumn Property="c => c.Problem" Title="Problem" />
                                <PropertyColumn Property="c => c.DeferredBopd" Title="Deferred (BOPD)" Format="N0" />
                                <PropertyColumn Property="c => c.EstCostUsd" Title="Est. Cost ($K)" Format="N0" />
                                <TemplateColumn Title="Priority">
                                    <CellTemplate>
                                        <MudChip T="string" Size="Size.Small"
                                                 Color="@PriorityColor(context.Item.Priority)">
                                            @context.Item.Priority
                                        </MudChip>
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn Title="Status">
                                    <CellTemplate>
                                        <StatusBadge Status="@context.Item.Status" />
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn>
                                    <CellTemplate>
                                        <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary">
                                            Review →
                                        </MudButton>
                                    </CellTemplate>
                                </TemplateColumn>
                            </Columns>
                        </MudDataGrid>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>
    }
    else
    {
        @* ── Decision Page for selected intervention ─────────────────────── *@
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
            <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="BackToList">
                Back to List
            </MudButton>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                / @_selectedIntervention.WellName / @_selectedIntervention.InterventionType
            </MudText>
        </MudStack>

        <MudGrid Spacing="3">

            @* LEFT — Supporting data (8 cols) *@
            <MudItem xs="12" lg="8">
                <MudStack Spacing="3">

                    @* Context banner *@
                    <MudPaper Elevation="2" Class="pa-4">
                        <MudGrid Spacing="2">
                            <MudItem xs="12">
                                <MudText Typo="Typo.h6">
                                    Decision: @_selectedIntervention.InterventionType — @_selectedIntervention.WellName
                                </MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">
                                    @_selectedIntervention.ProblemDescription
                                </MudText>
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Deferred Production</MudText>
                                <MudText Typo="Typo.h6" Color="Color.Error">@_selectedIntervention.DeferredBopd.ToString("N0") BOPD</MudText>
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Days Deferred</MudText>
                                <MudText Typo="Typo.h6" Color="Color.Warning">@_selectedIntervention.DaysDeferred days</MudText>
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Lost Revenue</MudText>
                                <MudText Typo="Typo.h6">$@((_selectedIntervention.DeferredBopd * _selectedIntervention.DaysDeferred * 70 / 1000).ToString("N0"))K</MudText>
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Est. Cost</MudText>
                                <MudText Typo="Typo.h6">$@_selectedIntervention.EstCostUsd.ToString("N0")K</MudText>
                            </MudItem>
                        </MudGrid>
                    </MudPaper>

                    @* Supporting data tabs *@
                    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true">
                        <MudTabPanel Text="Production History">
                            <MudPaper Elevation="0" Class="pa-3">
                                <MudChart ChartType="ChartType.Line"
                                          ChartSeries="@_wellRateSeries"
                                          XAxisLabels="@_wellRateLabels"
                                          Width="100%" Height="220px" />
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                                    Rate drop started @_selectedIntervention.OnsetDate — @_selectedIntervention.RootCause
                                </MudText>
                            </MudPaper>
                        </MudTabPanel>
                        <MudTabPanel Text="Diagnostics">
                            <MudPaper Elevation="0" Class="pa-3">
                                <MudList T="DiagnosticItem" Dense="true">
                                    @foreach (var d in _diagnostics)
                                    {
                                        <MudListItem T="DiagnosticItem" Value="d">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                                <MudText Typo="Typo.body2">@d.Parameter</MudText>
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                    <MudText Typo="Typo.body2">@d.Value</MudText>
                                                    <MudChip T="string" Size="Size.Small"
                                                             Color="@(d.IsAbnormal ? Color.Warning : Color.Success)">
                                                        @(d.IsAbnormal ? "Abnormal" : "Normal")
                                                    </MudChip>
                                                </MudStack>
                                            </MudStack>
                                        </MudListItem>
                                        <MudDivider />
                                    }
                                </MudList>
                            </MudPaper>
                        </MudTabPanel>
                        <MudTabPanel Text="Similar Past Cases">
                            <MudPaper Elevation="0" Class="pa-3">
                                <MudList T="HistoricalCase" Dense="true">
                                    @foreach (var c in _historicalCases)
                                    {
                                        <MudListItem T="HistoricalCase" Value="c">
                                            <MudStack Spacing="0">
                                                <MudText Typo="Typo.body2">@c.Well — @c.InterventionType (@c.Date)</MudText>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                    Uplift: @c.UpliftBopd BOPD · Cost: $@c.CostUsdK K · Success: @c.Outcome
                                                </MudText>
                                            </MudStack>
                                        </MudListItem>
                                        <MudDivider />
                                    }
                                </MudList>
                            </MudPaper>
                        </MudTabPanel>
                    </MudTabs>

                </MudStack>
            </MudItem>

            @* RIGHT — Recommendation + Decision (4 cols) *@
            <MudItem xs="12" lg="4">
                <MudStack Spacing="3">

                    @* Recommendation *@
                    <MudCard Elevation="2">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.Lightbulb" Color="Color.Warning" Size="Size.Small" />
                                    <MudText Typo="Typo.subtitle1">Recommendation</MudText>
                                </MudStack>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudAlert Severity="Severity.Warning" Class="mb-3">
                                <strong>@_selectedIntervention.RecommendedAction</strong>
                            </MudAlert>
                            <MudList T="string" Dense="true">
                                <MudListItem T="string" Value="@("scope")">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Scope</MudText>
                                    <MudText Typo="Typo.body2">@_selectedIntervention.Scope</MudText>
                                </MudListItem>
                                <MudListItem T="string" Value="@("duration")">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Est. Duration</MudText>
                                    <MudText Typo="Typo.body2">@_selectedIntervention.EstDurationDays days</MudText>
                                </MudListItem>
                                <MudListItem T="string" Value="@("payout")">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Payout Period</MudText>
                                    <MudText Typo="Typo.body2">@_selectedIntervention.PayoutMonths months</MudText>
                                </MudListItem>
                            </MudList>
                        </MudCardContent>
                    </MudCard>

                    @* Decision panel *@
                    @if (!string.IsNullOrWhiteSpace(_selectedIntervention.WorkOrderId) || !string.IsNullOrWhiteSpace(_selectedIntervention.AfeNumber))
                    {
                        <MudCard Elevation="2">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.subtitle1">Linked Downstream Records</MudText>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudStack Spacing="2">
                                    @if (!string.IsNullOrWhiteSpace(_selectedIntervention.WorkOrderId))
                                    {
                                        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                                   StartIcon="@Icons.Material.Filled.BuildCircle"
                                                   Href="@GetLinkedWorkOrderHref(_selectedIntervention.WorkOrderId)">
                                            Open Work Order @_selectedIntervention.WorkOrderId
                                        </MudButton>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(_selectedIntervention.AfeNumber))
                                    {
                                        <MudButton Variant="Variant.Outlined" Color="Color.Success"
                                                   StartIcon="@Icons.Material.Filled.RequestQuote"
                                                   Href="@GetLinkedAfeHref(_selectedIntervention.AfeNumber)">
                                            Open AFE @_selectedIntervention.AfeNumber
                                        </MudButton>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(_selectedIntervention.AbandonmentId))
                                    {
                                        <MudButton Variant="Variant.Outlined" Color="Color.Error"
                                                   StartIcon="@Icons.Material.Filled.ArrowForward"
                                                   Href="@GetLinkedDecommissioningHref(_selectedIntervention.WellId, _selectedIntervention.AbandonmentId, _selectedIntervention.ProcessInstanceId)">
                                            Open P&amp;A Programme @_selectedIntervention.AbandonmentId
                                        </MudButton>
                                    }
                                </MudStack>
                            </MudCardContent>
                        </MudCard>
                    }

                    <MudCard Elevation="3">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle1">Make Decision</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudTextField @bind-Value="_decisionNote" Label="Decision Note / Rationale"
                                          Lines="3" Variant="Variant.Outlined" Class="mb-3"
                                          Placeholder="Required before approving or deferring…" />
                            <MudStack Spacing="2">
                                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Success"
                                           StartIcon="@Icons.Material.Filled.CheckCircle"
                                           Disabled="@string.IsNullOrWhiteSpace(_decisionNote)"
                                           OnClick="ApproveIntervention">
                                    Approve &amp; Schedule
                                </MudButton>
                                <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Warning"
                                           StartIcon="@Icons.Material.Filled.PauseCircle"
                                           Disabled="@string.IsNullOrWhiteSpace(_decisionNote)"
                                           OnClick="DeferIntervention">
                                    Defer — Monitor
                                </MudButton>
                                @if (string.IsNullOrWhiteSpace(_selectedIntervention.AbandonmentId))
                                {
                                    <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Error"
                                               StartIcon="@Icons.Material.Filled.ArrowForward"
                                               Disabled="@string.IsNullOrWhiteSpace(_decisionNote)"
                                               OnClick="TransitionToDecommissioning">
                                        Transition to P&amp;A
                                    </MudButton>
                                }
                                else
                                {
                                    <MudButton FullWidth="true" Variant="Variant.Text" Color="Color.Error"
                                               StartIcon="@Icons.Material.Filled.OpenInNew"
                                               Href="@GetLinkedDecommissioningHref(_selectedIntervention.WellId, _selectedIntervention.AbandonmentId, _selectedIntervention.ProcessInstanceId)">
                                        Open Existing P&amp;A Programme
                                    </MudButton>
                                }
                                <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Error"
                                           StartIcon="@Icons.Material.Filled.Cancel"
                                           OnClick="RejectIntervention">
                                    Reject / Close
                                </MudButton>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>

                </MudStack>
            </MudItem>

        </MudGrid>
    }

</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "wellId")]
    public string? WellId { get; set; }

    [SupplyParameterFromQuery(Name = "returnTo")]
    public string? ReturnTo { get; set; }

    private string _fieldName = string.Empty;
    private string _decisionNote = "";
    private InterventionDetail? _selectedIntervention;

    private List<InterventionCandidate> _candidates = new();
    private List<DiagnosticItem>          _diagnostics = new();
    private List<HistoricalCase>          _historicalCases = new();
    private List<ChartSeries<double>>     _wellRateSeries = new();
    private string[]                      _wellRateLabels = Array.Empty<string>();
    private bool                          _isLoading;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summary = await ApiClient.GetAsync<FieldLifecycleSummary>("/api/field/current/summary");
            if (summary != null)
                _fieldName = summary.FieldName ?? _fieldName;
        }
        catch { /* field name is non-critical */ }

        _isLoading = true;
        try
        {
            var dtos = await ProductionService.GetInterventionCandidatesAsync();
            _candidates = (dtos ?? new())
                .Select(d => new InterventionCandidate(
                    d.WellId, d.WellName, d.InterventionType, d.Problem,
                    d.DeferredBopd, d.EstDaysSinceOnset, d.Priority, d.Status, d.EstCostUsd,
                    d.WorkOrderId, d.AfeId, d.AfeNumber, d.AbandonmentId, d.ProcessInstanceId))
                .ToList();
            if (!string.IsNullOrWhiteSpace(WellId))
            {
                var match = _candidates.FirstOrDefault(c => c.WellId == WellId);
                if (match != null) await SelectCandidateAsync(match);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Error loading candidates.", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OnCandidateClick(DataGridRowClickEventArgs<InterventionCandidate> args) =>
        _ = SelectCandidateAsync(args.Item);

    private async Task SelectCandidateAsync(InterventionCandidate c)
    {
        _selectedIntervention = new InterventionDetail(
            WellId:             c.WellId,
            WellName:           c.WellName,
            InterventionType:   c.InterventionType,
            Problem:            c.Problem,
            ProblemDescription: $"{c.Problem}. Work request raised {c.EstDaysSinceOnset} days ago.",
            DeferredBopd:       c.DeferredBopd,
            DaysDeferred:       c.EstDaysSinceOnset,
            EstCostUsd:         c.EstCostUsd,
            OnsetDate:          DateTime.UtcNow.AddDays(-c.EstDaysSinceOnset).ToString("dd MMM yyyy"),
            RootCause:          "Refer to well diagnostic data below",
            RecommendedAction:  $"Proceed with {c.InterventionType}",
            Scope:              $"{c.InterventionType} scope to be defined by well engineer",
            EstDurationDays:    7,
            PayoutMonths:       2,
            WorkOrderId:        c.WorkOrderId,
            AfeId:              c.AfeId,
            AfeNumber:          c.AfeNumber,
            AbandonmentId:      c.AbandonmentId,
            ProcessInstanceId:  c.ProcessInstanceId
        );
        _decisionNote = "";
        _diagnostics = new();
        _wellRateSeries = new();
        _wellRateLabels = Array.Empty<string>();
        try
        {
            var perf = await ProductionService.GetWellPerformanceAsync(c.WellId);
            if (perf?.WellTests != null)
            {
                var latest = perf.WellTests
                    .OrderByDescending(t => t.TestDate ?? t.TestStartDate ?? t.TestEndDate ?? DateTime.MinValue)
                    .FirstOrDefault();
                if (latest != null)
                {
                    _diagnostics.Add(new("Test Date",  latest.TestDate?.ToString("yyyy-MM-dd") ?? "N/A", false));
                    _diagnostics.Add(new("Test Type",  latest.TestType ?? "N/A", false));
                    _diagnostics.Add(new("Well Status", perf.Status ?? "UNKNOWN", perf.Status != "ACTIVE"));
                }
            }
        }
        catch { /* diagnostics are supplemental — do not block the decision flow */ }
        StateHasChanged();
    }

    private void BackToList()
    {
        _selectedIntervention = null;
        _decisionNote = "";
        _diagnostics = new();
        _wellRateSeries = new();
    }

    private void OpenNewIntervention()
    {
        var wellId = _selectedIntervention?.WellId ?? WellId;
        var title = _selectedIntervention?.RecommendedAction ?? "Intervention follow-up";
        var description = _selectedIntervention?.ProblemDescription ?? "Create an intervention work order for the selected well.";
        var query = new List<string> { "openCreate=true", $"subType={Uri.EscapeDataString(WorkOrderSubType.Corrective)}" };

        if (!string.IsNullOrWhiteSpace(wellId))
            query.Add($"wellId={Uri.EscapeDataString(wellId)}");

        if (!string.IsNullOrWhiteSpace(title))
            query.Add($"title={Uri.EscapeDataString(title)}");

        if (!string.IsNullOrWhiteSpace(description))
            query.Add($"description={Uri.EscapeDataString(description)}");

        if (!string.IsNullOrWhiteSpace(ReturnTo))
            query.Add($"returnTo={Uri.EscapeDataString(ReturnTo)}");

        NavigationManager.NavigateTo($"/ppdm39/workorder?{string.Join("&", query)}");
    }

    private async Task ApproveIntervention()
    {
        if (_selectedIntervention == null) return;
        try
        {
            var result = await ProductionService.RecordInterventionDecisionAsync(
                _selectedIntervention.WellId,
                new ProductionInterventionDecisionRequest
                {
                    Decision = "Approved",
                    Note = _decisionNote,
                    InterventionType = _selectedIntervention.InterventionType,
                    Problem = _selectedIntervention.ProblemDescription,
                    EstimatedCostUsd = _selectedIntervention.EstCostUsd,
                    CreateWorkOrder = true,
                    LinkAfe = true,
                    WorkOrderId = _selectedIntervention.WorkOrderId,
                    AfeId = _selectedIntervention.AfeId
                });
            if (!result.Success)
            {
                Snackbar.Add("Approval failed.", Severity.Error);
                return;
            }

            Snackbar.Add(result.Message ?? $"Intervention approved for {_selectedIntervention.WellName}.", Severity.Success);

            if (!string.IsNullOrWhiteSpace(result.WorkOrderId))
            {
                NavigationManager.NavigateTo($"/ppdm39/workorder/{Uri.EscapeDataString(result.WorkOrderId)}?returnTo={Uri.EscapeDataString(BuildInterventionReturnTo())}");
                return;
            }

            _selectedIntervention = null;
            await OnInitializedAsync();
        }
        catch (Exception) { Snackbar.Add("Approval failed.", Severity.Error); }
    }

    private async Task TransitionToDecommissioning()
    {
        if (_selectedIntervention == null) return;

        try
        {
            var result = await ProductionService.TransitionToDecommissioningAsync(
                _selectedIntervention.WellId,
                new ProductionDecommissioningTriggerRequest
                {
                    Note = _decisionNote,
                    InterventionType = _selectedIntervention.InterventionType,
                    Problem = _selectedIntervention.ProblemDescription,
                    EstimatedCostUsd = _selectedIntervention.EstCostUsd,
                    AbandonmentType = "PERMANENTLY_ABANDONED",
                    AbandonmentMethod = "CEMENT_PLUG",
                    StartWorkflow = true
                });

            if (!result.Success || string.IsNullOrWhiteSpace(result.AbandonmentId))
            {
                Snackbar.Add("Decommissioning handoff failed.", Severity.Error);
                return;
            }

            Snackbar.Add(
                result.Message ?? $"Decommissioning handoff created for {_selectedIntervention.WellName}.",
                result.WorkflowStarted || result.AlreadyExists ? Severity.Success : Severity.Warning);

            NavigationManager.NavigateTo(
                GetLinkedDecommissioningHref(
                    _selectedIntervention.WellId,
                    result.AbandonmentId,
                    result.ProcessInstanceId,
                    _decisionNote));
        }
        catch (Exception)
        {
            Snackbar.Add("Decommissioning handoff failed.", Severity.Error);
        }
    }

    private async Task DeferIntervention()
    {
        if (_selectedIntervention == null) return;
        try
        {
            var result = await ProductionService.RecordInterventionDecisionAsync(
                _selectedIntervention.WellId,
                new ProductionInterventionDecisionRequest { Decision = "Deferred", Note = _decisionNote });
            if (!result.Success)
            {
                Snackbar.Add("Deferral failed.", Severity.Error);
                return;
            }

            Snackbar.Add($"Intervention deferred — monitoring {_selectedIntervention.WellName}", Severity.Warning);
            _selectedIntervention = null;
            await OnInitializedAsync();
        }
        catch (Exception) { Snackbar.Add("Deferral failed.", Severity.Error); }
    }

    private async Task RejectIntervention()
    {
        if (_selectedIntervention == null) return;
        try
        {
            var result = await ProductionService.RecordInterventionDecisionAsync(
                _selectedIntervention.WellId,
                new ProductionInterventionDecisionRequest { Decision = "Rejected", Note = _decisionNote });
            if (!result.Success)
            {
                Snackbar.Add("Rejection failed.", Severity.Error);
                return;
            }

            Snackbar.Add($"Intervention closed for {_selectedIntervention.WellName}", Severity.Info);
            _selectedIntervention = null;
            await OnInitializedAsync();
        }
        catch (Exception) { Snackbar.Add("Rejection failed.", Severity.Error); }
    }

    private Color TypeColor(string t) => t switch
    {
        "Unplanned Shut-in" => Color.Error,
        "ESP Replacement"   => Color.Warning,
        "Acid Stimulation"  => Color.Info,
        _                   => Color.Default,
    };

    private Color PriorityColor(string p) => p switch
    {
        "HIGH"   => Color.Error,
        "MEDIUM" => Color.Warning,
        _        => Color.Default,
    };

    private record InterventionCandidate(string WellId, string WellName, string InterventionType, string Problem,
        double DeferredBopd, int EstDaysSinceOnset, string Priority, string Status, double EstCostUsd,
        string? WorkOrderId, string? AfeId, string? AfeNumber, string? AbandonmentId, string? ProcessInstanceId);

    private record InterventionDetail(string WellId, string WellName, string InterventionType, string Problem,
        string ProblemDescription, double DeferredBopd, int DaysDeferred, double EstCostUsd, string OnsetDate,
        string RootCause, string RecommendedAction, string Scope, int EstDurationDays, int PayoutMonths,
        string? WorkOrderId, string? AfeId, string? AfeNumber, string? AbandonmentId, string? ProcessInstanceId);

    private record DiagnosticItem(string Parameter, string Value, bool IsAbnormal);
    private record HistoricalCase(string Well, string InterventionType, string Date, int UpliftBopd, int CostUsdK, string Outcome);

    private string GetLinkedWorkOrderHref(string workOrderId) =>
        $"/ppdm39/workorder/{Uri.EscapeDataString(workOrderId)}?returnTo={Uri.EscapeDataString(BuildInterventionReturnTo())}";

    private string GetLinkedAfeHref(string afeNumber)
    {
        var href = $"/economics/afe?afeNumber={Uri.EscapeDataString(afeNumber)}";
        return href + $"&returnTo={Uri.EscapeDataString(BuildInterventionReturnTo())}";
    }

    private string GetLinkedDecommissioningHref(string wellId, string? abandonmentId, string? processInstanceId, string? handoffReason = null)
    {
        var query = new List<string>
        {
            $"wellId={Uri.EscapeDataString(wellId)}",
            "sourceProcess=production-intervention",
            $"returnTo={Uri.EscapeDataString(BuildInterventionReturnTo())}"
        };

        if (!string.IsNullOrWhiteSpace(abandonmentId))
            query.Add($"abandonmentId={Uri.EscapeDataString(abandonmentId)}");

        if (!string.IsNullOrWhiteSpace(processInstanceId))
            query.Add($"processInstanceId={Uri.EscapeDataString(processInstanceId)}");

        if (!string.IsNullOrWhiteSpace(handoffReason))
            query.Add($"handoffReason={Uri.EscapeDataString(handoffReason)}");

        return "/decommissioning/well-pa?" + string.Join("&", query);
    }

    private string BuildInterventionReturnTo()
    {
        var query = new List<string>();
        var wellId = _selectedIntervention?.WellId ?? WellId;

        if (!string.IsNullOrWhiteSpace(wellId))
            query.Add($"wellId={Uri.EscapeDataString(wellId)}");

        if (!string.IsNullOrWhiteSpace(ReturnTo))
            query.Add($"returnTo={Uri.EscapeDataString(ReturnTo)}");

        return query.Count == 0
            ? "/production/intervention"
            : "/production/intervention?" + string.Join("&", query);
    }
}
