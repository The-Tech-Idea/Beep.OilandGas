@page "/ppdm39/production/forecasts"
@using Beep.OilandGas.Models.Data
@using Beep.OilandGas.Models.Data.Calculations
@using Beep.OilandGas.Models.Core.Interfaces
@using Beep.OilandGas.Client.App
@using System.Security.Claims
@inject ApiClient ApiClient
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ICalculationServiceClient CalculationService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Track Production Forecasts</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @* ── Header ──────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Track Production Forecasts</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Decline-curve and forecast models</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Success"
                         Icon="@Icons.Material.Filled.ShowChart">Production</MudChip>
            </MudStack>
        </MudStack>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog">
            Create Forecast
        </MudButton>
    </MudStack>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }

    @* ── KPI Row ─────────────────────────────────────────────────────── *@
    <MudGrid Class="mb-4" Spacing="3">
        <MudItem xs="12" sm="6" md="4">
            <KpiCard Label="Total Forecasts" Value="@((_forecasts?.Count ?? 0).ToString())"
                     ValueColor="Color.Primary" Icon="@Icons.Material.Filled.ShowChart"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default"
                     TrendText="All forecast runs" />
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <KpiCard Label="Active"
                     Value="@((_forecasts?.Count(f => (f.Status ?? "Active") == "Active") ?? 0).ToString())"
                     ValueColor="Color.Success" Icon="@Icons.Material.Filled.PlayArrow"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default"
                     TrendText="Currently active" />
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <KpiCard Label="Archived"
                     Value="@((_forecasts?.Count(f => (f.Status ?? "Active") != "Active") ?? 0).ToString())"
                     ValueColor="Color.Default" Icon="@Icons.Material.Filled.Archive"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default"
                     TrendText="Superseded or archived" />
        </MudItem>
    </MudGrid>

    @* ── Forecasts Grid ───────────────────────────────────────────────── *@
    <MudCard Elevation="2">
        <MudCardContent Class="pa-0">
            @if (_forecasts != null && _forecasts.Any())
            {
                <MudDataGrid T="ProductionForecastResult" Items="@_forecasts" Dense="true" Hover="true" Striped="true"
                             SortMode="SortMode.Multiple" Filterable="true">
                    <Columns>
                        <PropertyColumn Property="f => f.ForecastId" Title="Forecast ID" />
                        <TemplateColumn Title="Method">
                            <CellTemplate>
                                <MudText Typo="Typo.body2">@context.Item.ForecastMethod.ToString()</MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Forecast Date">
                            <CellTemplate>
                                <MudText Typo="Typo.body2">
                                    @context.Item.ForecastDate.ToString("dd MMM yyyy")
                                </MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="End Date">
                            <CellTemplate>
                                <MudText Typo="Typo.body2">
                                    @((context.Item.ForecastPoints != null && context.Item.ForecastPoints.Any())
                                        ? context.Item.ForecastPoints.Last().Date.ToString("dd MMM yyyy")
                                        : "—")
                                </MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Status">
                            <CellTemplate>
                                <StatusBadge Status="@(context.Item.Status ?? "Active")" />
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                    <NoRecordsContent>
                        <MudStack AlignItems="AlignItems.Center" Class="pa-6">
                            <MudIcon Icon="@Icons.Material.Filled.ShowChart" Color="Color.Secondary"
                                     Class="og-icon-xl" />
                            <MudText Typo="Typo.body1">No forecasts match the current filter</MudText>
                        </MudStack>
                    </NoRecordsContent>
                </MudDataGrid>
            }
            else if (!_isLoading)
            {
                <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                    <MudIcon Icon="@Icons.Material.Filled.ShowChart" Color="Color.Secondary"
                             Class="og-icon-xl" />
                    <MudText Typo="Typo.h6">No forecasts generated yet</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Generate a decline-curve forecast for this field.
                    </MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="OpenCreateDialog" Class="mt-2">
                        Create First Forecast
                    </MudButton>
                </MudStack>
            }
        </MudCardContent>
    </MudCard>

</MudContainer>

@code {
    private string _fieldName = string.Empty;
    private List<ProductionForecastResult>? _forecasts;
    private bool _isLoading = false;
    private string? _currentUserId;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summary = await ApiClient.GetAsync<FieldLifecycleSummary>("/api/field/current/summary");
            if (summary != null)
                _fieldName = summary.FieldName ?? _fieldName;
        }
        catch { /* field name is non-critical */ }

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _currentUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "system";
        await LoadForecasts();
    }

    private async Task LoadForecasts()
    {
        _isLoading = true;
        try
        {
            // Try to load from API endpoint if it exists, otherwise use empty list
            // The service client doesn't have a method to list all forecasts yet
            var forecasts = await ApiClient.GetAsync<List<ProductionForecastResult>>("/api/production/field/forecasts") ?? new();            _forecasts = forecasts ?? new List<ProductionForecastResult>();
        }
        catch (Exception)
        {
            // If endpoint doesn't exist, start with empty list
            _forecasts = new List<ProductionForecastResult>();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OpenCreateDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ProductionForecastDialog>("Create Production Forecast", options);
        var result = await dialog.Result;

        if (result?.Canceled == false && result.Data is Dictionary<string, object> forecastData)
        {
            try
            {
                // Extract forecast parameters from dialog
                var forecastMethod = forecastData.ContainsKey("FORECAST_TYPE") ? forecastData["FORECAST_TYPE"]?.ToString() ?? "Exponential" : "Exponential";
                var forecastPeriod = 12; // Default 12 months, could be from dialog
                var fieldId = (string?)null; // Could be from current field context
                var wellUWI = (string?)null; // Could be selected from dialog

                // Generate forecast using service client
                var forecast = await CalculationService.GenerateForecastAsync(wellUWI, fieldId, forecastMethod, forecastPeriod);
                
                // Save the forecast
                var saved = await CalculationService.SaveForecastAsync(forecast, _currentUserId);
                
                if (saved)
                {
                    Snackbar.Add("Production forecast created and saved successfully", Severity.Success);
                    await LoadForecasts();
                }
                else
                {
                    Snackbar.Add("Forecast generated but failed to save", Severity.Warning);
                }
            }
            catch (Exception)
            {
                Snackbar.Add("Error creating production forecast.", Severity.Error);
            }
        }
    }

    private string GetPropertyValue(ProductionForecastResult forecast, string propertyName)
    {
        return propertyName switch
        {
            "FORECAST_ID" => forecast.ForecastId,
            "FORECAST_NAME" => $"Forecast {forecast.ForecastMethod}",
            "FORECAST_TYPE" => forecast.ForecastMethod.ToString(),
            "START_DATE" => forecast.ForecastDate.ToString("yyyy-MM-dd"),
            "END_DATE" => forecast.ForecastPoints.Any() ? forecast.ForecastPoints.Last().Date.ToString("yyyy-MM-dd") : "N/A",
            "FORECAST_STATUS" => forecast.Status ?? "Active",
            _ => "N/A"
        };
    }

    private string FormatDate(string? dateStr)
    {
        if (string.IsNullOrEmpty(dateStr) || dateStr == "N/A")
            return "N/A";

        if (DateTime.TryParse(dateStr, out var date))
            return date.ToString("yyyy-MM-dd");

        return dateStr;
    }
}

