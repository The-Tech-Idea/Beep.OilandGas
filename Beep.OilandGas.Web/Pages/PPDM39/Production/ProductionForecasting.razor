@page "/production/forecasting"
@using Beep.OilandGas.Models.Data.Calculations
@using Beep.OilandGas.Web.Services
@inject ISnackbar Snackbar
@inject ApiClient ApiClient
@inject IClientFileExportService ExportService
@using Beep.OilandGas.Models.Data.ProductionForecasting
@inject ICalculationServiceClient CalculationService
@inject IDevelopmentServiceClient DevelopmentService
@inject IProductionServiceClient ProductionService
@inject ILifeCycleService LifeCycleService

<PageTitle>Production Forecasting</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @if (_loading) { <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" /> }
    @if (_running) { <MudProgressLinear Indeterminate="true" Color="Color.Warning" Class="mb-2" /> }

    @* ── Header ──────────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Forecast Field Production</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — DCA-based decline curves and scenario planning</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.TrendingDown">Production</MudChip>
            </MudStack>
        </MudStack>
        <MudButton Variant="Variant.Outlined" Color="Color.Default"
                   StartIcon="@Icons.Material.Filled.Download"
                   OnClick="ExportForecast">
            Export
        </MudButton>
    </MudStack>

    @* ── Scenario selector + DCA parameters ─────────────────────────────── *@
    <MudPaper Elevation="1" Class="pa-3 mb-4">
        <MudGrid Spacing="2" AlignItems="AlignItems.Center">
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="string" Label="Active Scenario" @bind-Value="_activeScenario"
                           Variant="Variant.Outlined">
                    <MudSelectItem Value="@("Base")">Base Case</MudSelectItem>
                    <MudSelectItem Value="@("High")">High Case (+15%)</MudSelectItem>
                    <MudSelectItem Value="@("Low")">Low Case (-20%)</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="string" Label="Decline Type" @bind-Value="_declineType"
                           Variant="Variant.Outlined">
                    <MudSelectItem Value="@("Hyperbolic")">Hyperbolic</MudSelectItem>
                    <MudSelectItem Value="@("Exponential")">Exponential</MudSelectItem>
                    <MudSelectItem Value="@("Harmonic")">Harmonic</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudNumericField @bind-Value="_di" Label="Di (%/yr)" Variant="Variant.Outlined" Min="1" Max="100" />
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudNumericField @bind-Value="_bFactor" Label="b factor" Variant="Variant.Outlined" Min="0" Max="2" Step="0.1" />
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                           StartIcon="@Icons.Material.Filled.Calculate"
                           OnClick="RunForecast">
                    Run Forecast
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @* ── Scenario KPIs ────────────────────────────────────────────────────── *@
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="1P EUR (Oil)" Value="@_kpi1PEUR.ToString("N0")" Unit="MBBL"
                     ValueColor="Color.Primary" Icon="@Icons.Material.Filled.Storage"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default" TrendText="Proven" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="2P EUR (Oil)" Value="@_kpi2PEUR.ToString("N0")" Unit="MBBL"
                     ValueColor="Color.Success" Icon="@Icons.Material.Filled.Inventory"
                     TrendIcon="@Icons.Material.Filled.TrendingUp" TrendColor="Color.Success" TrendText="+8% vs 2P last yr" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Forecast Rate (2yr)" Value="@_kpiForecastRate.ToString("N0")" Unit="BOPD"
                     ValueColor="Color.Default" Icon="@Icons.Material.Filled.Timeline"
                     TrendIcon="@Icons.Material.Filled.TrendingDown" TrendColor="Color.Warning" TrendText="-14% decline" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Economic Limit" Value="@_kpiEconLimit" Unit=""
                     ValueColor="Color.Warning" Icon="@Icons.Material.Filled.AttachMoney"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default" TrendText="At $50/bbl Opex" />
        </MudItem>
    </MudGrid>

    @* ── Main Content ─────────────────────────────────────────────────────── *@
    <MudGrid Spacing="3">

        @* LEFT — Forecast charts (8 cols) *@
        <MudItem xs="12" lg="8">
            <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true">

                <MudTabPanel Text="Field Rate Forecast">
                    <MudPaper Elevation="0" Class="pa-3">
                        <MudChart ChartType="ChartType.Line"
                                  ChartSeries="@_rateForecastSeries"
                                  XAxisLabels="@_forecastLabels"
                                  Width="100%"
                                  Height="280px" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                            Field oil rate (BOPD) — Historical (solid) + Forecast (dashed) — Base / High / Low cases
                        </MudText>
                    </MudPaper>
                </MudTabPanel>

                <MudTabPanel Text="Cumulative Production">
                    <MudPaper Elevation="0" Class="pa-3">
                        <MudChart ChartType="ChartType.Line"
                                  ChartSeries="@_cumProductionSeries"
                                  XAxisLabels="@_forecastLabels"
                                  Width="100%"
                                  Height="280px" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                            Cumulative oil production (MBBl) — Actual + Forecast by scenario
                        </MudText>
                    </MudPaper>
                </MudTabPanel>

                <MudTabPanel Text="Well-by-Well Forecast">
                    <MudPaper Elevation="0" Class="pa-3">
                        <MudDataGrid T="WellForecastRow" Items="@_wellForecasts" Dense="true" ReadOnly="true" Hover="true">
                            <Columns>
                                <PropertyColumn Property="w => w.WellName" Title="Well" />
                                <PropertyColumn Property="w => w.CurrentRate" Title="Today (BOPD)" Format="N0" />
                                <PropertyColumn Property="w => w.Rate1Yr" Title="1Y (BOPD)" Format="N0" />
                                <PropertyColumn Property="w => w.Rate2Yr" Title="2Y (BOPD)" Format="N0" />
                                <PropertyColumn Property="w => w.RemainingEur" Title="Rem. EUR (MBBL)" Format="N0" />
                                <PropertyColumn Property="w => w.EconLimitYr" Title="Econ Limit (yr)" />
                                <TemplateColumn Title="DCA Fit">
                                    <CellTemplate>
                                        <MudChip T="string" Size="Size.Small"
                                                 Color="@(context.Item.DcaQuality == "Good" ? Color.Success : context.Item.DcaQuality == "Fair" ? Color.Warning : Color.Error)">
                                            @context.Item.DcaQuality
                                        </MudChip>
                                    </CellTemplate>
                                </TemplateColumn>
                            </Columns>
                        </MudDataGrid>
                    </MudPaper>
                </MudTabPanel>

            </MudTabs>
        </MudItem>

        @* RIGHT — Reserves reconciliation + scenario summary (4 cols) *@
        <MudItem xs="12" lg="4">
            <MudStack Spacing="3">

                @* Scenario comparison *@
                <ComparisonGridCard TItem="ScenarioRow" Items="@_scenarios" Title="Scenario Comparison">
                    <ColumnContent>
                        <PropertyColumn T="ScenarioRow" TProperty="string" Property="s => s.Name" Title="Scenario" />
                        <TemplateColumn T="ScenarioRow" Title="EUR (MBBL)">
                            <CellTemplate><MudText Typo="Typo.body2">@context.Item.EurMbbl.ToString("N0")</MudText></CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn T="ScenarioRow" Title="2Y Rate">
                            <CellTemplate><MudText Typo="Typo.body2">@context.Item.TwoYrRate.ToString("N0")</MudText></CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn T="ScenarioRow" Title="NPV">
                            <CellTemplate><MudText Typo="Typo.body2">$@context.Item.NpvMm.ToString("N0")MM</MudText></CellTemplate>
                        </TemplateColumn>
                    </ColumnContent>
                </ComparisonGridCard>

                @* Reserves reconciliation *@
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.subtitle1">Reserves Reconciliation (2P)</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent Class="pa-0">
                        <MudList T="ReconItem" Dense="true">
                            @foreach (var r in _reconciliation)
                            {
                                <MudListItem T="ReconItem" Value="r">
                                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                                        <MudText Typo="Typo.body2">@r.Label</MudText>
                                        <MudText Typo="Typo.body2"
                                                 Color="@(r.Value >= 0 ? Color.Default : Color.Error)">
                                            <strong>@r.Value.ToString("+N0;-N0") MBBL</strong>
                                        </MudText>
                                    </MudStack>
                                </MudListItem>
                                <MudDivider />
                            }
                        </MudList>
                    </MudCardContent>
                </MudCard>

                @* Actions *@
                <MudCard Elevation="2">
                    <MudCardContent>
                        <MudStack Spacing="2">
                            <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Save"
                                       OnClick="SaveForecast">
                                Save Forecast Revision
                            </MudButton>
                            <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Secondary"
                                       StartIcon="@Icons.Material.Filled.BarChart"
                                       Href="/reservoir/reserves">
                                Update Reserves Estimate
                            </MudButton>
                        </MudStack>
                    </MudCardContent>
                </MudCard>

            </MudStack>
        </MudItem>

    </MudGrid>

</MudContainer>

@code {
    private string _fieldName = string.Empty;
    private string? _currentFieldId;
    private string _activeScenario = "Base";
    private string _declineType = "Hyperbolic";
    private double _di = 18;
    private double _bFactor = 0.5;
    private bool _loading = true;
    private bool _running;
    private ProductionForecastResult? _latestForecast;

    private double _kpi1PEUR;
    private double _kpi2PEUR;
    private double _kpiForecastRate;
    private string _kpiEconLimit = "—";

    private List<ScenarioRow> _scenarios = new()
    {
        new("High",  0, 0, 0),
        new("Base",  0, 0, 0),
        new("Low",   0, 0, 0),
    };

    private List<ReconItem> _reconciliation = new()
    {
        new("Opening 2P",     0),
        new("Production YTD", 0),
        new("Closing 2P",     0),
    };

    private List<WellForecastRow> _wellForecasts = new();
    private List<ChartSeries<double>> _rateForecastSeries = new();
    private List<ChartSeries<double>> _cumProductionSeries = new();
    private string[] _forecastLabels = Array.Empty<string>();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var fieldInfo = await LifeCycleService.GetCurrentFieldAsync();
            if (fieldInfo != null)
            {
                _currentFieldId = fieldInfo.FieldId;
                _fieldName = fieldInfo.FieldName ?? _fieldName;
            }
        }
        catch { /* field name is non-critical */ }

        _loading = true;
        try
        {
            var wells = await DevelopmentService.GetWellsAsync();
            var productionWells = await ProductionService.GetDashboardWellsAsync();
            var productionWellLookup = productionWells
                .Where(w => !string.IsNullOrWhiteSpace(w.WellId))
                .GroupBy(w => w.WellId)
                .ToDictionary(g => g.Key, g => g.First());

            _wellForecasts = wells
                .Where(w => !string.IsNullOrWhiteSpace(w.UWI))
                .Select(w =>
                {
                    var wellId = w.UWI ?? string.Empty;
                    productionWellLookup.TryGetValue(wellId, out var productionWell);

                    return new WellForecastRow(
                        wellId,
                        w.WELL_NAME ?? wellId,
                        productionWell?.OilRate ?? 0,
                        0,
                        0,
                        0,
                        "—",
                        productionWell == null ? "Pending" : "Seeded");
                })
                .ToList();
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to load wells.", Severity.Warning);
        }
        finally { _loading = false; }
    }

    private async Task RunForecastAsync()
    {
        _running = true;
        try
        {
            var result = await CalculationService.GenerateForecastAsync(null, _currentFieldId, _declineType, 24);
            _latestForecast = result;

            if (result.ForecastPoints.Count > 0)
            {
                var pts = result.ForecastPoints;
                _forecastLabels = pts.Select(p => p.Date.ToString("MMM''yy")).ToArray();
                var baseRates = pts.Select(p => (double)(p.OilRate ?? 0m)).ToArray();
                var highRates = baseRates.Select(rate => rate * 1.15d).ToArray();
                var lowRates = baseRates.Select(rate => rate * 0.80d).ToArray();
                var baseCum = pts.Select(p => (double)(p.CumulativeOil ?? 0m)).ToArray();
                var highCum = baseCum.Select(volume => volume * 1.15d).ToArray();
                var lowCum = baseCum.Select(volume => volume * 0.80d).ToArray();

                _rateForecastSeries = new List<ChartSeries<double>>
                {
                    new ChartSeries<double> { Name = "High Case", Data = highRates },
                    new ChartSeries<double>
                    {
                        Name = "Base Case",
                        Data = baseRates
                    },
                    new ChartSeries<double> { Name = "Low Case", Data = lowRates }
                };

                _cumProductionSeries = new List<ChartSeries<double>>
                {
                    new ChartSeries<double> { Name = "High Case", Data = highCum },
                    new ChartSeries<double> { Name = "Base Case", Data = baseCum },
                    new ChartSeries<double> { Name = "Low Case", Data = lowCum }
                };

                _kpiForecastRate = baseRates.Length > 0 ? baseRates[Math.Min(23, baseRates.Length - 1)] : 0;
                _kpi2PEUR        = (double)result.EstimatedReserves;
                _kpi1PEUR        = _kpi2PEUR * 0.80; // 1P ≈ 80% of 2P (SPE-PRMS conservative estimate)
                _kpiEconLimit    = result.EconomicLimit.HasValue ? $"{result.EconomicLimit.Value:N0} BOPD" : "—";

                UpdateScenarioRows(result, baseRates, highRates, lowRates);
                UpdateReconciliation(result, baseCum);
                UpdateWellForecastRows(result, baseRates);
            }
            Snackbar.Add($"Forecast updated — {_declineType} decline, Di={_di}%/yr, b={_bFactor}", Severity.Success);
        }
        catch (Exception) { Snackbar.Add("Forecast failed.", Severity.Error); }
        finally { _running = false; }
    }

    private void RunForecast()  => _ = RunForecastAsync();
    private void SaveForecast() => _ = SaveForecastAsync();

    private async Task ExportForecast()
    {
        var payload = new
        {
            ExportType = "ProductionForecastPackage",
            ExportedAtUtc = DateTime.UtcNow,
            FieldName = _fieldName,
            Scenario = _activeScenario,
            DeclineType = _declineType,
            Parameters = new
            {
                InitialDeclinePct = _di,
                BFactor = _bFactor
            },
            Summary = new
            {
                OnePEurMbbl = _kpi1PEUR,
                TwoPEurMbbl = _kpi2PEUR,
                ForecastRateTwoYearBopd = _kpiForecastRate,
                EconomicLimit = _kpiEconLimit
            },
            Scenarios = _scenarios.Select(scenario => new
            {
                scenario.Name,
                scenario.EurMbbl,
                scenario.TwoYrRate,
                scenario.NpvMm
            }).ToList(),
            Reconciliation = _reconciliation.Select(item => new
            {
                item.Label,
                item.Value
            }).ToList(),
            WellForecasts = _wellForecasts.Select(forecast => new
            {
                forecast.WellName,
                forecast.CurrentRate,
                forecast.Rate1Yr,
                forecast.Rate2Yr,
                forecast.RemainingEur,
                forecast.EconLimitYr,
                forecast.DcaQuality
            }).ToList()
        };

        await ExportService.DownloadJsonAsync($"production-forecast-{DateTime.UtcNow:yyyyMMdd-HHmmss}", payload);
        Snackbar.Add("Forecast package exported.", Severity.Success);
    }

    private async Task SaveForecastAsync()
    {
        if (_latestForecast == null)
        {
            Snackbar.Add("Run a forecast before saving a revision.", Severity.Warning);
            return;
        }

        try
        {
            var payload = new ProductionForecastResult
            {
                ForecastId = string.IsNullOrWhiteSpace(_latestForecast.ForecastId) ? Guid.NewGuid().ToString() : _latestForecast.ForecastId,
                FieldId = _currentFieldId,
                ForecastDate = DateTime.UtcNow,
                ForecastMethod = ParseForecastType(_declineType),
                ForecastPoints = _latestForecast.ForecastPoints,
                EstimatedReserves = (decimal)_kpi2PEUR,
                EconomicLimit = _latestForecast.EconomicLimit,
                Status = _activeScenario,
                Notes = $"Scenario={_activeScenario}; Di={_di:N1}; b={_bFactor:N2}"
            };
            var saved = await CalculationService.SaveForecastAsync(payload);
            Snackbar.Add(saved ? "Forecast revision saved." : "Save failed.", saved ? Severity.Success : Severity.Error);
        }
        catch (Exception) { Snackbar.Add("Save failed.", Severity.Error); }
    }

    private void UpdateScenarioRows(ProductionForecastResult result, double[] baseRates, double[] highRates, double[] lowRates)
    {
        var baseTwoYearRate = baseRates.Length > 0 ? baseRates[Math.Min(23, baseRates.Length - 1)] : 0;
        var highTwoYearRate = highRates.Length > 0 ? highRates[Math.Min(23, highRates.Length - 1)] : 0;
        var lowTwoYearRate = lowRates.Length > 0 ? lowRates[Math.Min(23, lowRates.Length - 1)] : 0;
        var baseEur = (double)result.EstimatedReserves;

        _scenarios = new List<ScenarioRow>
        {
            new("High", baseEur * 1.15d, highTwoYearRate, 0),
            new("Base", baseEur, baseTwoYearRate, 0),
            new("Low", baseEur * 0.80d, lowTwoYearRate, 0),
        };
    }

    private void UpdateReconciliation(ProductionForecastResult result, double[] cumulativeOil)
    {
        var closing2P = (double)result.EstimatedReserves;
        var opening2P = closing2P;
        var productionYtd = cumulativeOil.Length > 0 ? cumulativeOil[Math.Min(11, cumulativeOil.Length - 1)] / 1000d : 0;

        _reconciliation = new List<ReconItem>
        {
            new("Opening 2P", opening2P),
            new("Production YTD", -productionYtd),
            new("Closing 2P", Math.Max(closing2P - productionYtd, 0)),
        };
    }

    private void UpdateWellForecastRows(ProductionForecastResult result, double[] baseRates)
    {
        if (_wellForecasts.Count == 0)
        {
            return;
        }

        var totalCurrentRate = _wellForecasts.Sum(row => row.CurrentRate);
        var rateAtOneYear = baseRates.Length > 0 ? baseRates[Math.Min(11, baseRates.Length - 1)] : 0;
        var rateAtTwoYears = baseRates.Length > 0 ? baseRates[Math.Min(23, baseRates.Length - 1)] : 0;
        var dcaQuality = GetDcaQuality(result.RSquared);

        _wellForecasts = _wellForecasts
            .Select(row =>
            {
                var share = totalCurrentRate > 0 ? row.CurrentRate / totalCurrentRate : 0;
                var remainingEur = (double)result.EstimatedReserves * share;
                var econLimitYear = result.EconomicLimit.HasValue && rateAtTwoYears > (double)result.EconomicLimit.Value
                    ? ">2"
                    : "2";

                return row with
                {
                    Rate1Yr = rateAtOneYear * share,
                    Rate2Yr = rateAtTwoYears * share,
                    RemainingEur = remainingEur,
                    EconLimitYr = econLimitYear,
                    DcaQuality = dcaQuality
                };
            })
            .ToList();
    }

    private static string GetDcaQuality(decimal? rSquared)
    {
        if (!rSquared.HasValue)
        {
            return "Pending";
        }

        return rSquared.Value switch
        {
            >= 0.85m => "Good",
            >= 0.65m => "Fair",
            _ => "Review"
        };
    }

    private static ForecastType ParseForecastType(string declineType)
    {
        return declineType.Trim().ToUpperInvariant() switch
        {
            "EXPONENTIAL" => ForecastType.Exponential,
            "HARMONIC" => ForecastType.Harmonic,
            "HYPERBOLIC" => ForecastType.Hyperbolic,
            _ => ForecastType.Decline
        };
    }

    private record FieldRefDto(string FieldId, string FieldName);

    private record ScenarioRow(string Name, double EurMbbl, double TwoYrRate, double NpvMm);
    private record ReconItem(string Label, double Value);
    private record WellForecastRow(string WellId, string WellName, double CurrentRate, double Rate1Yr, double Rate2Yr, double RemainingEur, string EconLimitYr, string DcaQuality);
}
