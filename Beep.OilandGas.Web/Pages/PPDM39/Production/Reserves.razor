@page "/ppdm39/production/reserves"
@using Beep.OilandGas.PPDM39.Models
@inject ApiClient ApiClient
@inject ISnackbar Snackbar
@inject IProductionServiceClient ProductionService

<PageTitle>Classify Production Reserves</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @* ── Header *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Classify Production Reserves</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Reserves classifications</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Success"
                         Icon="@Icons.Material.Filled.BarChart">Production</MudChip>
            </MudStack>
        </MudStack>
        <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.AddBox">Record Reserves</MudButton>
    </MudStack>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }

    @* ── KPI Row *@
    <MudGrid Class="mb-4" Spacing="3">
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Total Records" Value="@((_reserves?.Count ?? 0).ToString())"
                     ValueColor="Color.Primary" Icon="@Icons.Material.Filled.BarChart"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default"
                     TrendText="All reserve entries" />
        </MudItem>
    </MudGrid>

    @* ── Reserves Grid *@
    <MudCard Elevation="2">
        <MudCardContent Class="pa-0">
            @if (_reserves != null && _reserves.Any())
            {
                <MudDataGrid T="RESERVE_ENTITY" Items="@_reserves" Dense="true" Hover="true" Striped="true"
                             SortMode="SortMode.Multiple" Filterable="true">
                    <Columns>
                        <PropertyColumn Property="r => r.RESENT_ID" Title="Reserve ID" />
                        <PropertyColumn Property="r => r.RESENT_LONG_NAME" Title="Reserve Name" />
                        <PropertyColumn Property="r => r.PRIMARY_PRODUCT_TYPE" Title="Primary Product" />
                        <TemplateColumn Title="Effective Date">
                            <CellTemplate>
                                <MudText Typo="Typo.body2">@(context.Item.EFFECTIVE_DATE?.ToString("dd MMM yyyy") ?? "—")</MudText>
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                    <NoRecordsContent>
                        <MudStack AlignItems="AlignItems.Center" Class="pa-6">
                            <MudIcon Icon="@Icons.Material.Filled.BarChart" Color="Color.Secondary" Class="og-icon-xl" />
                            <MudText Typo="Typo.body1">No records match the current filter</MudText>
                        </MudStack>
                    </NoRecordsContent>
                </MudDataGrid>
            }
            else if (!_isLoading)
            {
                <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                    <MudIcon Icon="@Icons.Material.Filled.BarChart" Color="Color.Secondary" Class="og-icon-xl" />
                    <MudText Typo="Typo.h6">No reserves data loaded</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">No reserve classification records found for this field.</MudText>
                </MudStack>
            }
        </MudCardContent>
    </MudCard>

</MudContainer>

@code {
    private string _fieldName = string.Empty;
    private List<RESERVE_ENTITY>? _reserves;
    private bool _isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summary = await ApiClient.GetAsync<FieldLifecycleSummary>("/api/field/current/summary");
            if (summary != null)
                _fieldName = summary.FieldName ?? _fieldName;
        }
        catch { /* field name is non-critical */ }

        await LoadReserves();
    }

    private async Task LoadReserves()
    {
        _isLoading = true;
        try
        {
            _reserves = await ProductionService.GetReservesAsync();
        }
        catch (Exception)
        {
            Snackbar.Add("Error loading reserves.", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

}

