@page "/ppdm39/pumps/suckerrodpumping"
@using Beep.OilandGas.Models.Data
@using Beep.OilandGas.Models.Data.Pumps
@using Beep.OilandGas.Models.Core.Interfaces
@using Beep.OilandGas.Client.App
@using Beep.OilandGas.PPDM39.Models
@inject ISnackbar Snackbar
@inject IPumpServiceClient PumpService
@inject ApiClient ApiClient
@inject IDevelopmentServiceClient DevelopmentClient
@inject ILifeCycleService LifeCycleService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Design Sucker Rod Pump System</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Design Sucker Rod Pump System</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — SRP sizing, stroke analysis and performance optimisation</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Icon="@Icons.Material.Filled.SettingsInputComponent">Artificial Lift</MudChip>
            </MudStack>
        </MudStack>
    </MudStack>

    <MudPaper Class="pa-4">
        <MudText Typo="Typo.h6" Class="mb-4">Design Sucker Rod Pump System</MudText>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="@_wellUWI" Label="Well UWI" Variant="Variant.Outlined" Required="true" />
            <MudNumericField @bind-Value="@_wellDepth" Label="Well Depth (ft)" Variant="Variant.Outlined" />
            <MudNumericField @bind-Value="@_tubingDiameter" Label="Tubing Diameter (in)" Variant="Variant.Outlined" />
            <MudNumericField @bind-Value="@_wellheadPressure" Label="Wellhead Pressure (PSI)" Variant="Variant.Outlined" />
            <MudNumericField @bind-Value="@_bottomHolePressure" Label="Bottom Hole Pressure (PSI)" Variant="Variant.Outlined" />
            <MudNumericField @bind-Value="@_desiredFlowRate" Label="Desired Flow Rate (BBL/D)" Variant="Variant.Outlined" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="DesignPump" Disabled="@_isDesigning">
                Design Pump System
            </MudButton>
        </MudStack>

        @if (_isLoading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mt-4" />
        }

        @if (_pumpDesign != null)
        {
            <MudPaper Class="pa-4 mt-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-4">Pump Design Results</MudText>
                <MudStack Spacing="2">
                    <MudText>Design ID: @_pumpDesign.DesignId</MudText>
                    <MudText>Pump Depth: @_pumpDesign.PumpDepth.ToString("F2") ft</MudText>
                    <MudText>Pump Size: @_pumpDesign.PumpSize.ToString("F2")</MudText>
                    <MudText>Stroke Length: @_pumpDesign.StrokeLength.ToString("F2") in</MudText>
                    <MudText>Strokes Per Minute: @_pumpDesign.StrokesPerMinute.ToString("F2")</MudText>
                </MudStack>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4" OnClick="SaveDesign">
                    Save Design
                </MudButton>
            </MudPaper>
        }
    </MudPaper>

    <MudPaper Class="pa-4 mt-4">
        <MudText Typo="Typo.h6" Class="mb-4">Performance Analysis</MudText>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="@_pumpId" Label="Pump ID" Variant="Variant.Outlined" />
            <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="AnalyzePerformance" Disabled="@_isAnalyzing">
                Analyze Performance
            </MudButton>
        </MudStack>

        @if (_performance != null)
        {
            <MudPaper Class="pa-4 mt-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-4">Performance Results</MudText>
                <MudStack Spacing="2">
                    <MudText>Flow Rate: @_performance.FlowRate.ToString("F2") BBL/D</MudText>
                    <MudText>Efficiency: @FormatEfficiency(_performance.Efficiency)</MudText>
                    <MudText>Power Consumption: @_performance.PowerConsumption.ToString("F2") HP</MudText>
                </MudStack>
            </MudPaper>
        }
    </MudPaper>

    @if (_pumpDesign != null || _performance != null)
    {
        <LiftRecommendationCard Title="Lift Workflow Recommendation"
                                Subtitle="SRP candidate review"
                                Icon="@Icons.Material.Filled.SettingsInputComponent"
                                IconColor="Color.Warning"
                                Headline="@GetLiftRecommendationHeadline()"
                                Summary="@GetLiftRecommendationSummary()"
                                ImpactText="@GetLiftRecommendationImpactText()"
                                Severity="@GetLiftRecommendationSeverity()"
                                Facts="@GetLiftRecommendationFacts()"
                                Class="mt-4">
            <Actions>
                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.AutoGraph"
                           Href="@GetWellPerformanceUrl()">
                    Open Well Performance Optimizer
                </MudButton>
                @if (_performance == null && !string.IsNullOrWhiteSpace(_pumpId))
                {
                    <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.Tune"
                               OnClick="AnalyzePerformance"
                               Disabled="@_isAnalyzing">
                        Run Performance Validation
                    </MudButton>
                }
            </Actions>
        </LiftRecommendationCard>
    }
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "wellId")]
    public string? WellId { get; set; }

    private string _fieldName = string.Empty;
    private string _wellUWI = string.Empty;
    private decimal _wellDepth = 5000;
    private decimal _tubingDiameter = 2.5m;
    private decimal _wellheadPressure = 100;
    private decimal _bottomHolePressure = 2000;
    private decimal _desiredFlowRate = 500;
    private string _pumpId = string.Empty;
    private bool _isDesigning = false;
    private bool _isAnalyzing = false;
    private bool _isLoading = false;
    private SuckerRodPumpDesign? _pumpDesign;
    private SuckerRodPumpPerformance? _performance;
    private string? _currentUserId;

    private sealed class WellDto
    {
        public string UWI { get; set; } = string.Empty;
        public string? WELL_NAME { get; set; }
        public decimal? FINAL_TD { get; set; }
        public string? ASSIGNED_FIELD { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        try
        {
            try
            {
                var summary = await LifeCycleService.GetFieldLifecycleSummaryAsync();
                if (summary != null)
                    _fieldName = summary.FieldName ?? _fieldName;
            }
            catch { /* field name is non-critical */ }

            try
            {
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                _currentUserId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "system";

                var wells = (await DevelopmentClient.GetWellsAsync()).Select(MapWell).ToList();
                if (wells.Count > 0)
                {
                    var selectedWell = wells.Find(well => string.Equals(well.UWI, WellId, StringComparison.OrdinalIgnoreCase)) ?? wells[0];
                    _fieldName = selectedWell.ASSIGNED_FIELD ?? _fieldName;
                    _wellUWI = selectedWell.UWI;
                    _wellDepth = selectedWell.FINAL_TD ?? _wellDepth;
                }
            }
            catch (Exception)
            {
                Snackbar.Add("Error loading wells.", Severity.Warning);
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static WellDto MapWell(WELL well)
    {
        return new WellDto
        {
            UWI = well.UWI,
            WELL_NAME = well.WELL_NAME,
            FINAL_TD = well.FINAL_TD,
            ASSIGNED_FIELD = well.ASSIGNED_FIELD
        };
    }

    private async Task DesignPump()
    {
        if (string.IsNullOrEmpty(_wellUWI))
        {
            Snackbar.Add("Please enter a Well UWI", Severity.Warning);
            return;
        }

        _isDesigning = true;
        try
        {
            var wellProperties = new SuckerRodPumpWellProperties
            {
                WellDepth = _wellDepth,
                TubingSize = _tubingDiameter,
                DesiredProductionRate = _desiredFlowRate
            };

            _pumpDesign = await PumpService.DesignSuckerRodPumpSystemAsync(_wellUWI, wellProperties);
            _pumpId = _pumpDesign.DesignId;
            Snackbar.Add("Pump design completed", Severity.Success);
        }
        catch (Exception)
        {
            Snackbar.Add("Error designing pump.", Severity.Error);
        }
        finally
        {
            _isDesigning = false;
        }
    }

    private async Task SaveDesign()
    {
        if (_pumpDesign == null)
        {
            Snackbar.Add("No design to save", Severity.Warning);
            return;
        }

        try
        {
            var saved = await PumpService.SaveSuckerRodPumpDesignAsync(_pumpDesign, _currentUserId);
            if (saved)
            {
                Snackbar.Add("Pump design saved successfully", Severity.Success);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Error saving design.", Severity.Error);
        }
    }

    private async Task AnalyzePerformance()
    {
        if (string.IsNullOrEmpty(_pumpId))
        {
            Snackbar.Add("Please enter a Pump ID", Severity.Warning);
            return;
        }

        _isAnalyzing = true;
        try
        {
            _performance = await PumpService.AnalyzeSuckerRodPumpPerformanceAsync(_pumpId);
            Snackbar.Add("Performance analysis completed", Severity.Success);
        }
        catch (Exception)
        {
            Snackbar.Add("Error analyzing performance.", Severity.Error);
        }
        finally
        {
            _isAnalyzing = false;
        }
    }

    private Severity GetLiftRecommendationSeverity()
    {
        if (_performance != null)
        {
            var efficiency = NormalizeEfficiency(_performance.Efficiency);
            return efficiency >= 70m && _performance.FlowRate >= (_desiredFlowRate * 0.9m) ? Severity.Success : Severity.Warning;
        }

        return Severity.Info;
    }

    private string GetLiftRecommendationHeadline()
    {
        if (_performance != null)
        {
            var efficiency = NormalizeEfficiency(_performance.Efficiency);
            return efficiency >= 70m && _performance.FlowRate >= (_desiredFlowRate * 0.9m)
                ? "Advance sucker-rod candidate for production review"
                : "Tune sucker-rod settings before intervention review";
        }

        return "Validate sucker-rod design against live well underperformance";
    }

    private string GetLiftRecommendationSummary()
    {
        if (_performance != null)
        {
            return $"Performance validation indicates {_performance.FlowRate.ToString("N1")} BBL/D at {FormatEfficiency(_performance.Efficiency)} with {_performance.PowerConsumption.ToString("N1")} HP draw and {_performance.RodLoadPercentage.ToString("N1")}% rod load.";
        }

        if (_pumpDesign != null)
        {
            return $"SRP design is sized for approximately {_pumpDesign.EstimatedCapacity.ToString("N1")} BBL/D using {_pumpDesign.StrokeLength.ToString("N1")} in stroke length at {_pumpDesign.StrokesPerMinute.ToString("N1")} SPM. Run performance validation before field action.";
        }

        return "Generate a sucker-rod design to start the lift recommendation flow.";
    }

    private string GetLiftRecommendationImpactText()
    {
        return "Workflow handoff: compare this SRP candidate against current production deviation before intervention or work-order planning.";
    }

    private IReadOnlyList<RecommendationFactItem> GetLiftRecommendationFacts()
    {
        if (_performance != null)
        {
            return new RecommendationFactItem[]
            {
                new() { Label = "Validated Flow", Value = $"{_performance.FlowRate.ToString("N1")} BBL/D", ValueColor = Color.Success },
                new() { Label = "Efficiency", Value = FormatEfficiency(_performance.Efficiency), ValueColor = Color.Warning },
                new() { Label = "Rod Load", Value = $"{_performance.RodLoadPercentage.ToString("N1")}%", ValueColor = Color.Info }
            };
        }

        if (_pumpDesign != null)
        {
            return new RecommendationFactItem[]
            {
                new() { Label = "Estimated Capacity", Value = $"{_pumpDesign.EstimatedCapacity.ToString("N1")} BBL/D", ValueColor = Color.Success },
                new() { Label = "Stroke Program", Value = $"{_pumpDesign.StrokeLength.ToString("N1")} in / {_pumpDesign.StrokesPerMinute.ToString("N1")} SPM", ValueColor = Color.Primary },
                new() { Label = "Power Requirement", Value = $"{_pumpDesign.PowerRequirement.ToString("N1")} HP", ValueColor = Color.Warning }
            };
        }

        return Array.Empty<RecommendationFactItem>();
    }

    private string GetWellPerformanceUrl()
    {
        return string.IsNullOrWhiteSpace(_wellUWI)
            ? "/production/well-performance"
            : $"/production/well-performance?wellId={Uri.EscapeDataString(_wellUWI)}";
    }

    private static decimal NormalizeEfficiency(decimal value)
    {
        return value <= 1.5m ? value * 100m : value;
    }

    private static string FormatEfficiency(decimal value)
    {
        return NormalizeEfficiency(value).ToString("N1") + "%";
    }
}


