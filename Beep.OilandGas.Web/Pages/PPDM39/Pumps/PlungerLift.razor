@page "/ppdm39/pumps/plungerlift"
@using Beep.OilandGas.Models.Data
@using Beep.OilandGas.Models.Data.PlungerLift
@using Beep.OilandGas.Models.Core.Interfaces
@using Beep.OilandGas.Client.App
@using Beep.OilandGas.PPDM39.Models
@inject ISnackbar Snackbar
@inject IPumpServiceClient PumpService
@inject ApiClient ApiClient
@inject IDevelopmentServiceClient DevelopmentClient
@inject ILifeCycleService LifeCycleService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Design Plunger Lift System</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Design Plunger Lift System</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Plunger cycle design and optimisation</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Icon="@Icons.Material.Filled.SettingsInputComponent">Artificial Lift</MudChip>
            </MudStack>
        </MudStack>
    </MudStack>

    <MudPaper Class="pa-4">
        <MudText Typo="Typo.h6" Class="mb-4">Design Plunger Lift System</MudText>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="@_wellUWI" Label="Well UWI" Variant="Variant.Outlined" Required="true" />
            <MudNumericField @bind-Value="@_wellDepth" Label="Well Depth (ft)" Variant="Variant.Outlined" />
            <MudNumericField @bind-Value="@_tubingDiameter" Label="Tubing Diameter (in)" Variant="Variant.Outlined" />
            <MudNumericField @bind-Value="@_wellheadPressure" Label="Wellhead Pressure (PSI)" Variant="Variant.Outlined" />
            <MudNumericField @bind-Value="@_bottomHolePressure" Label="Bottom Hole Pressure (PSI)" Variant="Variant.Outlined" />
            <MudNumericField @bind-Value="@_gasOilRatio" Label="Gas Oil Ratio (SCF/BBL)" Variant="Variant.Outlined" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="DesignPlungerLift" Disabled="@_isDesigning">
                Design Plunger Lift System
            </MudButton>
        </MudStack>

        @if (_isLoading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mt-4" />
        }

        @if (_plungerDesign != null)
        {
            <MudPaper Class="pa-4 mt-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-4">Plunger Lift Design Results</MudText>
                <MudStack Spacing="2">
                    <MudText>Design ID: @_plungerDesign.DesignId</MudText>
                    <MudText>Plunger Type: @_plungerDesign.PlungerType</MudText>
                    <MudText>Operating Pressure: @_plungerDesign.OperatingPressure.ToString("F2") PSI</MudText>
                    <MudText>Cycle Time: @_plungerDesign.CycleTime.ToString("F2") minutes</MudText>
                </MudStack>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4" OnClick="SaveDesign">
                    Save Design
                </MudButton>
            </MudPaper>
        }
    </MudPaper>

    <MudPaper Class="pa-4 mt-4">
        <MudText Typo="Typo.h6" Class="mb-4">Performance Analysis</MudText>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="@_performanceWellUWI" Label="Well UWI" Variant="Variant.Outlined" />
            <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="AnalyzePerformance" Disabled="@_isAnalyzing">
                Analyze Performance
            </MudButton>
        </MudStack>

        @if (_performance != null)
        {
            <MudPaper Class="pa-4 mt-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-4">Performance Results</MudText>
                <MudStack Spacing="2">
                    <MudText>Production Rate: @_performance.ProductionRate.ToString("F2") BBL/D</MudText>
                    <MudText>Cycle Time: @_performance.CycleTime.ToString("F2") minutes</MudText>
                    <MudText>Efficiency: @FormatEfficiency(_performance.Efficiency)</MudText>
                </MudStack>
            </MudPaper>
        }
    </MudPaper>

    @if (_plungerDesign != null || _performance != null)
    {
        <LiftRecommendationCard Title="Lift Workflow Recommendation"
                                Subtitle="Plunger lift candidate review"
                                Icon="@Icons.Material.Filled.VerticalAlignTop"
                                IconColor="Color.Warning"
                                Headline="@GetLiftRecommendationHeadline()"
                                Summary="@GetLiftRecommendationSummary()"
                                ImpactText="@GetLiftRecommendationImpactText()"
                                Severity="@GetLiftRecommendationSeverity()"
                                Facts="@GetLiftRecommendationFacts()"
                                Class="mt-4">
            <Actions>
                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.AutoGraph"
                           Href="@GetWellPerformanceUrl()">
                    Open Well Performance Optimizer
                </MudButton>
                @if (_performance == null && !string.IsNullOrWhiteSpace(_performanceWellUWI))
                {
                    <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.Tune"
                               OnClick="AnalyzePerformance"
                               Disabled="@_isAnalyzing">
                        Run Performance Validation
                    </MudButton>
                }
            </Actions>
        </LiftRecommendationCard>
    }
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "wellId")]
    public string? WellId { get; set; }

    private string _fieldName = string.Empty;
    private string _wellUWI = string.Empty;
    private decimal _wellDepth = 5000;
    private decimal _tubingDiameter = 2.5m;
    private decimal _wellheadPressure = 100;
    private decimal _bottomHolePressure = 2000;
    private decimal _gasOilRatio = 500;
    private string _performanceWellUWI = string.Empty;
    private bool _isDesigning = false;
    private bool _isAnalyzing = false;
    private bool _isLoading = false;
    private PlungerLiftDesign? _plungerDesign;
    private PlungerLiftPerformance? _performance;
    private string? _currentUserId;

    private sealed class WellDto
    {
        public string UWI { get; set; } = string.Empty;
        public string? WELL_NAME { get; set; }
        public decimal? FINAL_TD { get; set; }
        public string? ASSIGNED_FIELD { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        try
        {
            try
            {
                var summary = await LifeCycleService.GetFieldLifecycleSummaryAsync();
                if (summary != null)
                    _fieldName = summary.FieldName ?? _fieldName;
            }
            catch { /* field name is non-critical */ }

            try
            {
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                _currentUserId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "system";

                var wells = (await DevelopmentClient.GetWellsAsync()).Select(MapWell).ToList();
                if (wells.Count > 0)
                {
                    var selectedWell = wells.Find(well => string.Equals(well.UWI, WellId, StringComparison.OrdinalIgnoreCase)) ?? wells[0];
                    _fieldName = selectedWell.ASSIGNED_FIELD ?? _fieldName;
                    _wellUWI = selectedWell.UWI;
                    _performanceWellUWI = selectedWell.UWI;
                    _wellDepth = selectedWell.FINAL_TD ?? _wellDepth;
                }
            }
            catch (Exception)
            {
                Snackbar.Add("Error loading wells.", Severity.Warning);
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static WellDto MapWell(WELL well)
    {
        return new WellDto
        {
            UWI = well.UWI,
            WELL_NAME = well.WELL_NAME,
            FINAL_TD = well.FINAL_TD,
            ASSIGNED_FIELD = well.ASSIGNED_FIELD
        };
    }

    private async Task DesignPlungerLift()
    {
        if (string.IsNullOrEmpty(_wellUWI))
        {
            Snackbar.Add("Please enter a Well UWI", Severity.Warning);
            return;
        }

        _isDesigning = true;
        try
        {
            var wellProperties = new PLUNGER_LIFT_WELL_PROPERTIES
            {
                WellDepth = _wellDepth,
                TUBING_DIAMETER = _tubingDiameter,
                WELLHEAD_PRESSURE = _wellheadPressure,
                BOTTOM_HOLE_PRESSURE = _bottomHolePressure,
                GAS_OIL_RATIO = _gasOilRatio
            };

            _plungerDesign = await PumpService.DesignPlungerLiftSystemAsync(_wellUWI, wellProperties);
            _performanceWellUWI = _wellUWI;
            Snackbar.Add("Plunger lift design completed", Severity.Success);
        }
        catch (Exception)
        {
            Snackbar.Add("Error designing plunger lift.", Severity.Error);
        }
        finally
        {
            _isDesigning = false;
        }
    }

    private async Task SaveDesign()
    {
        if (_plungerDesign == null)
        {
            Snackbar.Add("No design to save", Severity.Warning);
            return;
        }

        try
        {
            var saved = await PumpService.SavePlungerLiftDesignAsync(_plungerDesign, _currentUserId);
            if (saved)
            {
                Snackbar.Add("Plunger lift design saved successfully", Severity.Success);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Error saving design.", Severity.Error);
        }
    }

    private async Task AnalyzePerformance()
    {
        if (string.IsNullOrEmpty(_performanceWellUWI))
        {
            Snackbar.Add("Please enter a Well UWI", Severity.Warning);
            return;
        }

        _isAnalyzing = true;
        try
        {
            _performance = await PumpService.AnalyzePlungerLiftPerformanceAsync(_performanceWellUWI);
            Snackbar.Add("Performance analysis completed", Severity.Success);
        }
        catch (Exception)
        {
            Snackbar.Add("Error analyzing performance.", Severity.Error);
        }
        finally
        {
            _isAnalyzing = false;
        }
    }

    private Severity GetLiftRecommendationSeverity()
    {
        if (_performance != null)
        {
            var efficiency = NormalizeEfficiency(_performance.Efficiency);
            return efficiency >= 70m && _performance.DowntimeHours <= 4 ? Severity.Success : Severity.Warning;
        }

        return Severity.Info;
    }

    private string GetLiftRecommendationHeadline()
    {
        if (_performance != null)
        {
            var efficiency = NormalizeEfficiency(_performance.Efficiency);
            return efficiency >= 70m && _performance.DowntimeHours <= 4
                ? "Advance plunger lift candidate for production review"
                : "Reduce plunger downtime before intervention review";
        }

        return "Validate plunger lift design against live well underperformance";
    }

    private string GetLiftRecommendationSummary()
    {
        if (_performance != null)
        {
            return $"Performance validation indicates {_performance.ProductionRate.ToString("N1")} BBL/D at {FormatEfficiency(_performance.Efficiency)} with {_performance.CycleTime} minute cycles and {_performance.DowntimeHours} downtime hours.";
        }

        if (_plungerDesign != null)
        {
            return $"Plunger lift design targets {_plungerDesign.CycleTime} minute cycles at {_plungerDesign.OperatingPressure.ToString("N1")} PSI operating pressure. Run performance validation before field action.";
        }

        return "Generate a plunger lift design to start the lift recommendation flow.";
    }

    private string GetLiftRecommendationImpactText()
    {
        return "Workflow handoff: compare this plunger lift candidate against the current production gap before intervention or work-order planning.";
    }

    private IReadOnlyList<RecommendationFactItem> GetLiftRecommendationFacts()
    {
        if (_performance != null)
        {
            return new RecommendationFactItem[]
            {
                new() { Label = "Validated Rate", Value = $"{_performance.ProductionRate.ToString("N1")} BBL/D", ValueColor = Color.Success },
                new() { Label = "Efficiency", Value = FormatEfficiency(_performance.Efficiency), ValueColor = Color.Warning },
                new() { Label = "Downtime", Value = $"{_performance.DowntimeHours} hr", ValueColor = _performance.DowntimeHours <= 4 ? Color.Success : Color.Warning }
            };
        }

        if (_plungerDesign != null)
        {
            return new RecommendationFactItem[]
            {
                new() { Label = "Cycle Time", Value = $"{_plungerDesign.CycleTime} min", ValueColor = Color.Primary },
                new() { Label = "Operating Pressure", Value = $"{_plungerDesign.OperatingPressure.ToString("N1")} PSI", ValueColor = Color.Warning },
                new() { Label = "Plunger Type", Value = _plungerDesign.PlungerType.ToString(), ValueColor = Color.Info }
            };
        }

        return Array.Empty<RecommendationFactItem>();
    }

    private string GetWellPerformanceUrl()
    {
        var wellId = !string.IsNullOrWhiteSpace(_performanceWellUWI) ? _performanceWellUWI : _wellUWI;
        return string.IsNullOrWhiteSpace(wellId)
            ? "/production/well-performance"
            : $"/production/well-performance?wellId={Uri.EscapeDataString(wellId)}";
    }

    private static decimal NormalizeEfficiency(decimal value)
    {
        return value <= 1.5m ? value * 100m : value;
    }

    private static string FormatEfficiency(decimal value)
    {
        return NormalizeEfficiency(value).ToString("N1") + "%";
    }
}


