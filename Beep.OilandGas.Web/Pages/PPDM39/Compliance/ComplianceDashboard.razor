@page "/ppdm39/compliance"
@using Beep.OilandGas.Models.Data.Compliance
@inject Beep.OilandGas.Web.Services.ApiClient ApiClient
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Compliance Dashboard</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Regulatory Compliance Dashboard</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else
{
    @if (_score is not null)
    {
        <MudGrid Class="mb-4">
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="2" Class="pa-4 text-center">
                    <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Color="Color.Success" Size="Size.Large" />
                    <MudText Typo="Typo.h4">@(_score.OnTimeRate.ToString("F1"))%</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Default">On-Time Rate</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="2" Class="pa-4 text-center">
                    <MudIcon Icon="@Icons.Material.Outlined.Assignment" Color="Color.Info" Size="Size.Large" />
                    <MudText Typo="Typo.h4">@_score.TotalObligations</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Default">Total Obligations</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="2" Class="pa-4 text-center">
                    <MudIcon Icon="@Icons.Material.Outlined.Warning" Color="Color.Warning" Size="Size.Large" />
                    <MudText Typo="Typo.h4">@_overdueCount</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Default">Overdue</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="2" Class="pa-4 text-center">
                    <MudIcon Icon="@Icons.Material.Outlined.Schedule" Color="Color.Secondary" Size="Size.Large" />
                    <MudText Typo="Typo.h4">@_upcomingCount</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Default">Due in 30 Days</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }

    <MudPaper Elevation="2" Class="pa-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
            <MudText Typo="Typo.h6">Obligations</MudText>
            <MudSpacer />
            <MudSelect T="int" Value="@_selectedYear" Label="Year" Style="width:120px"
                       ValueChanged="@(async (int y) => { _selectedYear = y; await LoadAsync(); })">
                @foreach (var y in _years)
                {
                    <MudSelectItem Value="@y">@y</MudSelectItem>
                }
            </MudSelect>
        </MudStack>

        <MudDataGrid T="ObligationSummary" Items="@_obligations" Filterable="true" Sortable="true"
                     Hover="true" Dense="true" RowClick="@OnRowClick">
            <Columns>
                <PropertyColumn Property="x => x.ObligType"    Title="Type" />
                <PropertyColumn Property="x => x.Jurisdiction" Title="Jurisdiction" />
                <PropertyColumn Property="x => x.DueDate"      Title="Due Date" Format="yyyy-MM-dd" />
                <PropertyColumn Property="x => x.DaysUntilDue" Title="Days Left" />
                <TemplateColumn Title="Status">
                    <CellTemplate>
                        <MudChip T="string"
                                 Color="@StatusColor(context.Item.Status)"
                                 Size="Size.Small">
                            @context.Item.Status
                        </MudChip>
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.FulfillDate" Title="Fulfilled" />
            </Columns>
        </MudDataGrid>
    </MudPaper>
}

@if (!string.IsNullOrEmpty(_error))
{
    <MudAlert Severity="Severity.Error" Class="mt-2">@_error</MudAlert>
}

@code {
    private bool                     _loading  = true;
    private string?                  _error;
    private int                      _selectedYear = DateTime.Now.Year;
    private List<ObligationSummary>  _obligations  = new();
    private ComplianceScoreCard?     _score;
    private int                      _overdueCount;
    private int                      _upcomingCount;

    private List<int> _years = Enumerable.Range(DateTime.Now.Year - 3, 5).Reverse().ToList();

    protected override async Task OnInitializedAsync()
        => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _error   = null;
        try
        {
            _obligations  = await ApiClient.GetAsync<List<ObligationSummary>>(
                               $"/api/field/current/compliance/obligations?year={_selectedYear}")
                           ?? new();
            _score        = await ApiClient.GetAsync<ComplianceScoreCard>(
                               $"/api/field/current/compliance/score?year={_selectedYear}");
            var overdue   = await ApiClient.GetAsync<List<ObligationSummary>>(
                               "/api/field/current/compliance/obligations/overdue") ?? new();
            var upcoming  = await ApiClient.GetAsync<List<ObligationSummary>>(
                               "/api/field/current/compliance/obligations/upcoming?daysAhead=30") ?? new();
            _overdueCount  = overdue.Count;
            _upcomingCount = upcoming.Count;
        }
        catch (Exception)
        {
            _error = "Failed to load compliance data.";
            Snackbar.Add(_error, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void OnRowClick(DataGridRowClickEventArgs<ObligationSummary> args)
        => NavigationManager.NavigateTo("/ppdm39/compliance/obligation/" + args.Item.ObligationId);

    private static Color StatusColor(string status) => status switch
    {
        ObligationStatus.Submitted     => Color.Success,
        ObligationStatus.Overdue       => Color.Error,
        ObligationStatus.VarianceFlagged => Color.Warning,
        ObligationStatus.Waived        => Color.Default,
        _                              => Color.Info,
    };
}
