@page "/ppdm39/workorder/{Id}"
@using Beep.OilandGas.Models.Data.WorkOrder
@using Beep.OilandGas.Web.Services
@inject IWorkOrderServiceClient WorkOrderService
@inject ISnackbar Snackbar

<PageTitle>Work Order @Id</PageTitle>

<MudStack Spacing="3">

    @* ── Header ──────────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIconButton Icon="@Icons.Material.Outlined.ArrowBack"
                           Href="/ppdm39/workorder" Size="Size.Small" />
            <MudStack Spacing="0">
                <MudText Typo="Typo.h6">@(_detail?.InstanceName ?? "Work Order Detail")</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @Id — @(_detail?.WoSubType)
                </MudText>
            </MudStack>
        </MudStack>

        @if (_detail is not null)
        {
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                @if (!string.IsNullOrWhiteSpace(ReturnTo))
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small"
                               Href="@ReturnTo"
                               StartIcon="@Icons.Material.Outlined.ArrowBack">
                        Back to Optimizer
                    </MudButton>
                }
                <MudChip T="string" Color="StateColor(_detail.State)" Value="@_detail.State">
                    @_detail.State
                </MudChip>
                @if (_transitions.Count > 0)
                {
                    <MudMenu Label="Transition" EndIcon="@Icons.Material.Outlined.ArrowDropDown"
                             Variant="Variant.Filled" Color="Color.Primary">
                        @foreach (var t in _transitions)
                        {
                            <MudMenuItem OnClick="() => OpenTransitionDialog(t)">@t</MudMenuItem>
                        }
                    </MudMenu>
                }
            </MudStack>
        }
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_detail is not null)
    {
        <MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" Class="mt-1">

            @* ── Overview tab ────────────────────────────────────────── *@
            <MudTabPanel Text="Overview" Icon="@Icons.Material.Outlined.Info">
                <MudGrid Spacing="2" Class="pa-2">
                    <MudItem xs="12" md="6">
                        <MudPaper Elevation="1" Class="pa-3">
                            <MudText Typo="Typo.subtitle2" Class="mb-2">Details</MudText>
                            <MudStack Spacing="1">
                                <MudStack Row="true">
                                    <MudText Typo="Typo.subtitle2" Class="mr-2">Equipment</MudText>
                                    <MudText Typo="Typo.caption">@_detail.EquipmentId</MudText>
                                </MudStack>
                                <MudStack Row="true">
                                    <MudText Typo="Typo.subtitle2" Class="mr-2">Planned Start</MudText>
                                    <MudText Typo="Typo.caption">@_detail.PlannedStart?.ToString("dd-MMM-yyyy")</MudText>
                                </MudStack>
                                <MudStack Row="true">
                                    <MudText Typo="Typo.subtitle2" Class="mr-2">Actual Start</MudText>
                                    <MudText Typo="Typo.caption">@_detail.ActualStart?.ToString("dd-MMM-yyyy")</MudText>
                                </MudStack>
                                <MudStack Row="true">
                                    <MudText Typo="Typo.subtitle2" Class="mr-2">Completed</MudText>
                                    <MudText Typo="Typo.caption">@_detail.ActualEnd?.ToString("dd-MMM-yyyy")</MudText>
                                </MudStack>
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudPaper Elevation="1" Class="pa-3">
                            <MudText Typo="Typo.subtitle2" Class="mb-2">Budget vs Actual</MudText>
                            <MudStack Spacing="1">
                                <MudStack Row="true">
                                    <MudText Typo="Typo.subtitle2" Class="mr-2">Budget</MudText>
                                    <MudText Typo="Typo.caption">@_detail.BudgetAmt.ToString("N0")</MudText>
                                </MudStack>
                                <MudStack Row="true">
                                    <MudText Typo="Typo.subtitle2" Class="mr-2">Actual</MudText>
                                    <MudText Typo="Typo.caption">@_detail.ActualAmt.ToString("N0")</MudText>
                                </MudStack>
                                <MudStack Row="true">
                                    <MudText Typo="Typo.subtitle2" Class="mr-2">Steps</MudText>
                                    <MudText Typo="Typo.caption">@_detail.StepCount</MudText>
                                </MudStack>
                                <MudStack Row="true">
                                    <MudText Typo="Typo.subtitle2" Class="mr-2">Checklist</MudText>
                                    <MudText Typo="Typo.caption">@_detail.PassedConditions / @_detail.ConditionCount passed</MudText>
                                </MudStack>
                            </MudStack>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12">
                        <MudPaper Elevation="1" Class="pa-3">
                            <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Spacing="2">
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.subtitle2">AFE Linkage</MudText>
                                    @if (_linkedAfe is not null)
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Linked AFE @_linkedAfe.AfeNumber</MudText>
                                        <MudStack Row="true" Spacing="3" Wrap="Wrap.Wrap" Class="mt-1">
                                            <MudText Typo="Typo.caption"><strong>Status:</strong> @(_linkedAfe.Status ?? "Unknown")</MudText>
                                            <MudText Typo="Typo.caption"><strong>Estimate:</strong> @((_linkedAfe.EstimatedCost ?? 0m).ToString("N0"))</MudText>
                                            <MudText Typo="Typo.caption"><strong>Actual:</strong> @((_linkedAfe.ActualCost ?? 0m).ToString("N0"))</MudText>
                                        </MudStack>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">No AFE is linked yet. Create or link one to move this work order into the accounting lifecycle.</MudText>
                                    }
                                </MudStack>

                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                    @if (_linkedAfe is not null)
                                    {
                                        <MudButton Variant="Variant.Outlined" Color="Color.Success" Size="Size.Small"
                                                   Href="@GetAfeHref()"
                                                   StartIcon="@Icons.Material.Outlined.OpenInNew">
                                            Open AFE
                                        </MudButton>
                                    }
                                    <MudButton Variant="@(_linkedAfe is null ? Variant.Filled : Variant.Outlined)"
                                               Color="Color.Primary"
                                               Size="Size.Small"
                                               Disabled="@_afeBusy"
                                               StartIcon="@Icons.Material.Outlined.RequestQuote"
                                               OnClick="CreateOrLinkAfeAsync">
                                        @(_afeBusy ? "Linking..." : (_linkedAfe is null ? "Create / Link AFE" : "Refresh AFE Link"))
                                    </MudButton>
                                </MudStack>
                            </MudStack>
                        </MudPaper>
                    </MudItem>

                    @* Steps *@
                    @if (_detail.Steps.Count > 0)
                    {
                        <MudItem xs="12">
                            <MudPaper Elevation="1" Class="pa-3">
                                <MudText Typo="Typo.subtitle2" Class="mb-2">Steps</MudText>
                                <MudTable Items="_detail.Steps" Dense="true" Hover="true" Elevation="0">
                                    <HeaderContent>
                                        <MudTh>Seq</MudTh><MudTh>Name</MudTh><MudTh>Status</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd>@context.StepSeq</MudTd>
                                        <MudTd>@context.StepName</MudTd>
                                        <MudTd>
                                            <MudChip T="string" Size="Size.Small"
                                                     Color="@StepStatusColor(context.Status)"
                                                     Value="@context.Status">
                                                @context.Status
                                            </MudChip>
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            </MudTabPanel>

            @* ── Checklist tab ───────────────────────────────────────── *@
            <MudTabPanel Text="Checklist" Icon="@Icons.Material.Outlined.Checklist">
                <MudPaper Elevation="0" Class="pa-3">
                    @if (_checklist.Count == 0)
                    {
                        <MudText Color="Color.Secondary">No checklist items yet. Checklist is seeded when WO moves to Planned.</MudText>
                    }
                    else
                    {
                        <MudTable Items="_checklist" Dense="true" Hover="true" Elevation="0">
                            <HeaderContent>
                                <MudTh>#</MudTh>
                                <MudTh>Type</MudTh>
                                <MudTh>Condition</MudTh>
                                <MudTh>Status</MudTh>
                                <MudTh>Regulatory Ref</MudTh>
                                <MudTh>Action</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.CondSeq</MudTd>
                                <MudTd>@context.CondType</MudTd>
                                <MudTd>@context.RequiredText</MudTd>
                                <MudTd>
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@CondStatusColor(context.Status)"
                                             Value="@context.Status">
                                        @context.Status
                                    </MudChip>
                                </MudTd>
                                <MudTd><MudText Typo="Typo.caption" Color="Color.Secondary">@context.RegulatoryRef</MudText></MudTd>
                                <MudTd>
                                    @if (!string.Equals(context.Status, "PASS", StringComparison.OrdinalIgnoreCase)
                                         && !string.Equals(context.Status, "FAIL", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <MudIconButton Icon="@Icons.Material.Outlined.CheckCircleOutline"
                                                       Color="Color.Success" Size="Size.Small"
                                                       Title="Record PASS"
                                                       OnClick="@(async () => await RecordConditionAsync(context.CondSeq, "PASS"))" />
                                        <MudIconButton Icon="@Icons.Material.Outlined.Cancel"
                                                       Color="Color.Error" Size="Size.Small"
                                                       Title="Record FAIL"
                                                       OnClick="@(async () => await RecordConditionAsync(context.CondSeq, "FAIL"))" />
                                    }
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudPaper>
            </MudTabPanel>

            @* ── Costs tab ───────────────────────────────────────────── *@
            <MudTabPanel Text="Costs" Icon="@Icons.Material.Outlined.AttachMoney">
                <MudPaper Elevation="0" Class="pa-3">
                    @if (_costs.Count == 0)
                    {
                        <MudText Color="Color.Secondary">No cost lines found.</MudText>
                    }
                    else
                    {
                        <MudTable Items="_costs" Dense="true" Hover="true" Elevation="0">
                            <HeaderContent>
                                <MudTh>Code</MudTh>
                                <MudTh>Description</MudTh>
                                <MudTh><MudText Align="Align.Right">Budget</MudText></MudTh>
                                <MudTh><MudText Align="Align.Right">Actual</MudText></MudTh>
                                <MudTh><MudText Align="Align.Right">Variance %</MudText></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.CompCode</MudTd>
                                <MudTd>@context.Description</MudTd>
                                <MudTd><MudText Align="Align.Right">@context.BudgetAmt.ToString("N0")</MudText></MudTd>
                                <MudTd><MudText Align="Align.Right">@context.ActualAmt.ToString("N0")</MudText></MudTd>
                                <MudTd><MudText Align="Align.Right">
                                    <MudText Color="@(context.VariancePct > 10 ? Color.Error : Color.Default)">
                                        @context.VariancePct.ToString("F1")%
                                    </MudText>
                                </MudText></MudTd>
                            </RowTemplate>
                            <FooterContent>
                                <MudTd colspan="2"><strong>Total</strong></MudTd>
                                <MudTd><MudText Align="Align.Right"><strong>@_costs.Sum(c => c.BudgetAmt).ToString("N0")</strong></MudText></MudTd>
                                <MudTd><MudText Align="Align.Right"><strong>@_costs.Sum(c => c.ActualAmt).ToString("N0")</strong></MudText></MudTd>
                                <MudTd></MudTd>
                            </FooterContent>
                        </MudTable>
                    }
                </MudPaper>
            </MudTabPanel>

            @* ── Contractors tab ─────────────────────────────────────── *@
            <MudTabPanel Text="Contractors" Icon="@Icons.Material.Outlined.Engineering">
                <MudPaper Elevation="0" Class="pa-3">
                    @if (_contractors.Count == 0)
                    {
                        <MudText Color="Color.Secondary">No contractors assigned.</MudText>
                    }
                    else
                    {
                        <MudTable Items="_contractors" Dense="true" Hover="true" Elevation="0">
                            <HeaderContent>
                                <MudTh>Step</MudTh>
                                <MudTh>Contractor ID</MudTh>
                                <MudTh>Role</MudTh>
                                <MudTh>Assigned</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.StepId</MudTd>
                                <MudTd>@context.BaId</MudTd>
                                <MudTd>@context.RoleCode</MudTd>
                                <MudTd>@context.AssignedDate.ToString("dd-MMM-yyyy")</MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudPaper>
            </MudTabPanel>

        </MudTabs>
    }

    @if (!string.IsNullOrEmpty(_error))
    {
        <MudAlert Severity="Severity.Error" ShowCloseIcon="true"
                  CloseIconClicked="@(() => _error = null)">@_error</MudAlert>
    }

</MudStack>

@* ── Transition dialog ─────────────────────────────────────────────────────── *@
<MudDialog @bind-IsVisible="_showTransition" Options="@(new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">Transition to @_pendingTransition</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_transitionNotes" Label="Notes (optional)" Lines="3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showTransition = false)">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="ConfirmTransitionAsync">Confirm</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public string Id { get; set; } = string.Empty;

    [SupplyParameterFromQuery(Name = "returnTo")]
    public string? ReturnTo { get; set; }

    private string _loadedId = string.Empty;

    private WorkOrderDetailModel?         _detail;
    private List<string>                _transitions  = new();
    private List<InspectionCondition>   _checklist    = new();
    private List<CostVarianceLine>      _costs        = new();
    private List<ContractorAssignment>  _contractors  = new();
    private AFEResponse?                _linkedAfe;
    private bool                        _loading;
    private bool                        _afeBusy;
    private string?                     _error;

    // Transition
    private bool    _showTransition;
    private string  _pendingTransition = string.Empty;
    private string? _transitionNotes;

    protected override async Task OnInitializedAsync()
    {
        _loadedId = Id;
        await LoadAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Id == _loadedId) return;
        _loadedId = Id;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error   = null;
        try
        {
            _detail      = await WorkOrderService.GetWorkOrderAsync(Id);
            _transitions = await WorkOrderService.GetTransitionsAsync(Id);
            _checklist   = await WorkOrderService.GetChecklistAsync(Id);
            _costs       = await WorkOrderService.GetCostsAsync(Id);
            _contractors = await WorkOrderService.GetContractorsAsync(Id);
            await LoadLinkedAfeAsync();
        }
        catch (Exception) { _error = "Failed to load work order."; Snackbar.Add(_error, Severity.Error); }
        finally { _loading = false; }
    }

    private async Task LoadLinkedAfeAsync()
    {
        var afe = await WorkOrderService.GetAfeAsync(Id);
        _linkedAfe = string.IsNullOrWhiteSpace(afe.AfeId) ? null : afe;
    }

    private void OpenTransitionDialog(string toState)
    {
        _pendingTransition = toState;
        _transitionNotes   = null;
        _showTransition    = true;
    }

    private async Task ConfirmTransitionAsync()
    {
        try
        {
            var request = new TransitionWorkOrderRequest
            {
                ToState = _pendingTransition,
                Notes   = _transitionNotes
            };
            await WorkOrderService.TransitionAsync(Id, request);
            _showTransition = false;
            await LoadAsync();
        }
        catch (Exception) { _error = "Transition failed."; Snackbar.Add(_error, Severity.Error); }
    }

    private async Task RecordConditionAsync(int condSeq, string result)
    {
        try
        {
            await WorkOrderService.RecordConditionAsync(
                Id,
                condSeq,
                new RecordInspectionResultRequest { Result = result });
            _checklist = await WorkOrderService.GetChecklistAsync(Id);
        }
        catch (Exception) { _error = "Failed to record result."; Snackbar.Add(_error, Severity.Error); }
    }

    private async Task CreateOrLinkAfeAsync()
    {
        _afeBusy = true;
        try
        {
            var afe = await WorkOrderService.CreateOrLinkAfeAsync(Id);
            if (string.IsNullOrWhiteSpace(afe.AfeId))
            {
                Snackbar.Add("AFE linking is not available for this work order yet.", Severity.Warning);
                return;
            }

            _linkedAfe = afe;
            Snackbar.Add($"AFE {afe.AfeNumber} linked to work order {Id}.", Severity.Success);
        }
        catch (Exception)
        {
            _error = "Failed to create or link AFE.";
            Snackbar.Add(_error, Severity.Error);
        }
        finally
        {
            _afeBusy = false;
        }
    }

    private string GetAfeHref() =>
        string.IsNullOrWhiteSpace(_linkedAfe?.AfeNumber)
            ? "/economics/afe"
            : $"/economics/afe?afeNumber={Uri.EscapeDataString(_linkedAfe.AfeNumber)}{BuildReturnToQuery()}";

    private string BuildReturnToQuery() =>
        string.IsNullOrWhiteSpace(ReturnTo)
            ? string.Empty
            : $"&returnTo={Uri.EscapeDataString(ReturnTo)}";

    private static Color StateColor(string state) => state switch
    {
        WorkOrderState.Draft       => Color.Default,
        WorkOrderState.Planned     => Color.Info,
        WorkOrderState.InProgress  => Color.Warning,
        WorkOrderState.UnderReview => Color.Secondary,
        WorkOrderState.Completed   => Color.Success,
        WorkOrderState.Cancelled   => Color.Error,
        _                          => Color.Default
    };

    private static Color StepStatusColor(string status) => status switch
    {
        "COMPLETED" => Color.Success,
        "FAILED"    => Color.Error,
        "IN_PROGRESS" => Color.Warning,
        _           => Color.Default
    };

    private static Color CondStatusColor(string status) => status switch
    {
        "PASS"    => Color.Success,
        "FAIL"    => Color.Error,
        "PENDING" => Color.Default,
        _         => Color.Default
    };
}
