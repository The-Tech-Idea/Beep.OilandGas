@page "/data/quality-dashboard"
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject ApiClient ApiClient

<PageTitle>Assess Data Quality</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @if (_isLoading) { <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" /> }

    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Assess Data Quality</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">PPDM39 data quality scores &amp; issue register</MudText>
        </MudStack>
        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh" OnClick="RecalculateScores">
                Recalculate
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Download" OnClick="ExportReport">
                Export Report
            </MudButton>
        </MudStack>
    </MudStack>

    @* KPIs *@
    <MudGrid Class="mb-4" Spacing="3">
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Overall Quality Score" Value="@_overallScore.ToString("N1")" Unit="%"
                     ValueColor="@ScoreColor(_overallScore)"
                     Icon="@Icons.Material.Filled.Grade"
                     TrendIcon="@Icons.Material.Filled.TrendingUp" TrendColor="Color.Success" TrendText="vs last month" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Tables Assessed" Value="@_tables.Count.ToString()"
                     ValueColor="Color.Info" Icon="@Icons.Material.Filled.TableChart"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default" TrendText="PPDM39 core tables" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Open Issues" Value="@_issues.Count(i => !i.Resolved).ToString()"
                     ValueColor="Color.Warning" Icon="@Icons.Material.Filled.BugReport"
                     TrendIcon="@Icons.Material.Filled.TrendingDown" TrendColor="Color.Success" TrendText="Down from last run" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Critical Issues" Value="@_issues.Count(i => i.Severity == "CRITICAL" && !i.Resolved).ToString()"
                     ValueColor="Color.Error" Icon="@Icons.Material.Filled.ErrorOutline"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default" TrendText="Require immediate action" />
        </MudItem>
    </MudGrid>

    <MudGrid Spacing="3">

        @* Table quality scores *@
        <MudItem xs="12" md="6">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent><MudText Typo="Typo.subtitle1">Quality by Table</MudText></CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    <MudDataGrid T="TableQuality" Items="@_tables" Dense="true" Hover="true" Striped="true"
                                 SortMode="SortMode.Single">
                        <Columns>
                            <PropertyColumn Property="t => t.TableName"   Title="Table" />
                            <PropertyColumn Property="t => t.RecordCount" Title="Records" Format="N0" />
                            <TemplateColumn Title="Completeness">
                                <CellTemplate>
                                    <MudStack Spacing="0">
                                        <MudProgressLinear Value="@context.Item.Completeness"
                                                           Color="@ScoreColor(context.Item.Completeness)" />
                                        <MudText Typo="Typo.caption">@context.Item.Completeness.ToString("N0")%</MudText>
                                    </MudStack>
                                </CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="Overall">
                                <CellTemplate>
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@ScoreColor(context.Item.OverallScore)">
                                        @context.Item.OverallScore.ToString("N0")%
                                    </MudChip>
                                </CellTemplate>
                            </TemplateColumn>
                        </Columns>
                    </MudDataGrid>
                </MudCardContent>
            </MudCard>
        </MudItem>

        @* Quality trend chart + right column *@
        <MudItem xs="12" md="6">
            <MudStack Spacing="3">

                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent><MudText Typo="Typo.subtitle1">Quality Score Trend</MudText></CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudAlert Severity="Severity.Info" Dense="true">Historical trend data requires a scheduled quality scan. Run <strong>Recalculate Scores</strong> over multiple periods to build the trend.</MudAlert>
                    </MudCardContent>
                </MudCard>

                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent><MudText Typo="Typo.subtitle1">Issue Register</MudText></CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent Class="pa-0">
                        <MudDataGrid T="DataIssue" Items="@_issues.Where(i => !i.Resolved)" Dense="true" Hover="true">
                            <Columns>
                                <PropertyColumn Property="i => i.TableName"   Title="Table" />
                                <PropertyColumn Property="i => i.Description" Title="Issue" />
                                <TemplateColumn Title="Severity">
                                    <CellTemplate>
                                        <MudChip T="string" Size="Size.Small"
                                                 Color="@IssueSeverityColor(context.Item.Severity)">
                                            @context.Item.Severity
                                        </MudChip>
                                    </CellTemplate>
                                </TemplateColumn>
                                <PropertyColumn Property="i => i.RecordsAffected" Title="# Records" />
                                <TemplateColumn Title="" Sortable="false">
                                    <CellTemplate>
                                        <MudIconButton Icon="@Icons.Material.Filled.CheckCircle"
                                                       Title="Resolve issue"
                                                       Size="Size.Small" Color="Color.Success"
                                                       OnClick="@(() => ResolveIssue(context.Item))" />
                                    </CellTemplate>
                                </TemplateColumn>
                            </Columns>
                        </MudDataGrid>
                    </MudCardContent>
                </MudCard>

            </MudStack>
        </MudItem>

    </MudGrid>
</MudContainer>

@code {
    private double _overallScore = 0;
    private bool _isLoading = false;

    private sealed record TableQuality(string TableName, int RecordCount, double Completeness, double OverallScore);
    private List<TableQuality> _tables = new();

    private sealed record DataIssue(string TableName, string Description, string Severity, int RecordsAffected, bool Resolved);
    private List<DataIssue> _issues = new();

    // DTOs matching api/ppdm39/quality/dashboard response
    private sealed class DashboardResultDto
    {
        public double OverallQualityScore { get; set; }
        public int TotalTables { get; set; }
        public int TablesWithIssues { get; set; }
        public Dictionary<string, TableResultDto> TableQualityResults { get; set; } = new();
    }

    private sealed class TableResultDto
    {
        public string? TableName { get; set; }
        public double OverallQualityScore { get; set; }
        public int TotalRows { get; set; }
        public int CompleteRows { get; set; }
        public List<string> QualityIssues { get; set; } = new();
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadQualityDataAsync();
    }

    private async Task LoadQualityDataAsync()
    {
        _isLoading = true;
        try
        {
            var dashboard = await ApiClient.GetAsync<DashboardResultDto>("api/ppdm39/quality/dashboard");
            if (dashboard == null) return;

            _overallScore = dashboard.OverallQualityScore;

            _tables = dashboard.TableQualityResults.Values.Select(t => new TableQuality(
                t.TableName ?? "—",
                t.TotalRows,
                t.TotalRows > 0 ? Math.Round((double)t.CompleteRows / t.TotalRows * 100, 1) : 0,
                Math.Round(t.OverallQualityScore, 1)
            )).ToList();

            _issues = dashboard.TableQualityResults
                .SelectMany(kvp => kvp.Value.QualityIssues.Select(issue => new DataIssue(
                    kvp.Value.TableName ?? kvp.Key,
                    issue,
                    GuessIssueSeverity(issue),
                    0,
                    false)))
                .ToList();
        }
        catch (Exception)
        {
            Snackbar.Add("Error loading quality data.", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string GuessIssueSeverity(string issue)
    {
        var lower = issue.ToLowerInvariant();
        if (lower.Contains("critical") || lower.Contains("duplicate") || lower.Contains("corrupt"))
            return "CRITICAL";
        if (lower.Contains("missing") || lower.Contains("null") || lower.Contains("invalid"))
            return "HIGH";
        if (lower.Contains("out of range") || lower.Contains("format"))
            return "MEDIUM";
        return "LOW";
    }

    private List<DataIssue> _resolvedOverrides = new();

    private void ResolveIssue(DataIssue issue)
    {
        var idx = _issues.IndexOf(issue);
        if (idx >= 0)
            _issues[idx] = issue with { Resolved = true };
        Snackbar.Add($"Issue in {issue.TableName} marked resolved", Severity.Success);
    }

    private async Task RecalculateScores()
    {
        Snackbar.Add("Quality recalculation started", Severity.Info);
        await LoadQualityDataAsync();
    }

    private void ExportReport() => Snackbar.Add("Quality report export queued", Severity.Success);

    private Color ScoreColor(double score) => score switch
    {
        >= 90 => Color.Success,
        >= 75 => Color.Warning,
        _     => Color.Error,
    };

    private Color IssueSeverityColor(string sev) => sev switch
    {
        "CRITICAL" => Color.Error,
        "HIGH"     => Color.Warning,
        "MEDIUM"   => Color.Info,
        _          => Color.Default,
    };
}
