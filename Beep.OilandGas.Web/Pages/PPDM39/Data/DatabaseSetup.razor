@page "/ppdm39/database-setup"
@inject ISnackbar Snackbar

<PageTitle>Set Up PPDM39 Database</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="pa-4">

    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Set Up PPDM39 Database</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Configure and initialise the PPDM39 database connection</MudText>
        </MudStack>
        <StatusBadge Status="@(_isConnected ? "ACTIVE" : "FAILED")" />
    </MudStack>

    <MudGrid Spacing="3">

        @* Connection Settings *@
        <MudItem xs="12" md="7">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Storage" />
                            <MudText Typo="Typo.subtitle1">Connection Configuration</MudText>
                        </MudStack>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid Spacing="2">
                        <MudItem xs="12">
                            <MudSelect T="string" @bind-Value="_dbType" Label="Database Type" Variant="Variant.Outlined">
                                <MudSelectItem Value="@("SqlServer")">SQL Server</MudSelectItem>
                                <MudSelectItem Value="@("PostgreSQL")">PostgreSQL</MudSelectItem>
                                <MudSelectItem Value="@("SQLite")">SQLite</MudSelectItem>
                                <MudSelectItem Value="@("Oracle")">Oracle</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="8">
                            <MudTextField @bind-Value="_host" Label="Host / Server" Variant="Variant.Outlined"
                                          Placeholder="localhost" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="_port" Label="Port" Variant="Variant.Outlined"
                                          Placeholder="1433" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_database" Label="Database Name" Variant="Variant.Outlined"
                                          Placeholder="PPDM39" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_schema" Label="Schema" Variant="Variant.Outlined"
                                          Placeholder="dbo" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_username" Label="Username" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_password" Label="Password" Variant="Variant.Outlined"
                                          InputType="InputType.Password" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_connectionString" Label="Connection String (override)"
                                          Variant="Variant.Outlined" Lines="2"
                                          Placeholder="Optional — overrides fields above if provided" />
                        </MudItem>
                    </MudGrid>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.PlayArrow"
                               OnClick="TestConnection">
                        Test Connection
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Save" OnClick="SaveConnection">
                        Save &amp; Connect
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>

        @* Status + Actions panel *@
        <MudItem xs="12" md="5">
            <MudStack Spacing="3">

                @* Connection Status *@
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent><MudText Typo="Typo.subtitle1">Connection Status</MudText></CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudStack Spacing="2">
                            @foreach (var item in _statusItems)
                            {
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2">@item.Label</MudText>
                                    <MudChip T="string" Size="Size.Small" Color="@item.Color">@item.Value</MudChip>
                                </MudStack>
                            }
                        </MudStack>
                    </MudCardContent>
                </MudCard>

                @* Database Initialisation *@
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent><MudText Typo="Typo.subtitle1">Database Initialisation</MudText></CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body2" Class="mb-3">
                            Creates PPDM39 schema objects (tables, PKs, FKs) from the bundled DDL scripts.
                            Only use on an empty database.
                        </MudText>
                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
                            This operation is irreversible on a populated database. Ensure you have a backup first.
                        </MudAlert>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Outlined" Color="Color.Warning"
                                   StartIcon="@Icons.Material.Filled.Build"
                                   Disabled="@(!_isConnected)"
                                   OnClick="CreateSchema">
                            Create PPDM39 Schema
                        </MudButton>
                    </MudCardActions>
                </MudCard>

                @* Seed Data *@
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent><MudText Typo="Typo.subtitle1">Seed Reference Data</MudText></CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body2" Class="mb-2">
                            Loads PPDM39 LOV (R_*) tables and standard reference data from bundled CSV files.
                        </MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Outlined" Color="Color.Info"
                                   StartIcon="@Icons.Material.Filled.Upload"
                                   Disabled="@(!_isConnected)"
                                   OnClick="SeedData">
                            Seed Reference Data
                        </MudButton>
                    </MudCardActions>
                </MudCard>

            </MudStack>
        </MudItem>

    </MudGrid>
</MudContainer>

@code {
    private bool _isConnected = false;

    private string _dbType = "SqlServer";
    private string _host = "";
    private string _port = "1433";
    private string _database = "PPDM39";
    private string _schema = "dbo";
    private string _username = "";
    private string _password = "";
    private string _connectionString = "";

    private record StatusItem(string Label, string Value, Color Color);
    private List<StatusItem> _statusItems = new()
    {
        new("Status",       "Not connected",  Color.Default),
        new("PPDM Version", "—",              Color.Default),
        new("Table Count",  "—",              Color.Default),
        new("LOV Tables",   "—",              Color.Default),
    };

    private async Task TestConnection()
    {
        Snackbar.Add("Testing connection…", Severity.Info);
        await Task.Delay(800); // simulate async check
        _isConnected = true;
        _statusItems = new()
        {
            new("Status",       "Connected",     Color.Success),
            new("PPDM Version", "3.9",           Color.Success),
            new("Table Count",  "512",           Color.Success),
            new("LOV Tables",   "148",           Color.Success),
        };
        Snackbar.Add("Connection successful", Severity.Success);
    }

    private void SaveConnection()
    {
        Snackbar.Add("Connection settings saved", Severity.Success);
    }

    private void CreateSchema()
    {
        Snackbar.Add("PPDM39 schema creation started — check logs for progress", Severity.Warning);
    }

    private void SeedData()
    {
        Snackbar.Add("Reference data seeding started — this may take several minutes", Severity.Info);
    }
}
