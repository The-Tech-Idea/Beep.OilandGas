@page "/ppdm39/database-setup"
@inject ISnackbar Snackbar
@inject IDataManagementService DataManagementService
@inject NavigationManager NavigationManager
@using Beep.OilandGas.Models.Data
@using Beep.OilandGas.Models.Data.DataManagement
@using Beep.OilandGas.Web.Components.Data

<PageTitle>Database Setup Wizard</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @* ── Page Header ──────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">
                <MudIcon Icon="@Icons.Material.Filled.Storage" Class="mr-2" />
                PPDM39 Database Setup Wizard
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Connect, install schema modules, seed reference data
            </MudText>
        </MudStack>
        @if (_isConnected)
        {
            <MudChip T="string" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small">
                Connected — @(_savedConnectionName ?? _dbType)
            </MudChip>
        }
        else
        {
            <MudChip T="string" Color="Color.Default" Icon="@Icons.Material.Outlined.RadioButtonUnchecked" Size="Size.Small">
                Not connected
            </MudChip>
        }
    </MudStack>

    @* ── Stepper ──────────────────────────────────────────────────────────── *@
    <MudStepper @bind-ActiveIndex="_step" Color="Color.Primary" Linear="false">

        @* ── Step 1: Connection ──────────────────────────────────────────── *@
        <MudStep Title="Connection" Icon="@Icons.Material.Filled.Link">
            <MudGrid Spacing="3">

                @* Connection form *@
                <MudItem xs="12" md="7">
                    <MudCard Elevation="2">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudIcon Icon="@Icons.Material.Filled.Storage" />
                                    <MudText Typo="Typo.subtitle1">Connection Configuration</MudText>
                                </MudStack>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudGrid Spacing="2">
                                <MudItem xs="12">
                                    <MudSelect T="string" @bind-Value="_dbType" Label="Database Type" Variant="Variant.Outlined">
                                        <MudSelectItem Value="@("SqlServer")">SQL Server</MudSelectItem>
                                        <MudSelectItem Value="@("PostgreSQL")">PostgreSQL</MudSelectItem>
                                        <MudSelectItem Value="@("SQLite")">SQLite</MudSelectItem>
                                        <MudSelectItem Value="@("Oracle")">Oracle</MudSelectItem>
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" sm="8">
                                    <MudTextField @bind-Value="_host" Label="Host / Server" Variant="Variant.Outlined"
                                                  Placeholder="localhost" />
                                </MudItem>
                                <MudItem xs="12" sm="4">
                                    <MudTextField @bind-Value="_port" Label="Port" Variant="Variant.Outlined" Placeholder="1433" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudTextField @bind-Value="_database" Label="Database Name" Variant="Variant.Outlined" Placeholder="PPDM39" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudTextField @bind-Value="_schema" Label="Schema" Variant="Variant.Outlined" Placeholder="dbo" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudTextField @bind-Value="_username" Label="Username" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudTextField @bind-Value="_password" Label="Password" Variant="Variant.Outlined"
                                                  InputType="InputType.Password" />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudTextField @bind-Value="_connectionString" Label="Connection String (override)"
                                                  Variant="Variant.Outlined" Lines="2"
                                                  Placeholder="Optional — overrides fields above if provided" />
                                </MudItem>
                            </MudGrid>
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.PlayArrow"
                                       Disabled="@_isTesting" OnClick="TestConnection">
                                @(_isTesting ? "Testing…" : "Test Connection")
                            </MudButton>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Save"
                                       Disabled="@_isSaving" OnClick="SaveAndProceed">
                                @(_isSaving ? "Saving…" : "Save & Continue →")
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>

                @* Status + saved connections panel *@
                <MudItem xs="12" md="5">
                    <MudStack Spacing="3">
                        <MudCard Elevation="2">
                            <MudCardHeader>
                                <CardHeaderContent><MudText Typo="Typo.subtitle1">Connection Status</MudText></CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudStack Spacing="2">
                                    @foreach (var item in _statusItems)
                                    {
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <MudText Typo="Typo.body2">@item.Label</MudText>
                                            <MudChip T="string" Size="Size.Small" Color="@item.Color">@item.Value</MudChip>
                                        </MudStack>
                                    }
                                </MudStack>
                            </MudCardContent>
                        </MudCard>

                        @if (_existingConnections.Any())
                        {
                            <MudCard Elevation="1">
                                <MudCardHeader>
                                    <CardHeaderContent><MudText Typo="Typo.subtitle2">Saved Connections</MudText></CardHeaderContent>
                                </MudCardHeader>
                                <MudCardContent Class="pa-0">
                                    <MudList T="string" Dense="true">
                                        @foreach (var conn in _existingConnections)
                                        {
                                            <MudListItem Icon="@Icons.Material.Filled.Storage"
                                                         OnClick="@(() => SelectExistingConnection(conn))">
                                                <MudText Typo="Typo.body2">@conn.ConnectionName</MudText>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@conn.DatabaseType</MudText>
                                            </MudListItem>
                                        }
                                    </MudList>
                                </MudCardContent>
                            </MudCard>
                        }
                    </MudStack>
                </MudItem>

            </MudGrid>
        </MudStep>

        @* ── Step 2: Schema Modules ──────────────────────────────────────── *@
        <MudStep Title="Schema Modules" Icon="@Icons.Material.Filled.AccountTree">
            <MudStack Spacing="3">
                @if (!_isConnected)
                {
                    <MudAlert Severity="Severity.Warning">
                        Please save a connection in Step 1 before installing schema modules.
                    </MudAlert>
                }
                else
                {
                    <MudAlert Severity="Severity.Info" Dense="true">
                        Select individual modules to install, or click <strong>Install All</strong> to create the full PPDM39 schema.
                    </MudAlert>
                    <SchemaModuleManager ConnectionName="@_savedConnectionName"
                                         OnInstallComplete="HandleInstallComplete" />
                }
                <MudStack Row="true" Spacing="2" Class="mt-2">
                    <MudButton Variant="Variant.Outlined" OnClick="@(() => _step = 0)"
                               StartIcon="@Icons.Material.Filled.ArrowBack">Back</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               OnClick="@(() => _step = 2)"
                               EndIcon="@Icons.Material.Filled.ArrowForward">
                        Continue → Reference Data
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudStep>

        @* ── Step 3: Reference Data ──────────────────────────────────────── *@
        <MudStep Title="Reference Data" Icon="@Icons.Material.Filled.LibraryBooks">
            <MudStack Spacing="3">
                @if (!_isConnected)
                {
                    <MudAlert Severity="Severity.Warning">
                        Please save a connection in Step 1 before seeding reference data.
                    </MudAlert>
                }
                else
                {
                    <MudAlert Severity="Severity.Info" Dense="true">
                        Seed the R_* and RA_* reference tables with PPDM standard values.
                    </MudAlert>
                    <ReferenceValuesManager ConnectionName="@_savedConnectionName" />
                }
                <MudStack Row="true" Spacing="2" Class="mt-2">
                    <MudButton Variant="Variant.Outlined" OnClick="@(() => _step = 1)"
                               StartIcon="@Icons.Material.Filled.ArrowBack">Back</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               OnClick="@(() => _step = 3)"
                               EndIcon="@Icons.Material.Filled.ArrowForward">
                        Continue → Summary
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudStep>

        @* ── Step 4: Summary ────────────────────────────────────────────── *@
        <MudStep Title="Summary" Icon="@Icons.Material.Filled.CheckCircle">
            <MudStack Spacing="3">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderAvatar>
                            <MudAvatar Color="@(_isConnected ? Color.Success : Color.Default)">
                                <MudIcon Icon="@(_isConnected ? Icons.Material.Filled.CheckCircle : Icons.Material.Outlined.RadioButtonUnchecked)" />
                            </MudAvatar>
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            <MudText Typo="Typo.subtitle1">Setup Summary</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                @(_isConnected ? "Database configured and ready" : "Connection not yet established")
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudGrid Spacing="2">
                            <MudItem xs="12" sm="6">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Connection Name</MudText>
                                <MudText Typo="Typo.body2">@(_savedConnectionName ?? "—")</MudText>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Database Type</MudText>
                                <MudText Typo="Typo.body2">@_dbType</MudText>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Host</MudText>
                                <MudText Typo="Typo.body2">@(string.IsNullOrWhiteSpace(_host) ? "—" : _host)</MudText>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Database</MudText>
                                <MudText Typo="Typo.body2">@_database</MudText>
                            </MudItem>
                        </MudGrid>
                    </MudCardContent>
                </MudCard>

                <MudText Typo="Typo.subtitle2">Quick Actions</MudText>
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6" md="4">
                        <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.AccountTree"
                                   OnClick="@(() => NavigationManager.NavigateTo("/ppdm39/data-management/schema"))">
                            Schema Manager
                        </MudButton>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Default"
                                   StartIcon="@Icons.Material.Filled.TableView"
                                   OnClick="@(() => NavigationManager.NavigateTo("/ppdm39/data-management"))">
                            Data Management
                        </MudButton>
                    </MudItem>
                </MudGrid>

                <MudStack Row="true" Spacing="2" Class="mt-2">
                    <MudButton Variant="Variant.Outlined" OnClick="@(() => _step = 2)"
                               StartIcon="@Icons.Material.Filled.ArrowBack">Back</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.Done"
                               OnClick="@(() => NavigationManager.NavigateTo("/ppdm39/data-management"))">
                        Go to Data Management
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudStep>

    </MudStepper>

</MudContainer>

@code {
    private int _step;
    private bool _isConnected;
    private bool _isTesting;
    private bool _isSaving;
    private string? _savedConnectionName;

    private string _dbType = "SqlServer";
    private string _host = "";
    private string _port = "1433";
    private string _database = "PPDM39";
    private string _schema = "dbo";
    private string _username = "";
    private string _password = "";
    private string _connectionString = "";

    private List<DatabaseConnectionListItem> _existingConnections = new();

    private record StatusItem(string Label, string Value, Color Color);
    private List<StatusItem> _statusItems = new()
    {
        new("Status",       "Not connected", Color.Default),
        new("PPDM Version", "—",             Color.Default),
        new("Table Count",  "—",             Color.Default),
        new("LOV Tables",   "—",             Color.Default),
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _existingConnections = await DataManagementService.GetAllConnectionsAsync();
        }
        catch { /* non-critical */ }
    }

    private ConnectionConfig BuildConnectionConfig() => new()
    {
        ConnectionName   = $"{_database}_{_dbType}",
        DatabaseType     = _dbType,
        Host             = _host,
        Port             = int.TryParse(_port, out var port) ? port : 0,
        Database         = _database,
        Schema           = _schema,
        Username         = _username,
        Password         = _password,
        ConnectionString = string.IsNullOrWhiteSpace(_connectionString) ? null : _connectionString,
    };

    private async Task TestConnection()
    {
        _isTesting = true;
        Snackbar.Add("Testing connection…", Severity.Info);
        try
        {
            var result = await DataManagementService.TestConnectionAsync(BuildConnectionConfig());
            if (result.Success)
            {
                _isConnected = true;
                _statusItems = new()
                {
                    new("Status",       "Connected", Color.Success),
                    new("PPDM Version", "3.9",       Color.Success),
                    new("Table Count",  "—",         Color.Default),
                    new("LOV Tables",   "—",         Color.Default),
                };
                Snackbar.Add("Connection successful", Severity.Success);
            }
            else
            {
                _isConnected = false;
                Snackbar.Add($"Connection failed: {result.Message ?? result.ErrorDetails ?? "Unknown error"}", Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Error testing connection.", Severity.Error);
        }
        finally { _isTesting = false; }
    }

    private async Task SaveAndProceed()
    {
        _isSaving = true;
        try
        {
            var config = BuildConnectionConfig();
            var payload = new SaveConnectionRequest
            {
                Connection = config.ToConnectionProperties(),
                TestAfterSave = true,
                OpenAfterSave = false
            };
            var result = await DataManagementService.SaveConnectionAsync(payload);
            if (result.Success)
            {
                _savedConnectionName = result.ConnectionName ?? config.ConnectionName;
                _isConnected = true;
                _statusItems = new()
                {
                    new("Status",       "Connected",           Color.Success),
                    new("Connection",   _savedConnectionName!, Color.Success),
                    new("Database",     _database,             Color.Default),
                    new("Type",         _dbType,               Color.Default),
                };
                Snackbar.Add("Connection saved", Severity.Success);
                _existingConnections = await DataManagementService.GetAllConnectionsAsync();
                _step = 1;
            }
            else
            {
                Snackbar.Add($"Save failed: {result.Message ?? "Unknown error"}", Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Error saving connection.", Severity.Error);
        }
        finally { _isSaving = false; }
    }

    private void SelectExistingConnection(DatabaseConnectionListItem conn)
    {
        _savedConnectionName = conn.ConnectionName;
        _dbType = conn.DatabaseType ?? _dbType;
        _host = conn.Host ?? _host;
        _database = conn.Database ?? _database;
        _isConnected = true;
        _statusItems = new()
        {
            new("Status",       "Connected",              Color.Success),
            new("Connection",   conn.ConnectionName!,     Color.Success),
            new("Database",     conn.Database ?? "—",     Color.Default),
            new("Type",         conn.DatabaseType ?? "—", Color.Default),
        };
        Snackbar.Add($"Loaded connection '{conn.ConnectionName}'", Severity.Info);
        _step = 1;
    }

    private void HandleInstallComplete()
    {
        Snackbar.Add("Schema installation updated", Severity.Info);
    }

    // ── DTOs ──────────────────────────────────────────────────────────────────


}

