@page "/ppdm39/exploration/prospects"
@using Beep.OilandGas.Models.Data
@using System.Security.Claims
@inject ApiClient ApiClient
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager NavigationManager
@inject IExplorationServiceClient ExplorationService
@inject ILifeCycleService LifeCycleService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Evaluate Exploration Prospects</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @* ── Header ──────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Evaluate Exploration Prospects</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Prospect pipeline</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Info"
                         Icon="@Icons.Material.Filled.Explore">Exploration</MudChip>
            </MudStack>
        </MudStack>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog">
            Add Prospect
        </MudButton>
    </MudStack>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }

    @* ── KPI Row ─────────────────────────────────────────────────────── *@
    <MudGrid Class="mb-4" Spacing="3">
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Total Prospects" Value="@((_prospects?.Count ?? 0).ToString())"
                     ValueColor="Color.Primary" Icon="@Icons.Material.Filled.Layers"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default"
                     TrendText="All statuses" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Pending Evaluation"
                     Value="@((_prospects?.Count(p => string.IsNullOrWhiteSpace(p.Status) || p.Status == "PENDING" || p.Status == "NEW") ?? 0).ToString())"
                     ValueColor="Color.Warning" Icon="@Icons.Material.Filled.HourglassEmpty"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Warning"
                     TrendText="Awaiting review" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Approved"
                     Value="@((_prospects?.Count(p => p.Status == "APPROVED") ?? 0).ToString())"
                     ValueColor="Color.Success" Icon="@Icons.Material.Filled.CheckCircle"
                     TrendIcon="@Icons.Material.Filled.TrendingUp" TrendColor="Color.Success"
                     TrendText="Ready to drill" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Abandoned"
                     Value="@((_prospects?.Count(p => p.Status == "ABANDONED" || p.Status == "REJECTED") ?? 0).ToString())"
                     ValueColor="Color.Error" Icon="@Icons.Material.Filled.Cancel"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default"
                     TrendText="Not pursued" />
        </MudItem>
    </MudGrid>

    @* ── Prospect Grid ───────────────────────────────────────────────── *@
    <MudCard Elevation="2">
        <MudCardContent Class="pa-0">
            @if (_prospects != null && _prospects.Any())
            {
                <MudDataGrid T="ProspectListItem" Items="@_prospects" Dense="true" Hover="true" Striped="true"
                             SortMode="SortMode.Multiple" Filterable="true">
                    <Columns>
                        <PropertyColumn Property="p => p.Name" Title="Prospect Name" Sortable="true" />
                        <TemplateColumn Title="Status">
                            <CellTemplate>
                                <StatusBadge Status="@(context.Item.Status ?? "PENDING")" />
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Evaluation Date">
                            <CellTemplate>
                                <MudText Typo="Typo.body2">
                                    @(context.Item.EvaluationDate?.ToString("dd MMM yyyy") ?? "—")
                                </MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <PropertyColumn Property="p => p.Description" Title="Description" />
                        <TemplateColumn Title="Actions" Sortable="false">
                            <CellTemplate>
                                <MudStack Row="true" Spacing="1">
                                    <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary"
                                               StartIcon="@Icons.Material.Filled.Science"
                                               OnClick="@(() => OpenEditDialog(context.Item))">
                                        Evaluate
                                    </MudButton>
                                    <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Error"
                                               StartIcon="@Icons.Material.Filled.Delete"
                                               OnClick="@(() => DeleteProspect(context.Item))">
                                        Remove
                                    </MudButton>
                                </MudStack>
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                    <NoRecordsContent>
                        <MudStack AlignItems="AlignItems.Center" Class="pa-6">
                            <MudIcon Icon="@Icons.Material.Filled.Layers" Color="Color.Secondary"
                                     Class="og-icon-xl" />
                            <MudText Typo="Typo.body1">No prospects match the current filter</MudText>
                        </MudStack>
                    </NoRecordsContent>
                </MudDataGrid>
            }
            else if (!_isLoading)
            {
                <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                    <MudIcon Icon="@Icons.Material.Filled.Explore" Color="Color.Secondary"
                             Class="og-icon-xl" />
                    <MudText Typo="Typo.h6">No prospects yet</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Start by adding the first exploration prospect for this field.
                    </MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="OpenCreateDialog" Class="mt-2">
                        Add First Prospect
                    </MudButton>
                </MudStack>
            }
        </MudCardContent>
    </MudCard>

</MudContainer>

@code {
    private string _fieldName = string.Empty;
    private List<ProspectListItem>? _prospects;
    private bool _isLoading = false;
    private string? _currentUserId;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summary = await LifeCycleService.GetFieldLifecycleSummaryAsync();
            if (summary != null)
                _fieldName = summary.FieldName ?? _fieldName;
        }
        catch { /* field name is non-critical */ }

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _currentUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "system";
        await LoadProspects();
    }

    private async Task LoadProspects()
    {
        _isLoading = true;
        try
        {
            var prospects = await ExplorationService.GetProspectsAsync();
            _prospects = prospects
                .Select(prospect => new ProspectListItem(
                    prospect.PROSPECT_ID ?? string.Empty,
                    prospect.PROSPECT_NAME ?? prospect.PROSPECT_ID ?? "Unknown",
                    prospect.PROSPECT_STATUS,
                    prospect.DISCOVERY_DATE,
                    prospect.REMARK))
                .OrderBy(prospect => prospect.Name)
                .ToList();
        }
        catch (Exception)
        {
            Snackbar.Add("Error loading prospects.", Severity.Error);
            _prospects = new List<ProspectListItem>();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OpenCreateDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ProspectEditDialog>("Create Prospect", options);
        var result = await dialog.Result;

        if (result?.Canceled == false && result.Data is Dictionary<string, object> prospectData)
        {
            try
            {
                var prospect = new ProspectRequest
                {
                    ProspectName = prospectData.ContainsKey("PROSPECT_NAME") ? prospectData["PROSPECT_NAME"]?.ToString() ?? string.Empty : string.Empty,
                    FieldId = prospectData.ContainsKey("FIELD_ID") ? prospectData["FIELD_ID"]?.ToString() ?? string.Empty : string.Empty,
                    Description = prospectData.ContainsKey("DESCRIPTION") ? prospectData["DESCRIPTION"]?.ToString() : null,
                    Status = prospectData.ContainsKey("PROSPECT_STATUS") ? prospectData["PROSPECT_STATUS"]?.ToString() ?? string.Empty : string.Empty,
                    DiscoveryDate = prospectData.ContainsKey("DISCOVERY_DATE") && DateTime.TryParse(prospectData["DISCOVERY_DATE"]?.ToString(), out var discoveryDate) ? discoveryDate : DateTime.UtcNow,
                    RiskLevel = prospectData.ContainsKey("RISK_LEVEL") ? prospectData["RISK_LEVEL"]?.ToString() : null
                };

                await ExplorationService.CreateProspectAsync(prospect, _currentUserId);
                Snackbar.Add("Prospect created successfully", Severity.Success);
                await LoadProspects();
            }
            catch (Exception)
            {
                Snackbar.Add("Error creating prospect.", Severity.Error);
            }
        }
    }

    private async Task OpenEditDialog(ProspectListItem prospect)
    {
        Beep.OilandGas.PPDM39.Models.PROSPECT? currentProspect;
        try
        {
            currentProspect = await ExplorationService.GetProspectAsync(prospect.Id);
        }
        catch (Exception)
        {
            Snackbar.Add("Error loading prospect details.", Severity.Error);
            return;
        }

        if (currentProspect == null)
        {
            Snackbar.Add("Prospect not found.", Severity.Warning);
            return;
        }

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var parameters = new DialogParameters
        {
            ["Prospect"] = new Dictionary<string, object>
            {
                ["PROSPECT_NAME"] = currentProspect.PROSPECT_NAME ?? prospect.Name,
                ["PROSPECT_STATUS"] = currentProspect.PROSPECT_STATUS ?? prospect.Status ?? string.Empty,
                ["DESCRIPTION"] = currentProspect.REMARK ?? prospect.Description ?? string.Empty,
                ["DISCOVERY_DATE"] = currentProspect.DISCOVERY_DATE?.ToString("O") ?? prospect.EvaluationDate?.ToString("O") ?? string.Empty,
                ["ESTIMATED_RESERVES"] = currentProspect.AREA_SIZE?.ToString() ?? string.Empty
            }
        };
        var dialog = await DialogService.ShowAsync<ProspectEditDialog>("Edit Prospect", parameters, options);
        var result = await dialog.Result;

        if (result?.Canceled == false && result.Data is Dictionary<string, object> prospectData)
        {
            try
            {
                var request = BuildProspectRequest(prospectData, currentProspect);
                await ExplorationService.UpdateProspectAsync(prospect.Id, request, _currentUserId);
                Snackbar.Add("Prospect updated successfully", Severity.Success);
                await LoadProspects();
            }
            catch (Exception)
            {
                Snackbar.Add("Error updating prospect.", Severity.Error);
            }
        }
    }

    private async Task DeleteProspect(ProspectListItem prospect)
    {
        var result = await DialogService.ShowMessageBoxAsync(
            "Delete Prospect",
            $"Are you sure you want to delete prospect {prospect.Name}?",
            yesText: "Delete", cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                await ExplorationService.DeleteProspectAsync(prospect.Id, _currentUserId);
                Snackbar.Add("Prospect deleted successfully", Severity.Success);
                await LoadProspects();
            }
            catch (Exception)
            {
                Snackbar.Add("Error deleting prospect.", Severity.Error);
            }
        }
    }

    private static ProspectRequest BuildProspectRequest(Dictionary<string, object> prospectData, Beep.OilandGas.PPDM39.Models.PROSPECT? existingProspect = null)
    {
        var request = new ProspectRequest
        {
            ProspectId = existingProspect?.PROSPECT_ID,
            ProspectName = prospectData.ContainsKey("PROSPECT_NAME")
                ? prospectData["PROSPECT_NAME"]?.ToString() ?? existingProspect?.PROSPECT_NAME ?? string.Empty
                : existingProspect?.PROSPECT_NAME ?? string.Empty,
            Description = prospectData.ContainsKey("DESCRIPTION")
                ? prospectData["DESCRIPTION"]?.ToString()
                : existingProspect?.REMARK,
            Status = prospectData.ContainsKey("PROSPECT_STATUS")
                ? prospectData["PROSPECT_STATUS"]?.ToString() ?? existingProspect?.PROSPECT_STATUS
                : existingProspect?.PROSPECT_STATUS,
            DiscoveryDate = prospectData.ContainsKey("DISCOVERY_DATE") && DateTime.TryParse(prospectData["DISCOVERY_DATE"]?.ToString(), out var discoveryDate)
                ? discoveryDate
                : existingProspect?.DISCOVERY_DATE,
            RiskLevel = prospectData.ContainsKey("RISK_LEVEL") ? prospectData["RISK_LEVEL"]?.ToString() : null,
            ProspectType = existingProspect?.PROSPECT_TYPE,
            EstimatedOilVolume = prospectData.ContainsKey("ESTIMATED_RESERVES") && decimal.TryParse(prospectData["ESTIMATED_RESERVES"]?.ToString(), out var reserves)
                ? reserves
                : existingProspect?.AREA_SIZE,
            EstimatedVolumeOuom = existingProspect?.AREA_SIZE_OUOM
        };

        return request;
    }

    private sealed record ProspectListItem(string Id, string Name, string? Status, DateTime? EvaluationDate, string? Description);
}

