@page "/exploration/well-program"
@page "/exploration/well-program/new"
@page "/exploration/well-program/{Id}"
@using System.Linq
@inject ApiClient ApiClient
@inject IExplorationServiceClient ExplorationService
@inject ILifeCycleService LifeCycleService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Approve Well Programme</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="pa-4">

    @* Header *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-6">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                       OnClick='() => NavigationManager.NavigateTo("/exploration")'
                       Title="Back to Exploration" />
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Approve Well Programme</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName - Complete all steps to submit for sign-off</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Info" Icon="@Icons.Material.Filled.Explore">Exploration</MudChip>
            </MudStack>
        </MudStack>
    </MudStack>

    @if (_isLoadingProspects)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }

    <MudStepper @bind-ActiveIndex="_step"
                Linear="true"
                Color="Color.Primary"
                Class="mb-4">

        <MudStep Title="Well Objectives"
                 Icon="@Icons.Material.Filled.Flag"
                 CompletedIcon="@Icons.Material.Filled.CheckCircle">
            <MudGrid Spacing="3" Class="pt-4">
                <MudItem xs="12" md="6">
                    <MudSelect T="string"
                               @bind-Value="_form.ProspectId"
                               @bind-Value:after="OnProspectChangedAsync"
                               Label="Linked Prospect"
                               Variant="Variant.Outlined"
                               Required="true">
                        @foreach (var prospect in _prospects)
                        {
                            <MudSelectItem T="string" Value="@prospect.Id">@prospect.Name</MudSelectItem>
                        }
                    </MudSelect>
                    @if (!_isLoadingProspects && _prospects.Count == 0)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Warning" Class="mt-1">
                            No active field prospects are available to seed this well program.
                        </MudText>
                    }
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_form.WellName" Label="Proposed Well Name" Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_form.TargetZone" Label="Primary Target Zone" Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="string" @bind-Value="_form.WellType" Label="Well Type" Variant="Variant.Outlined">
                        <MudSelectItem T="string" Value="@("Wildcat")">Wildcat</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Appraisal")">Appraisal</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Step-out")">Step-out</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_form.Objectives"
                                  Label="Well Objectives"
                                  Lines="4"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  Placeholder="Define the primary objectives: test trap integrity, confirm reservoir quality, appraise resource." />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_form.ExpectedOutcome"
                                  Label="Expected Outcome (success case)"
                                  Lines="2"
                                  Variant="Variant.Outlined"
                                  Placeholder="Summarize the live prospect evaluation outcome and success case." />
                </MudItem>
            </MudGrid>
            <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-4">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="NextStep" Disabled="@(!Step1Valid)">
                    Continue
                </MudButton>
            </MudStack>
        </MudStep>

        <MudStep Title="Technical Summary"
                 Icon="@Icons.Material.Filled.Engineering"
                 CompletedIcon="@Icons.Material.Filled.CheckCircle">
            <MudGrid Spacing="3" Class="pt-4">
                <MudItem xs="12" md="4">
                    <MudNumericField @bind-Value="_form.PlannedTdM" Label="Planned TD (m)" Variant="Variant.Outlined" Min="0" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect T="string" @bind-Value="_form.Trajectory" Label="Well Trajectory" Variant="Variant.Outlined">
                        <MudSelectItem T="string" Value="@("Vertical")">Vertical</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Directional")">Directional</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Horizontal")">Horizontal</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudNumericField @bind-Value="_form.PlannedDurationDays" Label="Planned Duration (days)" Variant="Variant.Outlined" Min="1" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_form.FormationsToEncounter"
                                  Label="Formations to Encounter"
                                  Lines="2"
                                  Variant="Variant.Outlined"
                                  Placeholder="List formations in order from surface to TD" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_form.DrillingProgram"
                                  Label="Drilling Program Overview"
                                  Lines="4"
                                  Variant="Variant.Outlined"
                                  Placeholder="Describe casing program, BHA, drilling fluids, and testing scope." />
                </MudItem>
            </MudGrid>
            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-4">
                <MudButton Variant="Variant.Text" OnClick="PrevStep">Back</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="NextStep">Continue</MudButton>
            </MudStack>
        </MudStep>

        <MudStep Title="Risk Assessment"
                 Icon="@Icons.Material.Filled.Shield"
                 CompletedIcon="@Icons.Material.Filled.CheckCircle">
            <MudPaper Elevation="0" Class="pt-4">
                <MudText Typo="Typo.subtitle2" Class="mb-3">Technical and Operational Risks</MudText>
                <MudDataGrid T="WellProgramRiskItem" Items="@_form.Risks" Dense="true" Hover="true" Striped="true" Class="mb-4">
                    <Columns>
                        <PropertyColumn Property="r => r.Description" Title="Risk" />
                        <TemplateColumn Title="Likelihood">
                            <CellTemplate>
                                <MudChip T="string" Size="Size.Small" Color="@GetRiskColor(context.Item.Likelihood)">
                                    @context.Item.Likelihood
                                </MudChip>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Impact">
                            <CellTemplate>
                                <MudChip T="string" Size="Size.Small" Color="@GetRiskColor(context.Item.Impact)">
                                    @context.Item.Impact
                                </MudChip>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Mitigation">
                            <CellTemplate>
                                <MudText Typo="Typo.caption">@context.Item.Mitigation</MudText>
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                    <NoRecordsContent>
                        <MudStack AlignItems="AlignItems.Center" Class="pa-6">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                No prospect evaluation risks are available for the selected program yet.
                            </MudText>
                        </MudStack>
                    </NoRecordsContent>
                </MudDataGrid>
                <MudTextField @bind-Value="_form.HseConsiderations"
                              Label="HSE Considerations"
                              Lines="3"
                              Variant="Variant.Outlined"
                              Placeholder="Identify key HSE hazards and planned controls" />
            </MudPaper>
            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-4">
                <MudButton Variant="Variant.Text" OnClick="PrevStep">Back</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="NextStep">Continue</MudButton>
            </MudStack>
        </MudStep>

        <MudStep Title="Cost Estimate (AFE)"
                 Icon="@Icons.Material.Filled.AttachMoney"
                 CompletedIcon="@Icons.Material.Filled.CheckCircle">
            <MudPaper Elevation="0" Class="pt-4">
                <MudText Typo="Typo.subtitle2" Class="mb-3">AFE Line Items</MudText>
                <MudDataGrid T="WellProgramAfeLine" Items="@_form.AfeLines" Dense="true" Hover="true" Striped="true">
                    <Columns>
                        <PropertyColumn Property="l => l.AfeNumber" Title="AFE #" />
                        <PropertyColumn Property="l => l.Category" Title="Category" />
                        <PropertyColumn Property="l => l.Description" Title="Description" />
                        <TemplateColumn Title="Cost (USD)">
                            <CellTemplate>
                                <MudText Typo="Typo.body2">@context.Item.CostUsd.ToString("N0")</MudText>
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                    <NoRecordsContent>
                        <MudStack AlignItems="AlignItems.Center" Class="pa-6">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                No live AFE line items are linked to the selected prospect yet.
                            </MudText>
                        </MudStack>
                    </NoRecordsContent>
                </MudDataGrid>
                <MudStack Class="mt-2 pa-2" Spacing="1">
                    <MudStack Row="true" Spacing="2" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Contingency (15%)</MudText>
                        <MudText Typo="Typo.body2"><strong>@(_form.AfeLines.Sum(l => l.CostUsd) * 0.15m).ToString("N0")</strong></MudText>
                    </MudStack>
                    <MudStack Row="true" Spacing="2" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.body2"><strong>Total AFE</strong></MudText>
                        <MudText Typo="Typo.body2" Color="Color.Warning"><strong>@(_form.AfeLines.Sum(l => l.CostUsd) * 1.15m).ToString("N0")</strong></MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>
            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-4">
                <MudButton Variant="Variant.Text" OnClick="PrevStep">Back</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="NextStep">Continue</MudButton>
            </MudStack>
        </MudStep>

        <MudStep Title="Approval Sign-off"
                 Icon="@Icons.Material.Filled.Gavel"
                 CompletedIcon="@Icons.Material.Filled.CheckCircle">
            <MudGrid Spacing="3" Class="pt-4">
                <MudItem xs="12">
                    <MudPaper Elevation="1" Class="pa-4">
                        <MudText Typo="Typo.h6" Class="mb-3">Program Summary</MudText>
                        <MudGrid Spacing="2">
                            <MudItem xs="6" md="3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Well Name</MudText>
                                <MudText>@_form.WellName</MudText>
                            </MudItem>
                            <MudItem xs="6" md="3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Target Zone</MudText>
                                <MudText>@_form.TargetZone</MudText>
                            </MudItem>
                            <MudItem xs="6" md="3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Planned TD</MudText>
                                <MudText>@_form.PlannedTdM m</MudText>
                            </MudItem>
                            <MudItem xs="6" md="3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Total AFE</MudText>
                                <MudText>USD @(_form.AfeLines.Sum(l => l.CostUsd) * 1.15m).ToString("N0")</MudText>
                            </MudItem>
                        </MudGrid>
                        <MudDivider Class="my-3" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Objectives</MudText>
                        <MudText Typo="Typo.body2">@_form.Objectives</MudText>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="_form.ApproverComments"
                                  Label="Approver Comments"
                                  Lines="3"
                                  Variant="Variant.Outlined"
                                  Placeholder="Optional: add sign-off notes or conditions" />
                </MudItem>

                <MudItem xs="12">
                    <MudStack Row="true" Spacing="2" Justify="Justify.FlexStart">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Success"
                                   StartIcon="@Icons.Material.Filled.CheckCircle"
                                   OnClick="ApproveProgram">
                            Approve Well Program
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Warning"
                                   StartIcon="@Icons.Material.Filled.Schedule"
                                   OnClick="DeferProgram">
                            Defer to Next Cycle
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Error"
                                   StartIcon="@Icons.Material.Filled.Cancel"
                                   OnClick="RejectProgram">
                            Reject
                        </MudButton>
                    </MudStack>
                </MudItem>
            </MudGrid>
            <MudStack Row="true" Justify="Justify.FlexStart" Class="mt-4">
                <MudButton Variant="Variant.Text" OnClick="PrevStep">Back</MudButton>
            </MudStack>
        </MudStep>

    </MudStepper>

</MudContainer>

@code {
    [Parameter] public string? Id { get; set; }

    private string _fieldName = string.Empty;
    private int _step;
    private bool _isLoadingProspects;
    private List<ProspectOption> _prospects = new();
    private readonly WellProgramForm _form = new();

    protected override async Task OnInitializedAsync()
    {
        _isLoadingProspects = true;

        try
        {
            var summary = await LifeCycleService.GetFieldLifecycleSummaryAsync();
            if (summary != null)
                _fieldName = summary.FieldName ?? _fieldName;
        }
        catch
        {
            // Field name is non-critical.
        }

        try
        {
            await LoadProspectsAsync();

            var prospectId = ResolveProspectId();
            if (!string.IsNullOrWhiteSpace(prospectId))
                await LoadProspectDraftAsync(prospectId);
        }
        finally
        {
            _isLoadingProspects = false;
        }
    }

    private bool Step1Valid =>
        !string.IsNullOrWhiteSpace(_form.ProspectId) &&
        !string.IsNullOrWhiteSpace(_form.WellName) &&
        !string.IsNullOrWhiteSpace(_form.Objectives);

    private void NextStep()
    {
        if (_step < 4)
            _step++;
    }

    private void PrevStep()
    {
        if (_step > 0)
            _step--;
    }

    private Task ApproveProgram() => SubmitDecisionAsync("APPROVED");

    private Task DeferProgram() => SubmitDecisionAsync("DEFERRED");

    private Task RejectProgram() => SubmitDecisionAsync("REJECTED");

    private async Task LoadProspectsAsync()
    {
        try
        {
            var prospects = await ExplorationService.GetProspectsAsync();
            _prospects = prospects
                .Where(p => !string.Equals(p.ACTIVE_IND, "N", StringComparison.OrdinalIgnoreCase))
                .OrderBy(p => p.PROSPECT_NAME)
                .Select(p => new ProspectOption(
                    p.PROSPECT_ID ?? string.Empty,
                    p.PROSPECT_NAME ?? p.PROSPECT_ID ?? "Unnamed prospect"))
                .Where(p => !string.IsNullOrWhiteSpace(p.Id))
                .ToList();
        }
        catch (Exception)
        {
            Snackbar.Add("Error loading field prospects.", Severity.Warning);
        }
    }

    private async Task LoadProspectDraftAsync(string prospectId)
    {
        _form.Risks = new List<WellProgramRiskItem>();
        _form.AfeLines = new List<WellProgramAfeLine>();

        try
        {
            var prospect = await ExplorationService.GetProspectAsync(prospectId);
            if (prospect == null)
                return;

            _form.ProspectId = prospect.PROSPECT_ID ?? prospectId;

            if (string.IsNullOrWhiteSpace(_form.WellName))
                _form.WellName = BuildWellName(prospect);

            if (string.IsNullOrWhiteSpace(_form.TargetZone))
                _form.TargetZone = prospect.PROSPECT_TYPE ?? string.Empty;

            if (string.IsNullOrWhiteSpace(_form.Objectives) && !string.IsNullOrWhiteSpace(prospect.REMARK))
                _form.Objectives = prospect.REMARK;

            try
            {
                var evaluation = await ExplorationService.EvaluateProspectAsync(prospectId);

                if (string.IsNullOrWhiteSpace(_form.Objectives) && !string.IsNullOrWhiteSpace(evaluation.Recommendation))
                    _form.Objectives = evaluation.Recommendation;

                if (string.IsNullOrWhiteSpace(_form.ExpectedOutcome))
                    _form.ExpectedOutcome = BuildExpectedOutcome(evaluation);

                _form.Risks = BuildRiskItems(evaluation);
            }
            catch (Exception)
            {
                _form.Risks = new List<WellProgramRiskItem>();
            }

            try
            {
                var afeLines = await ExplorationService.GetProspectAfeLinesAsync(prospectId);
                _form.AfeLines = afeLines
                    .Select(line => new WellProgramAfeLine(
                        line.AfeNumber,
                        line.Category,
                        line.Description,
                        line.CostUsd))
                    .ToList();
            }
            catch (Exception)
            {
                _form.AfeLines = new List<WellProgramAfeLine>();
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Error loading prospect details for the well program.", Severity.Warning);
        }
    }

    private async Task OnProspectChangedAsync()
    {
        ResetProspectDraft();

        if (string.IsNullOrWhiteSpace(_form.ProspectId))
            return;

        await LoadProspectDraftAsync(_form.ProspectId);
    }

    private string? ResolveProspectId()
    {
        if (!string.IsNullOrWhiteSpace(Id) && !string.Equals(Id, "new", StringComparison.OrdinalIgnoreCase))
            return Id;

        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        return query.TryGetValue("prospectId", out var prospectId) ? prospectId.ToString() : null;
    }

    private async Task SubmitDecisionAsync(string decision)
    {
        var prospectId = !string.IsNullOrWhiteSpace(_form.ProspectId)
            ? _form.ProspectId
            : ResolveProspectId();

        if (string.IsNullOrWhiteSpace(prospectId))
        {
            Snackbar.Add("Select a prospect before submitting a well program decision.", Severity.Warning);
            return;
        }

        try
        {
            await ExplorationService.RecordProspectDecisionAsync(prospectId, decision, _form.ApproverComments);
        }
        catch (Exception)
        {
            Snackbar.Add("Error submitting decision.", Severity.Error);
            return;
        }

        Snackbar.Add(
            $"Well program {decision.ToLowerInvariant()}.",
            decision == "APPROVED" ? Severity.Success : decision == "DEFERRED" ? Severity.Warning : Severity.Error);

        NavigationManager.NavigateTo("/exploration");
    }

    private void ResetProspectDraft()
    {
        _form.WellName = string.Empty;
        _form.TargetZone = string.Empty;
        _form.Objectives = string.Empty;
        _form.ExpectedOutcome = string.Empty;
        _form.Risks = new List<WellProgramRiskItem>();
        _form.AfeLines = new List<WellProgramAfeLine>();
    }

    private sealed class WellProgramForm
    {
        public string ProspectId { get; set; } = string.Empty;
        public string WellName { get; set; } = string.Empty;
        public string TargetZone { get; set; } = string.Empty;
        public string WellType { get; set; } = "Wildcat";
        public string Objectives { get; set; } = string.Empty;
        public string ExpectedOutcome { get; set; } = string.Empty;
        public int PlannedTdM { get; set; } = 3500;
        public string Trajectory { get; set; } = "Vertical";
        public int PlannedDurationDays { get; set; } = 60;
        public string FormationsToEncounter { get; set; } = string.Empty;
        public string DrillingProgram { get; set; } = string.Empty;
        public string HseConsiderations { get; set; } = string.Empty;
        public string ApproverComments { get; set; } = string.Empty;
        public List<WellProgramRiskItem> Risks { get; set; } = new();
        public List<WellProgramAfeLine> AfeLines { get; set; } = new();
    }

    private sealed record ProspectOption(string Id, string Name);

    private sealed record WellProgramRiskItem(string Description, string Likelihood, string Impact, string Mitigation);

    private sealed record WellProgramAfeLine(string AfeNumber, string Category, string Description, decimal CostUsd);

    private static Color GetRiskColor(string level) => level switch
    {
        "High" => Color.Error,
        "Medium" => Color.Warning,
        _ => Color.Success
    };

    private static string BuildWellName(Beep.OilandGas.Models.Data.ProspectIdentification.PROSPECT prospect)
        => string.IsNullOrWhiteSpace(prospect.PROSPECT_NAME)
            ? string.Empty
            : $"{prospect.PROSPECT_NAME} A-01";

    private static string BuildExpectedOutcome(Beep.OilandGas.Models.Data.ProspectIdentification.ProspectEvaluation evaluation)
    {
        var resourceParts = new List<string>();

        if (evaluation.EstimatedOilResources.HasValue)
            resourceParts.Add($"Oil {evaluation.EstimatedOilResources.Value:N0} {evaluation.ResourceUnit ?? string.Empty}".Trim());

        if (evaluation.EstimatedGasResources.HasValue)
            resourceParts.Add($"Gas {evaluation.EstimatedGasResources.Value:N0} {evaluation.ResourceUnit ?? string.Empty}".Trim());

        var probability = evaluation.ProbabilityOfSuccess.GetValueOrDefault();
        if (probability > 1)
            probability /= 100m;

        var success = evaluation.ProbabilityOfSuccess.HasValue
            ? $"POS {probability:P0}"
            : string.Empty;

        return string.Join("; ", resourceParts.Append(success).Where(part => !string.IsNullOrWhiteSpace(part)));
    }

    private static List<WellProgramRiskItem> BuildRiskItems(Beep.OilandGas.Models.Data.ProspectIdentification.ProspectEvaluation evaluation)
    {
        if (!evaluation.RiskScore.HasValue
            && string.IsNullOrWhiteSpace(evaluation.RiskLevel)
            && string.IsNullOrWhiteSpace(evaluation.Remarks))
        {
            return new List<WellProgramRiskItem>();
        }

        var description = evaluation.RiskScore.HasValue
            ? $"Overall prospect risk score {evaluation.RiskScore.Value:N2}"
            : "Overall prospect risk assessment";

        return new List<WellProgramRiskItem>
        {
            new(
                description,
                FormatLikelihood(evaluation.ProbabilityOfSuccess.GetValueOrDefault()),
                string.IsNullOrWhiteSpace(evaluation.RiskLevel) ? "Unknown" : evaluation.RiskLevel,
                string.IsNullOrWhiteSpace(evaluation.Remarks) ? "No mitigation recorded" : evaluation.Remarks)
        };
    }

    private static string FormatLikelihood(decimal probability)
    {
        if (probability > 1)
            probability /= 100m;

        if (probability >= 0.67m)
            return "High";

        if (probability >= 0.34m)
            return "Medium";

        return probability > 0 ? "Low" : "Unknown";
    }
}