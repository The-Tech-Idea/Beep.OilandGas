@page "/ppdm39/exploration/seismic-surveys"
@using Beep.OilandGas.Models.Data
@using Beep.OilandGas.PPDM39.Models
@inject ApiClient ApiClient
@inject IExplorationServiceClient ExplorationService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager NavigationManager

<PageTitle>Plan Seismic Acquisition Surveys</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @* ── Header ──────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Plan Seismic Acquisition Surveys</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Seismic acquisition register</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Info"
                         Icon="@Icons.Material.Filled.Sensors">Exploration</MudChip>
            </MudStack>
        </MudStack>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog">
            Add Survey
        </MudButton>
    </MudStack>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }

    @* ── KPI Row ─────────────────────────────────────────────────────── *@
    <MudGrid Class="mb-4" Spacing="3">
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Total Surveys" Value="@((_surveys?.Count ?? 0).ToString())"
                     ValueColor="Color.Primary" Icon="@Icons.Material.Filled.Sensors"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default"
                     TrendText="All surveys" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="2D Surveys"
                     Value="@((_surveys?.Count(s => IsSurveyType(s, "2D")) ?? 0).ToString())"
                     ValueColor="Color.Info" Icon="@Icons.Material.Filled.Timeline"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default"
                     TrendText="Line surveys" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="3D Surveys"
                     Value="@((_surveys?.Count(s => IsSurveyType(s, "3D")) ?? 0).ToString())"
                     ValueColor="Color.Success" Icon="@Icons.Material.Filled.ViewInAr"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default"
                     TrendText="Volume surveys" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="4D / Other"
                     Value="@((_surveys?.Count(s => !IsSurveyType(s, "2D") && !IsSurveyType(s, "3D")) ?? 0).ToString())"
                     ValueColor="Color.Warning" Icon="@Icons.Material.Filled.BlurOn"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default"
                     TrendText="Time-lapse / other" />
        </MudItem>
    </MudGrid>

    @* ── Survey Grid ─────────────────────────────────────────────────── *@
    <MudCard Elevation="2">
        <MudCardContent Class="pa-0">
            @if (_surveys != null && _surveys.Any())
            {
                <MudDataGrid T="SEIS_ACQTN_SURVEY" Items="@_surveys" Dense="true" Hover="true" Striped="true"
                             SortMode="SortMode.Multiple" Filterable="true">
                    <Columns>
                        <TemplateColumn Title="Survey ID">
                            <CellTemplate>
                                <MudText Typo="Typo.body2">@context.Item.SEIS_ACQTN_SURVEY_ID</MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Survey Name">
                            <CellTemplate>
                                <MudText Typo="Typo.body2" Color="Color.Primary">
                                    @context.Item.ACQTN_SURVEY_NAME
                                </MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Type">
                            <CellTemplate>
                                <MudChip T="string" Size="Size.Small" Color="Color.Info">
                                    @GetSurveyType(context.Item)
                                </MudChip>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Start Date">
                            <CellTemplate>
                                <MudText Typo="Typo.body2">
                                    @FormatDate(context.Item.START_DATE)
                                </MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Completed">
                            <CellTemplate>
                                <MudText Typo="Typo.body2">@FormatDate(context.Item.COMPLETED_DATE)</MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Status">
                            <CellTemplate>
                                <StatusBadge Status="@GetStatus(context.Item)" />
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Actions" Sortable="false">
                            <CellTemplate>
                                <MudStack Row="true" Spacing="1">
                                    <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Info"
                                               StartIcon="@Icons.Material.Filled.Visibility"
                                               OnClick="@(() => ViewSurveyLines(context.Item))">
                                        Lines
                                    </MudButton>
                                </MudStack>
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                    <NoRecordsContent>
                        <MudStack AlignItems="AlignItems.Center" Class="pa-6">
                            <MudIcon Icon="@Icons.Material.Filled.Sensors" Color="Color.Secondary"
                                     Class="og-icon-xl" />
                            <MudText Typo="Typo.body1">No surveys match the current filter</MudText>
                        </MudStack>
                    </NoRecordsContent>
                </MudDataGrid>
            }
            else if (!_isLoading)
            {
                <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                    <MudIcon Icon="@Icons.Material.Filled.Sensors" Color="Color.Secondary"
                             Class="og-icon-xl" />
                    <MudText Typo="Typo.h6">No seismic surveys yet</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Register the first acquisition survey for this field.
                    </MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="OpenCreateDialog" Class="mt-2">
                        Add First Survey
                    </MudButton>
                </MudStack>
            }
        </MudCardContent>
    </MudCard>

</MudContainer>

@code {
    private string _fieldName = string.Empty;
    private List<SEIS_ACQTN_SURVEY>? _surveys;
    private bool _isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summary = await ApiClient.GetAsync<FieldLifecycleSummary>("/api/field/current/summary");
            if (summary != null)
                _fieldName = summary.FieldName ?? _fieldName;
        }
        catch { /* field name is non-critical */ }

        await LoadSurveys();
    }

    private async Task LoadSurveys()
    {
        _isLoading = true;
        try
        {
            _surveys = await ExplorationService.GetSeismicSurveysAsync();
        }
        catch (Exception)
        {
            Snackbar.Add("Error loading seismic surveys.", Severity.Error);
            _surveys = new List<SEIS_ACQTN_SURVEY>();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OpenCreateDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<SeismicSurveyEditDialog>("Create Seismic Survey", options);
        var result = await dialog.Result;

        if (result?.Canceled == false && result.Data is Dictionary<string, object> surveyData)
        {
            try
            {
                var request = BuildSurveyRequest(surveyData);
                await ExplorationService.CreateSeismicSurveyAsync(request);
                
                Snackbar.Add("Seismic survey created successfully", Severity.Success);
                await LoadSurveys();
            }
            catch (Exception)
            {
                Snackbar.Add("Error creating seismic survey.", Severity.Error);
            }
        }
    }

    private void ViewSurveyLines(SEIS_ACQTN_SURVEY survey)
    {
        var surveyId = survey.SEIS_ACQTN_SURVEY_ID;
        if (string.IsNullOrEmpty(surveyId))
            return;

        NavigationManager.NavigateTo($"/ppdm39/exploration/seismic-surveys/{Uri.EscapeDataString(surveyId)}/lines");
    }

    private static bool IsSurveyType(SEIS_ACQTN_SURVEY survey, string surveyType)
        => string.Equals(GetSurveyType(survey), surveyType, StringComparison.OrdinalIgnoreCase);

    private static string GetSurveyType(SEIS_ACQTN_SURVEY survey)
        => !string.IsNullOrWhiteSpace(survey.SEIS_SET_SUBTYPE) ? survey.SEIS_SET_SUBTYPE : survey.SEIS_DIMENSION ?? "Unknown";

    private static string GetStatus(SEIS_ACQTN_SURVEY survey)
    {
        if (survey.COMPLETED_DATE.HasValue)
            return "COMPLETE";

        return string.Equals(survey.ACTIVE_IND, "Y", StringComparison.OrdinalIgnoreCase)
            ? "ACTIVE"
            : "INACTIVE";
    }

    private static string FormatDate(DateTime? date)
        => date?.ToString("yyyy-MM-dd") ?? "Pending";

    private static SeismicSurveyRequest BuildSurveyRequest(Dictionary<string, object> surveyData)
    {
        surveyData.TryGetValue("SURVEY_NAME", out var surveyName);
        surveyData.TryGetValue("SURVEY_TYPE", out var surveyType);
        surveyData.TryGetValue("DESCRIPTION", out var description);
        surveyData.TryGetValue("ACQUISITION_DATE", out var acquisitionDate);
        surveyData.TryGetValue("AREA_COVERED", out var areaCovered);

        DateTime? parsedAcquisitionDate = acquisitionDate as DateTime?;
        if (!parsedAcquisitionDate.HasValue && acquisitionDate != null && DateTime.TryParse(acquisitionDate.ToString(), out var dateValue))
            parsedAcquisitionDate = dateValue;

        decimal? parsedArea = areaCovered as decimal?;
        if (!parsedArea.HasValue && areaCovered != null && decimal.TryParse(areaCovered.ToString(), out var areaValue))
            parsedArea = areaValue;

        return new SeismicSurveyRequest
        {
            SurveyName = surveyName?.ToString() ?? string.Empty,
            SurveyType = surveyType?.ToString(),
            Description = description?.ToString(),
            SurveyStartDate = parsedAcquisitionDate,
            SurveyArea = parsedArea,
            SurveyAreaOuom = parsedArea.HasValue ? "KM2" : null,
            Status = "PLANNED"
        };
    }
}
