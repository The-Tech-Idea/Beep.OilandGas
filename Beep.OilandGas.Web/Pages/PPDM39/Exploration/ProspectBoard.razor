@page "/exploration/prospect-board"
@inject ApiClient ApiClient
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Advance Prospect Maturation</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-4">

    @* ── Header ──────────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Advance Prospect Maturation</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Move prospects through the maturation funnel</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Info" Icon="@Icons.Material.Filled.Explore">Exploration</MudChip>
            </MudStack>
        </MudStack>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="AddLead">
            Add Lead
        </MudButton>
    </MudStack>

    @* ── Filter Bar ───────────────────────────────────────────────────────── *@
    <MudPaper Elevation="1" Class="pa-3 mb-4">
        <MudGrid Spacing="2" AlignItems="AlignItems.Center">
            <MudItem xs="12" sm="4" md="3">
                <MudSelect T="string" @bind-Value="_filterPlay" Label="Play Type" Dense="true" Margin="Margin.Dense" Clearable="true">
                    <MudSelectItem T="string" Value="@("Clastic")">Clastic</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Carbonate")">Carbonate</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Unconventional")">Unconventional</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4" md="3">
                <MudSelect T="string" @bind-Value="_filterBasin" Label="Basin" Dense="true" Margin="Margin.Dense" Clearable="true">
                    @foreach (var basin in _basins)
                    {
                        <MudSelectItem T="string" Value="@basin">@basin</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4" md="3">
                <MudSwitch @bind-Value="_showArchived" Color="Color.Primary" Label="Show dropped prospects" />
            </MudItem>
        </MudGrid>
    </MudPaper>

    @* ── Kanban Board ─────────────────────────────────────────────────────── *@
    <div class="kanban-board">
        @foreach (var stage in _stages)
        {
            var stageProspects = FilteredProspects(stage.Key);
            <div class="kanban-column">
                @* Column header *@
                <MudPaper Elevation="0" Class="kanban-col-header pa-2 mb-2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@stage.Value.Icon" Color="@stage.Value.Color" Size="Size.Small" />
                            <MudText Typo="Typo.subtitle2">@stage.Value.Name</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">@stageProspects.Count</MudChip>
                        </MudStack>
                    </MudStack>
                </MudPaper>

                @* Prospect cards *@
                @foreach (var prospect in stageProspects)
                {
                    <MudCard Elevation="1" Class="kanban-card mb-2"
                             @onclick="() => OpenProspect(prospect.Id)">
                        <MudCardContent Class="pa-3">
                            <MudStack Spacing="1">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2"><strong>@prospect.Name</strong></MudText>
                                    <StatusBadge Status="@prospect.Status" Size="Size.Small" />
                                </MudStack>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@prospect.Basin · @prospect.PlayType</MudText>
                                <MudDivider Class="my-1" />
                                <MudGrid Spacing="0">
                                    <MudItem xs="6">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Resource (P50)</MudText>
                                        <MudText Typo="Typo.body2">@prospect.ResourceP50 @prospect.ResourceUnit</MudText>
                                    </MudItem>
                                    <MudItem xs="6">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Chance (Pg)</MudText>
                                        <MudText Typo="Typo.body2" Color="@RiskColor(prospect.ChanceOfSuccess)">@prospect.ChanceOfSuccess.ToString("F0")%</MudText>
                                    </MudItem>
                                </MudGrid>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">In stage @prospect.DaysInStage days</MudText>
                            </MudStack>
                        </MudCardContent>
                        <MudCardActions Class="pa-2 pt-0">
                            @if (stage.Key != "drilled")
                            {
                                <div @onclick:stopPropagation="true">
                                    <MudButton Size="Size.Small"
                                               Variant="Variant.Text"
                                               Color="Color.Primary"
                                               OnClick="@(() => AdvanceStage(prospect))">
                                        Advance →
                                    </MudButton>
                                </div>
                            }
                        </MudCardActions>
                    </MudCard>
                }

                @* Empty column placeholder *@
                @if (stageProspects.Count == 0)
                {
                    <MudPaper Elevation="0" Class="kanban-empty pa-4">
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">No prospects</MudText>
                    </MudPaper>
                }
            </div>
        }
    </div>
</MudContainer>

@code {
    private string _fieldName = string.Empty;
    private string? _filterPlay;
    private string? _filterBasin;
    private bool _showArchived;

    private List<string> _basins = new();

    private Dictionary<string, StageInfo> _stages = new()
    {
        { "lead",      new("Leads",          Icons.Material.Filled.Search,           Color.Default) },
        { "screening", new("Screening",      Icons.Material.Filled.FilterAlt,        Color.Info)    },
        { "prospect",  new("Prospect",       Icons.Material.Filled.TravelExplore,    Color.Primary) },
        { "ranking",   new("Ranking",        Icons.Material.Filled.Leaderboard,      Color.Warning) },
        { "candidate", new("Drill Candidate",Icons.Material.Filled.OilBarrel,        Color.Success) },
        { "drilled",   new("Drilled",        Icons.Material.Filled.Done,             Color.Secondary) },
    };

    private List<ProspectItem> _allProspects = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summary = await ApiClient.GetAsync<FieldLifecycleSummary>("/api/field/current/summary");
            if (summary != null)
                _fieldName = summary.FieldName ?? _fieldName;
        }
        catch { /* field name is non-critical */ }

        try
        {
            var prospects = await ApiClient.GetAsync<List<PROSPECT>>(
                "/api/field/current/exploration/prospects") ?? new();
            if (prospects.Count > 0)
            {
                _allProspects = prospects.Select(p => new ProspectItem(
                    id:          p.PROSPECT_ID ?? string.Empty,
                    name:        p.PROSPECT_NAME ?? p.PROSPECT_ID ?? "Unknown",
                    stage:       MapStage(p.PROSPECT_TYPE, p.PROSPECT_STATUS),
                    playType:    p.PROSPECT_TYPE ?? "Unknown",
                    basin:       p.RESPONSIBLE_BA_ID ?? string.Empty,
                    resource:    (double)(p.AREA_SIZE ?? 0m),
                    unit:        p.AREA_SIZE_OUOM ?? "MMBO",
                    cos:         0,
                    status:      p.PROSPECT_STATUS ?? "ACTIVE",
                    daysInStage: 0
                )).ToList();
                _basins = _allProspects
                    .Select(p => p.Basin)
                    .Where(b => !string.IsNullOrWhiteSpace(b))
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .OrderBy(b => b)
                    .ToList();
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to load prospects.", Severity.Warning);
        }
    }

    private static string MapStage(string? prospectType, string? status) =>
        (prospectType?.ToUpperInvariant(), status?.ToUpperInvariant()) switch
        {
            ("LEAD", _)             => "lead",
            (_, "SCREENING")        => "screening",
            (_, "REVIEW")           => "ranking",
            (_, "APPROVED")         => "candidate",
            (_, "DRILLED" or "COMPLETE" or "COMPLETED") => "drilled",
            _                       => "prospect",
        };

    private List<ProspectItem> FilteredProspects(string stage)
    {
        return _allProspects
            .Where(p => p.Stage == stage)
            .Where(p => string.IsNullOrEmpty(_filterPlay) || p.PlayType == _filterPlay)
            .Where(p => string.IsNullOrEmpty(_filterBasin) || p.Basin == _filterBasin)
            .Where(p => _showArchived || p.Status != "ARCHIVED")
            .ToList();
    }

    private Color RiskColor(double pg) =>
        pg >= 30 ? Color.Success : pg >= 15 ? Color.Warning : Color.Error;

    private void OpenProspect(string id) =>
        NavigationManager.NavigateTo($"/exploration/prospect/{Uri.EscapeDataString(id)}");

    private void AddLead() =>
        NavigationManager.NavigateTo("/exploration/prospect/new");

    private async Task AdvanceStage(ProspectItem prospect)
    {
        var stageKeys = _stages.Keys.ToList();
        var currentIdx = stageKeys.IndexOf(prospect.Stage);
        if (currentIdx < 0 || currentIdx >= stageKeys.Count - 1) return;

        var nextStage = _stages[stageKeys[currentIdx + 1]];

        var parameters = new DialogParameters<StageAdvanceDialog>
        {
            { x => x.ProspectName, prospect.Name },
            { x => x.ToStageName, nextStage.Name }
        };
        var dialog = await DialogService.ShowAsync<StageAdvanceDialog>("Advance Prospect", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            prospect.Stage = stageKeys[currentIdx + 1];
            prospect.DaysInStage = 0;
            Snackbar.Add($"{prospect.Name} advanced to {nextStage.Name}", Severity.Success);
            StateHasChanged();
        }
    }

    private record StageInfo(string Name, string Icon, Color Color);
    private class ProspectItem
    {
        public string Id { get; set; }
        public string Name { get; set; }
        public string Stage { get; set; }
        public string PlayType { get; set; }
        public string Basin { get; set; }
        public double ResourceP50 { get; set; }
        public string ResourceUnit { get; set; }
        public double ChanceOfSuccess { get; set; }
        public string Status { get; set; }
        public int DaysInStage { get; set; }

        public ProspectItem(string id, string name, string stage, string playType, string basin,
            double resource, string unit, double cos, string status, int daysInStage)
        {
            Id = id; Name = name; Stage = stage; PlayType = playType; Basin = basin;
            ResourceP50 = resource; ResourceUnit = unit; ChanceOfSuccess = cos;
            Status = status; DaysInStage = daysInStage;
        }
    }
}
