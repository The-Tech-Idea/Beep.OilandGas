@page "/exploration"
@inject ApiClient ApiClient
@inject IExplorationServiceClient ExplorationService
@inject ILifeCycleService LifeCycleService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Exploration — @_fieldName</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @* ── Header ──────────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-6">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Monitor Exploration Activity</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Prospect portfolio &amp; well programmes</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Info" Icon="@Icons.Material.Filled.Explore">Exploration</MudChip>
            </MudStack>
        </MudStack>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick='() => NavigationManager.NavigateTo("/exploration/well-program/new")'>
            New Well Program
        </MudButton>
    </MudStack>

    @* ── Prospect Funnel KPIs ─────────────────────────────────────────────── *@
    <MudGrid Spacing="3" Class="mb-6">
        <MudItem xs="12" sm="6" md="2">
            <KpiCard Label="Active Leads"
                     Value="@_leads.ToString()"
                     ValueColor="Color.Default"
                     Icon="@Icons.Material.Filled.Search" />
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <KpiCard Label="Prospects"
                     Value="@_prospects.ToString()"
                     ValueColor="Color.Info"
                     Icon="@Icons.Material.Filled.Map" />
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <KpiCard Label="Drill Candidates"
                     Value="@_drillCandidates.ToString()"
                     ValueColor="Color.Primary"
                     Icon="@Icons.Material.Filled.OilBarrel" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Exploratory Wells (YTD)"
                     Value="@_exploratoryWells.ToString()"
                     ValueColor="Color.Warning"
                     Icon="@Icons.Material.Filled.Engineering" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Success Rate"
                     Value="@_successRate.ToString("F0")"
                     Unit="%"
                     ValueColor="@(_successRate >= 30 ? Color.Success : Color.Error)"
                     Icon="@Icons.Material.Filled.Stars"
                     TrendText="discoveries / wells drilled" />
        </MudItem>
    </MudGrid>

    @* ── Pending Decisions + Upcoming Programs ────────────────────────────── *@
    <MudGrid Spacing="3" Class="mb-6">
        <MudItem xs="12" md="6">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudIcon Icon="@Icons.Material.Filled.PendingActions" Color="Color.Warning" />
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1">Pending Decisions</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Gate reviews requiring action</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @if (_pendingDecisions.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">No pending decisions</MudText>
                    }
                    else
                    {
                        <MudList T="PendingDecision" Dense="true">
                            @foreach (var d in _pendingDecisions)
                            {
                                <MudListItem T="PendingDecision">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.body2">@d.Name</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@d.Description</MudText>
                                        </MudStack>
                                        <StatusBadge Status="@d.Status" />
                                    </MudStack>
                                </MudListItem>
                            }
                        </MudList>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudIcon Icon="@Icons.Material.Filled.Assignment" Color="Color.Primary" />
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1">Upcoming Well Programs</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Programs pending approval or scheduling</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @if (_upcomingPrograms.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">No upcoming well programs</MudText>
                    }
                    else
                    {
                        <MudList T="WellProgramSummary" Dense="true">
                            @foreach (var p in _upcomingPrograms)
                            {
                                <MudListItem T="WellProgramSummary">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.body2">@p.Name</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@p.TargetDate</MudText>
                                        </MudStack>
                                        <StatusBadge Status="@p.Status" />
                                    </MudStack>
                                </MudListItem>
                            }
                        </MudList>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    @* ── Quick Actions ────────────────────────────────────────────────────── *@
    <MudStack Row="true" Spacing="2">
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.ViewKanban"
                   OnClick='() => NavigationManager.NavigateTo("/exploration/prospect-board")'>
            Open Prospect Board
        </MudButton>
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Default"
                   StartIcon="@Icons.Material.Filled.SatelliteAlt"
                   OnClick='() => NavigationManager.NavigateTo("/exploration/seismic")'>
            Seismic Surveys
        </MudButton>
    </MudStack>

</MudContainer>

@code {
    private string _fieldName = string.Empty;
    private int _leads;
    private int _prospects;
    private int _drillCandidates;
    private int _exploratoryWells;
    private double _successRate;

    private List<PendingDecision> _pendingDecisions = new();
    private List<WellProgramSummary> _upcomingPrograms = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summary = await LifeCycleService.GetFieldLifecycleSummaryAsync();
            if (summary != null)
                _fieldName = summary.FieldName ?? _fieldName;
        }
        catch { /* field name is non-critical */ }

        try
        {
            var summary = await ExplorationService.GetDashboardSummaryAsync();
            if (summary != null)
            {
                _leads              = summary.LeadCount;
                _prospects          = summary.ProspectCount;
                _exploratoryWells   = summary.WellCount;
                _drillCandidates    = summary.SurveyCount;
                _successRate        = summary.SuccessRatePct;
                _pendingDecisions   = summary.PendingDecisions
                    .Select(d => new PendingDecision(d.Name, d.Description, d.Status))
                    .ToList();
                _upcomingPrograms   = summary.UpcomingPrograms
                    .Select(p => new WellProgramSummary(p.Name, p.TargetDate, p.Status))
                    .ToList();
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to load exploration summary.", Severity.Warning);
        }
    }

    private record PendingDecision(string Name, string Description, string Status);
    private record WellProgramSummary(string Name, string TargetDate, string Status = "PLANNED");
}
