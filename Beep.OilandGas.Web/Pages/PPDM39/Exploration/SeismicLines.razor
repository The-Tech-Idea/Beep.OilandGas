@page "/ppdm39/exploration/seismic-surveys/{SurveyId}/lines"
@using Beep.OilandGas.PPDM39.Models
@inject ApiClient ApiClient
@inject IExplorationServiceClient ExplorationService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager

<PageTitle>Inspect Seismic Line Coverage</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @* ── Header ──────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="GoBack"
                       Title="Back to Surveys" />
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Inspect Seismic Line Coverage</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — @_surveyDisplayName</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Info"
                         Icon="@Icons.Material.Filled.Timeline">Lines</MudChip>
            </MudStack>
        </MudStack>
    </MudStack>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }

    @* ── Lines Grid ──────────────────────────────────────────────────── *@
    <MudCard Elevation="2">
        <MudCardContent Class="pa-0">
            @if (_lines != null && _lines.Any())
            {
                <MudDataGrid T="SEIS_LINE" Items="@_lines" Dense="true" Hover="true" Striped="true"
                             SortMode="SortMode.Multiple" Filterable="true">
                    <Columns>
                        <TemplateColumn Title="Line ID">
                            <CellTemplate>
                                <MudText Typo="Typo.body2">@context.Item.SEIS_LINE_ID</MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Line Name">
                            <CellTemplate>
                                <MudText Typo="Typo.body2" Color="Color.Primary">
                                    @context.Item.LINE_NAME
                                </MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Dimension">
                            <CellTemplate>
                                <MudText Typo="Typo.body2">@context.Item.DIMENSION</MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Mode">
                            <CellTemplate>
                                <MudText Typo="Typo.body2">@GetMode(context.Item)</MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Survey Type">
                            <CellTemplate>
                                <MudText Typo="Typo.body2">@context.Item.SEIS_ACQTN_SET_SUBTYPE</MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Effective Date">
                            <CellTemplate>
                                <MudText Typo="Typo.body2">@FormatDate(context.Item.EFFECTIVE_DATE)</MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Status">
                            <CellTemplate>
                                <StatusBadge Status="@GetStatus(context.Item)" />
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                    <NoRecordsContent>
                        <MudStack AlignItems="AlignItems.Center" Class="pa-6">
                            <MudIcon Icon="@Icons.Material.Filled.Timeline" Color="Color.Secondary"
                                     Class="og-icon-xl" />
                            <MudText Typo="Typo.body1">No lines match the current filter</MudText>
                        </MudStack>
                    </NoRecordsContent>
                </MudDataGrid>
            }
            else if (!_isLoading)
            {
                <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                    <MudIcon Icon="@Icons.Material.Filled.Timeline" Color="Color.Secondary"
                             Class="og-icon-xl" />
                    <MudText Typo="Typo.h6">No seismic lines found</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Survey @SurveyId has no lines registered.
                    </MudText>
                    <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack"
                               OnClick="GoBack" Class="mt-2">
                        Back to Surveys
                    </MudButton>
                </MudStack>
            }
        </MudCardContent>
    </MudCard>

</MudContainer>

@code {
    [Parameter] public string SurveyId { get; set; } = string.Empty;

    private string _loadedId  = string.Empty;
    private string _fieldName = string.Empty;
    private string _surveyDisplayName = string.Empty;
    private List<SEIS_LINE>? _lines;
    private bool _isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summary = await ApiClient.GetAsync<FieldLifecycleSummary>("/api/field/current/summary");
            if (summary != null)
                _fieldName = summary.FieldName ?? _fieldName;
        }
        catch { /* field name is non-critical */ }

        _loadedId = SurveyId;
        await LoadLines();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (SurveyId == _loadedId) return;
        _loadedId = SurveyId;
        await LoadLines();
    }

    private async Task LoadLines()
    {
        _isLoading = true;
        try
        {
            _lines = await ExplorationService.GetSeismicLinesAsync(SurveyId);

            var surveys = await ExplorationService.GetSeismicSurveysAsync();
            var survey = surveys.FirstOrDefault(s => string.Equals(s.SEIS_ACQTN_SURVEY_ID, SurveyId, StringComparison.OrdinalIgnoreCase));
            _surveyDisplayName = survey?.ACQTN_SURVEY_NAME ?? SurveyId;
        }
        catch (Exception)
        {
            Snackbar.Add("Error loading seismic lines.", Severity.Error);
            _lines = new List<SEIS_LINE>();
            _surveyDisplayName = SurveyId;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/ppdm39/exploration/seismic-surveys");
    }

    private static string GetMode(SEIS_LINE line)
        => !string.IsNullOrWhiteSpace(line.REFRACTION_REFLECTION) ? line.REFRACTION_REFLECTION : line.TEST_EXPERIMENTAL ?? "Not specified";

    private static string GetStatus(SEIS_LINE line)
        => string.Equals(line.ACTIVE_IND, "Y", StringComparison.OrdinalIgnoreCase) ? "ACTIVE" : "INACTIVE";

    private static string FormatDate(DateTime? value)
        => value?.ToString("yyyy-MM-dd") ?? "Pending";
}
