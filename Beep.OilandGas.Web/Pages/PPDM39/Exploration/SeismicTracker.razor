@page "/exploration/seismic"
@inject ApiClient ApiClient
@inject IExplorationServiceClient ExplorationService
@inject ILifeCycleService LifeCycleService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Track Seismic Survey Progress</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @* ── Header ──────────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Track Seismic Survey Progress</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Acquisition, processing, and interpretation status</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Info" Icon="@Icons.Material.Filled.Sensors">Exploration</MudChip>
            </MudStack>
        </MudStack>
        <MudButton Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick='() => NavigationManager.NavigateTo("/ppdm39/exploration/seismic-surveys")'>Add Survey</MudButton>
    </MudStack>

    @* ── KPI Row ─────────────────────────────────────────────────────────── *@
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="12" sm="4">
            <KpiCard Label="Surveys Active"
                     Value="@_surveys.Count(s => s.Status is "ACTIVE" or "IN PROGRESS").ToString()"
                     Unit="surveys"
                     Icon="@Icons.Material.Filled.Sensors"
                     ValueColor="Color.Primary" />
        </MudItem>
        <MudItem xs="12" sm="4">
            <KpiCard Label="3D Surveys"
                     Value="@_surveys.Count(s => string.Equals(s.SurveyType, "3D", StringComparison.OrdinalIgnoreCase)).ToString()"
                     Unit="surveys"
                     Icon="@Icons.Material.Filled.ViewInAr"
                     ValueColor="Color.Info" />
        </MudItem>
        <MudItem xs="12" sm="4">
            <KpiCard Label="Complete This Year"
                     Value="@_surveys.Count(s => s.Status == "COMPLETE" && s.CompletionYear == DateTime.Now.Year).ToString()"
                     Unit="surveys"
                     Icon="@Icons.Material.Filled.CheckCircle"
                     ValueColor="Color.Success" />
        </MudItem>
    </MudGrid>

    @* ── Survey DataGrid ─────────────────────────────────────────────────── *@
    <MudDataGrid T="SeismicSurveyRow"
                 Items="@_surveys"
                 Dense="true"
                 Hover="true"
                 Striped="true"
                 Filterable="true"
                 SortMode="SortMode.Multiple"
                 ExpandSingleRow="false"
                 Groupable="false">
        <Columns>
            <HierarchyColumn T="SeismicSurveyRow" />
            <PropertyColumn Property="x => x.Name" Title="Survey Name" />
            <PropertyColumn Property="x => x.SurveyType" Title="Type">
                <CellTemplate>
                    <MudChip T="string" Size="Size.Small"
                             Color="@(context.Item.SurveyType == "3D" ? Color.Primary : Color.Default)">
                        @context.Item.SurveyType
                    </MudChip>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Status" Title="Status">
                <CellTemplate>
                    <StatusBadge Status="@context.Item.Status" />
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Dimension" Title="Dimension" />
            <PropertyColumn Property="x => x.StartDateLabel" Title="Start" />
            <PropertyColumn Property="x => x.CompletedDateLabel" Title="Completed" />
            <TemplateColumn Title="Actions" CellClass="d-flex justify-end">
                <CellTemplate>
                    <MudTooltip Text="View details">
                        <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                       Title="View details"
                                       Size="Size.Small"
                                       Color="Color.Primary"
                                       OnClick='@(() => NavigationManager.NavigateTo($"/ppdm39/exploration/seismic-surveys/{Uri.EscapeDataString(context.Item.Id)}/lines"))' />
                    </MudTooltip>
                </CellTemplate>
            </TemplateColumn>
        </Columns>

        @* Expandable row — processing/interpretation stage timeline *@
        <ChildRowContent>
            <MudPaper Elevation="0" Class="pa-4 ml-8">
                <MudGrid Spacing="3">
                    <MudItem xs="12" md="6">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Acquisition → Interpretation Pipeline</MudText>
                        <ProcessTimeline Steps="@context.Item.Stages" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Survey Details</MudText>
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.body2"><strong>Source:</strong> @context.Item.Source</MudText>
                            <MudText Typo="Typo.body2"><strong>Subtype:</strong> @context.Item.SurveyType</MudText>
                            <MudText Typo="Typo.body2"><strong>Remarks:</strong> @context.Item.Remarks</MudText>
                        </MudStack>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </ChildRowContent>

    </MudDataGrid>

</MudContainer>

@code {
    private string _fieldName = string.Empty;
    private List<SeismicSurveyRow> _surveys = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summary = await LifeCycleService.GetFieldLifecycleSummaryAsync();
            if (summary != null)
                _fieldName = summary.FieldName ?? _fieldName;
        }
        catch { /* field name is non-critical */ }

        try
        {
            var surveys = await ExplorationService.GetSeismicSurveysAsync();
            if (surveys.Count > 0)
            {
                _surveys = surveys
                    .Select(s => new SeismicSurveyRow(
                        s.SEIS_ACQTN_SURVEY_ID ?? string.Empty,
                        s.ACQTN_SURVEY_NAME ?? s.SEIS_ACQTN_SURVEY_ID ?? "Unknown",
                        GetSurveyType(s),
                        s.SEIS_DIMENSION ?? "Not specified",
                        GetSurveyStatus(s),
                        s.SOURCE ?? "Not specified",
                        s.REMARK ?? "No remarks recorded",
                        s.START_DATE,
                        s.COMPLETED_DATE,
                        BuildStages(s)))
                    .OrderByDescending(s => s.StartDate ?? s.CompletedDate)
                    .ToList();
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to load seismic surveys.", Severity.Warning);
        }
    }

    private class SeismicSurveyRow
    {
        public string Id { get; }
        public string Name { get; }
        public string SurveyType { get; }
        public string Dimension { get; }
        public string Status { get; }
        public string Source { get; }
        public string Remarks { get; }
        public DateTime? StartDate { get; }
        public DateTime? CompletedDate { get; }
        public string StartDateLabel => FormatDate(StartDate);
        public string CompletedDateLabel => FormatDate(CompletedDate);
        public int CompletionYear => CompletedDate?.Year ?? 0;
        public List<ProcessStep> Stages { get; }

        public SeismicSurveyRow(string id, string name, string surveyType, string dimension, string status,
            string source, string remarks, DateTime? startDate, DateTime? completedDate, List<ProcessStep> stages)
        {
            Id = id;
            Name = name;
            SurveyType = surveyType;
            Dimension = dimension;
            Status = status;
            Source = source;
            Remarks = remarks;
            StartDate = startDate;
            CompletedDate = completedDate;
            Stages = stages;
        }
    }

    private static string GetSurveyType(SEIS_ACQTN_SURVEY survey)
        => !string.IsNullOrWhiteSpace(survey.SEIS_SET_SUBTYPE) ? survey.SEIS_SET_SUBTYPE : survey.SEIS_DIMENSION ?? "Unknown";

    private static string GetSurveyStatus(SEIS_ACQTN_SURVEY survey)
    {
        if (survey.COMPLETED_DATE.HasValue)
            return "COMPLETE";

        return string.Equals(survey.ACTIVE_IND, "Y", StringComparison.OrdinalIgnoreCase)
            ? "ACTIVE"
            : "INACTIVE";
    }

    private static List<ProcessStep> BuildStages(SEIS_ACQTN_SURVEY survey)
    {
        var registeredDate = survey.ROW_CREATED_DATE ?? survey.EFFECTIVE_DATE;

        return new List<ProcessStep>
        {
            new("Registered", FormatDate(registeredDate), registeredDate.HasValue, !survey.START_DATE.HasValue && !survey.COMPLETED_DATE.HasValue),
            new("Acquisition", FormatDate(survey.START_DATE), survey.START_DATE.HasValue, survey.START_DATE.HasValue && !survey.COMPLETED_DATE.HasValue),
            new("Completed", FormatDate(survey.COMPLETED_DATE), survey.COMPLETED_DATE.HasValue, false)
        };
    }

    private static string FormatDate(DateTime? value)
        => value?.ToString("yyyy-MM-dd") ?? "Pending";
}
