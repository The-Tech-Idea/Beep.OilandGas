@page "/ppdm39/accounting/volume-reconciliation"
@using Beep.OilandGas.Models.Data.Accounting
@using Beep.OilandGas.Models.Data
@using VolumeReconciliationRequestDto = Beep.OilandGas.Models.Data.ProductionAccounting.VolumeReconciliationRequest
@inject IAccountingServiceClient AccountingServiceClient
@inject ILifeCycleService LifeCycleService
@inject ISnackbar Snackbar

<PageTitle>Reconcile Production Volumes</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Reconcile Production Volumes</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Cross-check metered vs allocated volumes</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Icon="@Icons.Material.Filled.AccountBalance">Accounting</MudChip>
            </MudStack>
        </MudStack>
    </MudStack>

    <MudPaper Class="pa-4">
        <MudStack Spacing="3" Class="mb-4">
            <MudDatePicker @bind-Date="@_startDate" Label="Start Date" Variant="Variant.Outlined" Required="true" />
            <MudDatePicker @bind-Date="@_endDate" Label="End Date" Variant="Variant.Outlined" Required="true" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Calculate" OnClick="ReconcileVolumes">
                Reconcile Volumes
            </MudButton>
        </MudStack>

        @if (_isLoading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
        }
        else if (_reconciliationResult != null)
        {
            <MudGrid Class="mt-4">
                <MudItem xs="12" md="6">
                    <MudCard Elevation="2">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">Reconciliation Summary</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudStack Spacing="2">
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="og-label-2xl">Status</MudText>
                                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(_reconciliationResult.Status)">
                                        @_reconciliationResult.Status
                                    </MudChip>
                                </MudStack>
                                <MudStack Row="true" Spacing="2">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="og-label-2xl">Field Production Volume</MudText>
                                    <MudText Typo="Typo.body2">@FormatDecimal(_reconciliationResult.FieldProductionVolume.ToString())</MudText>
                                </MudStack>
                                <MudStack Row="true" Spacing="2">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="og-label-2xl">Allocated Volume</MudText>
                                    <MudText Typo="Typo.body2">@FormatDecimal(_reconciliationResult.ALLOCATED_VOLUME.ToString())</MudText>
                                </MudStack>
                                <MudStack Row="true" Spacing="2">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="og-label-2xl">Discrepancy</MudText>
                                    <MudText Typo="Typo.body2">@FormatDecimal(_reconciliationResult.Discrepancy.ToString())</MudText>
                                </MudStack>
                                <MudStack Row="true" Spacing="2">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="og-label-2xl">Discrepancy %</MudText>
                                    <MudText Typo="Typo.body2">@FormatDecimal(_reconciliationResult.DiscrepancyPercentage.ToString())%</MudText>
                                </MudStack>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                @if (_reconciliationResult.OilVolume != null)
                {
                    <MudItem xs="12" md="6">
                        <MudCard Elevation="2">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">Oil Volume Breakdown</MudText>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudStack Spacing="2">
                                    <MudStack Row="true" Spacing="2">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="og-label-md">Field Volume</MudText>
                                        <MudText Typo="Typo.body2">@FormatDecimal(_reconciliationResult.OilVolume.FieldVolume.ToString())</MudText>
                                    </MudStack>
                                    <MudStack Row="true" Spacing="2">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="og-label-md">Allocated Volume</MudText>
                                        <MudText Typo="Typo.body2">@FormatDecimal(_reconciliationResult.OilVolume.ALLOCATED_VOLUME.ToString())</MudText>
                                    </MudStack>
                                    <MudStack Row="true" Spacing="2">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="og-label-md">Discrepancy</MudText>
                                        <MudText Typo="Typo.body2">@FormatDecimal(_reconciliationResult.OilVolume.Discrepancy.ToString())</MudText>
                                    </MudStack>
                                </MudStack>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>

            @if (_reconciliationResult.Issues != null && _reconciliationResult.Issues.Any())
            {
                <MudCard Elevation="2" Class="mt-4">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Reconciliation Issues</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudList T="string">
                            @foreach (var issue in _reconciliationResult.Issues)
                            {
                                <MudListItem T="string">
                                    <MudAlert Severity="@GetSeverity(issue.Severity)" Dense="true">
                                        <strong>@issue.IssueType:</strong> @issue.Description
                                    </MudAlert>
                                </MudListItem>
                            }
                        </MudList>
                    </MudCardContent>
                </MudCard>
            }
        }
        else if (!_isLoading)
        {
            <MudAlert Severity="Severity.Info">Select a date range and click 'Reconcile Volumes' to start reconciliation.</MudAlert>
        }
    </MudPaper>
</MudContainer>

@code {
    private string _fieldId = string.Empty;
    private string _fieldName = string.Empty;
    private DateTime? _startDate = DateTime.Today.AddMonths(-1);
    private DateTime? _endDate = DateTime.Today;
    private bool _isLoading = false;
    private VolumeReconciliationResult? _reconciliationResult;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summary = await LifeCycleService.GetFieldLifecycleSummaryAsync();
            if (summary != null)
            {
                _fieldId = summary.FieldId ?? string.Empty;
                _fieldName = summary.FieldName ?? _fieldName;
            }
        }
        catch { /* field name is non-critical */ }
    }

    private async Task ReconcileVolumes()
    {
        if (!_startDate.HasValue || !_endDate.HasValue)
        {
            Snackbar.Add("Please select both start and end dates", Severity.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(_fieldId))
        {
            Snackbar.Add("No active field is available for reconciliation.", Severity.Error);
            return;
        }

        _isLoading = true;
        try
        {
            var request = new VolumeReconciliationRequestDto
            {
                FieldId = _fieldId,
                StartDate = _startDate.Value,
                EndDate = _endDate.Value
            };

            _reconciliationResult = await AccountingServiceClient.ReconcileVolumesAsync(request);

            Snackbar.Add("Volume reconciliation completed", Severity.Success);
        }
        catch (Exception)
        {
            Snackbar.Add("Error reconciling volumes.", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private Color GetStatusColor(ReconciliationStatus status)
    {
        return status switch
        {
            ReconciliationStatus.Matched => Color.Success,
            ReconciliationStatus.VarianceDetected => Color.Warning,
            ReconciliationStatus.Error => Color.Error,
            _ => Color.Default
        };
    }

    private Severity GetSeverity(string? severity)
    {
        return severity?.ToUpperInvariant() switch
        {
            "ERROR" => Severity.Error,
            "WARNING" => Severity.Warning,
            _ => Severity.Info
        };
    }

    private string FormatDecimal(string? valueStr)
    {
        if (string.IsNullOrEmpty(valueStr))
            return "N/A";

        if (decimal.TryParse(valueStr, out var value))
            return value.ToString("F2");

        return valueStr;
    }
}


