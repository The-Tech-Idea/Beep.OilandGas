@page "/accounting/production"
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject ApiClient ApiClient

<PageTitle>Track Production Revenue</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @if (_loading) { <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" /> }

    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Track Production Revenue</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Revenue recognition &amp; volume reconciliation</MudText>
        </MudStack>
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudSelect T="string" @bind-Value="_period" Label="Period" Variant="Variant.Outlined" Dense="true" Class="og-select-md">
                <MudSelectItem Value="@("2026-03")">Mar 2026</MudSelectItem>
                <MudSelectItem Value="@("2026-02")">Feb 2026</MudSelectItem>
                <MudSelectItem Value="@("2026-01")">Jan 2026</MudSelectItem>
            </MudSelect>
            <MudChip T="string" Color="@(_closeStatus == "CLOSED" ? Color.Success : Color.Warning)" Size="Size.Small">@_closeStatus</MudChip>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Lock"
                       Disabled="@(_closeStatus == "CLOSED")"
                       OnClick="ClosePeriod">
                Close Period
            </MudButton>
        </MudStack>
    </MudStack>

    @* KPI row *@
    <MudGrid Class="mb-4" Spacing="3">
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Gross Revenue" Value="@_grossRevenue.ToString("N1")" Unit="$MM"
                     ValueColor="Color.Success" Icon="@Icons.Material.Filled.AttachMoney"
                     TrendIcon="@Icons.Material.Filled.TrendingUp" TrendColor="Color.Success" TrendText="+4.2% vs prior month" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Net Revenue" Value="@_netRevenue.ToString("N1")" Unit="$MM"
                     ValueColor="Color.Primary" Icon="@Icons.Material.Filled.MonetizationOn"
                     TrendIcon="@Icons.Material.Filled.TrendingUp" TrendColor="Color.Primary" TrendText="After royalties & taxes" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Total OPEX" Value="@_totalOpex.ToString("N1")" Unit="$MM"
                     ValueColor="Color.Warning" Icon="@Icons.Material.Filled.Receipt"
                     TrendIcon="@Icons.Material.Filled.TrendingFlat" TrendColor="Color.Default" TrendText="vs budget" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Label="Operating Margin" Value="@_operatingMargin.ToString("N1")" Unit="%"
                     ValueColor="@(_operatingMargin > 40 ? Color.Success : Color.Warning)"
                     Icon="@Icons.Material.Filled.Percent"
                     TrendIcon="@Icons.Material.Filled.TrendingUp" TrendColor="Color.Success" TrendText="Net/Gross ratio" />
        </MudItem>
    </MudGrid>

    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true">

        @* Tab 1: Revenue *@
        <MudTabPanel Text="Revenue" Icon="@Icons.Material.Filled.AttachMoney">
            <MudGrid Class="pa-4" Spacing="3">
                <MudItem xs="12" md="8">
                    <MudCard Elevation="1">
                        <MudCardHeader>
                            <CardHeaderContent><MudText Typo="Typo.subtitle1">Revenue by Product</MudText></CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudAlert Severity="Severity.Info" Dense="true">Revenue trend chart will display after transactions are loaded from the accounting system.</MudAlert>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudCard Elevation="1">
                        <MudCardHeader>
                            <CardHeaderContent><MudText Typo="Typo.subtitle1">Revenue Split</MudText></CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudAlert Severity="Severity.Info" Dense="true">Revenue split chart will display once product-level sales data is available.</MudAlert>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="12">
                    <MudCard Elevation="1">
                        <MudCardHeader>
                            <CardHeaderContent><MudText Typo="Typo.subtitle1">Revenue Line Items</MudText></CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent Class="pa-0">
                            <MudDataGrid T="RevenueLineItem" Items="@_revenueLines" Dense="true" Hover="true" Striped="true">
                                <Columns>
                                    <PropertyColumn Property="r => r.Description" Title="Description" />
                                    <PropertyColumn Property="r => r.Product" Title="Product" />
                                    <PropertyColumn Property="r => r.Volume" Title="Volume" />
                                    <PropertyColumn Property="r => r.Unit" Title="Unit" />
                                    <PropertyColumn Property="r => r.Price" Title="Price ($/unit)" Format="N2" />
                                    <PropertyColumn Property="r => r.AmountUsd" Title="Amount ($)" Format="N0" />
                                    <TemplateColumn Title="Type">
                                        <CellTemplate><StatusBadge Status="@context.Item.Type" /></CellTemplate>
                                    </TemplateColumn>
                                </Columns>
                            </MudDataGrid>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        @* Tab 2: Royalties & Deductions *@
        <MudTabPanel Text="Royalties &amp; Deductions" Icon="@Icons.Material.Filled.AccountBalance">
            <MudGrid Class="pa-4" Spacing="3">
                <MudItem xs="12">
                    <MudCard Elevation="1">
                        <MudCardHeader>
                            <CardHeaderContent><MudText Typo="Typo.subtitle1">Royalty &amp; Tax Summary</MudText></CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent Class="pa-0">
                            <MudDataGrid T="DeductionItem" Items="@_deductions" Dense="true" Hover="true">
                                <Columns>
                                    <PropertyColumn Property="d => d.Description" Title="Description" />
                                    <PropertyColumn Property="d => d.Rate" Title="Rate" />
                                    <PropertyColumn Property="d => d.BaseAmount" Title="Base ($)" Format="N0" />
                                    <PropertyColumn Property="d => d.DeductionUsd" Title="Deduction ($)" Format="N0" />
                                    <TemplateColumn Title="Category">
                                        <CellTemplate><StatusBadge Status="@context.Item.Category" /></CellTemplate>
                                    </TemplateColumn>
                                </Columns>
                            </MudDataGrid>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        @* Tab 3: OPEX *@
        <MudTabPanel Text="OPEX" Icon="@Icons.Material.Filled.Receipt">
            <MudGrid Class="pa-4" Spacing="3">
                <MudItem xs="12" md="7">
                    <MudCard Elevation="1">
                        <MudCardHeader>
                            <CardHeaderContent><MudText Typo="Typo.subtitle1">Operating Cost Breakdown</MudText></CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudAlert Severity="Severity.Info" Dense="true">OPEX breakdown chart will display once operating cost data is available.</MudAlert>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="12" md="5">
                    <MudCard Elevation="1">
                        <MudCardHeader>
                            <CardHeaderContent><MudText Typo="Typo.subtitle1">Budget vs Actual</MudText></CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudStack Spacing="2">
                                @foreach (var op in _opexVariance)
                                {
                                    <MudStack Spacing="0">
                                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                                            <MudText Typo="Typo.body2">@op.Category</MudText>
                                            <MudText Typo="Typo.caption" Color="@(op.Variance > 0 ? Color.Error : Color.Success)">
                                                @(op.Variance > 0 ? "+" : "")@op.Variance.ToString("N0") ($k)
                                            </MudText>
                                        </MudStack>
                                        <MudProgressLinear Color="@(op.Variance > 0 ? Color.Error : Color.Success)"
                                                           Value="@Math.Min(op.ActualPct, 100)" />
                                    </MudStack>
                                }
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

    </MudTabs>

</MudContainer>

@code {
    private string _fieldName = string.Empty;
    private string _period = DateTime.UtcNow.ToString("yyyy-MM");
    private string _closeStatus = "OPEN";
    private bool _loading = true;

    private double _grossRevenue;
    private double _totalOpex;
    private double _netRevenue => _grossRevenue - _totalOpex;
    private double _operatingMargin => _grossRevenue > 0 ? _netRevenue / _grossRevenue * 100 : 0;

    private record RevenueLineItem(string Description, string Product, double Volume, string Unit, double Price, double AmountUsd, string Type);
    private List<RevenueLineItem> _revenueLines = new();

    private record DeductionItem(string Description, string Rate, double BaseAmount, double DeductionUsd, string Category);
    private List<DeductionItem> _deductions = new();

    private record OpexVarianceItem(string Category, double Variance, double ActualPct);
    private List<OpexVarianceItem> _opexVariance = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summary = await ApiClient.GetAsync<FieldLifecycleSummary>("/api/field/current/summary");
            if (summary != null)
                _fieldName = summary.FieldName ?? _fieldName;
        }
        catch { /* field name is non-critical */ }

        _loading = true;
        try
        {
            var summary = await ApiClient.GetAsync<ProductionSummaryDto>("api/field/current/accounting/production-summary");
            if (summary != null)
            {
                _grossRevenue = (double)summary.GrossRevenue;
                _totalOpex    = (double)summary.TotalOpex;
                if (summary.OutstandingUsd > 0)
                    _deductions.Add(new DeductionItem("Outstanding Receivables", "Balance", (double)summary.OutstandingUsd, (double)summary.OutstandingUsd, "RECEIVABLE"));
            }

            var lines = await ApiClient.GetAsync<List<RevenueLineApiDto>>("api/field/current/accounting/revenue-lines") ?? new();            if (lines != null)
                _revenueLines = lines.Select(l => new RevenueLineItem(
                    l.Description ?? "Sales Transaction",
                    l.Product ?? "Oil",
                    (double)l.Volume,
                    l.Unit ?? "BBL",
                    (double)l.Price,
                    (double)l.AmountUsd,
                    l.Type ?? "ACTIVE")).ToList();
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to load accounting data.", Severity.Warning);
        }
        finally { _loading = false; }
    }

    private class ProductionSummaryDto
    {
        public decimal GrossRevenue   { get; set; }
        public decimal TotalOpex      { get; set; }
        public decimal NetRevenue     { get; set; }
        public int     OpenInvoices   { get; set; }
        public decimal OutstandingUsd { get; set; }
    }

    private class RevenueLineApiDto
    {
        public string?  Description { get; set; }
        public string?  Product     { get; set; }
        public string?  Unit        { get; set; }
        public decimal  Volume      { get; set; }
        public decimal  Price       { get; set; }
        public decimal  AmountUsd   { get; set; }
        public string?  Type        { get; set; }
    }

    private void ClosePeriod()
    {
        _closeStatus = "CLOSED";
        Snackbar.Add($"Period {_period} has been closed", Severity.Success);
    }
}
