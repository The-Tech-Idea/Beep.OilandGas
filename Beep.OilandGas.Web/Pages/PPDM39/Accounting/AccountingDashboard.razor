@page "/ppdm39/accounting/dashboard"
@using Beep.OilandGas.Models.Data.Accounting
@inject ApiClient ApiClient
@inject IAccountingServiceClient AccountingClient
@inject ILifeCycleService LifeCycleService
@inject ISnackbar Snackbar

<PageTitle>Monitor Accounting Activity</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @* ─── Header *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Monitor Accounting Activity</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_fieldName — Production accounting overview</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                         Icon="@Icons.Material.Filled.AccountBalance">Accounting</MudChip>
            </MudStack>
        </MudStack>
    </MudStack>

    @* ─── Navigation Cards *@
    <MudGrid Class="mb-4" Spacing="3">
        <MudItem xs="12" md="4">
            <MudCard Elevation="2">
                <MudCardContent>
                    <MudStack Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.CompareArrows" Color="Color.Primary" Class="og-icon-lg" />
                        <MudText Typo="Typo.h6">Volume Reconciliation</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Reconcile production volumes between sources</MudText>
                    </MudStack>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary"
                               Href="/ppdm39/accounting/volume-reconciliation"
                               EndIcon="@Icons.Material.Filled.ArrowForward">Go to Reconciliation</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudCard Elevation="2">
                <MudCardContent>
                    <MudStack Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Warning" Class="og-icon-lg" />
                        <MudText Typo="Typo.h6">Royalty Calculations</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">View and calculate production royalties</MudText>
                    </MudStack>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Warning"
                               Href="/ppdm39/accounting/royalties"
                               EndIcon="@Icons.Material.Filled.ArrowForward">Go to Royalties</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudCard Elevation="2">
                <MudCardContent>
                    <MudStack Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.PieChart" Color="Color.Secondary" Class="og-icon-lg" />
                        <MudText Typo="Typo.h6">Cost Allocation</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Allocate costs to production entities</MudText>
                    </MudStack>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Secondary"
                               Href="/ppdm39/accounting/cost-allocation"
                               EndIcon="@Icons.Material.Filled.ArrowForward">Go to Cost Allocation</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }

    @* ─── Recent Activities Grid *@
    <MudCard Elevation="2">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">Recent Accounting Activities</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent Class="pa-0">
            @if (_recentActivities != null && _recentActivities.Any())
            {
                <MudDataGrid T="AccountingActivityDto" Items="@_recentActivities" Dense="true" Hover="true" Striped="true"
                             SortMode="SortMode.Multiple" Filterable="true">
                    <Columns>
                        <PropertyColumn Property="a => a.ActivityType" Title="Activity Type" />
                        <PropertyColumn Property="a => a.Date" Title="Date" />
                        <PropertyColumn Property="a => a.Description" Title="Description" />
                    </Columns>
                    <NoRecordsContent>
                        <MudStack AlignItems="AlignItems.Center" Class="pa-6">
                            <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Secondary" Class="og-icon-xl" />
                            <MudText Typo="Typo.body1">No activities match the current filter</MudText>
                        </MudStack>
                    </NoRecordsContent>
                </MudDataGrid>
            }
            else if (!_isLoading)
            {
                <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                    <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Secondary" Class="og-icon-xl" />
                    <MudText Typo="Typo.h6">No recent activities</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Accounting activity will appear here as it is recorded.</MudText>
                </MudStack>
            }
        </MudCardContent>
    </MudCard>

</MudContainer>

@code {
    private string _fieldName = string.Empty;
    private List<AccountingActivityDto>? _recentActivities;
    private bool _isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var summary = await LifeCycleService.GetFieldLifecycleSummaryAsync();
            if (summary != null)
                _fieldName = summary.FieldName ?? _fieldName;
        }
        catch { /* field name is non-critical */ }

        await LoadRecentActivities();
    }

    private async Task LoadRecentActivities()
    {
        _isLoading = true;
        try
        {
            _recentActivities = await AccountingClient.GetRecentActivitiesAsync();
        }
        catch (Exception)
        {
            Snackbar.Add("Error loading recent activities.", Severity.Error);
            _recentActivities = new();
        }
        finally
        {
            _isLoading = false;
        }
    }
}
