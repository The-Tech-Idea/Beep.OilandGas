@page "/ppdm39/data-management/schema"
@inject ApiClient ApiClient
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@using Beep.OilandGas.Web.Components.Data

<PageTitle>Schema Management</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">

    @* ── Breadcrumb ───────────────────────────────────────────────────────── *@
    <MudBreadcrumbs Items="_breadcrumbs" Class="pa-0 mb-3" />

    @* ── Header ──────────────────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4" Wrap="Wrap.Wrap">
        <MudIcon Icon="@Icons.Material.Filled.AccountTree" Color="Color.Primary" Size="Size.Large" />
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Schema Management</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Install PPDM39 schema modules and seed reference data per database connection
            </MudText>
        </MudStack>
        <MudSpacer />
        <MudButton StartIcon="@Icons.Material.Filled.Settings"
                   Variant="Variant.Outlined" Size="Size.Small"
                   OnClick="@(() => NavigationManager.NavigateTo("/ppdm39/database-setup"))">
            Database Setup Wizard
        </MudButton>
    </MudStack>

    @* ── Connection selector ──────────────────────────────────────────────── *@
    <MudCard Elevation="1" Class="mb-4">
        <MudCardContent>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Wrap="Wrap.Wrap">
                <MudText Typo="Typo.subtitle2" Style="white-space:nowrap">Active Connection:</MudText>
                @if (_loadingConnections)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                }
                else
                {
                    <MudSelect T="string" @bind-Value="_selectedConnection"
                               Variant="Variant.Outlined" Dense="true"
                               Style="min-width:260px"
                               Label="Select Connection"
                               AnchorOrigin="Origin.BottomLeft">
                        @foreach (var c in _connections)
                        {
                            <MudSelectItem Value="@c.ConnectionName">
                                @c.ConnectionName — @c.DatabaseType
                            </MudSelectItem>
                        }
                    </MudSelect>
                }
                @if (!string.IsNullOrWhiteSpace(_selectedConnection))
                {
                    <MudChip T="string" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small">
                        @_selectedConnection
                    </MudChip>
                }
            </MudStack>
        </MudCardContent>
    </MudCard>

    @* ── Tabs ─────────────────────────────────────────────────────────────── *@
    <MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">

        @* Tab 1: Schema Modules *@
        <MudTabPanel Text="Schema Modules" Icon="@Icons.Material.Filled.AccountTree">
            @if (string.IsNullOrWhiteSpace(_selectedConnection))
            {
                <MudAlert Severity="Severity.Info">Select a connection above to manage schema modules.</MudAlert>
            }
            else
            {
                <SchemaModuleManager ConnectionName="@_selectedConnection"
                                     OnInstallComplete="HandleInstallComplete" />
            }
        </MudTabPanel>

        @* Tab 2: Reference Data *@
        <MudTabPanel Text="Reference Data" Icon="@Icons.Material.Filled.LibraryBooks">
            @if (string.IsNullOrWhiteSpace(_selectedConnection))
            {
                <MudAlert Severity="Severity.Info">Select a connection above to manage reference data.</MudAlert>
            }
            else
            {
                <ReferenceValuesManager ConnectionName="@_selectedConnection" />
            }
        </MudTabPanel>

    </MudTabs>

</MudContainer>

@code {
    private string? _selectedConnection;
    private bool _loadingConnections;
    private List<ConnectionSummaryItem> _connections = new();

    private readonly List<BreadcrumbItem> _breadcrumbs = new()
    {
        new BreadcrumbItem("Data Management", href: "/ppdm39/data-management"),
        new BreadcrumbItem("Schema Management", href: null, disabled: true),
    };

    protected override async Task OnInitializedAsync()
    {
        _loadingConnections = true;
        try
        {
            var result = await ApiClient.GetAsync<List<ConnectionSummaryItem>>("api/ppdm39/schema/connections") ?? new();            _connections = result ?? new();
            if (_connections.Count == 1)
                _selectedConnection = _connections[0].ConnectionName;
        }
        catch (Exception)
        {
            Snackbar.Add("Error loading connections.", Severity.Error);
        }
        finally
        {
            _loadingConnections = false;
        }
    }

    private void HandleInstallComplete()
    {
        Snackbar.Add("Schema updated successfully", Severity.Success);
    }

    private sealed class ConnectionSummaryItem
    {
        public string? ConnectionName { get; set; }
        public string? DatabaseType   { get; set; }
        public string? Host           { get; set; }
        public string? Database       { get; set; }
    }
}
